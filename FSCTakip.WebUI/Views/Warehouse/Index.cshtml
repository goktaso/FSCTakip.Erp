@model List<FSCTakip.Core.Entities.Warehouse>
@{
    ViewData["Title"] = "Depo Tanımlamaları";
}

@section TopbarPrimary {
    <button class="btn btn-primary btn-sm px-3" onclick="openModal(0)">
        <i class="fas fa-plus me-1"></i> Yeni Depo Ekle
    </button>
}
@section TopbarSecondary {
    <button class="btn btn-outline-secondary btn-sm" onclick="$('#filterPanel').slideToggle()">
        <i class="fas fa-filter me-1"></i> Filtrele
    </button>
    <a href="/Warehouse/Export" class="btn btn-outline-success btn-sm">
        <i class="fas fa-file-excel me-1"></i> Excel
    </a>
}

<!-- Filtre -->
<div id="filterPanel" class="filter-panel" style="display:none;">
    <div class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label small fw-semibold">Depo Adı / Kod</label>
            <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="Ara..." oninput="filterTable()">
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Durum</label>
            <select id="statusFilter" class="form-select form-select-sm" onchange="filterTable()">
                <option value="">Tümü</option>
                <option value="1">Aktif</option>
                <option value="0">Pasif</option>
            </select>
        </div>
    </div>
</div>

<!-- Özet kartlar -->
<div class="stats-grid" style="grid-template-columns:repeat(3,1fr); margin-bottom:16px;">
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-warehouse"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.Count</div>
            <div class="stat-label">Toplam Depo</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fas fa-check-circle"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.Count(w => w.IsActive)</div>
            <div class="stat-label">Aktif</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fas fa-pause-circle"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.Count(w => !w.IsActive)</div>
            <div class="stat-label">Pasif</div>
        </div>
    </div>
</div>

<!-- Tablo -->
<div class="table-card">
    <div class="table-responsive">
        <table class="data-table" id="mainTable">
            <thead>
                <tr>
                    <th style="width:120px;">KOD</th>
                    <th>DEPO ADI</th>
                    <th class="text-center" style="width:100px;">DURUM</th>
                    <th class="text-center" style="width:110px;">İŞLEMLER</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">Henüz depo kaydı yok.</td></tr>
                }
                @foreach (var item in Model)
                {
                    <tr data-name="@item.Name.ToLower()" data-code="@item.Code.ToLower()" data-active="@(item.IsActive ? "1" : "0")">
                        <td><code class="text-primary fw-semibold">@item.Code</code></td>
                        <td><strong>@item.Name</strong></td>
                        <td class="text-center">
                            <span id="badge_@item.Id" class="badge @(item.IsActive ? "badge-success" : "badge-warning")">
                                @(item.IsActive ? "Aktif" : "Pasif")
                            </span>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-icon btn-outline-primary" title="Düzenle" onclick="openModal(@item.Id)">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-icon @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                    id="toggleBtn_@item.Id"
                                    title="@(item.IsActive ? "Pasife Al" : "Aktife Al")"
                                    onclick="toggleStatus(@item.Id)">
                                <i class="fas @(item.IsActive ? "fa-pause" : "fa-play")"></i>
                            </button>
                            <button class="btn btn-icon btn-outline-danger" title="Sil" onclick="deleteItem(@item.Id, '@item.Name')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="formModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold mb-0" id="modalTitle">
                    <i class="fas fa-warehouse me-2 text-primary"></i>Depo
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="itemId">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold">Depo Kodu <span class="text-danger">*</span></label>
                        <input type="text" id="itemCode" class="form-control" placeholder="DEP-01" maxlength="20">
                    </div>
                    <div class="col-md-8">
                        <label class="form-label small fw-semibold">Depo Adı <span class="text-danger">*</span></label>
                        <input type="text" id="itemName" class="form-control" placeholder="Hammadde Deposu" maxlength="100">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary btn-sm px-4" onclick="saveItem()">
                    <i class="fas fa-save me-1"></i> Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openModal(id) {
    document.getElementById('itemId').value = id;
    document.getElementById('itemCode').value = '';
    document.getElementById('itemName').value = '';
    document.getElementById('modalTitle').innerHTML = id === 0
        ? '<i class="fas fa-warehouse me-2 text-primary"></i>Yeni Depo'
        : '<i class="fas fa-edit me-2 text-primary"></i>Depo Düzenle';

    if (id > 0) {
        fetch(`/Warehouse/Get?id=${id}`)
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    document.getElementById('itemCode').value = res.data.code;
                    document.getElementById('itemName').value = res.data.name;
                }
            });
    }
    new bootstrap.Modal(document.getElementById('formModal')).show();
}

function saveItem() {
    const id   = parseInt(document.getElementById('itemId').value);
    const code = document.getElementById('itemCode').value.trim();
    const name = document.getElementById('itemName').value.trim();

    if (!code || !name) { alert('Kod ve Adı zorunludur.'); return; }

    const fd = new FormData();
    fd.append('Id',   id);
    fd.append('Code', code);
    fd.append('Name', name);

    fetch('/Warehouse/Save', { method: 'POST', body: fd,
        headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' }
    })
    .then(r => r.json())
    .then(res => {
        if (res.success) location.reload();
        else alert(res.message);
    });
}

function toggleStatus(id) {
    fetch(`/Warehouse/ToggleStatus?id=${id}`, { method: 'POST' })
        .then(r => r.json())
        .then(res => {
            if (!res.success) { alert(res.message); return; }
            const badge = document.getElementById(`badge_${id}`);
            const btn   = document.getElementById(`toggleBtn_${id}`);
            if (res.isActive) {
                badge.className = 'badge badge-success'; badge.textContent = 'Aktif';
                btn.className   = 'btn btn-icon btn-outline-warning'; btn.title = 'Pasife Al';
                btn.innerHTML   = '<i class="fas fa-pause"></i>';
            } else {
                badge.className = 'badge badge-warning'; badge.textContent = 'Pasif';
                btn.className   = 'btn btn-icon btn-outline-success'; btn.title = 'Aktife Al';
                btn.innerHTML   = '<i class="fas fa-play"></i>';
            }
        });
}

function deleteItem(id, name) {
    if (!confirm(`"${name}" deposunu silmek istiyor musunuz?`)) return;
    fetch(`/Warehouse/Delete?id=${id}`, { method: 'POST' })
        .then(r => r.json())
        .then(res => {
            if (res.success) location.reload();
            else alert(res.message);
        });
}

function filterTable() {
    const q      = document.getElementById('searchInput').value.toLowerCase();
    const status = document.getElementById('statusFilter').value;
    document.querySelectorAll('#mainTable tbody tr').forEach(row => {
        const nm = row.dataset.name ?? '';
        const cd = row.dataset.code ?? '';
        const ac = row.dataset.active ?? '';
        const matchQ = !q || nm.includes(q) || cd.includes(q);
        const matchS = !status || ac === status;
        row.style.display = (matchQ && matchS) ? '' : 'none';
    });
}
</script>
}
