@model List<FSCTakip.Core.Entities.EtlJob>
@{
    ViewData["Title"] = "Aktarım Geçmişi";
}

@section TopbarActions {
    <a href="/Etl/Import" class="btn btn-outline-primary btn-sm">
        <i class="fas fa-file-upload me-1"></i> Yeni Aktarım
    </a>
    <a href="/Etl/Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i> ETL Paneli
    </a>
}

<!-- Özet Kartlar -->
<div class="stats-grid" style="grid-template-columns:repeat(4,1fr); margin-bottom:16px;">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fas fa-exchange-alt"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.Count</div>
            <div class="stat-label">Toplam</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.Count(j => j.Status == "Completed")</div>
            <div class="stat-label">Başarılı</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fas fa-exclamation-circle"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.Count(j => j.Status == "Partial")</div>
            <div class="stat-label">Kısmi</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fee2e2;"><i class="fas fa-times-circle" style="color:#ef4444;"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.Count(j => j.Status == "Failed")</div>
            <div class="stat-label">Hatalı</div>
        </div>
    </div>
</div>

<!-- Tablo -->
<div class="table-card">
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>AKTARIM TÜRÜ</th>
                    <th>BAĞLANTI / KAYNAK</th>
                    <th>DOSYA</th>
                    <th class="text-center">TOPLAM</th>
                    <th class="text-center">EKLENDİ</th>
                    <th class="text-center">GÜNCELLENDİ</th>
                    <th class="text-center">ATLANDI</th>
                    <th class="text-center">HATA</th>
                    <th>DURUM</th>
                    <th>SÜRE</th>
                    <th>TARİH</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="11" class="text-center text-muted py-5">Aktarım geçmişi bulunamadı.</td></tr>
                }
                @foreach (var j in Model)
                {
                    var duration = j.CompletedAt.HasValue
                        ? (j.CompletedAt.Value - j.StartedAt).TotalSeconds
                        : (double?)null;

                    <tr style="@(j.ErrorDetails != null ? "cursor:pointer;" : "")"
                        onclick="@(j.ErrorDetails != null ? $"showErrors({j.Id})" : "")">
                        <td><strong>@JobTypeLabel(j.JobType)</strong></td>
                        <td class="text-muted small">@(j.EtlConnection?.Name ?? j.Source ?? "—")</td>
                        <td class="text-muted small" style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@j.SourceFile">
                            @(j.SourceFile ?? "—")
                        </td>
                        <td class="text-center">@j.TotalRecords</td>
                        <td class="text-center text-success fw-semibold">@j.InsertedCount</td>
                        <td class="text-center text-primary fw-semibold">@j.UpdatedCount</td>
                        <td class="text-center text-muted">@j.SkippedCount</td>
                        <td class="text-center @(j.ErrorCount > 0 ? "text-danger fw-semibold" : "text-muted")">@j.ErrorCount</td>
                        <td>@StatusBadge(j.Status)</td>
                        <td class="text-muted small">@(duration.HasValue ? $"{duration.Value:F1}s" : "—")</td>
                        <td class="text-muted small">@j.StartedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    </tr>
                    @if (!string.IsNullOrWhiteSpace(j.ErrorDetails))
                    {
                        <tr id="err_@j.Id" style="display:none;">
                            <td colspan="11" style="padding:0 16px 12px; background:#fef2f2;">
                                <div class="small fw-semibold text-danger mb-1">Hata Detayları</div>
                                <pre style="font-size:11px; color:#991b1b; white-space:pre-wrap; margin:0;">@j.ErrorDetails</pre>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string JobTypeLabel(string t) => t switch {
        "LotImport"      => "Hammadde Lot",
        "UretimImport"   => "Üretim Kaydı",
        "SatisImport"    => "Satış Kaydı",
        "ProductImport"  => "Ürün Aktarımı",
        "SupplierImport" => "Tedarikçi Aktarımı",
        "CustomerImport" => "Müşteri Aktarımı",
        _ => t
    };

    Microsoft.AspNetCore.Html.HtmlString StatusBadge(string s) => new(s switch {
        "Completed" => "<span class=\"badge badge-success\">Tamamlandı</span>",
        "Partial"   => "<span class=\"badge badge-warning\">Kısmi</span>",
        "Failed"    => "<span class=\"badge\" style=\"background:#fee2e2;color:#991b1b;\">Hatalı</span>",
        _           => "<span class=\"badge badge-warning\">Çalışıyor</span>"
    });
}

@section Scripts {
<script>
function showErrors(id) {
    const row = document.getElementById(`err_${id}`);
    if (row) row.style.display = row.style.display === 'none' ? '' : 'none';
}
</script>
}
