@using FSCTakip.Core.Entities
@{
    ViewData["Title"] = "Netsis Senkronizasyonu";
    var connections = ViewBag.Connections as List<EtlConnection> ?? new();
    var recentJobs  = ViewBag.RecentJobs  as List<EtlJob>        ?? new();
}

@section TopbarActions {
    <a href="/Etl/Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i> ETL Paneli
    </a>
    <a href="/Etl/History" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-history me-1"></i> Geçmiş
    </a>
}

<div class="row g-4">

    <!-- Sol Panel — Kontroller -->
    <div class="col-md-5">

        <!-- Bağlantı -->
        <div class="table-card p-4 mb-4">
            <h6 class="fw-semibold mb-3">
                <i class="fas fa-database me-2 text-primary"></i>Netsis Bağlantısı
            </h6>

            @if (connections.Any())
            {
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Bağlantı Profili</label>
                    <select id="connectionId" class="form-select">
                        <option value="">— Varsayılan (appsettings) —</option>
                        @foreach (var c in connections)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
            }
            else
            {
                <input type="hidden" id="connectionId" value="">
                <div class="alert alert-info py-2 mb-3 small">
                    <i class="fas fa-info-circle me-1"></i>
                    Varsayılan bağlantı kullanılıyor: <strong>ARDA\ARDA / ACOREFSC25</strong>
                    <br>
                    <a href="/Etl/Connections" class="small">Bağlantı profili eklemek için tıklayın</a>
                </div>
            }
        </div>

        <!-- Senkronizasyon Türleri -->
        <div class="table-card p-4">
            <h6 class="fw-semibold mb-3">
                <i class="fas fa-sync me-2 text-success"></i>Senkronizasyon
            </h6>

            <div class="d-grid gap-2">
                <button class="btn btn-outline-primary text-start" onclick="runSync('ProductImport')">
                    <i class="fas fa-boxes me-2"></i>
                    <strong>Ürünleri Senkronize Et</strong>
                    <br>
                    <small class="text-muted ms-4">TBLSTSABIT → Ürünler (Grup 10/20/30/40/50)</small>
                </button>
                <button class="btn btn-outline-warning text-start" onclick="runSync('SupplierImport')">
                    <i class="fas fa-truck me-2"></i>
                    <strong>Tedarikçileri Senkronize Et</strong>
                    <br>
                    <small class="text-muted ms-4">TBLCASABIT (TİP=S) → Tedarikçiler</small>
                </button>
                <button class="btn btn-outline-success text-start" onclick="runSync('CustomerImport')">
                    <i class="fas fa-users me-2"></i>
                    <strong>Müşterileri Senkronize Et</strong>
                    <br>
                    <small class="text-muted ms-4">TBLCASABIT (TİP=A) → Müşteriler</small>
                </button>
                <hr class="my-1">
                <button class="btn btn-primary text-start" onclick="runAll()">
                    <i class="fas fa-sync-alt me-2"></i>
                    <strong>Tümünü Senkronize Et</strong>
                    <br>
                    <small class="text-white-50 ms-4">Ürün + Tedarikçi + Müşteri sırasıyla</small>
                </button>
            </div>
        </div>

        <!-- ETL Excel İndir -->
        <div class="table-card p-4 mt-4">
            <h6 class="fw-semibold mb-1">
                <i class="fas fa-file-excel me-2 text-success"></i>Netsis ETL Excel Dosyaları
            </h6>
            <p class="text-muted small mb-3">
                ACOREFSC25 veritabanından çıkarılan hazır veri dosyaları.
                Sisteme aktarmadan önce gözden geçirin.
            </p>
            <div class="d-grid gap-2">
                <a href="/Etl/DownloadNetsisEtl?file=ETL_Tedarikciler" class="btn btn-outline-success text-start btn-sm">
                    <i class="fas fa-download me-2"></i>
                    <strong>Tedarikçiler</strong>
                    <span class="text-muted ms-1">— 12 tedarikçi (S tipi)</span>
                </a>
                <a href="/Etl/DownloadNetsisEtl?file=ETL_Musteriler" class="btn btn-outline-success text-start btn-sm">
                    <i class="fas fa-download me-2"></i>
                    <strong>Müşteriler</strong>
                    <span class="text-muted ms-1">— 316 müşteri (ACORE23)</span>
                </a>
                <a href="/Etl/DownloadNetsisEtl?file=ETL_HammaddeGirisleri" class="btn btn-outline-primary text-start btn-sm">
                    <i class="fas fa-download me-2"></i>
                    <strong>Hammadde Girişleri</strong>
                    <span class="text-muted ms-1">— 160 kayıt / 151 lot (2022-2025)</span>
                </a>
            </div>
            <div class="alert alert-warning py-2 mt-3 mb-0 small">
                <i class="fas fa-info-circle me-1"></i>
                Excel dosyalarını indirip kontrol ettikten sonra
                <strong>Excel Aktarımı</strong> sayfasından sisteme yükleyebilirsiniz.
                Sarı alanlar (FSC Kodu, Bitiş Tarihi) manuel doldurulmalıdır.
            </div>
        </div>

    </div>

    <!-- Sağ Panel — Durum -->
    <div class="col-md-7">

        <!-- Başlangıç -->
        <div id="panelStart" class="table-card p-5 text-center">
            <div style="width:72px;height:72px;border-radius:50%;background:#f0fdf4;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                <i class="fas fa-database" style="font-size:32px;color:#16a34a;"></i>
            </div>
            <div class="fw-semibold mb-1" style="font-size:16px;">Netsis'ten Senkronize Et</div>
            <div class="text-muted small mb-3">Sol panelden senkronize etmek istediğiniz veri türünü seçin.</div>
            <div class="p-3 rounded text-start" style="background:#f8fafc; border:1px solid #e5e7eb; font-size:12px;">
                <div class="fw-semibold mb-1 text-muted">Bağlantı Bilgileri</div>
                <code>Server: ARDA\ARDA<br>Database: ACOREFSC25<br>User: data</code>
            </div>
        </div>

        <!-- Yükleniyor -->
        <div id="panelLoading" class="table-card p-5 text-center" style="display:none;">
            <div class="spinner-border text-success mb-3" style="width:56px;height:56px;"></div>
            <div class="fw-semibold" id="loadingMsg">Senkronize ediliyor...</div>
            <div class="text-muted small mt-1">Netsis veritabanından veriler alınıyor. Lütfen bekleyin.</div>
        </div>

        <!-- Sonuç -->
        <div id="panelResult" class="table-card p-4" style="display:none;">
            <div class="d-flex align-items-center gap-2 mb-3">
                <i id="resultIcon" class="fas fa-check-circle text-success" style="font-size:22px;"></i>
                <h6 class="fw-semibold mb-0" id="resultTitle">Senkronizasyon Tamamlandı</h6>
                <a href="/Etl/History" class="btn btn-outline-secondary btn-sm ms-auto">
                    <i class="fas fa-history me-1"></i> Geçmiş
                </a>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-3 text-center p-2 rounded" style="background:#f0fdf4; border:1px solid #bbf7d0;">
                    <div class="fw-bold text-success" id="rInserted" style="font-size:28px;">0</div>
                    <div class="text-muted" style="font-size:11px;">Eklendi</div>
                </div>
                <div class="col-3 text-center p-2 rounded" style="background:#eff6ff; border:1px solid #bfdbfe;">
                    <div class="fw-bold text-primary" id="rUpdated" style="font-size:28px;">0</div>
                    <div class="text-muted" style="font-size:11px;">Güncellendi</div>
                </div>
                <div class="col-3 text-center p-2 rounded" style="background:#f8fafc; border:1px solid #e5e7eb;">
                    <div class="fw-bold text-muted" id="rSkipped" style="font-size:28px;">0</div>
                    <div class="text-muted" style="font-size:11px;">Atlandı</div>
                </div>
                <div class="col-3 text-center p-2 rounded" style="background:#fef2f2; border:1px solid #fecaca;">
                    <div class="fw-bold text-danger" id="rErrors" style="font-size:28px;">0</div>
                    <div class="text-muted" style="font-size:11px;">Hata</div>
                </div>
            </div>
            <div id="errorDetails" style="display:none;">
                <div class="small fw-semibold text-danger mb-1">
                    <i class="fas fa-exclamation-triangle me-1"></i>Hata Detayları
                </div>
                <pre id="errorList" class="p-3 rounded" style="background:#fef2f2;font-size:11px;max-height:180px;overflow-y:auto;color:#991b1b;"></pre>
            </div>
            <button class="btn btn-outline-secondary btn-sm mt-2" onclick="resetPanel()">
                <i class="fas fa-redo me-1"></i> Yeni Senkronizasyon
            </button>
        </div>

        <!-- Son İşler -->
        @if (recentJobs.Any())
        {
            <div class="table-card mt-4">
                <div class="p-3 border-bottom">
                    <strong class="small"><i class="fas fa-history me-1 text-muted"></i>Son Senkronizasyonlar</strong>
                </div>
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>TÜR</th>
                                <th class="text-center">EKLENDİ</th>
                                <th class="text-center">GÜN.</th>
                                <th class="text-center">HATA</th>
                                <th>DURUM</th>
                                <th>TARİH</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var j in recentJobs)
                            {
                                <tr>
                                    <td><strong>@JobTypeLabel(j.JobType)</strong></td>
                                    <td class="text-center text-success fw-semibold">@j.InsertedCount</td>
                                    <td class="text-center text-primary fw-semibold">@j.UpdatedCount</td>
                                    <td class="text-center @(j.ErrorCount > 0 ? "text-danger fw-semibold" : "text-muted")">@j.ErrorCount</td>
                                    <td>@StatusBadge(j.Status)</td>
                                    <td class="text-muted small">@j.StartedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

    </div>
</div>

@functions {
    string JobTypeLabel(string t) => t switch {
        "ProductImport"  => "Ürün",
        "SupplierImport" => "Tedarikçi",
        "CustomerImport" => "Müşteri",
        _ => t
    };

    Microsoft.AspNetCore.Html.HtmlString StatusBadge(string s) => new(s switch {
        "Completed" => "<span class=\"badge badge-success\">Tamamlandı</span>",
        "Partial"   => "<span class=\"badge badge-warning\">Kısmi</span>",
        "Failed"    => "<span class=\"badge\" style=\"background:#fee2e2;color:#991b1b;\">Hatalı</span>",
        _           => "<span class=\"badge badge-warning\">Çalışıyor</span>"
    });
}

@section Scripts {
<script>
const syncLabels = {
    ProductImport:  'Ürünler senkronize ediliyor...',
    SupplierImport: 'Tedarikçiler senkronize ediliyor...',
    CustomerImport: 'Müşteriler senkronize ediliyor...'
};

function runSync(type) {
    const connId = document.getElementById('connectionId')?.value ?? '';
    if (!confirm(`Netsis'ten "${syncLabels[type] ?? type}" çalıştırılacak. Onaylıyor musunuz?`)) return;
    startSync(type, connId);
}

async function runAll() {
    const connId = document.getElementById('connectionId')?.value ?? '';
    if (!confirm('Ürün, Tedarikçi ve Müşteri sırasıyla senkronize edilecek. Onaylıyor musunuz?')) return;

    showLoading('Ürünler senkronize ediliyor... (1/3)');
    let totIns = 0, totUpd = 0, totSkp = 0, totErr = 0, allErrors = [];

    for (const type of ['ProductImport', 'SupplierImport', 'CustomerImport']) {
        document.getElementById('loadingMsg').textContent =
            type === 'ProductImport'  ? 'Ürünler senkronize ediliyor... (1/3)' :
            type === 'SupplierImport' ? 'Tedarikçiler senkronize ediliyor... (2/3)' :
                                       'Müşteriler senkronize ediliyor... (3/3)';
        const fd = new FormData();
        fd.append('syncType', type);
        if (connId) fd.append('connectionId', connId);
        try {
            const res = await fetch('/Etl/NetsisExecute', { method: 'POST', body: fd }).then(r => r.json());
            if (res.success) {
                totIns += res.inserted ?? 0;
                totUpd += res.updated ?? 0;
                totSkp += res.skipped ?? 0;
                totErr += res.errorCount ?? 0;
                if (res.errors) allErrors.push(...res.errors);
            } else {
                allErrors.push(`${type}: ${res.message}`);
                totErr++;
            }
        } catch(e) { allErrors.push(`${type}: ${e.message}`); totErr++; }
    }

    showResult(totIns, totUpd, totSkp, totErr, allErrors);
}

function startSync(type, connId) {
    showLoading(syncLabels[type] ?? 'Senkronize ediliyor...');
    const fd = new FormData();
    fd.append('syncType', type);
    if (connId) fd.append('connectionId', connId);

    fetch('/Etl/NetsisExecute', { method: 'POST', body: fd })
        .then(r => r.json())
        .then(res => {
            if (res.success) {
                showResult(res.inserted, res.updated, res.skipped, res.errorCount, res.errors);
            } else {
                hideLoading();
                alert('Hata: ' + res.message);
            }
        })
        .catch(e => { hideLoading(); alert('Bağlantı hatası: ' + e.message); });
}

function showLoading(msg) {
    document.getElementById('panelStart').style.display  = 'none';
    document.getElementById('panelResult').style.display = 'none';
    document.getElementById('panelLoading').style.display = '';
    document.getElementById('loadingMsg').textContent = msg;
}

function hideLoading() {
    document.getElementById('panelLoading').style.display = 'none';
    document.getElementById('panelStart').style.display   = '';
}

function showResult(ins, upd, skp, errCnt, errors) {
    document.getElementById('panelLoading').style.display = 'none';
    document.getElementById('panelResult').style.display  = '';

    document.getElementById('rInserted').textContent = ins ?? 0;
    document.getElementById('rUpdated').textContent  = upd ?? 0;
    document.getElementById('rSkipped').textContent  = skp ?? 0;
    document.getElementById('rErrors').textContent   = errCnt ?? 0;

    const isOk = !errCnt || errCnt === 0;
    document.getElementById('resultIcon').className = isOk
        ? 'fas fa-check-circle text-success' : 'fas fa-exclamation-circle text-warning';
    document.getElementById('resultTitle').textContent = isOk
        ? 'Senkronizasyon Başarıyla Tamamlandı' : 'Senkronizasyon Kısmen Tamamlandı';

    const errDiv  = document.getElementById('errorDetails');
    const errList = document.getElementById('errorList');
    if (errors && errors.length > 0) {
        errList.textContent = errors.join('\n');
        errDiv.style.display = '';
    } else {
        errDiv.style.display = 'none';
    }
}

function resetPanel() {
    document.getElementById('panelResult').style.display  = 'none';
    document.getElementById('panelStart').style.display   = '';
}
</script>
}
