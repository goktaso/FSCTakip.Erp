@{
    ViewData["Title"] = "ERP Entegrasyonu";
}

<div class="page-header">
    <h4 class="page-title"><i class="fas fa-plug me-2 text-primary"></i>ERP Entegrasyonu</h4>
    <span class="text-muted small">Faz 4 — Geliştirme Aşamasında</span>
</div>

<div class="table-card p-4 text-center" style="min-height:300px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:16px;">
    <div style="width:80px; height:80px; border-radius:50%; background:#eff6ff; display:flex; align-items:center; justify-content:center;">
        <i class="fas fa-plug" style="font-size:36px; color:#3b82f6;"></i>
    </div>
    <h5 class="fw-semibold mb-1">ERP Entegrasyon Modülü</h5>
    <p class="text-muted mb-0" style="max-width:480px; font-size:14px;">
        Bu modül ERP sistemleri ile otomatik veri senkronizasyonu sağlayacaktır.
        Staging tabloları, bağlantı yönetimi ve zamanlı görevler bu modül kapsamında geliştirilecektir.
    </p>

    <div class="row g-3 mt-2" style="max-width:640px; width:100%;">
        <div class="col-md-4">
            <div class="p-3 rounded border text-start" style="background:#f8fafc;">
                <div class="fw-semibold small mb-1"><i class="fas fa-database me-1 text-primary"></i>Staging Tabloları</div>
                <div class="text-muted" style="font-size:12px;">ERP verisi için ara tablolar</div>
                <span class="badge badge-warning mt-2">Planlandı</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 rounded border text-start" style="background:#f8fafc;">
                <div class="fw-semibold small mb-1"><i class="fas fa-link me-1 text-success"></i>Bağlantı Yönetimi</div>
                <div class="text-muted" style="font-size:12px;">ERP API bağlantı ayarları</div>
                <span class="badge badge-warning mt-2">Planlandı</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 rounded border text-start" style="background:#f8fafc;">
                <div class="fw-semibold small mb-1"><i class="fas fa-sync-alt me-1 text-purple"></i>Oto Senkron</div>
                <div class="text-muted" style="font-size:12px;">Zamanlı otomatik aktarım</div>
                <span class="badge badge-warning mt-2">Planlandı</span>
            </div>
        </div>
    </div>
</div>
