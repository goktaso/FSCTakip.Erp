@model IEnumerable<FSCTakip.Core.Entities.Supplier>
@{
    ViewData["Title"] = "Tedarikçi Tanımları";
}

@* Üst Aksiyon Çubuğu *@
<div class="row mb-3 align-items-center">
    <div class="col-md-6">
        <h4 class="mb-0 font-weight-bold text-primary text-uppercase">Tedarikçi Listesi</h4>
    </div>
    <div class="col-md-6 text-right">
        <button class="btn btn-outline-secondary btn-sm" onclick="$('#filterPanel').slideToggle()">
            <i class="fas fa-filter mr-1"></i> Filtrele
        </button>
        <button class="btn btn-outline-success btn-sm ml-1" onclick="exportToExcel()">
            <i class="fas fa-file-excel mr-1"></i> Excel
        </button>
        <button class="btn btn-primary btn-sm ml-1" onclick="openAddModal()">
            <i class="fas fa-plus mr-1"></i> Yeni Tedarikçi
        </button>
    </div>
</div>

@* Filtre Paneli *@
<div id="filterPanel" class="card mb-3 shadow-sm border-left-primary" style="display:none;">
    <div class="card-body py-3">
        <div class="row align-items-end">
            <div class="col-md-4">
                <label class="small font-weight-bold text-uppercase">Tedarikçi Ara</label>
                <input type="text" id="supplierSearch" class="form-control form-control-sm" placeholder="İsim veya kod yazın...">
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary btn-sm btn-block" onclick="filterSuppliers()">
                    <i class="fas fa-search mr-1"></i> Sorgula
                </button>
            </div>
        </div>
    </div>
</div>

@* Tablo *@
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="suppliersTable">
                <thead class="bg-light text-dark text-uppercase small font-weight-bold">
                    <tr>
                        <th>Tedarikçi Kodu</th>
                        <th>Tedarikçi Adı</th>
                        <th>Yetkili</th>
                        <th>Telefon</th>
                        <th>FSC Kodu</th>
                        <th style="width: 100px;">Durum</th>
                        <th class="text-right" style="width: 80px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge badge-light border">@item.SupplierCode</span></td>
                            <td class="font-weight-bold">@item.Name</td>
                            <td>@item.ContactPerson</td>
                            <td>@item.Phone</td>
                            <td><small class="text-muted">@item.FscCode</small></td>
                            <td>
                                <div class="custom-control custom-switch">
                                    <input type="checkbox" class="custom-control-input" id="sw_@item.Id" @(item.IsActive ? "checked" : "") onclick="toggleStatus(@item.Id)">
                                    <label class="custom-control-label" for="sw_@item.Id">@(item.IsActive ? "Aktif" : "Pasif")</label>
                                </div>
                            </td>
                            <td class="text-right">
                                <button class="btn btn-sm btn-outline-primary" onclick="editSupplier(@item.Id)">
                                    <i class="fas fa-edit"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* TEDARİKÇİ MODALI *@
<div class="modal fade" id="supplierModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-secondary text-white py-2">
                <h6 class="modal-title font-weight-bold"><i class="fas fa-truck mr-2"></i>Tedarikçi Formu</h6>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <form asp-controller="Suppliers" asp-action="Save" method="post">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="supplierId" value="0" />

                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label class="small font-weight-bold">Tedarikçi Adı <span class="text-danger">*</span></label>
                                <input type="text" name="Name" id="supplierName" class="form-control text-uppercase" required />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="small font-weight-bold">Yetkili Kişi</label>
                                <input type="text" name="ContactPerson" id="contactPerson" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="small font-weight-bold">Telefon</label>
                                <input type="text" name="Phone" id="phone" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="small font-weight-bold">E-Posta</label>
                                <input type="email" name="Email" id="email" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="small font-weight-bold">FSC Sertifika No</label>
                                <input type="text" name="FscCode" id="fscCode" class="form-control text-uppercase" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="small font-weight-bold">FSC Geçerlilik Tarihi</label>
                                <input type="date" name="FscExpiryDate" id="fscExpiryDate" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light py-2 text-right">
                    <button type="button" class="btn btn-link btn-sm text-dark" data-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary btn-sm px-4">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAddModal() {
            $('#supplierId').val(0);
            $('form')[0].reset();
            $('.modal-title').html('<i class="fas fa-plus mr-2"></i>Yeni Tedarikçi Ekle');
            $('#supplierModal').modal('show');
        }

        function editSupplier(id) {
            $.get('/Suppliers/GetSupplier', { id: id }, function(data) {
                if (data.success) {
                    $('#supplierId').val(data.id);
                    $('#supplierName').val(data.name);
                    $('#contactPerson').val(data.contactPerson);
                    $('#phone').val(data.phone);
                    $('#email').val(data.email);
                    $('#fscCode').val(data.fscCode);
                    $('#fscExpiryDate').val(data.fscExpiryDate);

                    $('.modal-title').html('<i class="fas fa-edit mr-2"></i>Tedarikçi Düzenle');
                    $('#supplierModal').modal('show');
                }
            });
        }

        function toggleStatus(id) {
            $.post('/Suppliers/ToggleStatus', { id: id }, function(res) {
                if (res.success) {
                    const toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 1000 });
                    toast.fire({ icon: 'success', title: 'Güncellendi' });
                }
            });
        }

        function filterSuppliers() {
            var val = $("#supplierSearch").val().toLowerCase();
            $("#suppliersTable tbody tr").filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(val) > -1);
            });
        }

        function exportToExcel() { window.location.href = '/Suppliers/ExportExcel'; }
    </script>
}