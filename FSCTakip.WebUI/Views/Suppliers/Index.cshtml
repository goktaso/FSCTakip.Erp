@model IEnumerable<FSCTakip.Core.Entities.Supplier>
@{
    ViewData["Title"] = "Tedarikçiler";
    var total    = Model?.Count() ?? 0;
    var active   = Model?.Count(s => s.IsActive) ?? 0;
    var fscOk    = Model?.Count(s => s.IsFscActive && s.FscExpiryDate.HasValue && s.FscExpiryDate.Value > DateTime.Today) ?? 0;
    var expiring = Model?.Count(s => s.FscExpiryDate.HasValue && s.FscExpiryDate.Value <= DateTime.Today.AddDays(90) && s.FscExpiryDate.Value > DateTime.Today) ?? 0;
}

@section TopbarPrimary {
    <button class="btn-topbar-add" onclick="openAddModal()">
        <span class="btn-add-icon"><i class="fas fa-plus"></i></span>
        Yeni Tedarikçi
    </button>
}
@section TopbarActions {
    <button class="topbar-btn btn-filter" onclick="$('#filterPanel').slideToggle()">
        <i class="fas fa-filter"></i> Filtrele
    </button>
    <button class="topbar-btn" onclick="openFscImportModal()"
            style="color:#92400e;border-color:#fde68a;background:#fffbeb;"
            title="FSC kodlarını Excel ile toplu güncelle">
        <i class="fas fa-certificate"></i> FSC Yükle
    </button>
    <button class="topbar-btn btn-excel" onclick="location.href='/Suppliers/ExportSuppliers'">
        <i class="fas fa-file-excel"></i> Excel
    </button>
}

<!-- Stat Kartları -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-truck"></i></div>
            <div>
                <div class="stat-value">@total</div>
                <div class="stat-label">Toplam Tedarikçi</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-check-circle"></i></div>
            <div>
                <div class="stat-value">@active</div>
                <div class="stat-label">Aktif Tedarikçi</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon @(fscOk > 0 ? "green" : "red")"><i class="fas fa-certificate"></i></div>
            <div>
                <div class="stat-value">@fscOk</div>
                <div class="stat-label">FSC Sertifikalı</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon @(expiring > 0 ? "amber" : "green")"><i class="fas fa-exclamation-triangle"></i></div>
            <div>
                <div class="stat-value">@expiring</div>
                <div class="stat-label">90 Günde Bitiyor</div>
                @if (expiring > 0)
                {
                    <div style="font-size:10px;color:#f59e0b;">⚠ FSC uyarısı var</div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Filtre Paneli -->
<div id="filterPanel" class="filter-panel mb-3" style="display:none;">
    <div class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Tedarikçi Ara</label>
            <input type="text" id="supplierSearch" class="form-control form-control-sm"
                   placeholder="İsim, kod veya FSC no ile arayın..." oninput="filterSuppliers()">
        </div>
        <div class="col-md-3">
            <label class="form-label">FSC Durumu</label>
            <select id="fscFilter" class="form-select form-select-sm" onchange="filterSuppliers()">
                <option value="">— Tümü —</option>
                <option value="active">FSC Aktif</option>
                <option value="expiring">Yakında Bitiyor</option>
            </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-outline-secondary btn-sm w-100" onclick="clearFilter()">
                <i class="fas fa-times me-1"></i> Temizle
            </button>
        </div>
    </div>
</div>

<!-- Tablo -->
<div class="table-card">
    <table class="data-table" id="suppliersTable">
        <thead>
            <tr>
                <th>TEDARİKÇİ ADI</th>
                <th>KOD</th>
                <th>İLETİŞİM</th>
                <th>VERGİ</th>
                <th>FSC SERTİFİKA</th>
                <th class="text-center">DURUM</th>
                <th class="text-center">İŞLEM</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr><td colspan="7">
                    <div class="empty-state">
                        <div class="empty-icon"><i class="fas fa-truck"></i></div>
                        <h6>Henüz tedarikçi kaydı yok</h6>
                        <p><strong>+ Yeni Tedarikçi</strong> butonu ile ilk tedarikçinizi ekleyin.</p>
                    </div>
                </td></tr>
            }
            @foreach (var item in Model ?? Enumerable.Empty<FSCTakip.Core.Entities.Supplier>())
            {
                var fscDays  = item.FscExpiryDate.HasValue ? (int)(item.FscExpiryDate.Value - DateTime.Today).TotalDays : (int?)null;
                var fscClass = item.IsFscActive && fscDays.HasValue && fscDays.Value > 30 ? "fsc-badge active"
                             : fscDays.HasValue && fscDays.Value <= 0 ? "fsc-badge expired"
                             : item.IsFscActive ? "fsc-badge warning" : "fsc-badge expired";
                <tr>
                    <td>
                        <div class="fw-semibold" style="font-size:13px;color:#1d4ed8;">@item.Name</div>
                        @if (!string.IsNullOrEmpty(item.ContactPerson))
                        {
                            <div class="text-muted" style="font-size:11px;">
                                <i class="fas fa-user me-1"></i>@item.ContactPerson
                            </div>
                        }
                    </td>
                    <td>
                        <span class="badge badge-gray" style="font-size:11px;letter-spacing:.03em;">@item.SupplierCode</span>
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Phone))
                        {
                            <div style="font-size:12px;"><i class="fas fa-phone me-1 text-muted"></i>@item.Phone</div>
                        }
                        @if (!string.IsNullOrEmpty(item.Email))
                        {
                            <div style="font-size:11px;color:#1d4ed8;text-transform:lowercase;">
                                <i class="fas fa-envelope me-1 text-muted"></i>@item.Email
                            </div>
                        }
                    </td>
                    <td>
                        <div style="font-size:12px;font-weight:500;">@(item.TaxOffice ?? "—")</div>
                        <div class="text-muted" style="font-size:11px;">@(item.TaxNumber ?? "—")</div>
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.FscCode))
                        {
                            <span class="@fscClass">
                                <i class="fas fa-certificate"></i> @item.FscCode
                            </span>
                            <div class="text-muted" style="font-size:11px;margin-top:3px;">
                                @if (fscDays.HasValue)
                                {
                                    @(fscDays.Value <= 0 ? "⚠ Süresi geçti" : fscDays.Value <= 30 ? $"⚠ {fscDays.Value} gün kaldı" : $"✓ {item.FscExpiryDate!.Value:dd.MM.yyyy}")
                                }
                            </div>
                        }
                        else { <span class="text-muted" style="font-size:12px;">FSC kodu yok</span> }
                    </td>
                    <td class="text-center">
                        <span class="badge @(item.IsActive ? "badge-green" : "badge-gray")" id="badge_@item.Id">
                            @(item.IsActive ? "Aktif" : "Pasif")
                        </span>
                    </td>
                    <td class="text-center">
                        <div class="d-flex gap-1 justify-content-center">
                            <button class="btn btn-sm" title="Düzenle" onclick="editSupplier(@item.Id)"
                                    style="padding:4px 10px;background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;border-radius:6px;">
                                <i class="fas fa-pen"></i>
                            </button>
                            <button class="btn btn-sm" title="@(item.IsActive ? "Pasife Al" : "Aktife Al")"
                                    onclick="toggleSupplierStatus(@item.Id)"
                                    style="padding:4px 10px;background:#f9fafb;color:#374151;border:1px solid #e5e7eb;border-radius:6px;">
                                <i class="fas fa-power-off"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Tedarikçi Modal -->
<div class="modal fade" id="supplierModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header dark">
                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-truck" style="color:#93c5fd;font-size:15px;"></i>
                    <h5 class="modal-title fw-semibold mb-0 fs-6" id="supplierModalTitle">Tedarikçi Formu</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Suppliers" asp-action="Save" method="post" id="supplierForm">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="suppId" value="0" />
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">Tedarikçi Ünvanı <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="Name" id="suppName" required
                                   style="text-transform:uppercase;" placeholder="Büyük harf ile girilir">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Tedarikçi Kodu</label>
                            <input type="text" class="form-control" name="SupplierCode" id="suppCode"
                                   readonly style="background:#f8fafc;color:#6b7280;" placeholder="Otomatik">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Yetkili Kişi <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="ContactPerson" id="suppContact" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="Phone" id="suppPhone" required placeholder="5xxxxxxxxx">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-Posta</label>
                            <input type="text" class="form-control" name="Email" id="suppEmail"
                                   placeholder="ornek@firma.com" style="text-transform:lowercase;">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Şehir</label>
                            <input type="text" class="form-control" name="City" id="suppCity">
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Adres</label>
                            <input type="text" class="form-control" name="Address" id="suppAddress">
                        </div>
                        <div class="col-md-4">
                            <div class="row g-2">
                                <div class="col-12">
                                    <label class="form-label">Vergi Dairesi</label>
                                    <input type="text" class="form-control" name="TaxOffice" id="suppTaxOffice">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Vergi No</label>
                                    <input type="text" class="form-control" name="TaxNumber" id="suppTaxNumber" maxlength="11">
                                </div>
                            </div>
                        </div>
                        <!-- FSC Bölümü -->
                        <div class="col-12">
                            <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:14px;">
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <i class="fas fa-certificate text-success"></i>
                                    <span class="fw-semibold" style="font-size:13px;color:#166534;">FSC Sertifika Bilgileri</span>
                                </div>
                                <div class="row g-2">
                                    <div class="col-md-6">
                                        <label class="form-label">FSC Sertifika No</label>
                                        <input type="text" class="form-control" name="FscCode" id="suppFsc"
                                               placeholder="FSC-C123456">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Sertifika Bitiş Tarihi</label>
                                        <input type="date" class="form-control" name="FscExpiryDate" id="suppDate">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary btn-sm px-4">
                        <i class="fas fa-save me-1"></i> Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- FSC Toplu Güncelleme Modal -->
<div class="modal fade" id="fscImportModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background:#92400e;color:#fff;">
                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-certificate" style="font-size:15px;"></i>
                    <h5 class="modal-title fw-semibold mb-0 fs-6">FSC Kodu Toplu Güncelleme</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" style="filter:invert(1) opacity(.7);"></button>
            </div>
            <div class="modal-body">
                <div class="info-card warning mb-3">
                    <i class="fas fa-info-circle" style="color:#d97706;"></i>
                    <div style="font-size:12.5px;">
                        <ol class="mb-0 ps-3">
                            <li><strong>FSC Şablonu İndir</strong> butonu ile şablonu indirin.</li>
                            <li>Sarı alanlara <strong>FscKodu</strong> ve <strong>FscBitisTarihi</strong> girin.</li>
                            <li>Dosyayı kaydedin ve aşağıdan yükleyin.</li>
                        </ol>
                    </div>
                </div>
                <div>
                    <label class="form-label">Excel Dosyası (.xlsx)</label>
                    <input type="file" id="fscFile" class="form-control form-control-sm" accept=".xlsx,.xls">
                    <div class="text-muted mt-1" style="font-size:11.5px;">
                        <i class="fas fa-info-circle me-1"></i>Yalnızca FSC_Kodlari şablonu kabul edilir.
                    </div>
                </div>
                <div id="fscImportResult" style="display:none;" class="mt-3"></div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <a href="/Suppliers/ExportFscTemplate" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-download me-1"></i> Şablonu İndir
                </a>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Kapat</button>
                    <button type="button" id="fscUploadBtn" class="btn btn-sm px-4"
                            style="background:#92400e;color:#fff;" onclick="uploadFscCodes()">
                        <i class="fas fa-upload me-1"></i> Yükle
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function filterSuppliers() {
        var search = (document.getElementById('supplierSearch').value || '').toLowerCase();
        var fscVal = document.getElementById('fscFilter').value;
        document.querySelectorAll('#suppliersTable tbody tr').forEach(function(tr) {
            var text    = tr.textContent.toLowerCase();
            var badge   = tr.querySelector('.fsc-badge');
            var fscMatch = fscVal === '' ? true
                : fscVal === 'active'   ? (badge && badge.classList.contains('active'))
                : (badge && badge.classList.contains('warning'));
            tr.style.display = (text.includes(search) && fscMatch) ? '' : 'none';
        });
    }

    function clearFilter() {
        document.getElementById('supplierSearch').value = '';
        document.getElementById('fscFilter').value = '';
        filterSuppliers();
    }

    function openAddModal() {
        document.getElementById('supplierForm').reset();
        document.getElementById('suppId').value = 0;
        document.getElementById('supplierModalTitle').textContent = 'Yeni Tedarikçi Ekle';
        bootstrap.Modal.getOrCreateInstance(document.getElementById('supplierModal')).show();
    }

    function editSupplier(id) {
        $.get('/Suppliers/GetSupplier/' + id, function (res) {
            if (res.success) {
                document.getElementById('suppId').value      = res.data.id;
                document.getElementById('suppName').value    = res.data.name;
                document.getElementById('suppCode').value    = res.data.supplierCode;
                document.getElementById('suppContact').value = res.data.contactPerson || '';
                document.getElementById('suppPhone').value   = res.data.phone || '';
                document.getElementById('suppEmail').value   = res.data.email || '';
                document.getElementById('suppAddress').value = res.data.address || '';
                document.getElementById('suppCity').value    = res.data.city || '';
                document.getElementById('suppTaxOffice').value = res.data.taxOffice || '';
                document.getElementById('suppTaxNumber').value = res.data.taxNumber || '';
                document.getElementById('suppFsc').value     = res.data.fscCode || '';
                if (res.data.fscExpiryDate)
                    document.getElementById('suppDate').value = res.data.fscExpiryDate.split('T')[0];
                document.getElementById('supplierModalTitle').textContent = 'Tedarikçi Düzenle';
                bootstrap.Modal.getOrCreateInstance(document.getElementById('supplierModal')).show();
            }
        });
    }

    function toggleSupplierStatus(id) {
        $.post('/Suppliers/ToggleStatus', { id: id }, function (res) {
            if (res.success) {
                const badge = document.getElementById('badge_' + id);
                if (badge) {
                    badge.className = 'badge ' + (res.isActive ? 'badge-green' : 'badge-gray');
                    badge.textContent = res.isActive ? 'Aktif' : 'Pasif';
                }
            }
        });
    }

    function openFscImportModal() {
        document.getElementById('fscFile').value = '';
        document.getElementById('fscImportResult').style.display = 'none';
        bootstrap.Modal.getOrCreateInstance(document.getElementById('fscImportModal')).show();
    }

    function uploadFscCodes() {
        const file = document.getElementById('fscFile').files[0];
        if (!file) { showToast('Lütfen bir Excel dosyası seçin.', 'warning'); return; }
        const btn = document.getElementById('fscUploadBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Yükleniyor...';
        const fd = new FormData();
        fd.append('file', file);
        fetch('/Suppliers/ImportFscCodes', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(res => {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-upload me-1"></i> Yükle';
                const box = document.getElementById('fscImportResult');
                box.style.display = '';
                box.className = res.success ? 'info-card success' : 'info-card danger';
                box.innerHTML = `<i class="fas fa-${res.success ? 'check-circle' : 'times-circle'}"></i>
                    <div style="font-size:12.5px;"><strong>${res.message}</strong>` +
                    (res.errors?.length ? '<ul class="mb-0 mt-1 ps-3">' + res.errors.map(e => `<li>${e}</li>`).join('') + '</ul>' : '') +
                    '</div>';
                if (res.success) setTimeout(() => location.reload(), 2000);
            })
            .catch(() => {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-upload me-1"></i> Yükle';
                showToast('Bağlantı hatası.', 'error');
            });
    }

    document.getElementById('suppEmail')?.addEventListener('blur', function() {
        this.value = this.value.replace(/İ/g,'i').replace(/I/g,'ı').replace(/\s/g,'').toLowerCase();
    });
    document.getElementById('suppPhone')?.addEventListener('input', function() {
        this.value = this.value.replace(/\D/g,'').slice(0,11);
    });
</script>
}
