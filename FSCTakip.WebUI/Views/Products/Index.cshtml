@model IEnumerable<FSCTakip.Core.Entities.Product>
@{
    ViewData["Title"] = "Ürün Tanımları";
    var productGroups = ViewData["ProductGroups"] as SelectList ?? new SelectList(new List<SelectListItem>());
    var fscTypes      = ViewData["FscTypes"]      as SelectList ?? new SelectList(new List<SelectListItem>());
    var paperTypes    = ViewData["PaperTypes"]    as SelectList ?? new SelectList(new List<SelectListItem>());
    var paperColors   = ViewData["PaperColors"]   as SelectList ?? new SelectList(new List<SelectListItem>());
    var paperWeights  = ViewData["PaperWeights"]  as SelectList ?? new SelectList(new List<SelectListItem>());
    var paperWidths   = ViewData["PaperWidths"]   as SelectList ?? new SelectList(new List<SelectListItem>());
    var suppliers     = ViewData["Suppliers"]     as SelectList ?? new SelectList(new List<SelectListItem>());

    int?   filterSupplier = ViewBag.SupplierId     as int?;
    int?   filterGroup    = ViewBag.ProductGroupId as int?;
    string filterSearch   = ViewBag.Search         as string ?? "";
}

@* Üst Aksiyon Çubuğu *@
<div class="row mb-3 align-items-center">
    <div class="col-md-6">
        <h4 class="mb-0 font-weight-bold text-primary text-uppercase">Ürün Listesi
            <small class="text-muted fw-normal ms-2" style="font-size:13px;">@Model.Count() kayıt</small>
        </h4>
    </div>
    <div class="col-md-6 text-right">
        <button class="btn btn-outline-secondary btn-sm" onclick="$('#filterPanel').slideToggle()">
            <i class="fas fa-filter mr-1"></i> Filtrele @(filterSupplier.HasValue || filterGroup.HasValue || !string.IsNullOrEmpty(filterSearch) ? "●" : "")
        </button>
        <button class="btn btn-outline-success btn-sm ml-1" onclick="exportToExcel()">
            <i class="fas fa-file-excel mr-1"></i> Excel
        </button>
        <button class="btn btn-primary btn-sm ml-1" onclick="openAddModal()">
            <i class="fas fa-plus mr-1"></i> Yeni Ürün
        </button>
    </div>
</div>

@* Filtre Paneli — server-side *@
<div id="filterPanel" class="card mb-3 shadow-sm border-left-primary"
     style="@(filterSupplier.HasValue || filterGroup.HasValue || !string.IsNullOrEmpty(filterSearch) ? "" : "display:none;")">
    <div class="card-body py-3">
        <form method="get" action="/Products">
            <div class="d-flex align-items-end gap-2 flex-wrap">
                <div style="display:flex;flex-direction:column;">
                    <label class="small fw-bold text-uppercase">Ara (Kod / Ad)</label>
                    <input type="text" name="search" class="form-control form-control-sm"
                           value="@filterSearch" placeholder="Kod veya ürün adı..." style="min-width:180px;" />
                </div>
                <div style="display:flex;flex-direction:column;">
                    <label class="small fw-bold text-uppercase">Tedarikçi</label>
                    <div class="mcd" id="mcd-prod-sup" data-placeholder="— Tümü —" style="min-width:200px;">
                        <button type="button" class="mcd-btn" onclick="mcdOpen('mcd-prod-sup')">
                            <span class="mcd-lbl">
                                @{
                                    var selSupText = (suppliers.FirstOrDefault(s => s.Value == filterSupplier?.ToString()))?.Text;
                                }
                                @(selSupText ?? "— Tümü —")
                            </span>
                            <i class="fas fa-angle-down mcd-arrow"></i>
                        </button>
                        <div class="mcd-panel" id="mcd-prod-sup-panel" style="display:none;">
                            <div class="mcd-search-row">
                                <input type="text" class="mcd-search" placeholder="Tedarikçi ara..." oninput="mcdSearch(this)">
                            </div>
                            <div class="mcd-items">
                                <label class="mcd-row">
                                    <input type="radio" name="supplierId" value="" class="mcd-rb"
                                           onchange="mcdSingleSelect('mcd-prod-sup','','— Tümü —')"
                                           checked="@(filterSupplier == null ? "checked" : null)">
                                    <span class="mcd-name">— Tümü —</span>
                                </label>
                                @foreach (var s in suppliers)
                                {
                                    <label class="mcd-row">
                                        <input type="radio" name="supplierId" value="@s.Value" class="mcd-rb"
                                               onchange="mcdSingleSelect('mcd-prod-sup','@s.Value','@s.Text.Replace("'","\\'")')"
                                               checked="@(filterSupplier?.ToString() == s.Value ? "checked" : null)">
                                        <span class="mcd-name">@s.Text</span>
                                    </label>
                                }
                            </div>
                            <div class="mcd-empty" style="display:none;">Sonuç yok</div>
                        </div>
                    </div>
                </div>
                <div style="display:flex;flex-direction:column;">
                    <label class="small fw-bold text-uppercase">Ürün Grubu</label>
                    <div class="mcd" id="mcd-prod-grp" data-placeholder="— Tümü —" style="min-width:160px;">
                        <button type="button" class="mcd-btn" onclick="mcdOpen('mcd-prod-grp')">
                            <span class="mcd-lbl">
                                @{
                                    var selGrpText = (productGroups.FirstOrDefault(g => g.Value == filterGroup?.ToString()))?.Text;
                                }
                                @(selGrpText ?? "— Tümü —")
                            </span>
                            <i class="fas fa-angle-down mcd-arrow"></i>
                        </button>
                        <div class="mcd-panel" id="mcd-prod-grp-panel" style="display:none;">
                            <div class="mcd-search-row">
                                <input type="text" class="mcd-search" placeholder="Grup ara..." oninput="mcdSearch(this)">
                            </div>
                            <div class="mcd-items">
                                <label class="mcd-row">
                                    <input type="radio" name="productGroupId" value="" class="mcd-rb"
                                           onchange="mcdSingleSelect('mcd-prod-grp','','— Tümü —')"
                                           checked="@(filterGroup == null ? "checked" : null)">
                                    <span class="mcd-name">— Tümü —</span>
                                </label>
                                @foreach (var g in productGroups)
                                {
                                    <label class="mcd-row">
                                        <input type="radio" name="productGroupId" value="@g.Value" class="mcd-rb"
                                               onchange="mcdSingleSelect('mcd-prod-grp','@g.Value','@g.Text.Replace("'","\\'")')"
                                               checked="@(filterGroup?.ToString() == g.Value ? "checked" : null)">
                                        <span class="mcd-name">@g.Text</span>
                                    </label>
                                }
                            </div>
                            <div class="mcd-empty" style="display:none;">Sonuç yok</div>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-1">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fas fa-search me-1"></i> Filtrele
                    </button>
                    <a href="/Products" class="btn btn-outline-secondary btn-sm">Temizle</a>
                </div>
            </div>
        </form>
    </div>
</div>

@* Ürün Tablosu *@
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 data-table" id="productsTable">
                <thead class="bg-light text-dark text-uppercase small font-weight-bold">
                    <tr>
                        <th style="width: 100px;">Ürün Kodu</th>
                        <th>Ürün Adı</th>
                        <th>Tedarikçi</th>
                        <th>Grup</th>
                        <th>Renk</th>
                        <th>Gr.</th>
                        <th>En</th>
                        <th>Birim</th> @* GÜNCELLENDİ *@
                        <th>FSC Tipi</th>
                        <th style="width: 100px;">Durum</th>
                        <th class="text-right" style="width: 80px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong class="text-primary">@item.ProductCode</strong>
                                    @if (!string.IsNullOrEmpty(item.ExternalCode))
                                    {
                                        <div class="text-muted" style="font-size:10px;" title="Harici ERP Kodu"><i class="fas fa-link me-1"></i>@item.ExternalCode</div>
                                    }
                                </td>
                                <td class="small font-weight-bold">@item.ProductName</td>
                                <td><span class="text-muted small">@(item.Supplier?.Name ?? "-")</span></td>
                                <td><span class="badge badge-blue" style="font-size:11px;">@(item.ProductGroup?.GroupName ?? "-")</span></td>
                                <td>@(item.PaperColor?.Name ?? "-")</td>
                                <td>@(item.PaperWeight != null ? $"{item.PaperWeight.Value} {item.PaperWeight.Unit}" : "-")</td>
                                <td>@(item.PaperWidth != null ? $"{item.PaperWidth.Value} {item.PaperWidth.Unit}" : "-")</td>
                                <td><span class="badge badge-info py-1 px-2">@(item.Unit ?? "-")</span></td>
                                <td><small>@(item.FscType?.Name ?? "-")</small></td>
                                <td>
                                    <div class="custom-control custom-switch">
                                        <input type="checkbox" class="custom-control-input" id="sw_@item.Id" @(item.IsActive ? "checked" : "") onclick="toggleProduct(@item.Id)">
                                        <label class="custom-control-label" for="sw_@item.Id">@(item.IsActive ? "Aktif" : "Pasif")</label>
                                    </div>
                                </td>
                                <td class="text-right">
                                    <button class="btn btn-sm btn-outline-primary" onclick="editProduct(@item.Id)" title="Düzenle">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    @{
                                        var groupName = item.ProductGroup?.GroupName ?? "";
                                        bool isHammadde = groupName.Contains("Hammadde", StringComparison.OrdinalIgnoreCase);
                                    }
                                    @if (!isHammadde)
                                    {
                                        <a href="/Products/Recipe/@item.Id" class="btn btn-sm btn-outline-success" title="Reçete / BOM">
                                            <i class="fas fa-list-ul"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" disabled title="Hammadde için reçete gerekmez">
                                            <i class="fas fa-list-ul"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Ürün Form Modalı *@
<div class="modal fade" id="productModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title font-weight-bold"><i class="fas fa-box mr-2"></i>Ürün Formu</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Products" asp-action="Save" method="post">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="productId" value="0" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Ürün Grubu <span class="text-danger">*</span></label>
                            <div class="qa-group">
                                <select name="ProductGroupId" id="productGroupId" class="form-control form-select" required>
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (var g in productGroups)
                                    { <option value="@g.Value">@g.Text</option> }
                                </select>
                                <button type="button" class="qa-btn" onclick="openQuickAdd('productgroup','productGroupId')" title="Yeni Ürün Grubu Ekle"><i class="fas fa-plus"></i></button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Tedarikçi</label>
                            <div class="qa-group">
                                <select name="SupplierId" id="supplierId" class="form-control form-select">
                                    <option value="">-- Tedarikçi Seçiniz --</option>
                                    @foreach (var s in suppliers)
                                    { <option value="@s.Value">@s.Text</option> }
                                </select>
                                <button type="button" class="qa-btn" onclick="openQuickAdd('supplier','supplierId')" title="Yeni Tedarikçi Ekle"><i class="fas fa-plus"></i></button>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-semibold">Dahili Kod</label>
                            <input type="text" id="productCode" class="form-control bg-light" readonly placeholder="Otomatik" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-semibold" title="Netsis / ERP stok kodu (STOK_KODU)">Harici Kod <i class="fas fa-info-circle text-muted" style="font-size:10px;"></i></label>
                            <input type="text" name="ExternalCode" id="productExtCode" class="form-control text-uppercase" placeholder="Örn: 001.01.001">
                        </div>
                        <div class="col-md-8">
                            <label class="form-label small fw-semibold">Ürün Adı <span class="text-danger">*</span></label>
                            <input type="text" name="ProductName" id="productName" class="form-control text-uppercase" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Kağıt Rengi</label>
                            <div class="qa-group">
                                <select name="PaperColorId" id="paperColorId" class="form-control form-select">
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (var c in paperColors)
                                    { <option value="@c.Value">@c.Text</option> }
                                </select>
                                <button type="button" class="qa-btn" onclick="openQuickAdd('papercolor','paperColorId')" title="Yeni Renk Ekle"><i class="fas fa-plus"></i></button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Gramaj (gr/m²)</label>
                            <div class="qa-group">
                                <select name="PaperWeightId" id="paperWeightId" class="form-control form-select">
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (var w in paperWeights)
                                    { <option value="@w.Value">@w.Text</option> }
                                </select>
                                <button type="button" class="qa-btn" onclick="openQuickAdd('paperweight','paperWeightId')" title="Yeni Gramaj Ekle"><i class="fas fa-plus"></i></button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Kağıt Eni (mm)</label>
                            <div class="qa-group">
                                <select name="PaperWidthId" id="paperWidthId" class="form-control form-select">
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (var w in paperWidths)
                                    { <option value="@w.Value">@w.Text</option> }
                                </select>
                                <button type="button" class="qa-btn" onclick="openQuickAdd('paperwidth','paperWidthId')" title="Yeni En Ekle"><i class="fas fa-plus"></i></button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Birim</label>
                            <input type="text" name="Unit" id="unit" class="form-control text-uppercase" value="ADET" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">FSC Tipi</label>
                            <div class="qa-group">
                                <select name="FscTypeId" id="fscTypeId" class="form-control form-select">
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (var f in fscTypes)
                                    { <option value="@f.Value">@f.Text</option> }
                                </select>
                                <button type="button" class="qa-btn" onclick="openQuickAdd('fsctype','fscTypeId')" title="Yeni FSC Tipi Ekle"><i class="fas fa-plus"></i></button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Kağıt Tipi</label>
                            <div class="qa-group">
                                <select name="PaperTypeId" id="paperTypeId" class="form-control form-select">
                                    <option value="">-- Seçiniz --</option>
                                    @foreach (var p in paperTypes)
                                    { <option value="@p.Value">@p.Text</option> }
                                </select>
                                <button type="button" class="qa-btn" onclick="openQuickAdd('papertype','paperTypeId')" title="Yeni Kağıt Tipi Ekle"><i class="fas fa-plus"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary btn-sm px-4">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const _productModal = new bootstrap.Modal(document.getElementById('productModal'));

        function openAddModal() {
            document.getElementById('productId').value       = '0';
            document.getElementById('productGroupId').value  = '';
            document.getElementById('supplierId').value      = '';
            document.getElementById('productCode').value     = '';
            document.getElementById('productName').value     = '';
            document.getElementById('paperColorId').value    = '';
            document.getElementById('paperWeightId').value   = '';
            document.getElementById('paperWidthId').value    = '';
            document.getElementById('fscTypeId').value       = '';
            document.getElementById('paperTypeId').value     = '';
            document.querySelector('.modal-title').innerHTML = '<i class="fas fa-plus me-2"></i>Yeni Ürün Ekle';
            _productModal.show();
        }

        function editProduct(id) {
            fetch(`/Products/GetProduct?id=${id}`)
                .then(r => r.json())
                .then(data => {
                    if (!data.success) return;
                    document.getElementById('productId').value      = data.id;
                    document.getElementById('productGroupId').value = data.productGroupId || '';
                    document.getElementById('supplierId').value     = data.supplierId || '';
                    document.getElementById('productCode').value    = data.productCode;
                    document.getElementById('productExtCode').value = data.externalCode || '';
                    document.getElementById('productName').value    = data.productName;
                    document.getElementById('paperColorId').value   = data.paperColorId || '';
                    document.getElementById('paperWeightId').value  = data.paperWeightId || '';
                    document.getElementById('paperWidthId').value   = data.paperWidthId || '';
                    document.getElementById('unit').value           = data.unit;
                    document.getElementById('fscTypeId').value      = data.fscTypeId || '';
                    document.getElementById('paperTypeId').value    = data.paperTypeId || '';
                    document.querySelector('.modal-title').innerHTML = '<i class="fas fa-edit me-2"></i>Ürün Düzenle';
                    _productModal.show();
                });
        }

        function toggleProduct(id) {
            fetch('/Products/ToggleStatus', {
                method: 'POST',
                body: (() => { const f = new FormData(); f.append('id', id); return f; })()
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) showToast('Durum güncellendi.', 'success');
            });
        }

        // Topbar globalSearch → DataTables
        $(document).on('init.dt', '#productsTable', function() {
            var dt = $(this).DataTable();
            var si = document.getElementById('globalSearch');
            var sd = document.getElementById('searchDropdown');
            if (!si) return;
            if (sd) sd.classList.remove('show');
            si.addEventListener('input', function(e) {
                if (sd) sd.classList.remove('show');
                dt.search(this.value).draw();
                e.stopPropagation();
            }, true);
            si.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') { this.value = ''; dt.search('').draw(); e.preventDefault(); e.stopPropagation(); }
            }, true);
        });

        function exportToExcel() {
            const params = new URLSearchParams(window.location.search);
            window.location.href = '/Products/ExportIndex?' + params.toString();
        }
    </script>
}
