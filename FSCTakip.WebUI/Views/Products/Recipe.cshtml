@model List<FSCTakip.Core.Entities.ProductRecipe>
@using FSCTakip.Core.Entities
@{
    var product  = ViewBag.Product  as Product;
    var avail    = ViewBag.AvailableProducts as List<Product> ?? new();
    ViewData["Title"] = $"Reçete — {product?.ProductName}";
    int parentId = product?.Id ?? 0;
}

@section TopbarPrimary {
    <button class="btn btn-primary btn-sm px-3" onclick="openAddModal()">
        <i class="fas fa-plus me-1"></i> Bileşen Ekle
    </button>
}
@section TopbarActions {
    <a href="/Products/Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i> Ürünler
    </a>
}

<!-- Ürün Bilgi Kartı -->
<div class="table-card p-3 mb-3">
    <div class="d-flex align-items-center gap-3">
        <div style="width:48px;height:48px;border-radius:12px;background:#eff6ff;display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-box" style="color:#1d4ed8;font-size:20px;"></i>
        </div>
        <div>
            <div class="fw-semibold" style="font-size:15px;">@product?.ProductName</div>
            <div class="text-muted small">
                <code>@product?.ProductCode</code>
                @if (product?.ProductGroup != null)
                {
                    <span class="ms-2">· @product.ProductGroup.GroupName</span>
                }
                <span class="ms-2">· Birim: @product?.Unit</span>
            </div>
        </div>
        <div class="ms-auto d-flex gap-3 text-center">
            <div>
                <div class="fw-semibold" style="font-size:20px; color:#1d4ed8;">@Model.Count</div>
                <div class="text-muted" style="font-size:11px;">Bileşen</div>
            </div>
            <div>
                <div class="fw-semibold" style="font-size:20px; color:#16a34a;">@Model.Count(r => r.IsActive)</div>
                <div class="text-muted" style="font-size:11px;">Aktif</div>
            </div>
        </div>
    </div>
</div>

<!-- Reçete Tablosu -->
@if (!Model.Any())
{
    <div class="table-card p-5 text-center">
        <div style="width:64px;height:64px;border-radius:50%;background:#f3f4f6;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
            <i class="fas fa-list-ul" style="font-size:24px;color:#9ca3af;"></i>
        </div>
        <div class="fw-semibold mb-1">Henüz Reçete Tanımlanmamış</div>
        <div class="text-muted small mb-3">Bu ürünün üretimi için gereken hammadde ve bileşenleri ekleyin.</div>
        <button class="btn btn-primary btn-sm px-4" onclick="openAddModal()">
            <i class="fas fa-plus me-1"></i> İlk Bileşeni Ekle
        </button>
    </div>
}
else
{
    <div class="table-card">
        <div class="p-3 border-bottom d-flex align-items-center gap-2">
            <i class="fas fa-list-ul text-primary"></i>
            <strong class="small">Hammadde / Bileşen Listesi</strong>
            <span class="text-muted small ms-auto">Standart miktarlar 1 birim üretim için</span>
        </div>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>BILEŞEN ÜRÜN</th>
                        <th>KOD</th>
                        <th>GRUP</th>
                        <th>KULLANIM YERİ</th>
                        <th class="text-end">STANDART MİKTAR</th>
                        <th>BİRİM</th>
                        <th class="text-center" style="width:90px;">DURUM</th>
                        <th class="text-center" style="width:110px;">İŞLEM</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model)
                    {
                        <tr style="@(!line.IsActive ? "opacity:.55;" : "")">
                            <td>
                                <strong>@line.ChildProduct?.ProductName</strong>
                            </td>
                            <td><code style="font-size:11px;">@line.ChildProduct?.ProductCode</code></td>
                            <td class="text-muted" style="font-size:12px;">@line.ChildProduct?.ProductGroup?.GroupName</td>
                            <td>
                                @if (!string.IsNullOrEmpty(line.BilesenYeri))
                                {
                                    <span class="badge" style="background:#ede9fe;color:#5b21b6;font-size:11px;">
                                        <i class="fas fa-layer-group me-1" style="font-size:9px;"></i>@line.BilesenYeri
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:11px;">—</span>
                                }
                            </td>
                            <td class="text-end fw-semibold">@line.StandardQuantity.ToString("N4")</td>
                            <td class="text-muted">@line.Unit</td>
                            <td class="text-center">
                                <span id="badge_@line.Id" class="badge @(line.IsActive ? "badge-success" : "badge-warning")">
                                    @(line.IsActive ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-icon btn-outline-primary" title="Düzenle" onclick="openModal(@line.Id)">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-icon @(line.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                        id="toggleBtn_@line.Id"
                                        title="@(line.IsActive ? "Pasife Al" : "Aktife Al")"
                                        onclick="toggleLine(@line.Id)">
                                    <i class="fas @(line.IsActive ? "fa-pause" : "fa-play")"></i>
                                </button>
                                <button class="btn btn-icon btn-outline-danger" title="Sil" onclick="deleteLine(@line.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Özet bilgi -->
        <div class="p-3 border-top" style="font-size:12px; color:#6b7280; background:#fafafa; border-radius:0 0 8px 8px;">
            <i class="fas fa-info-circle me-1 text-primary"></i>
            Bu reçete iş emri oluşturulurken <strong>Reçeteden Yükle</strong> butonu ile otomatik olarak uygulanabilir.
            Pasif bileşenler otomatik yüklemeye dahil edilmez.
        </div>
    </div>
}

<!-- Modal — Çoklu Bileşen Ekle -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header dark">
                <h5 class="modal-title fw-semibold mb-0">
                    <i class="fas fa-plus me-2"></i>Bileşen Ekle
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="max-height:75vh;overflow-y:auto;">
                <!-- Arama -->
                <div class="mb-3">
                    <input type="text" id="addSearch" class="form-control form-control-sm"
                           placeholder="Stok kodu, dış kod veya ürün adı ile ara..."
                           oninput="filterAddList()">
                </div>
                <!-- Ürün Listesi (Checkbox) -->
                <div id="addProductList" style="border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;max-height:250px;overflow-y:auto;">
                    @foreach (var p in avail)
                    {
                        var pc = (p.ProductCode ?? "").Trim();
                        var ec = (p.ExternalCode ?? "").Trim();
                        var pn = (p.ProductName  ?? "").Trim();
                        var st = $"{pc} {ec} {pn}".ToLower();
                        <label class="add-prod-row"
                               data-filter="@st"
                               style="display:flex;align-items:center;gap:8px;padding:8px 12px;cursor:pointer;border-bottom:1px solid #f3f4f6;user-select:none;">
                            <input type="checkbox" class="add-cb" value="@p.Id"
                                   data-name="@pn" data-code="@pc" data-ext="@ec"
                                   onchange="onAddCbChange(this)"
                                   style="accent-color:#1976d2;min-width:16px;height:16px;">
                            @if (!string.IsNullOrEmpty(pc))  { <span style="font-size:10.5px;background:#f3f4f6;color:#374151;padding:1px 6px;border-radius:4px;white-space:nowrap;">@pc</span> }
                            @if (!string.IsNullOrEmpty(ec))  { <span style="font-size:10.5px;background:#eef2ff;color:#3730a3;padding:1px 6px;border-radius:4px;white-space:nowrap;">@ec</span> }
                            <span style="font-size:13px;color:#111827;">@pn</span>
                        </label>
                    }
                </div>
                <!-- Seçilen Ürünler — Miktar Girişi -->
                <div id="addSelections" class="mt-3" style="display:none;">
                    <div class="fw-semibold small mb-2" style="color:#374151;">
                        <i class="fas fa-list-check me-1 text-primary"></i>Seçilen Bileşenler — Miktarları Girin
                    </div>
                    <div id="addRows"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary btn-sm px-4" onclick="saveAllLines()">
                    <i class="fas fa-save me-1"></i> Tümünü Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal — Tekli Düzenleme (id>0) -->
<div class="modal fade" id="formModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header dark">
                <h5 class="modal-title fw-semibold mb-0" id="modalTitle">
                    <i class="fas fa-edit me-2"></i>Bileşen Düzenle
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="lineId">
                <input type="hidden" id="parentId" value="@parentId">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label small fw-semibold">Bileşen Ürün</label>
                        <input type="text" id="editProductName" class="form-control" readonly
                               style="background:#f8fafc;color:#374151;">
                        <input type="hidden" id="childProductId">
                    </div>
                    <div class="col-md-12">
                        <label class="form-label small fw-semibold">
                            <i class="fas fa-layer-group me-1 text-muted"></i>Kullanım Yeri
                        </label>
                        <div class="d-flex gap-1 flex-wrap mb-2">
                            @foreach (var yer in new[] { "Gövde", "Sap", "Dip Kapak", "Etiket", "Diğer" })
                            {
                                <button type="button" class="btn btn-sm"
                                        style="font-size:11px;padding:2px 10px;background:rgba(109,40,217,.08);color:#5b21b6;border:1px solid rgba(109,40,217,.25);"
                                        onclick="document.getElementById('bilesenYeri').value='@yer'">
                                    @yer
                                </button>
                            }
                        </div>
                        <input type="text" id="bilesenYeri" class="form-control form-control-sm"
                               placeholder="Serbest giriş..." maxlength="50">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Standart Miktar <span class="text-danger">*</span>
                            <span class="text-muted fw-normal">(1 birim üretim için)</span>
                        </label>
                        <input type="text" id="standardQty" class="form-control" inputmode="decimal" placeholder="Örn: 0,0023">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Birim <span class="text-danger">*</span></label>
                        <select id="unit" class="form-select">
                            <option value="kg">kg</option>
                            <option value="Adet">Adet</option>
                            <option value="m²">m²</option>
                            <option value="m">m</option>
                            <option value="lt">lt</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary btn-sm px-4" onclick="saveLine()">
                    <i class="fas fa-save me-1"></i> Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let _modal, _addModal;

// ── Çoklu Bileşen Ekleme ────────────────────────────────────────────────────
function openAddModal() {
    // Tüm checkbox'ları sıfırla
    document.querySelectorAll('.add-cb').forEach(cb => cb.checked = false);
    document.getElementById('addSearch').value = '';
    document.getElementById('addRows').innerHTML = '';
    document.getElementById('addSelections').style.display = 'none';
    document.querySelectorAll('.add-prod-row').forEach(r => r.style.display = '');
    _addModal = new bootstrap.Modal(document.getElementById('addModal'));
    _addModal.show();
}

function filterAddList() {
    const term = document.getElementById('addSearch').value.toLowerCase().trim();
    document.querySelectorAll('.add-prod-row').forEach(row => {
        const txt = row.getAttribute('data-filter') || '';
        row.style.display = (!term || txt.includes(term)) ? 'flex' : 'none';
    });
}

function onAddCbChange(cb) {
    const pid  = cb.value;
    const name = cb.dataset.name;
    const code = cb.dataset.code;
    const ext  = cb.dataset.ext;

    if (cb.checked) {
        // Seçim satırı oluştur
        const row = document.createElement('div');
        row.id = 'addRow_' + pid;
        row.className = 'mb-3 p-3 rounded';
        row.style.cssText = 'background:#f8fafc;border:1px solid #e5e7eb;';
        row.innerHTML = `
            <div class="fw-semibold small mb-2" style="color:#111827;">
                ${code ? '<span style="font-size:10.5px;background:#f3f4f6;color:#374151;padding:1px 6px;border-radius:4px;margin-right:4px;">'+code+'</span>' : ''}
                ${ext  ? '<span style="font-size:10.5px;background:#eef2ff;color:#3730a3;padding:1px 6px;border-radius:4px;margin-right:4px;">'+ext+'</span>' : ''}
                ${name}
            </div>
            <div class="d-flex gap-2 align-items-end flex-wrap">
                <div style="min-width:130px;">
                    <label style="font-size:11px;font-weight:600;color:#6b7280;margin-bottom:3px;">MİKTAR *</label>
                    <input type="text" id="qty_${pid}" class="form-control form-control-sm" placeholder="ör: 0,0023" inputmode="decimal">
                </div>
                <div style="min-width:90px;">
                    <label style="font-size:11px;font-weight:600;color:#6b7280;margin-bottom:3px;">BİRİM</label>
                    <select id="unit_${pid}" class="form-select form-select-sm">
                        <option value="kg">kg</option>
                        <option value="Adet">Adet</option>
                        <option value="m²">m²</option>
                        <option value="m">m</option>
                        <option value="lt">lt</option>
                    </select>
                </div>
                <div style="flex:1;min-width:160px;">
                    <label style="font-size:11px;font-weight:600;color:#6b7280;margin-bottom:3px;">KULLANIM YERİ</label>
                    <div class="d-flex gap-1 flex-wrap mb-1">
                        ${['Gövde','Sap','Dip Kapak','Etiket','Diğer'].map(y =>
                            `<button type="button" class="btn btn-sm" style="font-size:10px;padding:1px 7px;background:rgba(109,40,217,.08);color:#5b21b6;border:1px solid rgba(109,40,217,.25);"
                                onclick="document.getElementById('yer_${pid}').value='${y}'">${y}</button>`
                        ).join('')}
                    </div>
                    <input type="text" id="yer_${pid}" class="form-control form-control-sm" placeholder="Serbest giriş..." maxlength="50">
                </div>
            </div>`;
        document.getElementById('addRows').appendChild(row);
    } else {
        document.getElementById('addRow_' + pid)?.remove();
    }
    document.getElementById('addSelections').style.display =
        document.querySelectorAll('.add-cb:checked').length > 0 ? '' : 'none';
}

async function saveAllLines() {
    const checked = [...document.querySelectorAll('.add-cb:checked')];
    if (!checked.length) { showToast('En az bir bileşen seçin.', 'warning'); return; }

    let added = 0, errors = [];
    for (const cb of checked) {
        const pid  = cb.value;
        const qRaw = document.getElementById('qty_' + pid)?.value || '';
        const qty  = normalizeDecimalInput(qRaw);
        if (isNaN(qty) || qty <= 0) { errors.push(cb.dataset.name + ': geçerli miktar girin'); continue; }

        const fd = new FormData();
        fd.append('Id', '0');
        fd.append('ParentProductId', document.getElementById('parentId').value);
        fd.append('ChildProductId', pid);
        fd.append('StandardQuantity', qty.toString().replace('.', ','));
        fd.append('Unit', document.getElementById('unit_' + pid)?.value || 'kg');
        fd.append('BilesenYeri', document.getElementById('yer_' + pid)?.value?.trim() || '');

        const res = await fetch('/Products/SaveRecipeLine', { method: 'POST', body: fd }).then(r => r.json()).catch(() => ({ success: false }));
        if (res.success) added++;
        else errors.push(cb.dataset.name + ': ' + (res.message || 'hata'));
    }

    if (errors.length) showToast('Hatalar: ' + errors.join(', '), 'warning');
    if (added > 0) {
        showToast(`${added} bileşen reçeteye eklendi.`, 'success');
        setTimeout(() => { _addModal?.hide(); location.reload(); }, 600);
    }
}

// ── Tekli Düzenleme ──────────────────────────────────────────────────────────
function openModal(id) {
    if (id === 0) { openAddModal(); return; }
    document.getElementById('lineId').value      = id;
    document.getElementById('standardQty').value = '';
    document.getElementById('unit').value        = 'kg';
    document.getElementById('bilesenYeri').value = '';

    fetch(`/Products/GetRecipeLine?id=${id}`)
        .then(r => r.json())
        .then(res => {
            if (!res.success) return;
            document.getElementById('editProductName').value = res.data.childProductId; // geçici
            document.getElementById('childProductId').value  = res.data.childProductId;
            document.getElementById('standardQty').value    = res.data.standardQuantity;
            document.getElementById('unit').value           = res.data.unit;
            document.getElementById('bilesenYeri').value    = res.data.bilesenYeri || '';
            // Ürün adını göster
            const opts = document.querySelectorAll('.add-cb');
            // avail listesinden ara
            let pname = '';
            document.querySelectorAll('.add-prod-row .add-cb').forEach(cb => {
                if (cb.value == res.data.childProductId) pname = cb.dataset.name;
            });
            document.getElementById('editProductName').value = pname || ('Ürün #' + res.data.childProductId);
        });

    _modal = new bootstrap.Modal(document.getElementById('formModal'));
    _modal.show();
}

function normalizeDecimalInput(value) {
    let s = (value || '').toString().trim();
    if (!s) return NaN;

    s = s.replace(/\s/g, '');
    
    // Türkçe format kontrolü: son ayırıcı virgül mü?
    const lastComma = s.lastIndexOf(',');
    const lastDot = s.lastIndexOf('.');
    
    // Önceki sayısal karakterler
    const hasComma = lastComma >= 0;
    const hasDot = lastDot >= 0;
    
    if (hasComma && hasDot) {
        // İki ayırıcı varsa, sonuncusu ondalık kabul edilir
        const sepIndex = Math.max(lastComma, lastDot);
        const intPart = s.slice(0, sepIndex).replace(/[.,]/g, '');
        const fracPart = s.slice(sepIndex + 1).replace(/[.,]/g, '');
        s = `${intPart}.${fracPart}`;
    } else if (hasComma) {
        // Sadece virgül varsa (TR formatı)
        const intPart = s.slice(0, lastComma).replace(/[.,]/g, '');
        const fracPart = s.slice(lastComma + 1).replace(/[.,]/g, '');
        s = `${intPart}.${fracPart}`;
    } else if (hasDot) {
        // Sadece nokta varsa (EN formatı)
        const intPart = s.slice(0, lastDot).replace(/[.,]/g, '');
        const fracPart = s.slice(lastDot + 1).replace(/[.,]/g, '');
        s = `${intPart}.${fracPart}`;
    } else {
        //Ayırıcı yoksa
        s = s.replace(/[.,]/g, '');
    }

    s = s.replace(/[^0-9.-]/g, '');
    const num = Number(s);
    return Number.isFinite(num) ? num : NaN;
}

function saveLine() {
    const childId = document.getElementById('childProductId').value;
    const qtyRaw  = document.getElementById('standardQty').value;
    const qty     = normalizeDecimalInput(qtyRaw);

    if (!childId) { showToast('Bileşen ürün seçiniz.', 'warning'); return; }
    if (isNaN(qty) || qty <= 0) { showToast('Geçerli bir miktar giriniz.', 'warning'); return; }

const fd = new FormData();
    fd.append('Id',               document.getElementById('lineId').value);
    fd.append('ParentProductId',  document.getElementById('parentId').value);
    fd.append('ChildProductId',   childId);
    // TR formatı (virgül ondalık) olarak gönder - controller bunu bekliyor
    fd.append('StandardQuantity', qty.toString().replace('.', ','));
    fd.append('Unit',             document.getElementById('unit').value);
    fd.append('BilesenYeri',      document.getElementById('bilesenYeri').value.trim());

    fetch('/Products/SaveRecipeLine', { method: 'POST', body: fd })
        .then(r => r.json())
        .then(res => {
            if (res.success) { _modal.hide(); location.reload(); }
            else showToast(res.message || 'Kayıt sırasında hata oluştu.', 'error');
        });
}

function toggleLine(id) {
    fetch(`/Products/ToggleRecipeLine?id=${id}`, { method: 'POST' })
        .then(r => r.json())
        .then(res => {
            if (!res.success) { showToast(res.message || 'İşlem başarısız.', 'error'); return; }
            const badge = document.getElementById(`badge_${id}`);
            const btn   = document.getElementById(`toggleBtn_${id}`);
            if (res.isActive) {
                badge.className = 'badge badge-success'; badge.textContent = 'Aktif';
                btn.className   = 'btn btn-icon btn-outline-warning'; btn.title = 'Pasife Al';
                btn.innerHTML   = '<i class="fas fa-pause"></i>';
            } else {
                badge.className = 'badge badge-warning'; badge.textContent = 'Pasif';
                btn.className   = 'btn btn-icon btn-outline-success'; btn.title = 'Aktife Al';
                btn.innerHTML   = '<i class="fas fa-play"></i>';
            }
            // satır opaklığını güncelle
            btn.closest('tr').style.opacity = res.isActive ? '1' : '0.55';
        });
}

function deleteLine(id) {
    Swal.fire({
        title: 'Bileşeni Sil',
        text: 'Bu bileşeni reçeteden kaldırmak istiyor musunuz?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Evet, Sil',
        cancelButtonText: 'Vazgeç',
        confirmButtonColor: '#dc2626'
    }).then(r => {
        if (!r.isConfirmed) return;
        fetch(`/Products/DeleteRecipeLine?id=${id}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => { if (res.success) location.reload(); else showToast(res.message || 'Silme başarısız.', 'error'); });
    });
}

/* ─── REÇETE BİLEŞEN ÜRÜN ARAMA + LİSTE FİLTRELEME ─────────── */
function initRecipeProductSelectSearch() {
    const searchInput = document.getElementById('childProductSearch');
    const productSelect = document.getElementById('childProductId');
    if (!searchInput || !productSelect) return;

    const originalOptions = Array.from(productSelect.options).map(o => ({
        value: o.value,
        text: o.textContent || '',
        search: o.dataset.search || ''
    }));

    function renderOptions(term, keepValue) {
        const q = (term || '').trim().toLowerCase();
        const selectedVal = keepValue ?? productSelect.value;

        productSelect.innerHTML = '';
        originalOptions.forEach(item => {
            if (!q || !item.value || item.search.includes(q)) {
                const opt = document.createElement('option');
                opt.value = item.value;
                opt.textContent = item.text;
                if (item.search) opt.dataset.search = item.search;
                productSelect.appendChild(opt);
            }
        });

        if (selectedVal && Array.from(productSelect.options).some(o => o.value === selectedVal)) {
            productSelect.value = selectedVal;
        }
    }

    window.setRecipeProductSearchFromSelection = function () {
        const selected = Array.from(productSelect.options).find(o => o.value === productSelect.value);
        if (!selected || !selected.value) return;
        const selectedId = selected.value;
        const selectedText = selected.textContent || '';
        const selectedSearch = selected.dataset.search || '';

        productSelect.innerHTML = '';
        const opt = document.createElement('option');
        opt.value = selectedId;
        opt.textContent = selectedText;
        opt.dataset.search = selectedSearch;
        productSelect.appendChild(opt);
        productSelect.value = selectedId;
    };

    searchInput.addEventListener('input', function () {
        renderOptions(this.value, '');
    });

    productSelect.addEventListener('change', function () {
        if (!this.value) return;
        window.setRecipeProductSearchFromSelection();
    });

    renderOptions('', '');
}

initRecipeProductSelectSearch();
</script>
}
