@model ErrorViewModel
@{
    ViewData["Title"] = "Beklenmeyen Hata";
}
<div class="d-flex flex-column align-items-center justify-content-center" style="min-height:60vh;">
    <div class="text-center p-5" style="max-width:520px;">
        <div style="width:80px;height:80px;border-radius:50%;background:#fef3c7;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
            <i class="fas fa-triangle-exclamation" style="font-size:32px;color:#d97706;"></i>
        </div>
        <h4 class="fw-bold mb-2">Beklenmeyen bir hata oluştu</h4>
        <p class="text-muted mb-4">
            İşleminiz sırasında bir sorun yaşandı. Sayfayı yenileyip tekrar deneyin.
            Sorun sürerse aşağıdaki referans numarasıyla sistem sorumlunuza bildirin.
        </p>
        @if (Model?.ShowRequestId == true)
        {
            <div class="mb-4">
                <span class="text-muted small">Referans No:</span>
                <code style="font-size:13px;">@Model.RequestId</code>
            </div>
        }
        <a href="/" class="btn btn-primary">
            <i class="fas fa-home me-1"></i> Ana Sayfaya Dön
        </a>
    </div>
</div>
