function appConfirm(message, opts = {}) {
    return new Promise(resolve => {
        const danger = (opts.danger != null) ? opts.danger
                     : /\bsil|kaldır|geri alınamaz|iptal et|dönüştür/i.test(message || '');
        const accent = danger ? '#dc2626' : '#1976d2';
        const icon   = opts.icon || (danger ? 'triangle-exclamation' : 'circle-question');
        const title  = opts.title || (danger ? 'Onay Gerekiyor' : 'Onay');
        const okText = opts.confirmText || (danger ? 'Evet, Devam Et' : 'Tamam');
        const noText = opts.cancelText || 'İptal';
        const esc = String(message || '')
            .replace(/[&<>"]/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c]))
            .replace(/\n/g, '<br>');

        const ov = document.createElement('div');
        ov.className = 'app-confirm-overlay';
        ov.innerHTML = `
          <div class="app-confirm-card" role="alertdialog" aria-modal="true">
            <div class="app-confirm-icon" style="background:${accent}1a;color:${accent};"><i class="fas fa-${icon}"></i></div>
            <div class="app-confirm-title">${title}</div>
            <div class="app-confirm-msg">${esc}</div>
            <div class="app-confirm-actions">
              <button type="button" class="app-confirm-btn cancel">${noText}</button>
              <button type="button" class="app-confirm-btn ok" style="background:${accent};box-shadow:0 4px 14px ${accent}59;">${okText}</button>
            </div>
          </div>`;
        document.body.appendChild(ov);
        requestAnimationFrame(() => ov.classList.add('show'));

        const close = (val) => {
            ov.classList.remove('show');
            setTimeout(() => ov.remove(), 180);
            document.removeEventListener('keydown', onKey);
            resolve(val);
        };
        const onKey = (e) => {
            if (e.key === 'Escape') close(false);
            else if (e.key === 'Enter') close(true);
        };
        ov.querySelector('.ok').addEventListener('click', () => close(true));
        ov.querySelector('.cancel').addEventListener('click', () => close(false));
        ov.addEventListener('mousedown', (e) => { if (e.target === ov) close(false); });
        document.addEventListener('keydown', onKey);
        setTimeout(() => ov.querySelector('.ok')?.focus(), 50);
    });
}
window.appConfirm = appConfirm;

/* native alert() -> ARD temalı toast (hata tonu) */
window.alert = function (m) { (window.showToast || function () {})(String(m), 'error'); };

/* ── SweetAlert uyumlu shim: tüm Swal.fire(...) çağrılarını ARD temasına taşır ── */
function appSwalFire(arg, _text, _icon) {
    const o = (typeof arg === 'string') ? { title: arg, text: _text, icon: _icon } : (arg || {});
    const palette = {
        success:  ['#16a34a', 'circle-check'],
        error:    ['#dc2626', 'circle-xmark'],
        warning:  ['#d97706', 'triangle-exclamation'],
        question: ['#1976d2', 'circle-question'],
        info:     ['#1976d2', 'circle-info']
    };
    const type = o.icon || (o.showCancelButton ? 'question' : 'info');
    const [accent, faIcon] = palette[type] || palette.info;
    const esc = (s) => String(s == null ? '' : s)
        .replace(/[&<>"]/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c]))
        .replace(/\n/g, '<br>');
    const bodyHtml   = (o.html != null) ? o.html : esc(o.text);
    const hasCancel  = !!o.showCancelButton;
    const hasConfirm = o.showConfirmButton !== false;
    const okText = o.confirmButtonText || 'Tamam';
    const noText = o.cancelButtonText  || 'İptal';

    return new Promise(resolve => {
        const ov = document.createElement('div');
        ov.className = 'app-confirm-overlay';
        let actions = '';
        if (hasCancel || hasConfirm) {
            actions = '<div class="app-confirm-actions">';
            if (hasCancel)  actions += `<button type="button" class="app-confirm-btn cancel">${noText}</button>`;
            if (hasConfirm) actions += `<button type="button" class="app-confirm-btn ok" style="background:${accent};box-shadow:0 4px 14px ${accent}59;">${okText}</button>`;
            actions += '</div>';
        }
        ov.innerHTML = `
          <div class="app-confirm-card" role="alertdialog" aria-modal="true">
            <div class="app-confirm-icon" style="background:${accent}1a;color:${accent};"><i class="fas fa-${faIcon}"></i></div>
            ${o.title ? `<div class="app-confirm-title">${esc(o.title)}</div>` : ''}
            ${bodyHtml ? `<div class="app-confirm-msg">${bodyHtml}</div>` : ''}
            ${actions}
          </div>`;
        document.body.appendChild(ov);
        requestAnimationFrame(() => ov.classList.add('show'));

        let timer = null;
        const close = (confirmed) => {
            if (timer) clearTimeout(timer);
            ov.classList.remove('show');
            setTimeout(() => ov.remove(), 180);
            document.removeEventListener('keydown', onKey);
            resolve({ isConfirmed: confirmed, isDismissed: !confirmed, isDenied: false, value: confirmed });
        };
        const onKey = (e) => {
            if (e.key === 'Escape') close(false);
            else if (e.key === 'Enter' && hasConfirm) close(true);
        };
        ov.querySelector('.ok')?.addEventListener('click', () => close(true));
        ov.querySelector('.cancel')?.addEventListener('click', () => close(false));
        ov.addEventListener('mousedown', (e) => { if (e.target === ov) close(false); });
        document.addEventListener('keydown', onKey);
        if (hasConfirm) setTimeout(() => ov.querySelector('.ok')?.focus(), 50);
        if (o.timer) timer = setTimeout(() => close(false), o.timer);
    });
}
/* OK-only kısayol: appAlert('mesaj', { icon:'success', title:'...' }) */
window.appAlert = (message, opts = {}) => appSwalFire(Object.assign({ text: message, icon: 'info' }, opts));
/* Mevcut Swal.fire çağrılarını çağrı yerlerini değiştirmeden temalı yap */
if (window.Swal) { window.Swal.fire = appSwalFire; }
else { window.Swal = { fire: appSwalFire, close: function () {} }; }

/* ── Sidebar Text-Node Guard (tekrar eden siyah yazıları engelle) ───── */
(function () {
    const sidebar = document.getElementById('sidebar');
    if (!sidebar) return;

    function cleanNavItems() {
        document.querySelectorAll('.sidebar-nav .nav-item').forEach(item => {
            // nav-link dışındaki serbest text node'ları temizle
            Array.from(item.childNodes).forEach(node => {
                if (node.nodeType === Node.TEXT_NODE && node.textContent && node.textContent.trim()) {
                    node.textContent = '';
                }
            });
            // Daha önce eklenmiş tooltip/span kopyaları varsa kaldır
            item.querySelectorAll(':scope > .nav-tooltip').forEach(el => el.remove());
            item.querySelectorAll(':scope > span:not(.nav-link-item)').forEach(el => el.remove());
        });
    }

    cleanNavItems();

    // İleride tekrar eklenirse otomatik temizle
    const observer = new MutationObserver(() => cleanNavItems());
    observer.observe(sidebar, { childList: true, subtree: true, characterData: true });
})();

/* ── Sidebar Arama ──────────────────────────────────────────────────── */
(function () {
    const input   = document.getElementById('sidebarSearch');
    const clearBtn= document.getElementById('sidebarSearchClear');
    const noResult= document.getElementById('sidebarNoResult');
    if (!input) return;

    // Tüm menü öğelerini topla (bir kez)
    const items = Array.from(document.querySelectorAll('.sidebar-nav .nav-item')).map(item => {
        const link  = item.querySelector('.nav-link-item');
        const label = item.querySelector('.nav-label');
        // Bu öğenin ait olduğu collapse (section) div'ini bul
        const section = item.closest('.nav-section-collapse');
        // Section'ın toggle butonunu bul
        const toggle = section ? document.querySelector(`[data-bs-target="#${section.id}"]`) : null;
        return { item, link, label, section, toggle, originalText: label ? label.textContent.trim() : '' };
    }).filter(x => x.label);

    function highlight(text, query) {
        if (!query) return text;
        const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        return text.replace(new RegExp(`(${escaped})`, 'gi'), '<mark>$1</mark>');
    }

    function doSearch(q) {
        const query = q.trim().toLowerCase();
        clearBtn.style.display = query ? 'block' : 'none';
        noResult.style.display = 'none';

        if (!query) {
            // Aramayı temizle — her şeyi normale döndür
            items.forEach(({ item, label, section, toggle, originalText }) => {
                item.style.display = '';
                label.innerHTML = originalText;
                // Açık olan section'ı kapat (orijinal sayfa durumuna dön)
                if (section && section.dataset.searchOpened === '1') {
                    section.classList.remove('show');
                    if (toggle) toggle.setAttribute('aria-expanded', 'false');
                    delete section.dataset.searchOpened;
                }
            });
            return;
        }

        // Section'ları önce gizle
        document.querySelectorAll('.nav-section-collapse').forEach(s => {
            s._searchVisible = false;
        });

        let totalVisible = 0;
        items.forEach(({ item, label, section, originalText }) => {
            const match = originalText.toLowerCase().includes(query);
            if (match) {
                item.style.display = '';
                label.innerHTML = highlight(originalText, q.trim());
                if (section) section._searchVisible = true;
                totalVisible++;
            } else {
                item.style.display = 'none';
                label.innerHTML = originalText;
            }
        });

        // Section'ları aç/kapat
        document.querySelectorAll('.nav-section-collapse').forEach(sec => {
            const toggle = document.querySelector(`[data-bs-target="#${sec.id}"]`);
            if (sec._searchVisible) {
                if (!sec.classList.contains('show')) {
                    sec.classList.add('show');
                    sec.dataset.searchOpened = '1';
                    if (toggle) toggle.setAttribute('aria-expanded', 'true');
                }
            } else {
                if (sec.classList.contains('show') && sec.dataset.searchOpened === '1') {
                    sec.classList.remove('show');
                    if (toggle) toggle.setAttribute('aria-expanded', 'false');
                    delete sec.dataset.searchOpened;
                }
            }
        });

        noResult.style.display = totalVisible === 0 ? 'block' : 'none';
    }

    input.addEventListener('input', () => doSearch(input.value));

    clearBtn.addEventListener('click', () => {
        input.value = '';
        doSearch('');
        input.focus();
    });

    // Ctrl+K → arama kutusuna focus
    document.addEventListener('keydown', e => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            const sidebar = document.getElementById('sidebar');
            if (sidebar && sidebar.classList.contains('collapsed')) return;
            e.preventDefault();
            input.focus();
            input.select();
        }
        if (e.key === 'Escape' && document.activeElement === input) {
            input.value = '';
            doSearch('');
            input.blur();
        }
    });
})();

/* ── Keyboard Shortcuts ─────────────────────────────────────────────── */
(function () {
    let _shortcutsModal = null;
    document.addEventListener('keydown', function (e) {
        const tag = (document.activeElement || {}).tagName;
        const isInput = tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';

        // ? → kısayol yardımı (input dışında)
        if (e.key === '?' && !isInput) {
            e.preventDefault();
            const el = document.getElementById('shortcutsModal');
            if (el) {
                if (!_shortcutsModal) _shortcutsModal = new bootstrap.Modal(el);
                _shortcutsModal.show();
            }
            return;
        }
        if (!e.ctrlKey && !e.metaKey) return;
        switch (e.key) {
            case 'n': case 'N':
                e.preventDefault(); openAddModal(); break;
            case 'e': case 'E':
                e.preventDefault(); exportToExcel(); break;
            case 'f': case 'F':
                e.preventDefault(); toggleFilter(); break;
            case 'd': case 'D':
                if (!isInput) { e.preventDefault(); document.getElementById('darkModeToggle')?.click(); }
                break;
        }
    });
})();

/* ── Page Progress Bar ──────────────────────────────────────────────── */
(function () {
    const bar = document.getElementById('pageProgressBar');
    if (!bar) return;
    let _t;
    function start() {
        clearTimeout(_t);
        bar.style.width = '0%'; bar.style.opacity = '1';
        bar.style.transition = 'width 8s cubic-bezier(.1,1,.1,1),opacity .4s';
        setTimeout(() => { bar.style.width = '80%'; }, 10);
    }
    function done() {
        bar.style.transition = 'width .2s ease,opacity .4s';
        bar.style.width = '100%';
        _t = setTimeout(() => { bar.style.opacity = '0'; setTimeout(() => { bar.style.width = '0%'; }, 400); }, 300);
    }
    // Link tıklamalarında başlat
    document.addEventListener('click', e => {
        const a = e.target.closest('a[href]');
        if (!a) return;
        const href = a.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('javascript') || a.target === '_blank') return;
        if (a.hasAttribute('data-bs-toggle')) return;
        start();
    });
    // Form submit'te başlat
    document.addEventListener('submit', () => start());
    // Yükleme bitince bitir
    window.addEventListener('load', done);
    // Eğer hâlâ yüklü değilse
    if (document.readyState === 'complete') done();
})();

function toggleFilter() {
    const p = document.getElementById('filterPanel');
    if (p) p.style.display = p.style.display === 'none' ? 'block' : 'none';
}
function openAddModal() {
