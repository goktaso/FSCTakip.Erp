// ── GENEL QUICK-ADD ROUTER ─────────────────────────────────────────────
// supplier / customer / fsctype → tam form modalları
// Diğerleri → basit jenerik modal

var _qaModal = null;
var _qaTargetSelectId = null;
var _qaCurrentConfig = null;

function openQuickAdd(type, targetSelectId) {
    // Tam form modal türleri
    if (type === 'supplier') { _resetAndOpenFullModal('qaSupplierModal', targetSelectId); return; }
    if (type === 'customer') { _resetAndOpenFullModal('qaCustomerModal', targetSelectId); return; }
    if (type === 'fsctype')  { _resetAndOpenFullModal('qaFscTypeModal',  targetSelectId); return; }

    // Jenerik basit modal (diğerleri)
    const cfg = QA_CONFIGS[type];
    if (!cfg) { console.error('QuickAdd: unknown type', type); return; }
    _qaTargetSelectId = targetSelectId;
    _qaCurrentConfig  = cfg;

    // Header
    document.getElementById('qaTitle').textContent = cfg.title;
    const icon = document.getElementById('qaHeaderIcon');
    icon.innerHTML = `<i class="${cfg.icon}"></i>`;
    document.getElementById('qaHeader').style.background = cfg.color;

    // Form alanlarını oluştur
    let html = '<div class="row g-3">';
    cfg.fields.forEach(f => {
        if (f.type === 'static') {
            html += `<div class="col-6">
                <label class="form-label small fw-semibold">${f.label}</label>
                <input type="text" class="form-control form-control-sm" value="${f.val||''}" readonly style="background:#f8fafc;">
                <input type="hidden" name="${f.name}" value="${f.val||''}">
            </div>`;
        } else if (f.type === 'number') {
            html += `<div class="col-6">
                <label class="form-label small fw-semibold">${f.label}${f.req?'<span class="text-danger ms-1">*</span>':''}</label>
                <input type="number" class="form-control form-control-sm" name="${f.name}"
                       ${f.min!==undefined?'min="'+f.min+'"':''} ${f.step?'step="'+f.step+'"':'step="1"'}
                       ${f.req?'required':''}>
            </div>`;
        } else {
            html += `<div class="col-12">
                <label class="form-label small fw-semibold">${f.label}${f.req?'<span class="text-danger ms-1">*</span>':''}</label>
                <input type="text" class="form-control form-control-sm" name="${f.name}"
                       ${f.ph?'placeholder="'+f.ph+'"':''} ${f.maxlen?'maxlength="'+f.maxlen+'"':''}
                       ${f.req?'required':''} ${f.upper?'style="text-transform:uppercase;"':''}>
            </div>`;
        }
    });
    html += '</div>';
    document.getElementById('qaBody').innerHTML = html;

    if (!_qaModal) {
        const el = document.getElementById('quickAddModal');
        _qaModal = new bootstrap.Modal(el);
        document.getElementById('qaClose').addEventListener('click',  () => _qaModal.hide());
        document.getElementById('qaCancelBtn').addEventListener('click', () => _qaModal.hide());
        document.getElementById('qaSaveBtn').addEventListener('click', saveQuickAdd);
    }
    _qaModal.show();
    setTimeout(() => { const inp = document.querySelector('#qaBody input:not([readonly])'); if(inp) inp.focus(); }, 350);
}

async function saveQuickAdd() {
    const cfg = _qaCurrentConfig;
    const body = document.getElementById('qaBody');

    const inputs = body.querySelectorAll('input[required]');
    let valid = true;
    inputs.forEach(i => { if (!i.value.trim()) { i.classList.add('is-invalid'); valid = false; } else { i.classList.remove('is-invalid'); } });
    if (!valid) return;

    body.querySelectorAll('input[style*="uppercase"]').forEach(i => { i.value = i.value.toUpperCase(); });

    const fd = new FormData();
    body.querySelectorAll('input[name]').forEach(i => fd.append(i.name, i.value.trim()));

    const btn = document.getElementById('qaSaveBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Kaydediliyor...';

    try {
        const res  = await fetch(cfg.url, { method:'POST', body: fd });
        const json = await res.json();
        if (json.success) {
            const sel = document.getElementById(_qaTargetSelectId);
            if (sel) {
                const opt = new Option(json.text, json.id, true, true);
                sel.appendChild(opt);
                sel.value = json.id;
                sel.dispatchEvent(new Event('change'));
            }
            _qaModal.hide();
            showToast(`${cfg.title.replace('Yeni ','')}: "${json.text}" eklendi.`, 'success');
        } else {
            showToast(json.message || 'Kayıt hatası.', 'error');
        }
    } catch(e) {
        showToast('Bağlantı hatası.', 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-check me-1"></i> Kaydet & Seç';
    }
}
</script>

