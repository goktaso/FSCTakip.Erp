<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - FSC Takip ERP</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css">

    <style>
        :root {
            --sidebar-bg:      #1a2744;
            --sidebar-hover:   rgba(255,255,255,.07);
            --sidebar-active:  rgba(25,118,210,.22);
            --accent:          #1976d2;
            --accent-dark:     #1565c0;
            --accent-light:    #e3f2fd;
            --topbar-h:        56px;
            --sidebar-w:       250px;
            --sidebar-w-col:   64px;
            --card-radius:     10px;
            --shadow-sm:       0 1px 4px rgba(0,0,0,.08);
            --shadow-md:       0 4px 16px rgba(0,0,0,.12);
            --text-muted:      #6b7280;
            --border:          #e5e7eb;
            --bg-page:         #f0f2f5;
            --table-header-bg: #1a2744;
            --table-header-color: #fff;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: 'Inter', 'Segoe UI', sans-serif;
            font-size: 14px;
            background: var(--bg-page);
            color: #111827;
            overflow-x: hidden;
        }

        /* ── SIDEBAR ───────────────────────────────────── */
        .sidebar {
            position: fixed; top: 0; left: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--sidebar-bg);
            display: flex; flex-direction: column;
            transition: width .25s cubic-bezier(.4,0,.2,1);
            z-index: 1050;
            overflow: hidden;
        }
        .sidebar.collapsed { width: var(--sidebar-w-col); }

        .sidebar-logo {
            display: flex; align-items: center; gap: 10px;
            padding: 16px;
            border-bottom: 1px solid rgba(255,255,255,.08);
            white-space: nowrap; overflow: hidden;
            text-decoration: none;
            background: rgba(0,0,0,.15);
        }
        .sidebar-logo .logo-icon {
            width: 34px; height: 34px; border-radius: 8px;
            background: linear-gradient(135deg, #1976d2, #0d47a1);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; font-size: 15px; color: #fff;
        }
        .sidebar-logo .logo-text { color: #fff; font-weight: 700; font-size: 15px; line-height: 1.2; }
        .sidebar-logo .logo-sub  { color: rgba(255,255,255,.45); font-size: 10px; font-weight: 400; letter-spacing:.03em; }
        .sidebar.collapsed .logo-text,
        .sidebar.collapsed .logo-sub { display: none; }

        .sidebar-nav { flex: 1; overflow-y: auto; overflow-x: hidden; padding: 8px 0; }
        .sidebar-nav::-webkit-scrollbar { width: 4px; }
        .sidebar-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 4px; }

        .nav-section {
            padding: 14px 16px 4px;
            font-size: 10px; font-weight: 600; letter-spacing: .1em;
            color: rgba(255,255,255,.28); text-transform: uppercase;
            white-space: nowrap; overflow: hidden;
        }
        .sidebar.collapsed .nav-section { opacity: 0; height: 0; padding: 0; }

        .nav-item { margin: 1px 6px; }
        .nav-link-item {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 10px; border-radius: 7px;
            color: rgba(255,255,255,.65); font-size: 13.5px; font-weight: 500;
            text-decoration: none; white-space: nowrap; overflow: hidden;
            transition: background .15s, color .15s;
            cursor: pointer; border: none; background: none; width: 100%; text-align: left;
        }
        .nav-link-item:hover { background: var(--sidebar-hover); color: #fff; }
        .nav-link-item.active {
            background: var(--sidebar-active);
            color: #fff;
            box-shadow: inset 3px 0 0 var(--accent);
        }
        .nav-link-item .nav-icon {
            width: 22px; text-align: center; font-size: 14px; flex-shrink: 0;
            color: rgba(255,255,255,.45);
        }
        .nav-link-item.active .nav-icon,
        .nav-link-item:hover .nav-icon { color: #60a5fa; }
        .nav-link-item .nav-label { flex: 1; }
        .nav-link-item .nav-arrow {
            font-size: 10px; transition: transform .2s;
            color: rgba(255,255,255,.3);
        }
        .nav-link-item[aria-expanded="true"] .nav-arrow { transform: rotate(90deg); }
        .sidebar.collapsed .nav-label,
        .sidebar.collapsed .nav-arrow { display: none; }

        .nav-sub { padding-left: 12px; }
        .nav-sub .nav-item { margin: 1px 0; }
        .nav-sub .nav-link-item {
            font-size: 13px; font-weight: 400;
            padding: 7px 10px;
            color: rgba(255,255,255,.5);
        }
        .nav-sub .nav-link-item::before {
            content: ''; width: 5px; height: 5px; border-radius: 50%;
            background: rgba(255,255,255,.2); flex-shrink: 0;
        }
        .nav-sub .nav-link-item.active::before,
        .nav-sub .nav-link-item:hover::before { background: #60a5fa; }
        .sidebar.collapsed .nav-sub { display: none; }

        .sidebar-footer {
            padding: 10px 12px;
            border-top: 1px solid rgba(255,255,255,.08);
            white-space: nowrap; overflow: hidden;
            background: rgba(0,0,0,.15);
        }
        .sidebar-user {
            display: flex; align-items: center; gap: 10px;
            color: rgba(255,255,255,.6); font-size: 12px;
        }
        .sidebar-user .avatar {
            width: 30px; height: 30px; border-radius: 50%;
            background: linear-gradient(135deg, #1976d2, #0d47a1);
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; color: #fff; font-weight: 700; flex-shrink: 0;
        }
        .sidebar.collapsed .sidebar-user span { display: none; }

        /* ── TOPBAR ────────────────────────────────────── */
        .topbar {
            position: fixed; top: 0;
            left: var(--sidebar-w); right: 0;
            height: var(--topbar-h);
            background: #fff;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
            padding: 0 18px; gap: 10px;
            transition: left .25s cubic-bezier(.4,0,.2,1);
            z-index: 1000; box-shadow: 0 1px 6px rgba(0,0,0,.07);
        }
        .sidebar.collapsed ~ .page-shell .topbar { left: var(--sidebar-w-col); }

        .topbar-toggle {
            width: 34px; height: 34px; border-radius: 7px;
            border: 1px solid var(--border); background: transparent;
            display: flex; align-items: center; justify-content: center;
            color: #374151; cursor: pointer; flex-shrink: 0;
            transition: background .15s;
        }
        .topbar-toggle:hover { background: var(--accent-light); color: var(--accent); }

        .topbar-title { font-size: 15px; font-weight: 600; color: #111827; }
        .topbar-breadcrumb { font-size: 11.5px; color: var(--text-muted); }

        .topbar-user {
            display: flex; align-items: center; gap: 8px;
            padding: 5px 10px; border-radius: 8px;
            border: 1px solid var(--border);
            background: #fafafa;
        }
        .topbar-user .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: linear-gradient(135deg, #1976d2, #0d47a1);
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; color: #fff;
        }
        .topbar-user .user-name { font-size: 12.5px; font-weight: 600; color: #111827; }
        .topbar-user .user-role { font-size: 11px; color: var(--text-muted); }

        .topbar-actions { display: flex; align-items: center; gap: 6px; }
        .topbar-btn {
            height: 32px; padding: 0 13px; border-radius: 7px; font-size: 12.5px;
            font-weight: 500; display: inline-flex; align-items: center; gap: 6px;
            border: 1px solid var(--border); background: #fff; color: #374151;
            cursor: pointer; text-decoration: none; transition: all .15s;
        }
        .topbar-btn:hover { background: var(--bg-page); color: #111827; }
        .topbar-btn.btn-primary-custom {
            background: var(--accent); border-color: var(--accent); color: #fff;
        }
        .topbar-btn.btn-primary-custom:hover { background: var(--accent-dark); color: #fff; }
        .topbar-btn.btn-excel { color: #166534; border-color: #bbf7d0; background: #f0fdf4; }
        .topbar-btn.btn-excel:hover { background: #dcfce7; color: #166534; }
        .topbar-btn.btn-pdf { color: #991b1b; border-color: #fecaca; background: #fff5f5; }
        .topbar-btn.btn-pdf:hover { background: #fee2e2; color: #991b1b; }
        .topbar-btn.btn-filter { color: #92400e; border-color: #fde68a; background: #fffbeb; }
        .topbar-btn.btn-filter:hover { background: #fef3c7; color: #92400e; }
        .btn-logout {
            width: 32px; height: 32px; border-radius: 7px; padding: 0;
            border: 1px solid #fecaca; background: #fff5f5; color: #dc2626;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: all .15s; font-size: 13px;
        }
        .btn-logout:hover { background: #fee2e2; }

        /* Topbar birincil aksiyon butonu */
        .topbar-primary { display: flex; align-items: center; }
        .btn-topbar-add {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 0 20px; height: 36px; border-radius: 8px;
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
            color: #fff !important; border: none; cursor: pointer;
            font-size: 13.5px; font-weight: 600; letter-spacing: .01em;
            box-shadow: 0 2px 8px rgba(25,118,210,.35);
            transition: all .18s; text-decoration: none; white-space: nowrap;
        }
        .btn-topbar-add:hover {
            background: linear-gradient(135deg, var(--accent-dark) 0%, #0d47a1 100%);
            box-shadow: 0 4px 14px rgba(25,118,210,.45);
            transform: translateY(-1px); color: #fff;
        }
        .btn-topbar-add .btn-add-icon {
            width: 20px; height: 20px; border-radius: 5px;
            background: rgba(255,255,255,.22);
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; flex-shrink: 0;
        }

        /* ── PAGE SHELL ────────────────────────────────── */
        .page-shell {
            margin-left: var(--sidebar-w);
            transition: margin-left .25s cubic-bezier(.4,0,.2,1);
        }
        .sidebar.collapsed ~ .page-shell { margin-left: var(--sidebar-w-col); }

        .page-body {
            padding: 20px 22px 32px;
            margin-top: var(--topbar-h);
            min-height: calc(100vh - var(--topbar-h));
        }

        /* ── CARDS ─────────────────────────────────────── */
        .card {
            border: 1px solid var(--border) !important;
            border-radius: var(--card-radius) !important;
            box-shadow: var(--shadow-sm);
        }
        .card-header-accent, .card-header-blue {
            background: linear-gradient(135deg, #1a2744 0%, #243566 100%);
            color: #fff; padding: 13px 18px;
            border-radius: var(--card-radius) var(--card-radius) 0 0 !important;
            font-weight: 600; font-size: 14px;
            display: flex; align-items: center; gap: 8px;
        }
        .card-header-green {
            background: linear-gradient(135deg, #166534 0%, #15803d 100%);
            color: #fff; padding: 13px 18px;
            border-radius: var(--card-radius) var(--card-radius) 0 0 !important;
            font-weight: 600; font-size: 14px;
            display: flex; align-items: center; gap: 8px;
        }

        /* ── STAT CARDS ────────────────────────────────── */
        .stat-card {
            background: #fff; border: 1px solid var(--border);
            border-radius: var(--card-radius); padding: 16px 18px;
            display: flex; align-items: center; gap: 14px;
            box-shadow: var(--shadow-sm); transition: box-shadow .2s, transform .2s;
        }
        .stat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
        .stat-icon {
            width: 44px; height: 44px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 17px; flex-shrink: 0;
        }
        .stat-icon.blue   { background: #dbeafe; color: #1d4ed8; }
        .stat-icon.green  { background: #dcfce7; color: #166534; }
        .stat-icon.amber  { background: #fef3c7; color: #92400e; }
        .stat-icon.red    { background: #fee2e2; color: #991b1b; }
        .stat-icon.purple { background: #ede9fe; color: #5b21b6; }
        .stat-icon.navy   { background: #e0e7ff; color: #3730a3; }
        .stat-value { font-size: 22px; font-weight: 700; color: #111827; line-height: 1; }
        .stat-label { font-size: 12px; color: var(--text-muted); margin-top: 3px; }
        .stat-trend { font-size: 11px; font-weight: 500; }
        .stat-trend.up   { color: #16a34a; }
        .stat-trend.down { color: #dc2626; }

        /* ── TABLE ─────────────────────────────────────── */
        .table-card { border-radius: var(--card-radius); overflow: hidden; border: 1px solid var(--border); box-shadow: var(--shadow-sm); }
        .table { margin: 0; }
        .table thead th {
            background: var(--table-header-bg); color: var(--table-header-color);
            font-size: 11.5px; font-weight: 600; text-transform: uppercase;
            letter-spacing: .05em; padding: 11px 14px;
            border-bottom: none; white-space: nowrap; border-color: rgba(255,255,255,.1);
        }
        .table thead th:first-child { border-radius: 0; }
        .table-filter-row th {
            background: #f1f5f9 !important; color: #374151 !important;
            padding: 6px 8px !important; border-bottom: 1px solid var(--border) !important;
            font-size: 11px !important; text-transform: none !important; letter-spacing: 0 !important;
        }
        .table-filter-row th select,
        .table-filter-row th input {
            width: 100%; font-size: 11px; padding: 3px 6px;
            border: 1px solid #d1d5db; border-radius: 4px; background: #fff;
        }
        .table tbody tr { transition: background .1s; }
        .table tbody tr:hover { background: #f8faff; }
        .table tbody td { padding: 10px 14px; border-color: #f1f5f9; vertical-align: middle; }
        .table tbody tr:last-child td { border-bottom: none; }
        .table-link { color: var(--accent); text-decoration: none; font-weight: 500; }
        .table-link:hover { color: var(--accent-dark); text-decoration: underline; }

        /* ── BADGES ────────────────────────────────────── */
        .badge { font-weight: 500; font-size: 11px; padding: 3px 9px; border-radius: 20px; }
        .badge-green  { background: #dcfce7; color: #166534; }
        .badge-red    { background: #fee2e2; color: #991b1b; }
        .badge-amber  { background: #fef3c7; color: #92400e; }
        .badge-blue   { background: #dbeafe; color: #1d4ed8; }
        .badge-gray   { background: #f3f4f6; color: #374151; }
        .badge-purple { background: #ede9fe; color: #5b21b6; }
        .badge-navy   { background: #e0e7ff; color: #3730a3; }

        /* ── FILTER PANEL ──────────────────────────────── */
        .filter-panel {
            background: #fff; border: 1px solid var(--border);
            border-radius: var(--card-radius); padding: 14px 18px;
            margin-bottom: 14px; box-shadow: var(--shadow-sm);
            border-left: 3px solid var(--accent);
        }

        /* ── MODAL ─────────────────────────────────────── */
        .modal-content { border: none !important; border-radius: 12px !important; box-shadow: 0 20px 60px rgba(0,0,0,.18) !important; overflow: hidden; }
        .modal-header { padding: 16px 20px; border-bottom: 1px solid var(--border) !important; }
        .modal-header.dark { background: var(--sidebar-bg); color: #fff; }
        .modal-header.dark .btn-close { filter: invert(1) opacity(.7); }
        .modal-body { padding: 20px; }
        .modal-footer { padding: 12px 20px; background: #f8fafc; border-top: 1px solid var(--border) !important; }

        .form-label { font-size: 12px; font-weight: 600; color: #374151; margin-bottom: 4px; }
        .form-control, .form-select {
            border-radius: 7px; border: 1px solid #d1d5db;
            font-size: 13.5px; padding: 7px 11px;
            transition: border-color .15s, box-shadow .15s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--accent); box-shadow: 0 0 0 3px rgba(25,118,210,.15);
        }
        .input-group-text {
            background: #f9fafb; border-color: #d1d5db;
            color: var(--text-muted); font-size: 13px;
        }

        /* ── BUTTONS ───────────────────────────────────── */
        .btn { border-radius: 7px; font-size: 13.5px; font-weight: 500; }
        .btn-primary { background: var(--accent); border-color: var(--accent); }
        .btn-primary:hover { background: var(--accent-dark); border-color: var(--accent-dark); }
        .btn-success { background: #16a34a; border-color: #16a34a; }
        .btn-success:hover { background: #15803d; border-color: #15803d; }
        .btn-sm { border-radius: 6px; font-size: 12px; }

        /* ── PROGRESS ──────────────────────────────────── */
        .progress { border-radius: 20px; background: #e9ecef; height: 6px; }
        .progress-bar { border-radius: 20px; transition: width .4s ease; }

        /* ── MOBILE ────────────────────────────────────── */
        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); width: var(--sidebar-w) !important; }
            .sidebar.mobile-open { transform: translateX(0); }
            .page-shell { margin-left: 0 !important; }
            .topbar { left: 0 !important; }
            .page-body { padding: 14px; }
            .topbar-user { display: none; }
        }

        /* ── OVERLAY ───────────────────────────────────── */
        .sidebar-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.45); z-index: 1049;
        }
        .sidebar-overlay.active { display: block; }

        /* ── SCROLLBAR ─────────────────────────────────── */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #c1c8d4; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #9ca3af; }

        /* ── ANIMATIONS ────────────────────────────────── */
        .fade-in { animation: fadeIn .3s ease; }
        @@keyframes fadeIn { from { opacity:0; transform:translateY(5px); } to { opacity:1; transform:translateY(0); } }

        /* ── EMPTY STATE ───────────────────────────────── */
        .empty-state { padding: 60px 20px; text-align: center; }
        .empty-state i { font-size: 40px; color: #d1d5db; margin-bottom: 12px; display: block; }
        .empty-state p { color: var(--text-muted); margin: 0; }

        /* ── TOAST ─────────────────────────────────────── */
        .toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; }

        /* ── PAGE TITLE BAR ────────────────────────────── */
        .page-title-bar {
            background: #fff; border: 1px solid var(--border);
            border-radius: var(--card-radius); padding: 12px 18px;
            margin-bottom: 16px; box-shadow: var(--shadow-sm);
            display: flex; align-items: center; gap: 12px;
        }
        .page-title-bar .ptb-icon {
            width: 36px; height: 36px; border-radius: 8px;
            background: var(--accent-light); color: var(--accent);
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; flex-shrink: 0;
        }
        .page-title-bar .ptb-title { font-size: 15px; font-weight: 700; color: #111827; }
        .page-title-bar .ptb-sub { font-size: 12px; color: var(--text-muted); }
        .page-title-bar .ptb-badge {
            background: var(--accent); color: #fff;
            font-size: 11px; font-weight: 600; padding: 2px 9px;
            border-radius: 20px;
        }
    </style>
</head>
<body>

@{
    var ctrl   = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
}

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- ── SIDEBAR ─────────────────────────────────────────── -->
<aside class="sidebar" id="sidebar">

    <a class="sidebar-logo" href="/Home/Index">
        <div class="logo-icon"><i class="fas fa-leaf"></i></div>
        <div>
            <div class="logo-text">FSC Takip ERP</div>
            <div class="logo-sub">Kraft Kağıt İzlenebilirlik</div>
        </div>
    </a>

    <nav class="sidebar-nav">

        <div class="nav-section">Genel</div>
        <div class="nav-item">
            <a class="nav-link-item @(ctrl=="Home"?"active":"")" href="/Home/Index">
                <span class="nav-icon"><i class="fas fa-chart-pie"></i></span>
                <span class="nav-label">Dashboard</span>
            </a>
        </div>

        <div class="nav-section">FSC İşlemleri</div>
        <div class="nav-item">
            <a class="nav-link-item @(ctrl=="Purchase"?"active":"")" href="/Purchase/Index">
                <span class="nav-icon"><i class="fas fa-truck-loading"></i></span>
                <span class="nav-label">Hammadde Girişi</span>
            </a>
        </div>

        <div class="nav-item">
            <a class="nav-link-item @(ctrl=="Production"&&action=="Index"?"active":"")" href="/Production/Index">
                <span class="nav-icon"><i class="fas fa-industry"></i></span>
                <span class="nav-label">İş Emirleri</span>
            </a>
        </div>
        <div class="nav-item">
            <a class="nav-link-item @(ctrl=="Production"&&action=="WasteReport"?"active":"")" href="/Production/WasteReport">
                <span class="nav-icon"><i class="fas fa-burn"></i></span>
                <span class="nav-label">Fire Raporu</span>
            </a>
        </div>

        <div class="nav-item">
            <a class="nav-link-item @(ctrl=="Sales"?"active":"")" href="/Sales/Index">
                <span class="nav-icon"><i class="fas fa-shipping-fast"></i></span>
                <span class="nav-label">Satış / Sevkiyat</span>
            </a>
        </div>

        <div class="nav-item">
            <a class="nav-link-item @(ctrl=="Stock"?"active":"")" href="/Stock/Index">
                <span class="nav-icon"><i class="fas fa-warehouse"></i></span>
                <span class="nav-label">Stok Durumu</span>
            </a>
        </div>

        <div class="nav-section">Ticari</div>
        <div class="nav-item">
            <a class="nav-link-item @(ctrl=="Customers"?"active":"")" href="/Customers/Index">
                <span class="nav-icon"><i class="fas fa-user-tie"></i></span>
                <span class="nav-label">Müşteriler</span>
            </a>
