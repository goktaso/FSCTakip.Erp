// Her modalın kendi singleton + target select ID'si

var _qaFullModals = {};
var _qaFullTargetId = {};

function _getOrCreateModal(id) {
    if (!_qaFullModals[id]) {
        _qaFullModals[id] = new bootstrap.Modal(document.getElementById(id));
    }
    return _qaFullModals[id];
}

function _resetAndOpenFullModal(modalId, targetSelectId) {
    _qaFullTargetId[modalId] = targetSelectId;
    // Tüm input/textarea temizle
    document.querySelectorAll('#' + modalId + ' input:not([readonly]):not([type="checkbox"]), #' + modalId + ' textarea').forEach(el => {
        el.value = '';
        el.classList.remove('is-invalid');
    });
    // Checkbox'ları sıfırla
    document.querySelectorAll('#' + modalId + ' input[type="checkbox"]').forEach(el => { el.checked = true; });
    _getOrCreateModal(modalId).show();
    setTimeout(() => {
        const first = document.querySelector('#' + modalId + ' input:not([readonly])');
        if (first) first.focus();
    }, 350);
}

async function _saveFullModal(modalId, url, buildFd, btnId, labelBase) {
    const fd  = buildFd();
    if (!fd) return; // validation failed
    const btn = document.getElementById(btnId);
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Kaydediliyor...';
    try {
        const res  = await fetch(url, { method: 'POST', body: fd });
        const json = await res.json();
        if (json.success) {
            const targetId = _qaFullTargetId[modalId];
            const sel = document.getElementById(targetId);
            if (sel) {
                const opt = new Option(json.text, json.id, true, true);
                sel.appendChild(opt);
                sel.value = json.id;
                sel.dispatchEvent(new Event('change'));
            }
            _getOrCreateModal(modalId).hide();
            showToast(labelBase + ': "' + json.text + '" eklendi.', 'success');
        } else {
            showToast(json.message || 'Kayıt hatası.', 'error');
        }
    } catch(e) {
        showToast('Bağlantı hatası.', 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-check me-1"></i> Kaydet & Seç';
    }
}

