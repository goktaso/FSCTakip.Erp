/* ── Bildirim Zili ──────────────────────────────────────────────────── */
(function () {
    const bell     = document.getElementById('notifBell');
    const dropdown = document.getElementById('notifDropdown');
    const badge    = document.getElementById('notifBadge');
    const list     = document.getElementById('notifList');
    if (!bell || !dropdown) return;

    let loaded = false;

    bell.addEventListener('click', function (e) {
        e.stopPropagation();
        const isOpen = dropdown.classList.contains('show');
        dropdown.classList.toggle('show');
        if (!isOpen && !loaded) {
            loaded = true;
            fetch('/Home/GetNotifications')
                .then(r => r.json())
                .then(data => {
                    list.innerHTML = '';
                    if (!data || data.length === 0) {
                        list.innerHTML = '<li class="notif-empty">Bildirim yok</li>';
                        return;
                    }
                    let urgentCount = 0;
                    data.forEach(n => {
                        if (n.urgent) urgentCount++;
                        const li = document.createElement('li');
                        li.className = 'notif-item';
                        const color = n.urgent ? '#dc2626' : '#d97706';
                        li.innerHTML = `<i class="fas fa-circle" style="color:${color};font-size:7px;flex-shrink:0;margin-top:5px;"></i>
                            <div><div style="font-size:12.5px;font-weight:600;color:#111827;">${n.title}</div>
                            <div style="font-size:11.5px;color:#6b7280;">${n.message}</div></div>`;
                        list.appendChild(li);
                    });
                    if (urgentCount > 0) {
                        badge.textContent = urgentCount;
                        badge.style.display = 'flex';
                    }
                })
                .catch(() => { list.innerHTML = '<li class="notif-empty">Yüklenemedi</li>'; });
        }
    });

    document.addEventListener('click', function (e) {
        if (!bell.contains(e.target) && !dropdown.contains(e.target)) {
            dropdown.classList.remove('show');
        }
    });
})();

