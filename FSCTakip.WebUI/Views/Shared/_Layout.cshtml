/* ── Global Topbar Arama ────────────────────────────────────────────── */
(function () {
    const input    = document.getElementById('globalSearch');
    const dropdown = document.getElementById('searchDropdown');
    if (!input) return;

    let _timer, _lastQ = '';
    const iconMap = {
        'Müşteri':    { icon: 'fa-user-tie',    color: '#1d4ed8' },
        'Tedarikçi':  { icon: 'fa-truck',       color: '#16a34a' },
        'Ürün':       { icon: 'fa-box-open',    color: '#7c3aed' },
        'Lot':        { icon: 'fa-layer-group', color: '#d97706' }
    };

    function render(data) {
        dropdown.innerHTML = '';
        if (!data || !data.length) {
            dropdown.innerHTML = '<div class="search-no-result"><i class="fas fa-search me-2 opacity-50"></i>Sonuç bulunamadı</div>';
            dropdown.classList.add('show');
            return;
        }
        // Gruplara ayır
        const groups = {};
        data.forEach(item => {
            (groups[item.type] = groups[item.type] || []).push(item);
        });
        Object.keys(groups).forEach(type => {
            const grp = document.createElement('div');
            grp.className = 'search-result-group';
            const im = iconMap[type] || { icon: 'fa-circle', color: '#6b7280' };
            grp.innerHTML = `<div class="search-result-label">${type}</div>`;
            groups[type].forEach(item => {
                const li = document.createElement('div');
                li.className = 'search-result-item';
                li.innerHTML = `<i class="fas ${im.icon}" style="color:${im.color};"></i>
                    <div><div class="sri-main">${item.title}</div>${item.sub ? `<div class="sri-sub">${item.sub}</div>` : ''}</div>`;
                li.onclick = () => { location.href = item.url; };
                grp.appendChild(li);
            });
            dropdown.appendChild(grp);
        });
        dropdown.classList.add('show');
    }

    function search(q) {
        if (q === _lastQ) return;
        _lastQ = q;
        if (q.length < 2) { dropdown.classList.remove('show'); return; }
        dropdown.innerHTML = '<div class="search-no-result"><i class="fas fa-spinner fa-spin me-2"></i>Aranıyor…</div>';
        dropdown.classList.add('show');
        fetch('/Home/GlobalSearch?q=' + encodeURIComponent(q))
            .then(r => r.json()).then(render).catch(() => dropdown.classList.remove('show'));
    }

    input.addEventListener('input', () => {
        clearTimeout(_timer);
        _timer = setTimeout(() => search(input.value.trim()), 280);
    });
    input.addEventListener('keydown', e => {
        if (e.key === 'Escape') { dropdown.classList.remove('show'); input.blur(); }
    });
    document.addEventListener('click', e => {
        if (!input.parentElement.contains(e.target)) dropdown.classList.remove('show');
    });

    // Ctrl+K kısayolu
    document.addEventListener('keydown', e => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault(); input.focus(); input.select();
        }
    });
})();

