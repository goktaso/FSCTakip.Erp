<script>
(function () {
    const sidebar  = document.getElementById('sidebar');
    const overlay  = document.getElementById('sidebarOverlay');
    const toggle   = document.getElementById('sidebarToggle');
    const isMobile = () => window.innerWidth <= 768;
    const isTablet = () => window.innerWidth > 768 && window.innerWidth <= 1024;

    toggle.addEventListener('click', () => {
        if (isMobile()) {
            sidebar.classList.toggle('mobile-open');
            overlay.classList.toggle('active');
        } else {
            sidebar.classList.toggle('collapsed');
            // Tablet'te kullanıcı genişletti → 'false' kaydet (varsayılanı eziyor)
            localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
        }
    });

    overlay.addEventListener('click', () => {
        sidebar.classList.remove('mobile-open');
        overlay.classList.remove('active');
    });

    // Başlangıç durumu
    if (!isMobile()) {
        if (isTablet()) {
            // Tablet: kullanıcı açıkça 'false' yazmadıysa kapalı başlat
            if (localStorage.getItem('sidebarCollapsed') !== 'false') {
                sidebar.classList.add('collapsed');
            }
        } else {
            // Masaüstü: kayıtlı tercih
            if (localStorage.getItem('sidebarCollapsed') === 'true') {
                sidebar.classList.add('collapsed');
            }
        }
    }

    // Pencere boyutu değişince yeniden değerlendir (yön değişimi vb.)
    let _resizeTimer;
    window.addEventListener('resize', () => {
        clearTimeout(_resizeTimer);
        _resizeTimer = setTimeout(() => {
            if (isMobile()) {
                // Mobil: sidebar'ı gizle
                sidebar.classList.remove('collapsed');
                sidebar.classList.remove('mobile-open');
                overlay.classList.remove('active');
            } else if (isTablet()) {
                // Tablet'e geçildi: kullanıcı açmadıysa kapat
                if (localStorage.getItem('sidebarCollapsed') !== 'false') {
                    sidebar.classList.add('collapsed');
                }
            }
        }, 150);
    });
})();

// ── NAV SECTION COLLAPSE — localStorage ile durum kalıcı ────────────────
(function () {
    const KEY      = 'navSecState';
    const sections = ['sec-genel', 'sec-fsc', 'sec-ticari', 'sec-rapor', 'sec-tanim'];

    // Kayıtlı durumu oku
    let saved = {};
    try { saved = JSON.parse(localStorage.getItem(KEY) || '{}'); } catch (e) {}

    sections.forEach(id => {
        const el  = document.getElementById(id);
        const btn = document.querySelector(`[data-bs-target="#${id}"]`);
        if (!el || !btn) return;

        // Eğer localStorage'da kayıt varsa sunucu-side durumunu geçersiz kıl
        if (id in saved) {
            if (saved[id]) {
                el.classList.add('show');
                btn.setAttribute('aria-expanded', 'true');
            } else {
                el.classList.remove('show');
                btn.setAttribute('aria-expanded', 'false');
            }
        }

        // Toggle olaylarını dinle ve kaydet
        el.addEventListener('shown.bs.collapse',  () => saveSec(id, true));
        el.addEventListener('hidden.bs.collapse', () => saveSec(id, false));
    });

    function saveSec(id, open) {
        let s = {};
        try { s = JSON.parse(localStorage.getItem(KEY) || '{}'); } catch (e) {}
        s[id] = open;
        localStorage.setItem(KEY, JSON.stringify(s));
    }
})();

// ── Global PDF Viewer ────────────────────────────────────────────────────
var _pdfModal = null;
function showPdf(url, title) {
    var el = document.getElementById('pdfViewerModal');
    if (!el) { window.open(url, '_blank'); return; }
    document.getElementById('pdfViewerTitle').textContent = title || 'Belge';
    document.getElementById('pdfViewerFrame').src = url;
    document.getElementById('pdfViewerLink').href = url;
    if (!_pdfModal) _pdfModal = new bootstrap.Modal(el);
    _pdfModal.show();
}
document.addEventListener('DOMContentLoaded', function () {
    var el = document.getElementById('pdfViewerModal');
    if (el) el.addEventListener('hide.bs.modal', function () {
        document.getElementById('pdfViewerFrame').src = '';
    });
});

function showToast(msg, type = 'success') {
    const icons  = { success:'check-circle', error:'times-circle', warning:'exclamation-triangle', info:'info-circle' };
    const colors = { success:'#166534', error:'#991b1b', warning:'#92400e', info:'#1d4ed8' };
    const bg     = { success:'#f0fdf4', error:'#fef2f2', warning:'#fffbeb', info:'#eff6ff' };
    const id = 'toast-' + Date.now();
    const el = document.createElement('div');
    el.id = id;
    el.style.cssText = `background:${bg[type]};border:1px solid ${colors[type]}33;border-left:4px solid ${colors[type]};
        border-radius:10px;padding:11px 15px;margin-top:7px;display:flex;align-items:center;gap:10px;
        min-width:280px;box-shadow:0 4px 16px rgba(0,0,0,.12);animation:fadeIn .25s ease;font-size:13.5px;`;
    el.innerHTML = `<i class="fas fa-${icons[type]}" style="color:${colors[type]};font-size:15px;"></i>
        <span style="color:#111827;flex:1;">${msg}</span>
        <button onclick="this.parentElement.remove()" style="background:none;border:none;cursor:pointer;color:#9ca3af;font-size:15px;">×</button>`;
    document.getElementById('toastContainer').appendChild(el);
    setTimeout(() => el.remove(), 4500);
}

