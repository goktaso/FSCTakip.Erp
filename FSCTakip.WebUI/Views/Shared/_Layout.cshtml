    var ctrl   = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";

    // Hangi sidebar bölümü aktif?
    var activeSection = ctrl switch {
        "Purchase" or "Stock"                             => "hammadde",
        "Planning" or "Production"                        => "uretim",
        "Sales" or "Customers"                            => "satis",
        "Suppliers" or "Products"                         => "tedarik",
        "Reports" or "AuditPeriod"                        => "fsc-izleme",
        "Conversion"                                      => "hammadde",
        "DocumentArchive"                                 => "belge",
        "Product" or "Paper" or "Machine" or "Warehouse"
            or "Etl" or "Guide" or "UnitConversion"       => "tanim",
        "Users" or "Groups" or "AuditLog"                 => "admin",
        _                                                 => "genel"
    };

    string Sec(string id) => activeSection == id ? "show" : "";
    string Exp(string id) => activeSection == id ? "true" : "false";
}

