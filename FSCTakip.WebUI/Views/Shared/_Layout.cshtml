var _pdfModal = null;
function showPdf(url, title) {
    var el = document.getElementById('pdfViewerModal');
    if (!el) { window.open(url, '_blank'); return; }
    document.getElementById('pdfViewerTitle').textContent = title || 'Belge';
    document.getElementById('pdfViewerFrame').src = url;
    document.getElementById('pdfViewerLink').href = url;
    if (!_pdfModal) _pdfModal = new bootstrap.Modal(el);
    _pdfModal.show();
}
document.addEventListener('DOMContentLoaded', function () {
    var el = document.getElementById('pdfViewerModal');
    if (el) el.addEventListener('hide.bs.modal', function () {
        document.getElementById('pdfViewerFrame').src = '';
    });
});

function showToast(msg, type = 'success') {
    const icons  = { success:'check-circle', error:'times-circle', warning:'exclamation-triangle', info:'info-circle' };
    const colors = { success:'#166534', error:'#991b1b', warning:'#92400e', info:'#1d4ed8' };
    const bg     = { success:'#f0fdf4', error:'#fef2f2', warning:'#fffbeb', info:'#eff6ff' };
    const id = 'toast-' + Date.now();
    const el = document.createElement('div');
    el.id = id;
    el.style.cssText = `background:${bg[type]};border:1px solid ${colors[type]}33;border-left:4px solid ${colors[type]};
        border-radius:10px;padding:11px 15px;margin-top:7px;display:flex;align-items:center;gap:10px;
        min-width:280px;box-shadow:0 4px 16px rgba(0,0,0,.12);animation:fadeIn .25s ease;font-size:13.5px;`;
    el.innerHTML = `<i class="fas fa-${icons[type]}" style="color:${colors[type]};font-size:15px;"></i>
        <span style="color:#111827;flex:1;">${msg}</span>
        <button onclick="this.parentElement.remove()" style="background:none;border:none;cursor:pointer;color:#9ca3af;font-size:15px;">×</button>`;
    document.getElementById('toastContainer').appendChild(el);
    setTimeout(() => el.remove(), 4500);
}

function toggleFilter() {
    const p = document.getElementById('filterPanel');
    if (p) p.style.display = p.style.display === 'none' ? 'block' : 'none';
}
function openAddModal() {
    const fn = window.openAddModalFn;
    if (typeof fn === 'function') fn();
    else showToast('Bu sayfa için ekleme formu tanımlanmadı.', 'info');
}
