<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - FSC Takip ERP</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css">

    <style>
        :root {
            --sidebar-bg:      #1a2744;
            --sidebar-hover:   rgba(255,255,255,.07);
            --sidebar-active:  rgba(25,118,210,.22);
            --accent:          #1976d2;
            --accent-dark:     #1565c0;
            --accent-light:    #e3f2fd;
            --topbar-h:        56px;
            --sidebar-w:       250px;
            --sidebar-w-col:   64px;
            --card-radius:     10px;
            --shadow-sm:       0 1px 4px rgba(0,0,0,.08);
            --shadow-md:       0 4px 16px rgba(0,0,0,.12);
            --text-muted:      #6b7280;
            --border:          #e5e7eb;
            --bg-page:         #f0f2f5;
            --table-header-bg: #1a2744;
            --table-header-color: #fff;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: 'Inter', 'Segoe UI', sans-serif;
            font-size: 14px;
            background: var(--bg-page);
            color: #111827;
            overflow-x: hidden;
        }

        /* ── SIDEBAR ───────────────────────────────────── */
        .sidebar {
            position: fixed; top: 0; left: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--sidebar-bg);
            display: flex; flex-direction: column;
            transition: width .25s cubic-bezier(.4,0,.2,1);
            z-index: 1050;
            overflow: hidden;
        }
        .sidebar.collapsed { width: var(--sidebar-w-col); }

        .sidebar-logo {
            display: flex; align-items: center; gap: 10px;
            padding: 16px;
            border-bottom: 1px solid rgba(255,255,255,.08);
            white-space: nowrap; overflow: hidden;
            text-decoration: none;
            background: rgba(0,0,0,.15);
        }
        .sidebar-logo .logo-icon {
            width: 34px; height: 34px; border-radius: 8px;
            background: linear-gradient(135deg, #1976d2, #0d47a1);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; font-size: 15px; color: #fff;
        }
        .sidebar-logo .logo-text { color: #fff; font-weight: 700; font-size: 15px; line-height: 1.2; }
        .sidebar-logo .logo-sub  { color: rgba(255,255,255,.45); font-size: 10px; font-weight: 400; letter-spacing:.03em; }
        .sidebar.collapsed .logo-text,
        .sidebar.collapsed .logo-sub { display: none; }

        .sidebar-nav { flex: 1; overflow-y: auto; overflow-x: hidden; padding: 8px 0; }
        .sidebar-nav::-webkit-scrollbar { width: 4px; }
        .sidebar-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 4px; }

        .nav-section {
            padding: 14px 16px 4px;
            font-size: 10px; font-weight: 600; letter-spacing: .1em;
            color: rgba(255,255,255,.28); text-transform: uppercase;
            white-space: nowrap; overflow: hidden;
        }
        .sidebar.collapsed .nav-section { opacity: 0; height: 0; padding: 0; }

        .nav-item { margin: 1px 6px; }
        .nav-link-item {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 10px; border-radius: 7px;
            color: rgba(255,255,255,.65); font-size: 13.5px; font-weight: 500;
            text-decoration: none; white-space: nowrap; overflow: hidden;
            transition: background .15s, color .15s;
            cursor: pointer; border: none; background: none; width: 100%; text-align: left;
        }
        .nav-link-item:hover { background: var(--sidebar-hover); color: #fff; }
        .nav-link-item.active {
            background: var(--sidebar-active);
            color: #fff;
            box-shadow: inset 3px 0 0 var(--accent);
        }
        .nav-link-item.active::after {
            content: '';
            position: absolute; right: 0; top: 50%; transform: translateY(-50%);
            width: 4px; height: 70%; border-radius: 4px 0 0 4px;
            background: var(--accent); opacity: .6;
        }
        .nav-item { position: relative; }
        .nav-link-item .nav-icon {
            width: 22px; text-align: center; font-size: 14px; flex-shrink: 0;
            color: rgba(255,255,255,.45);
        }
        .nav-link-item.active .nav-icon,
        .nav-link-item:hover .nav-icon { color: #60a5fa; }
        .nav-link-item .nav-label { flex: 1; }
        .nav-link-item .nav-arrow {
            font-size: 10px; transition: transform .2s;
            color: rgba(255,255,255,.3);
        }
        .nav-link-item[aria-expanded="true"] .nav-arrow { transform: rotate(90deg); }
        .sidebar.collapsed .nav-label,
        .sidebar.collapsed .nav-arrow { display: none; }

        /* ── Sidebar Tooltip (kolaps modda hover) ────── */
        .sidebar.collapsed .nav-item .nav-tooltip {
            position: absolute; left: calc(var(--sidebar-w-col) + 8px); top: 50%;
            transform: translateY(-50%);
            background: #1a2744; color: #fff; font-size: 12px; font-weight: 500;
            padding: 6px 11px; border-radius: 7px; white-space: nowrap;
            box-shadow: 0 4px 14px rgba(0,0,0,.3); z-index: 2000;
            opacity: 0; pointer-events: none;
            transition: opacity .15s, left .15s;
        }
        .sidebar.collapsed .nav-item .nav-tooltip::before {
            content: '';
            position: absolute; right: 100%; top: 50%; transform: translateY(-50%);
            border: 5px solid transparent; border-right-color: #1a2744;
        }
        .sidebar.collapsed .nav-item:hover .nav-tooltip { opacity: 1; left: calc(var(--sidebar-w-col) + 12px); }

        /* Güvenlik: nav-item içindeki istenmeyen serbest metin/tooltip kopyaları görünmesin */
        .sidebar .nav-item > .nav-tooltip {
            display: none !important;
        }
        .sidebar .nav-item > :not(.nav-link-item):not(.nav-tooltip) {
            display: none !important;
        }

        .nav-sub { padding-left: 12px; }
        .nav-sub .nav-item { margin: 1px 0; }
        .nav-sub .nav-link-item {
            font-size: 13px; font-weight: 400;
            padding: 7px 10px;
            color: rgba(255,255,255,.5);
        }
        .nav-sub .nav-link-item::before {
            content: ''; width: 5px; height: 5px; border-radius: 50%;
            background: rgba(255,255,255,.2); flex-shrink: 0;
        }
        .nav-sub .nav-link-item.active::before,
        .nav-sub .nav-link-item:hover::before { background: #60a5fa; }
        .sidebar.collapsed .nav-sub { display: none; }

        /* ── COLLAPSIBLE NAV SECTIONS ──────────────────────────── */
        .nav-section-toggle {
            width: 100%; display: flex; align-items: center; justify-content: space-between;
            padding: 12px 16px 4px;
            background: none; border: none; cursor: pointer;
            font-size: 10px; font-weight: 600; letter-spacing: .1em;
            color: rgba(255,255,255,.30); text-transform: uppercase;
            white-space: nowrap; overflow: hidden;
            transition: color .15s; line-height: 1.4;
        }
        .nav-section-toggle:hover { color: rgba(255,255,255,.52); }
        .nav-section-toggle:focus { outline: none; box-shadow: none; }
        .nav-section-arrow {
            font-size: 9px; flex-shrink: 0; margin-left: 4px;
            color: rgba(255,255,255,.22);
            transition: transform .22s ease;
        }
        .nav-section-toggle[aria-expanded="true"] .nav-section-arrow { transform: rotate(90deg); }
        /* İkon-only modda başlıklar gizlenir, tüm öğeler görünür kalır */
        .sidebar.collapsed .nav-section-toggle {
            opacity: 0; height: 0; padding: 0; pointer-events: none; overflow: hidden;
        }
        .sidebar.collapsed .nav-section-collapse { display: block !important; }

        /* ── Sidebar Arama ──────────────────────────────── */
        .sidebar-search-wrap {
            padding: 8px 10px 4px;
            border-bottom: 1px solid rgba(255,255,255,.07);
            flex-shrink: 0;
        }
        .sidebar.collapsed .sidebar-search-wrap { display: none; }
        .sidebar-search-box {
            position: relative; display: flex; align-items: center;
        }
        .sidebar-search-box input {
            width: 100%; padding: 7px 10px 7px 32px;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
            border-radius: 8px; color: #fff; font-size: 12.5px;
            outline: none; transition: background .15s, border-color .15s;
        }
        .sidebar-search-box input::placeholder { color: rgba(255,255,255,.35); }
        .sidebar-search-box input:focus {
            background: rgba(255,255,255,.13); border-color: rgba(255,255,255,.28);
        }
        .sidebar-search-box .srch-icon {
            position: absolute; left: 10px; font-size: 11px;
            color: rgba(255,255,255,.35); pointer-events: none;
        }
        .sidebar-search-box .srch-clear {
            position: absolute; right: 8px; font-size: 11px;
            color: rgba(255,255,255,.4); cursor: pointer;
            display: none; background: none; border: none; padding: 2px 4px;
            line-height: 1;
        }
        .sidebar-search-box .srch-clear:hover { color: rgba(255,255,255,.8); }
        .sidebar-no-result {
            padding: 12px 16px; font-size: 12px;
            color: rgba(255,255,255,.35); text-align: center; display: none;
        }
        /* Arama sırasında highlight */
        .nav-label mark {
            background: rgba(25,118,210,.55); color: #fff;
            border-radius: 3px; padding: 0 2px;
        }

        .sidebar-footer {
            padding: 10px 12px;
            border-top: 1px solid rgba(255,255,255,.08);
            white-space: nowrap; overflow: hidden;
            background: rgba(0,0,0,.15);
        }
        .sidebar-user {
            display: flex; align-items: center; gap: 10px;
            color: rgba(255,255,255,.6); font-size: 12px;
        }
        .sidebar-user .avatar {
            width: 30px; height: 30px; border-radius: 50%;
            background: linear-gradient(135deg, #1976d2, #0d47a1);
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; color: #fff; font-weight: 700; flex-shrink: 0;
        }
        .sidebar.collapsed .sidebar-user span { display: none; }

        /* ── TOPBAR ────────────────────────────────────── */
        .topbar {
            position: fixed; top: 0;
            left: var(--sidebar-w); right: 0;
            height: var(--topbar-h);
            background: #fff;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
            padding: 0 18px; gap: 10px;
            transition: left .25s cubic-bezier(.4,0,.2,1);
            z-index: 1000; box-shadow: 0 1px 6px rgba(0,0,0,.07);
        }
        .sidebar.collapsed ~ .page-shell .topbar { left: var(--sidebar-w-col); }

        .topbar-toggle {
            width: 34px; height: 34px; border-radius: 7px;
            border: 1px solid var(--border); background: transparent;
            display: flex; align-items: center; justify-content: center;
            color: #374151; cursor: pointer; flex-shrink: 0;
            transition: background .15s;
        }
        .topbar-toggle:hover { background: var(--accent-light); color: var(--accent); }

        .topbar-title { font-size: 15px; font-weight: 600; color: #111827; }
        .topbar-breadcrumb { font-size: 11.5px; color: var(--text-muted); }

        .topbar-user {
            display: flex; align-items: center; gap: 8px;
            padding: 5px 10px; border-radius: 8px;
            border: 1px solid var(--border);
            background: #fafafa;
        }
        .topbar-user .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: linear-gradient(135deg, #1976d2, #0d47a1);
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; color: #fff;
        }
        .topbar-user .user-name { font-size: 12.5px; font-weight: 600; color: #111827; }
        .topbar-user .user-role { font-size: 11px; color: var(--text-muted); }

        .topbar-actions { display: flex; align-items: center; gap: 6px; }
        .topbar-btn {
            height: 32px; padding: 0 13px; border-radius: 7px; font-size: 12.5px;
            font-weight: 500; display: inline-flex; align-items: center; gap: 6px;
            border: 1px solid var(--border); background: #fff; color: #374151;
            cursor: pointer; text-decoration: none; transition: all .15s;
        }
        .topbar-btn:hover { background: var(--bg-page); color: #111827; }
        .topbar-btn.btn-primary-custom {
            background: var(--accent); border-color: var(--accent); color: #fff;
        }
        .topbar-btn.btn-primary-custom:hover { background: var(--accent-dark); color: #fff; }
        .topbar-btn.btn-excel { color: #166534; border-color: #bbf7d0; background: #f0fdf4; }
        .topbar-btn.btn-excel:hover { background: #dcfce7; color: #166534; }
        .topbar-btn.btn-pdf { color: #991b1b; border-color: #fecaca; background: #fff5f5; }
        .topbar-btn.btn-pdf:hover { background: #fee2e2; color: #991b1b; }
        .topbar-btn.btn-filter { color: #92400e; border-color: #fde68a; background: #fffbeb; }
        .topbar-btn.btn-filter:hover { background: #fef3c7; color: #92400e; }
        .btn-logout {
            width: 32px; height: 32px; border-radius: 7px; padding: 0;
            border: 1px solid #fecaca; background: #fff5f5; color: #dc2626;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: all .15s; font-size: 13px;
        }
        .btn-logout:hover { background: #fee2e2; }

        /* ── Topbar ikon butonları (zil, dark mode) ─── */
        .topbar-icon-btn {
            position: relative;
            width: 36px; height: 36px; border-radius: 8px; border: 1px solid #d1d5db;
            background: #f3f4f6; color: #374151; font-size: 15px;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: all .15s; flex-shrink: 0;
            box-shadow: 0 1px 2px rgba(0,0,0,.06);
        }
        .topbar-icon-btn:hover { background: #e2e8f0; color: var(--accent); border-color: var(--accent); transform: translateY(-1px); box-shadow: 0 3px 8px rgba(0,0,0,.1); }

        /* ── Bildirim badge ── */
        .notif-badge {
            position: absolute; top: -4px; right: -4px;
            min-width: 17px; height: 17px; border-radius: 9px; padding: 0 4px;
            background: #ef4444; color: #fff; font-size: 10px; font-weight: 700;
            display: flex; align-items: center; justify-content: center;
            border: 2px solid #fff; line-height: 1;
        }

        /* ── Bildirim dropdown ── */
        .notif-dropdown {
            display: none; position: absolute; top: calc(100% + 8px); right: 0;
            width: 310px; background: #fff; border-radius: 10px;
            box-shadow: 0 8px 32px rgba(0,0,0,.14); border: 1px solid var(--border);
            z-index: 2000; overflow: hidden;
        }
        .notif-dropdown.show { display: block; }
        .notif-header {
            padding: 10px 14px; font-size: 12.5px; font-weight: 700; color: #111827;
            border-bottom: 1px solid var(--border); background: #f9fafb;
        }
        .notif-list { list-style: none; margin: 0; padding: 0; max-height: 320px; overflow-y: auto; }
        .notif-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 14px; font-size: 12px; cursor: pointer; transition: background .12s;
            border-bottom: 1px solid #f3f4f6;
        }
        .notif-item:hover { background: #f9fafb; }
        .notif-item i { font-size: 13px; flex-shrink: 0; }
        .notif-item.notif-danger   { border-left: 3px solid #ef4444; }
        .notif-item.notif-danger i { color: #ef4444; }
        .notif-item.notif-warning  { border-left: 3px solid #f59e0b; }
        .notif-item.notif-warning i{ color: #f59e0b; }
        .notif-item.notif-info     { border-left: 3px solid #3b82f6; }
        .notif-item.notif-info i   { color: #3b82f6; }
        .notif-empty { padding: 16px 14px; font-size: 12px; color: var(--text-muted); text-align: center; }

        /* ── Dark Mode ── */
        body.dark-mode {
            --bg-page: #0f172a; --border: #1e293b; --text-muted: #94a3b8;
            --table-header-bg: #0f172a;
            background: #0f172a; color: #e2e8f0;
        }
        body.dark-mode .topbar { background: #1e293b; border-color: #334155; }
        body.dark-mode .table-card,
        body.dark-mode .stat-card,
        body.dark-mode .card { background: #1e293b; border-color: #334155; }
        body.dark-mode .stat-label { color: #94a3b8; }
        body.dark-mode .data-table thead { background: #0f172a; }
        body.dark-mode .data-table tbody tr:hover { background: rgba(255,255,255,.04); }
        body.dark-mode .topbar-user { background: #334155; border-color: #475569; }
        body.dark-mode .topbar-user .user-name { color: #e2e8f0; }
        body.dark-mode .topbar-icon-btn { background: #334155; border-color: #475569; color: #e2e8f0; box-shadow: 0 1px 3px rgba(0,0,0,.2); }
        body.dark-mode .notif-dropdown { background: #1e293b; border-color: #334155; }
        body.dark-mode .notif-header   { background: #0f172a; color: #e2e8f0; border-color: #334155; }
        body.dark-mode .notif-item     { border-bottom-color: #334155; }
        body.dark-mode .notif-item:hover { background: #334155; }
        body.dark-mode .page-header .page-title { color: #e2e8f0; }
        body.dark-mode .text-muted { color: #94a3b8 !important; }
        body.dark-mode .topbar-title  { color: #e2e8f0; }
        body.dark-mode .topbar-btn    { background: #334155; border-color: #475569; color: #cbd5e1; }
        body.dark-mode .topbar-btn:hover { background: #475569; }
        body.dark-mode .btn-logout    { background: rgba(239,68,68,.12); border-color: #ef4444; }
        body.dark-mode .form-control,
        body.dark-mode .form-select   { background: #334155; border-color: #475569; color: #e2e8f0; }
        body.dark-mode .modal-content { background: #1e293b; }
        body.dark-mode .modal-header  { border-color: #334155; }
        body.dark-mode .modal-body    { color: #e2e8f0; }
        body.dark-mode .modal-footer  { border-color: #334155; }

        /* Topbar birincil aksiyon butonu */
        .topbar-primary { display: flex; align-items: center; }
        .btn-topbar-add {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 0 20px; height: 36px; border-radius: 8px;
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
            color: #fff !important; border: none; cursor: pointer;
            font-size: 13.5px; font-weight: 600; letter-spacing: .01em;
            box-shadow: 0 2px 8px rgba(25,118,210,.35);
            transition: all .18s; text-decoration: none; white-space: nowrap;
        }
        .btn-topbar-add:hover {
            background: linear-gradient(135deg, var(--accent-dark) 0%, #0d47a1 100%);
            box-shadow: 0 4px 14px rgba(25,118,210,.45);
            transform: translateY(-1px); color: #fff;
        }
        .btn-topbar-add .btn-add-icon {
            width: 20px; height: 20px; border-radius: 5px;
            background: rgba(255,255,255,.22);
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; flex-shrink: 0;
        }

        /* ── PAGE SHELL ────────────────────────────────── */
        .page-shell {
            margin-left: var(--sidebar-w);
            transition: margin-left .25s cubic-bezier(.4,0,.2,1);
        }
        .sidebar.collapsed ~ .page-shell { margin-left: var(--sidebar-w-col); }

        .page-body {
            padding: 20px 22px 32px;
            margin-top: var(--topbar-h);
            min-height: calc(100vh - var(--topbar-h));
        }

        /* ── CARDS ─────────────────────────────────────── */
        .card {
            border: 1px solid var(--border) !important;
            border-radius: var(--card-radius) !important;
            box-shadow: var(--shadow-sm);
        }
        .card-header-accent, .card-header-blue {
            background: linear-gradient(135deg, #1a2744 0%, #243566 100%);
            color: #fff; padding: 13px 18px;
            border-radius: var(--card-radius) var(--card-radius) 0 0 !important;
            font-weight: 600; font-size: 14px;
            display: flex; align-items: center; gap: 8px;
        }
        .card-header-green {
            background: linear-gradient(135deg, #166534 0%, #15803d 100%);
            color: #fff; padding: 13px 18px;
            border-radius: var(--card-radius) var(--card-radius) 0 0 !important;
            font-weight: 600; font-size: 14px;
            display: flex; align-items: center; gap: 8px;
        }

        /* ── STAT CARDS ────────────────────────────────── */
        .stat-card {
            background: #fff; border: 1px solid var(--border);
            border-radius: var(--card-radius); padding: 16px 18px;
            display: flex; align-items: center; gap: 14px;
            box-shadow: var(--shadow-sm); transition: box-shadow .2s, transform .2s;
        }
        .stat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
        .stat-icon {
            width: 44px; height: 44px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 17px; flex-shrink: 0;
        }
        .stat-icon.blue   { background: #dbeafe; color: #1d4ed8; }
        .stat-icon.green  { background: #dcfce7; color: #166534; }
        .stat-icon.amber  { background: #fef3c7; color: #92400e; }
        .stat-icon.red    { background: #fee2e2; color: #991b1b; }
        .stat-icon.purple { background: #ede9fe; color: #5b21b6; }
        .stat-icon.navy   { background: #e0e7ff; color: #3730a3; }
        .stat-value { font-size: 22px; font-weight: 700; color: #111827; line-height: 1; }
        .stat-label { font-size: 12px; color: var(--text-muted); margin-top: 3px; }
        .stat-trend { font-size: 11px; font-weight: 500; }
        .stat-trend.up   { color: #16a34a; }
        .stat-trend.down { color: #dc2626; }

        /* ── TABLE ─────────────────────────────────────── */
        .table-card { border-radius: var(--card-radius); overflow: hidden; border: 1px solid var(--border); box-shadow: var(--shadow-sm); }
        .table { margin: 0; }
        .table thead th {
            background: var(--table-header-bg); color: var(--table-header-color);
            font-size: 11.5px; font-weight: 600; text-transform: uppercase;
            letter-spacing: .05em; padding: 11px 14px;
            border-bottom: none; white-space: nowrap; border-color: rgba(255,255,255,.1);
        }
        .table thead th:first-child { border-radius: 0; }
        .table-filter-row th {
            background: #f1f5f9 !important; color: #374151 !important;
            padding: 6px 8px !important; border-bottom: 1px solid var(--border) !important;
            font-size: 11px !important; text-transform: none !important; letter-spacing: 0 !important;
        }
        .table-filter-row th select,
        .table-filter-row th input {
            width: 100%; font-size: 11px; padding: 3px 6px;
            border: 1px solid #d1d5db; border-radius: 4px; background: #fff;
        }
        .table tbody tr { transition: background .1s; }
        .table tbody tr:hover { background: #f8faff; }
        .table tbody td { padding: 10px 14px; border-color: #f1f5f9; vertical-align: middle; }
        .table tbody tr:last-child td { border-bottom: none; }
        .table-link { color: var(--accent); text-decoration: none; font-weight: 500; }
        .table-link:hover { color: var(--accent-dark); text-decoration: underline; }

        /* ── BADGES ────────────────────────────────────── */
        .badge { font-weight: 500; font-size: 11px; padding: 3px 9px; border-radius: 20px; }
        .badge-green  { background: #dcfce7; color: #166534; }
        .badge-red    { background: #fee2e2; color: #991b1b; }
        .badge-amber  { background: #fef3c7; color: #92400e; }
        .badge-blue   { background: #dbeafe; color: #1d4ed8; }
        .badge-gray   { background: #f3f4f6; color: #374151; }
        .badge-purple { background: #ede9fe; color: #5b21b6; }
        .badge-navy   { background: #e0e7ff; color: #3730a3; }

        /* ── FILTER PANEL ──────────────────────────────── */
        .filter-panel {
            background: #fff; border: 1px solid var(--border);
            border-radius: var(--card-radius); padding: 14px 18px;
            margin-bottom: 14px; box-shadow: var(--shadow-sm);
            border-left: 3px solid var(--accent);
        }

        /* ── MODAL ─────────────────────────────────────── */
        .modal-content { border: none !important; border-radius: 12px !important; box-shadow: 0 20px 60px rgba(0,0,0,.18) !important; overflow: hidden; }
        .modal-header { padding: 16px 20px; border-bottom: 1px solid var(--border) !important; }
        .modal-header.dark { background: var(--sidebar-bg); color: #fff; }
        .modal-header.dark .btn-close { filter: invert(1) opacity(.7); }
        .modal-body { padding: 20px; }
        .modal-footer { padding: 12px 20px; background: #f8fafc; border-top: 1px solid var(--border) !important; }

        .form-label { font-size: 12px; font-weight: 600; color: #374151; margin-bottom: 4px; }
        .form-control, .form-select {
            border-radius: 7px; border: 1px solid #d1d5db;
            font-size: 13.5px; padding: 7px 11px;
            transition: border-color .15s, box-shadow .15s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--accent); box-shadow: 0 0 0 3px rgba(25,118,210,.15);
        }
        .input-group-text {
            background: #f9fafb; border-color: #d1d5db;
            color: var(--text-muted); font-size: 13px;
        }

        /* ── BUTTONS ───────────────────────────────────── */
        .btn { border-radius: 7px; font-size: 13.5px; font-weight: 500; }
        .btn-primary { background: var(--accent); border-color: var(--accent); }
        .btn-primary:hover { background: var(--accent-dark); border-color: var(--accent-dark); }
        .btn-success { background: #16a34a; border-color: #16a34a; }
        .btn-success:hover { background: #15803d; border-color: #15803d; }
        .btn-sm { border-radius: 6px; font-size: 12px; }

        /* ── PROGRESS ──────────────────────────────────── */
        .progress { border-radius: 20px; background: #e9ecef; height: 6px; }
        .progress-bar { border-radius: 20px; transition: width .4s ease; }

        /* ── TABLET (769–1024px) ───────────────────────── */
        @@media (min-width: 769px) and (max-width: 1024px) {
            .page-body { padding: 16px 18px 28px; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
            .topbar-user .user-name,
            .topbar-user .user-role { font-size: 11px; }
        }

        /* ── MOBILE (≤768px) ───────────────────────────── */
        @@media (max-width: 768px) {
            /* Sidebar: gizli, overlay ile açılır */
            .sidebar { transform: translateX(-100%); width: var(--sidebar-w) !important; }
            .sidebar.mobile-open { transform: translateX(0); }
            .page-shell { margin-left: 0 !important; }
            .topbar { left: 0 !important; padding: 0 12px; gap: 8px; }
            .page-body { padding: 12px 12px 24px; }
            .topbar-user { display: none; }

            /* Tablo: yatay kaydırma */
            .card > .card-body { overflow-x: auto; -webkit-overflow-scrolling: touch; }
            .table { min-width: 480px; }
            .data-table { min-width: 480px; }

            /* İstatistik kartları: 2 sütun */
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
            .stat-card { padding: 12px 14px; }
            .stat-value { font-size: 18px; }

            /* Dokunma hedefleri */
            .btn { min-height: 36px; }
            .topbar-btn { height: 36px; padding: 0 11px; }
            .btn-topbar-add { height: 38px; padding: 0 12px; font-size: 12.5px; }
            .form-control, .form-select { padding: 8px 10px; font-size: 14px; }

            /* Toast: ekranın altında tam genişlik */
            .toast-container { bottom: 16px; right: 10px; left: 10px; }
            .toast-container > div { min-width: unset !important; width: 100%; }

            /* Modal: daha dar ekrana uygun */
            .modal-dialog { margin: 8px auto; }
            .modal-body { padding: 16px; }
        }

        /* ── KÜÇÜK TELEFON (≤576px) ─────────────────────── */
        @@media (max-width: 576px) {
            .stats-grid { grid-template-columns: 1fr; }
            .modal-dialog { margin: 6px; max-width: calc(100vw - 12px); }
            .topbar-title { font-size: 13px; }
            .filter-form { flex-direction: column; align-items: stretch; }
            .filter-form .form-control,
            .filter-form .form-select { min-width: unset; width: 100%; }
            .page-body { padding: 10px 10px 20px; }
        }

        /* ── OVERLAY ───────────────────────────────────── */
        .sidebar-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.45); z-index: 1049;
        }
        .sidebar-overlay.active { display: block; }

        /* ── SCROLLBAR ─────────────────────────────────── */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #c1c8d4; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #9ca3af; }

        /* ── ANIMATIONS ────────────────────────────────── */
        .fade-in { animation: fadeIn .3s ease; }
        @@keyframes fadeIn { from { opacity:0; transform:translateY(5px); } to { opacity:1; transform:translateY(0); } }

        /* ── BELGE NO LİNKİ ────────────────────────────── */
        .doc-num-btn {
            background: none; border: none; padding: 0; cursor: pointer;
            font-size: inherit; font-weight: 600; color: #1a2744;
            text-decoration: underline; text-decoration-style: dotted;
            text-underline-offset: 3px; transition: color .15s;
        }
        .doc-num-btn:hover { color: var(--accent); text-decoration-style: solid; }

        /* ── STATS GRID ────────────────────────────────── */
        .stats-grid {
            display: grid;
            gap: 14px;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        }

        /* ── DATA TABLE ────────────────────────────────── */
        .data-table {
            width: 100%; border-collapse: collapse; font-size: 13px; margin: 0;
        }
        .data-table thead tr {
            background: var(--table-header-bg);
        }
        .data-table thead th {
            color: var(--table-header-color); font-size: 11px; font-weight: 600;
            text-transform: uppercase; letter-spacing: .06em;
            padding: 11px 14px; white-space: nowrap; border: none;
        }
        .data-table tbody tr {
            border-bottom: 1px solid #f1f5f9;
            transition: background .12s;
        }
        .data-table tbody tr:nth-child(even) { background: #fafbfd; }
        .data-table tbody tr:hover { background: #eff6ff !important; }
        .data-table tbody tr:last-child { border-bottom: none; }
        .data-table tbody td {
            padding: 10px 14px; vertical-align: middle; color: #374151;
        }
        .data-table tfoot td {
            padding: 10px 14px; background: #f1f5f9;
            border-top: 2px solid #e2e8f0; font-weight: 600; font-size: 12px;
        }

        /* ── DATATABLES OVERRIDE ──────────────────────── */
        div.dataTables_wrapper { padding: 0; }
        div.dataTables_wrapper div.dataTables_length,
        div.dataTables_wrapper div.dataTables_filter,
        div.dataTables_wrapper div.dataTables_info,
        div.dataTables_wrapper div.dataTables_paginate { padding: 10px 14px; font-size: 12px; }
        div.dataTables_wrapper div.dataTables_filter { text-align: right; }
        div.dataTables_wrapper div.dataTables_filter input {
            border: 1px solid var(--border); border-radius: 7px; padding: 4px 10px;
            font-size: 12px; outline: none; width: 180px;
        }
        div.dataTables_wrapper div.dataTables_filter input:focus { border-color: var(--accent); }
        div.dataTables_wrapper div.dataTables_length select {
            border: 1px solid var(--border); border-radius: 6px; padding: 3px 6px; font-size: 12px;
        }
        div.dataTables_paginate .paginate_button {
            border-radius: 6px !important; border: 1px solid var(--border) !important;
            padding: 4px 10px !important; font-size: 12px !important; margin: 0 2px !important;
        }
        div.dataTables_paginate .paginate_button.current,
        div.dataTables_paginate .paginate_button.current:hover {
            background: var(--accent) !important; border-color: var(--accent) !important; color: #fff !important;
        }
        div.dataTables_paginate .paginate_button:hover {
            background: var(--bg-page) !important; border-color: var(--border) !important; color: #374151 !important;
        }
        table.dataTable.no-footer { border-bottom: none; }
        table.dataTable thead .sorting::after,
        table.dataTable thead .sorting_asc::after,
        table.dataTable thead .sorting_desc::after { opacity: .7; }
        body.dark-mode div.dataTables_wrapper div.dataTables_filter input,
        body.dark-mode div.dataTables_wrapper div.dataTables_length select { background:#334155;border-color:#475569;color:#e2e8f0; }
        body.dark-mode div.dataTables_paginate .paginate_button { background:#1e293b!important;border-color:#334155!important;color:#94a3b8!important; }
        body.dark-mode div.dataTables_wrapper div.dataTables_info,
        body.dark-mode div.dataTables_wrapper div.dataTables_length { color:#94a3b8; }

        /* ── SKELETON LOADER ───────────────────────────── */
        @@keyframes shimmer {
            0%   { background-position: -600px 0; }
            100% { background-position: 600px 0; }
        }
        .skeleton {
            background: linear-gradient(90deg, #f0f2f5 25%, #e8eaed 50%, #f0f2f5 75%);
            background-size: 600px 100%; animation: shimmer 1.4s infinite linear;
            border-radius: 6px; display: inline-block;
        }
        body.dark-mode .skeleton {
            background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%);
            background-size: 600px 100%;
        }
        .skeleton-row { display: flex; gap: 10px; margin-bottom: 10px; align-items: center; }
        .skeleton-row .sk-cell { height: 14px; border-radius: 4px; }

        /* ── GLOBAL TOPBAR SEARCH ──────────────────────── */
        .topbar-search-wrap {
            position: relative; width: 220px;
        }
        .topbar-search-input {
            width: 100%; height: 34px; border-radius: 8px; border: 1px solid var(--border);
            padding: 0 10px 0 32px; font-size: 12.5px; background: #f9fafb;
            outline: none; transition: all .15s, width .2s; color: #374151;
        }
        .topbar-search-input:focus { border-color: var(--accent); background: #fff; box-shadow: 0 0 0 3px rgba(25,118,210,.1); width: 260px; }
        .topbar-search-icon {
            position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
            color: #9ca3af; font-size: 12px; pointer-events: none;
        }
        .topbar-search-kbd {
            position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
            font-size: 10px; color: #9ca3af; background: #f3f4f6; border: 1px solid #e5e7eb;
            border-radius: 4px; padding: 1px 5px; pointer-events: none;
        }
        .search-dropdown {
            display: none; position: absolute; top: calc(100% + 6px); left: 0; right: 0;
            background: #fff; border-radius: 10px; border: 1px solid var(--border);
            box-shadow: 0 8px 32px rgba(0,0,0,.13); z-index: 2100; overflow: hidden;
            max-height: 380px; overflow-y: auto;
        }
        .search-dropdown.show { display: block; }
        .search-result-group { padding: 6px 0; border-bottom: 1px solid #f3f4f6; }
        .search-result-group:last-child { border-bottom: none; }
        .search-result-label { padding: 4px 14px; font-size: 10px; font-weight: 700;
            color: var(--text-muted); text-transform: uppercase; letter-spacing: .06em; }
        .search-result-item {
            display: flex; align-items: center; gap: 10px;
            padding: 8px 14px; cursor: pointer; transition: background .1s; font-size: 12.5px;
        }
        .search-result-item:hover { background: #f0f7ff; }
        .search-result-item i { font-size: 13px; width: 18px; text-align: center; flex-shrink: 0; }
        .search-result-item .sri-main { font-weight: 500; color: #111827; }
        .search-result-item .sri-sub  { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
        .search-no-result { padding: 18px 14px; text-align: center; color: var(--text-muted); font-size: 12.5px; }
        body.dark-mode .topbar-search-input { background:#334155;border-color:#475569;color:#e2e8f0; }
        body.dark-mode .topbar-search-input:focus { background:#475569; }
        body.dark-mode .topbar-search-kbd { background:#334155;border-color:#475569;color:#64748b; }
        body.dark-mode .search-dropdown { background:#1e293b;border-color:#334155; }
        body.dark-mode .search-result-item:hover { background:#334155; }
        body.dark-mode .search-result-item .sri-main { color:#e2e8f0; }

        /* ── PRINT ─────────────────────────────────────── */
        @@media print {
            .sidebar, .topbar, .topbar-actions, .btn-topbar-add,
            .notif-wrap, #darkModeToggle, .topbar-search-wrap,
            .modal, #pageProgressBar, .toast-container { display: none !important; }
            .page-shell { margin-left: 0 !important; }
            .page-body { padding: 0 !important; }
            body { background: #fff !important; color: #000 !important; }
            .table-card { box-shadow: none !important; border: 1px solid #ccc !important; }
            .data-table { font-size: 11px !important; }
            .data-table thead { background: #1a2744 !important; -webkit-print-color-adjust: exact; }
            .stat-card { border: 1px solid #e5e7eb !important; box-shadow: none !important; }
            a { color: #000 !important; text-decoration: none !important; }
            .badge { border: 1px solid #ccc; }
        }

        /* ── EMPTY STATE ───────────────────────────────── */
        .empty-state {
            padding: 56px 20px; text-align: center;
        }
        .empty-state .empty-icon {
            width: 64px; height: 64px; border-radius: 16px;
            background: #f1f5f9; display: inline-flex;
            align-items: center; justify-content: center;
            font-size: 28px; color: #94a3b8; margin-bottom: 14px;
        }
        .empty-state h6 { font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 5px; }
        .empty-state p { color: var(--text-muted); font-size: 12.5px; margin: 0; }
        .empty-state i { font-size: 40px; color: #d1d5db; margin-bottom: 12px; display: block; }

        /* ── TOAST ─────────────────────────────────────── */
        .toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; }

        /* ── PAGE TITLE BAR ────────────────────────────── */
        .page-title-bar {
            background: #fff; border: 1px solid var(--border);
            border-radius: var(--card-radius); padding: 12px 18px;
            margin-bottom: 16px; box-shadow: var(--shadow-sm);
            display: flex; align-items: center; gap: 12px;
        }
        .page-title-bar .ptb-icon {
            width: 36px; height: 36px; border-radius: 8px;
            background: var(--accent-light); color: var(--accent);
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; flex-shrink: 0;
        }
        .page-title-bar .ptb-title { font-size: 15px; font-weight: 700; color: #111827; }
        .page-title-bar .ptb-sub { font-size: 12px; color: var(--text-muted); }
        .page-title-bar .ptb-badge {
            background: var(--accent); color: #fff;
            font-size: 11px; font-weight: 600; padding: 2px 9px;
            border-radius: 20px;
        }

        /* ── INFO CARD (açıklama kartı) ─────────────────── */
        .info-card {
            background: #f8faff; border: 1px solid #dbeafe;
            border-radius: 10px; padding: 12px 16px;
            display: flex; gap: 10px; align-items: flex-start;
        }
        .info-card.warning { background: #fffbeb; border-color: #fde68a; }
        .info-card.danger  { background: #fef2f2; border-color: #fecaca; }
        .info-card.success { background: #f0fdf4; border-color: #bbf7d0; }
        .info-card i { font-size: 15px; margin-top: 1px; flex-shrink: 0; }

        /* ── SECTION HEADER ────────────────────────────── */
        .section-header {
            display: flex; align-items: center; gap: 8px;
            padding: 12px 16px; border-bottom: 1px solid var(--border);
            background: #fff;
        }
        .section-header .sh-icon {
            width: 30px; height: 30px; border-radius: 7px;
            display: flex; align-items: center; justify-content: center;
            font-size: 13px; flex-shrink: 0;
        }
        .section-header .sh-title { font-size: 13px; font-weight: 600; color: #1e293b; }
        .section-header .sh-sub { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
        .section-header .sh-actions { margin-left: auto; display: flex; gap: 6px; }

        /* ── DETAIL ROW ────────────────────────────────── */
        .detail-row {
            display: flex; padding: 8px 0;
            border-bottom: 1px solid #f1f5f9; font-size: 13px;
            align-items: flex-start;
        }
        .detail-row:last-child { border-bottom: none; }
        .detail-row .dr-label {
            width: 140px; flex-shrink: 0;
            color: var(--text-muted); font-size: 12px;
        }
        .detail-row .dr-value { font-weight: 500; color: #1e293b; flex: 1; }

        /* ── FSC BADGE ──────────────────────────────────── */
        .fsc-badge {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600;
        }
        .fsc-badge.active  { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
        .fsc-badge.warning { background: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
        .fsc-badge.expired { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
        .fsc-badge.none    { background: #f3f4f6; color: #6b7280; border: 1px solid #d1d5db; }

        /* ── PROGRESS STACKED BAR ───────────────────────── */
        .stock-bar {
            height: 6px; border-radius: 4px; background: #e5e7eb;
            overflow: hidden; min-width: 60px;
        }
        .stock-bar-fill {
            height: 100%; border-radius: 4px;
            transition: width .4s cubic-bezier(.4,0,.2,1);
        }

        /* ── NAV TABS IMPROVED ──────────────────────────── */
        .nav-tabs .nav-link {
            color: #6b7280; font-size: 13px; font-weight: 500;
            padding: 8px 16px; border-radius: 8px 8px 0 0;
            border: 1px solid transparent; transition: all .15s;
        }
        .nav-tabs .nav-link:hover { color: var(--accent); background: #f0f4ff; }
        .nav-tabs .nav-link.active {
            color: var(--accent); background: #fff;
            border-color: var(--border) var(--border) #fff;
            font-weight: 600;
        }

        /* ── TOPBAR PAGE TITLE ──────────────────────────── */
        .topbar-page-title {
            font-size: 14px; font-weight: 600; color: #1e293b; letter-spacing: -.01em;
        }

        /* ── QUICK ACTION CARD ──────────────────────────── */
        .quick-action {
            display: flex; align-items: center; gap: 8px;
            padding: 9px 12px; border-radius: 8px;
            border: 1px solid var(--border); background: #fff;
            text-decoration: none; color: #374151; font-size: 12.5px;
            transition: all .15s; cursor: pointer;
        }
        .quick-action:hover {
            border-color: var(--accent); background: #eff6ff;
            color: var(--accent); transform: translateY(-1px);
            box-shadow: 0 3px 10px rgba(25,118,210,.12);
        }
        .quick-action i { font-size: 14px; flex-shrink: 0; }

        /* ── PAGE HEADER ────────────────────────────────── */
        .page-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 18px; padding-bottom: 12px;
            border-bottom: 1px solid var(--border);
        }
        .page-title {
            font-size: 17px; font-weight: 700; color: #1e293b;
            margin: 0; display: flex; align-items: center; gap: 8px;
        }

        /* ── FILTER CARD / FORM ─────────────────────────── */
        .filter-card {
            background: #fff; border: 1px solid var(--border);
            border-radius: var(--card-radius); padding: 12px 16px;
            margin-bottom: 14px; box-shadow: var(--shadow-sm);
            border-left: 3px solid var(--accent);
        }
        .filter-form {
            display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
        }
        .filter-form .form-control,
        .filter-form .form-select { min-width: 140px; }

        /* ── BOOTSTRAP BADGE OVERRIDE ───────────────────── */
        .badge-success  { background: #dcfce7 !important; color: #166534 !important; }
        .badge-danger   { background: #fee2e2 !important; color: #991b1b !important; }
        .badge-warning  { background: #fef3c7 !important; color: #92400e !important; }
        .badge-info     { background: #dbeafe !important; color: #1d4ed8 !important; }
        .badge-primary  { background: #dbeafe !important; color: #1d4ed8 !important; }
        .badge-secondary{ background: #f3f4f6 !important; color: #374151 !important; }
        /* soft variants (no !important — used inline alongside .badge) */
        .badge-success-soft  { background: #dcfce7; color: #166534; }
        .badge-danger-soft   { background: #fee2e2; color: #991b1b; }
        .badge-warning-soft  { background: #fef3c7; color: #92400e; }
        .badge-info-soft     { background: #dbeafe; color: #1d4ed8; }
        .badge-secondary-soft{ background: #f3f4f6; color: #374151; }
        .badge-amber         { background: #fef3c7 !important; color: #92400e !important; }

        /* ── STOCK BAR COLORS ───────────────────────────── */
        .bg-success-soft { background: #16a34a; }
        .bg-warning-soft { background: #d97706; }
        .bg-danger-soft  { background: #dc2626; }

        /* ── QUICK-ADD INLINE BUTTON ─────────────────────── */
        .qa-group { display: flex; gap: 4px; align-items: stretch; }
        .qa-group > select,
        .qa-group > .form-select { flex: 1; min-width: 0; }
        .qa-btn {
            width: 32px; min-width: 32px;
            border-radius: 6px;
            border: 1.5px dashed #93c5fd;
            background: #eff6ff; color: #1d4ed8;
            cursor: pointer; font-size: 12px;
            display: flex; align-items: center; justify-content: center;
            transition: all .15s; padding: 0; line-height: 1;
        }
        .qa-btn:hover { background: #dbeafe; border-style: solid; border-color: #1d4ed8; transform: none; }
        .qa-btn:active { background: #bfdbfe; }
        /* QuickAdd modal header color band */
        .qa-modal-header { border-radius: 0; padding: 14px 20px; }
    </style>
</head>
<body>

