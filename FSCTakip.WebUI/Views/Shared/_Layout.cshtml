        {
            <div class="topbar-primary me-3">
                @await RenderSectionAsync("TopbarPrimary", required: false)
            </div>
        }

        <!-- Sayfa başlığı -->
        <div style="min-width:0;flex:1;">
            <div class="topbar-title" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@ViewData["Title"]</div>
        </div>

        <!-- Sayfa bazlı aksiyonlar + sağ araç çubuğu (margin-left:auto ile sağa yasla) -->
