@model IEnumerable<FSCTakip.Core.Entities.BagType>
@{
    ViewData["Title"] = "Torba Tipi Tanımları";
}

@* --- ÜST AKSİYON BUTONLARI --- *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="m-0 font-weight-bold text-secondary"><i class="fas fa-shopping-bag mr-2"></i>Torba Tipi Listesi</h5>
    <div>
        <button class="btn btn-sm btn-outline-secondary" onclick="$('#filterPanel').slideToggle()">
            <i class="fas fa-filter"></i> Filtrele
        </button>
        <button class="btn btn-sm btn-outline-success" onclick="exportToExcel()">
            <i class="fas fa-file-excel"></i> Excel
        </button>
        <button class="btn btn-sm btn-outline-dark" onclick="window.print()">
            <i class="fas fa-print"></i> Yazdır
        </button>
        <button class="btn btn-sm btn-secondary text-white" onclick="openAddModal()">
            <i class="fas fa-plus"></i> Yeni Torba Tipi
        </button>
    </div>
</div>

@* --- FİLTRELEME PANELİ --- *@
<div id="filterPanel" class="card mb-3 shadow-sm border-left-secondary" style="display:none;">
    <div class="card-body py-3">
        <div class="row align-items-end">
            <div class="col-md-9">
                <label class="small font-weight-bold text-uppercase text-secondary">Torba Tipi Ara</label>
                <input type="text" id="bagTypeSearch" class="form-control form-control-sm border-secondary" placeholder="Aramak istediğiniz torba tipi veya kod...">
            </div>
            <div class="col-md-3">
                <button class="btn btn-secondary btn-sm btn-block text-white" onclick="filterBagTypes()">
                    <i class="fas fa-search mr-1"></i> Sorgula
                </button>
            </div>
        </div>
    </div>
</div>

@* --- TABLO ALANI --- *@
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="bagTypesTable">
                <thead class="bg-light text-dark text-uppercase small font-weight-bold">
                    <tr>
                        <th style="width: 80px;" class="text-center">ID</th>
                        <th>Torba Tipi</th>
                        <th class="text-center">Kısa Kod</th>
                        <th>Teknik Açıklama</th>
                        <th class="text-center" style="width: 100px;">Durum</th>
                        <th class="text-right" style="width: 130px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center text-muted">@item.Id</td>
                            <td><strong class="text-primary">@item.Name</strong></td>
                            <td class="text-center"><code>@item.Code</code></td>
                            <td><small class="text-muted">@item.Description</small></td>
                            <td class="text-center">
                                <div class="custom-control custom-switch">
                                    <input type="checkbox" class="custom-control-input" id="status_@item.Id"
                                           @(item.IsActive ? "checked" : "")
                                           onchange="toggleStatus(@item.Id)">
                                    <label class="custom-control-label cursor-pointer" for="status_@item.Id"></label>
                                </div>
                            </td>
                            <td class="text-right">
                                <button class="btn btn-sm btn-outline-primary mr-1"
                                        onclick="editBagType(@item.Id, '@item.Name', '@item.Code', '@item.Description')">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteBagType(@item.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* --- MODAL: EKLE/DÜZENLE --- *@
<div class="modal fade" id="bagTypeModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-secondary text-white">
                <h6 class="modal-title font-weight-bold"><i class="fas fa-shopping-bag mr-2"></i>Torba Tipi Formu</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="SaveBagType" method="post">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="bagId" value="0" />
                    <div class="form-group mb-3">
                        <label class="small font-weight-bold">Torba Tipi Adı <span class="text-danger">*</span></label>
                        <input type="text" name="Name" id="bagName" class="form-control" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="small font-weight-bold">Kısa Kod</label>
                        <input type="text" name="Code" id="bagCode" class="form-control">
                    </div>
                    <div class="form-group mb-0">
                        <label class="small font-weight-bold">Teknik Açıklama</label>
                        <textarea name="Description" id="bagDesc" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light p-2">
                    <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-secondary btn-sm px-4 text-white">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterBagTypes() {
            var value = $("#bagTypeSearch").val().toLowerCase();
            $("#bagTypesTable tbody tr").filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
            });
        }

        function openAddModal() {
            $('#bagId').val(0);
            $('#bagName').val('');
            $('#bagCode').val('');
            $('#bagDesc').val('');
            $('.modal-title').html('<i class="fas fa-plus mr-2"></i>Yeni Torba Tipi');
            bootstrap.Modal.getOrCreateInstance(document.getElementById('bagTypeModal')).show();
        }

        function editBagType(id, name, code, desc) {
            $('#bagId').val(id);
            $('#bagName').val(name);
            $('#bagCode').val(code);
            $('#bagDesc').val(desc);
            $('.modal-title').html('<i class="fas fa-edit mr-2"></i>Torba Tipi Düzenle');
            bootstrap.Modal.getOrCreateInstance(document.getElementById('bagTypeModal')).show();
        }

        function toggleStatus(id) {
            $.post('/Product/ToggleBagTypeStatus', { id: id }, function (res) {
                if (!res.success) {
                    Swal.fire('Hata!', res.message, 'error');
                    let chk = $(`#status_${id}`);
                    chk.prop('checked', !chk.is(':checked'));
                }
            });
        }

        function deleteBagType(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu torba tipi kalıcı olarak silinecektir!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#5a5c69',
                cancelButtonColor: '#e74a3b',
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Product/DeleteBagType', { id: id }, function (res) {
                        if (res.success) {
                            Swal.fire({ icon: 'success', title: 'Başarılı', text: res.message, timer: 1000, showConfirmButton: false }).then(() => location.reload());
                        } else {
                            Swal.fire('Hata!', res.message, 'error');
                        }
                    });
                }
            });
        }

        function exportToExcel() {
            window.location.href = '@Url.Action("ExportBagTypes", "Product")';
        }
    </script>
}
