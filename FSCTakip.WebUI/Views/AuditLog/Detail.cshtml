@model FSCTakip.Core.Entities.AuditLog
@using System.Text.Json
@{
    ViewData["Title"] = $"Günlük Detayı #{Model.Id}";

    var (badgeCls, actionLabel) = Model.Action switch {
        "INSERT" => ("bg-success", "Ekleme"),
        "UPDATE" => ("bg-warning text-dark", "Güncelleme"),
        "DELETE" => ("bg-danger", "Silme"),
        _ => ("bg-secondary", Model.Action)
    };

    Dictionary<string, JsonElement>? oldDict = null;
    Dictionary<string, JsonElement>? newDict = null;
    try { if (Model.OldValues != null) oldDict = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(Model.OldValues); } catch { }
    try { if (Model.NewValues != null) newDict = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(Model.NewValues); } catch { }

    var allKeys = new HashSet<string>();
    if (oldDict != null) foreach (var k in oldDict.Keys) allKeys.Add(k);
    if (newDict != null) foreach (var k in newDict.Keys) allKeys.Add(k);
}

<div class="mb-3">
    <a href="/AuditLog" class="btn btn-sm btn-outline-secondary me-2">
        <i class="fas fa-arrow-left me-1"></i>Günlüğe Dön
    </a>
    <span class="badge @badgeCls fs-6">@actionLabel</span>
</div>

<div class="row g-3">
    <!-- Meta bilgiler -->
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-dark text-white py-2">
                <i class="fas fa-info-circle me-1"></i> İşlem Bilgisi
            </div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">Günlük ID</dt>
                    <dd class="col-7 fw-semibold">#@Model.Id</dd>

                    <dt class="col-5 text-muted">Tablo</dt>
                    <dd class="col-7">
                        <span class="badge bg-light text-dark border">@Model.TableName</span>
                    </dd>

                    <dt class="col-5 text-muted">Kayıt ID</dt>
                    <dd class="col-7">@(Model.RecordId.HasValue ? "#" + Model.RecordId : "—")</dd>

                    <dt class="col-5 text-muted">İşlem</dt>
                    <dd class="col-7"><span class="badge @badgeCls">@actionLabel</span></dd>

                    <dt class="col-5 text-muted">Kullanıcı</dt>
                    <dd class="col-7 fw-semibold">
                        <i class="fas fa-user me-1 text-primary"></i>@(Model.ChangedBy ?? "—")
                    </dd>

                    <dt class="col-5 text-muted">Tarih / Saat</dt>
                    <dd class="col-7">@Model.ChangedAt.ToString("dd.MM.yyyy HH:mm:ss")</dd>

                    @if (!string.IsNullOrEmpty(Model.IpAddress))
                    {
                        <dt class="col-5 text-muted">IP Adresi</dt>
                        <dd class="col-7 font-monospace small">@Model.IpAddress</dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <!-- Değişiklik detayı -->
    <div class="col-md-8">
        @if (Model.Action == "UPDATE" && allKeys.Any())
        {
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark py-2">
                    <i class="fas fa-exchange-alt me-1"></i> Değişen Alanlar
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-secondary">
                            <tr>
                                <th style="width:30%">Alan</th>
                                <th class="text-danger"><i class="fas fa-minus-circle me-1"></i>Eski Değer</th>
                                <th class="text-success"><i class="fas fa-plus-circle me-1"></i>Yeni Değer</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var key in allKeys.OrderBy(k => k))
                            {
                                var oldVal = oldDict != null && oldDict.TryGetValue(key, out var ov) ? ov.ToString() : "—";
                                var newVal = newDict != null && newDict.TryGetValue(key, out var nv) ? nv.ToString() : "—";
                                var changed = oldVal != newVal;
                                <tr class="@(changed ? "" : "text-muted")">
                                    <td class="fw-semibold small">@key</td>
                                    <td class="@(changed ? "text-danger" : "") small font-monospace">@oldVal</td>
                                    <td class="@(changed ? "text-success fw-semibold" : "") small font-monospace">@newVal</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (Model.Action == "INSERT" && newDict != null)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white py-2">
                    <i class="fas fa-plus-circle me-1"></i> Eklenen Kayıt
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-secondary">
                            <tr><th style="width:35%">Alan</th><th>Değer</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var kv in newDict.OrderBy(k => k.Key))
                            {
                                <tr>
                                    <td class="fw-semibold small">@kv.Key</td>
                                    <td class="small font-monospace text-success">@kv.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (Model.Action == "DELETE" && oldDict != null)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white py-2">
                    <i class="fas fa-trash me-1"></i> Silinen Kayıt
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-secondary">
                            <tr><th style="width:35%">Alan</th><th>Değer</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var kv in oldDict.OrderBy(k => k.Key))
                            {
                                <tr>
                                    <td class="fw-semibold small">@kv.Key</td>
                                    <td class="small font-monospace text-danger">@kv.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <!-- Ham JSON -->
            <div class="card shadow-sm">
                <div class="card-header bg-light py-2">Ham Veri</div>
                <div class="card-body">
                    @if (Model.OldValues != null)
                    {
                        <p class="text-danger fw-semibold mb-1">Eski:</p>
                        <pre class="bg-light p-2 rounded small">@Model.OldValues</pre>
                    }
                    @if (Model.NewValues != null)
                    {
                        <p class="text-success fw-semibold mb-1">Yeni:</p>
                        <pre class="bg-light p-2 rounded small">@Model.NewValues</pre>
                    }
                </div>
            </div>
        }
    </div>
</div>
