@model List<FSCTakip.Core.Entities.WorkOrder>
@using FSCTakip.Core.Entities
@{
    Layout = null;
    var now = DateTime.Now;
    var company = ViewBag.Company as CompanySetting;
    var companyName = string.IsNullOrWhiteSpace(company?.CompanyName) ? "ARD SİSTEM VE DANIŞMANLIK" : company!.CompanyName;
}
<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>İş Emri Formu</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 11pt; color: #1a1a1a; background: #fff; }
.print-page { padding: 20mm 15mm; page-break-after: always; }
.print-page:last-child { page-break-after: auto; }
.header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #1565c0; padding-bottom: 10px; margin-bottom: 16px; }
.company-name { font-size: 16pt; font-weight: 700; color: #1565c0; }
.doc-title { font-size: 13pt; font-weight: 700; color: #1a1a1a; margin-top: 4px; }
.doc-meta { text-align: right; font-size: 10pt; color: #444; line-height: 1.6; }
.status-badge { display: inline-block; font-weight: 700; font-size: 9pt; padding: 3px 10px; border-radius: 4px; margin-top: 4px; }
.section { margin-bottom: 14px; }
.section-title { font-size: 9pt; font-weight: 700; color: #1565c0; text-transform: uppercase; letter-spacing: .05em; border-bottom: 1px solid #ddd; padding-bottom: 3px; margin-bottom: 8px; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 20px; }
.info-row { display: flex; gap: 6px; font-size: 10pt; }
.info-label { color: #666; min-width: 110px; flex-shrink: 0; }
.info-value { font-weight: 600; }
table { width: 100%; border-collapse: collapse; font-size: 10pt; }
th { background: #1565c0; color: #fff; font-weight: 600; padding: 6px 8px; text-align: left; }
td { padding: 5px 8px; border-bottom: 1px solid #e8e8e8; vertical-align: top; }
tr:nth-child(even) td { background: #f5f8ff; }
tfoot td { font-weight: 700; background: #eef2ff !important; border-top: 2px solid #1565c0; }
.fsc-tag { display: inline-block; background: #e8f5e9; color: #1b5e20; font-size: 8pt; font-weight: 600; padding: 1px 6px; border-radius: 3px; border: 1px solid #a5d6a7; }
.empty-note { padding: 12px; text-align: center; color: #888; font-size: 10pt; font-style: italic; }
.footer { margin-top: 20px; border-top: 1px solid #ddd; padding-top: 12px; font-size: 9pt; color: #666; display: flex; justify-content: space-between; }
.signature-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-top: 24px; }
.sig-box { border-top: 1px solid #999; padding-top: 6px; text-align: center; font-size: 9pt; color: #555; }
@@media print {
  .print-page { padding: 10mm; }
  .no-print { display: none !important; }
  @* Force color print *@
  -webkit-print-color-adjust: exact;
  print-color-adjust: exact;
}
</style>
</head>
<body>

<div class="no-print" style="background:#1565c0;color:#fff;padding:8px 16px;margin-bottom:0;display:flex;justify-content:space-between;align-items:center;">
  <span style="font-weight:600;">İş Emri Formu Önizleme — @Model.Count adet form</span>
  <button onclick="window.print()" style="background:#fff;color:#1565c0;border:none;padding:6px 16px;border-radius:4px;font-weight:700;cursor:pointer;">🖨 Yazdır / PDF Kaydet</button>
</div>

@foreach (var wo in Model)
{
    var tuketim = wo.ProductionDetails.Sum(d => d.ConsumedWeight);
    var fire    = wo.ProductionDetails.Sum(d => d.WasteWeight);
    var (statusBg, statusFg, statusLabel) = wo.Status switch {
        WorkOrderStatus.Taslak     => ("#f3f4f6", "#374151", "Taslak"),
        WorkOrderStatus.Uretimde   => ("#fef3c7", "#92400e", "Üretimde"),
        WorkOrderStatus.Tamamlandi => ("#dcfce7", "#166534", "Tamamlandı"),
        WorkOrderStatus.Iptal      => ("#fee2e2", "#991b1b", "İptal"),
        _ => ("#f3f4f6", "#374151", "—")
    };
    var details = wo.ProductionDetails.OrderBy(d => d.ProductionDate).ToList();

    <div class="print-page">
        <!-- BAŞLIK -->
        <div class="header">
            <div>
                <div class="company-name">@companyName</div>
                <div class="doc-title">İş Emri Formu</div>
                <div class="status-badge" style="background:@statusBg;color:@statusFg;">@statusLabel</div>
                @if (!string.IsNullOrWhiteSpace(company?.FscCocCode) || !string.IsNullOrWhiteSpace(company?.FscLicenseCode))
                {
                    <div style="font-size:8pt;color:#1b5e20;margin-top:3px;">
                        @if (!string.IsNullOrWhiteSpace(company?.FscCocCode)) { <span>FSC CoC: <strong>@company!.FscCocCode</strong></span> }
                        @if (!string.IsNullOrWhiteSpace(company?.FscLicenseCode)) { <span> · Lisans: <strong>@company!.FscLicenseCode</strong></span> }
                    </div>
                }
            </div>
            <div class="doc-meta">
                <div><strong>İş Emri No:</strong> @wo.WorkOrderNo</div>
                <div><strong>Plan Tarihi:</strong> @wo.PlannedDate.ToString("dd.MM.yyyy")</div>
                <div><strong>Makine:</strong> @(wo.Machine?.Name ?? "—")</div>
                <div><strong>Düzenleme:</strong> @now.ToString("dd.MM.yyyy HH:mm")</div>
            </div>
        </div>

        <!-- ÜRÜN BİLGİLERİ -->
        <div class="section">
            <div class="section-title">Ürün Bilgileri</div>
            <div class="info-grid">
                <div class="info-row"><span class="info-label">Ürün Adı:</span><span class="info-value">@(wo.Product?.ProductName ?? "—")</span></div>
                <div class="info-row"><span class="info-label">Ürün Kodu:</span><span class="info-value">@(wo.Product?.ProductCode ?? "—")</span></div>
                <div class="info-row"><span class="info-label">FSC Tipi:</span><span class="info-value">@(wo.Product?.FscType?.Code ?? "FSC'siz")</span></div>
                <div class="info-row"><span class="info-label">Makine:</span><span class="info-value">@(wo.Machine?.Name ?? "—")</span></div>
                <div class="info-row"><span class="info-label">Plan Adet:</span><span class="info-value">@wo.PlannedQuantity.ToString("N0")</span></div>
                <div class="info-row"><span class="info-label">Gerçek Adet:</span><span class="info-value">@wo.ActualQuantity.ToString("N0")</span></div>
                @if (!string.IsNullOrWhiteSpace(wo.Notes))
                {
                    <div class="info-row" style="grid-column:1/-1"><span class="info-label">Notlar:</span><span class="info-value">@wo.Notes</span></div>
                }
            </div>
        </div>

        <!-- KULLANILAN HAMMADDELER -->
        <div class="section">
            <div class="section-title">Kullanılan Hammaddeler</div>
            @if (details.Count == 0)
            {
                <div class="empty-note">Bu iş emrinde henüz tüketim kaydı girilmemiş.</div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Bobin/Seri No</th>
                            <th>Parti No</th>
                            <th>Hammadde</th>
                            <th>Tedarikçi</th>
                            <th>FSC Tipi</th>
                            <th style="text-align:right">Tüketilen (kg)</th>
                            <th style="text-align:right">Fire (kg)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rowNum = 1; }
                        @foreach (var d in details)
                        {
                            var lot = d.FscSerial?.Lot;
                            <tr>
                                <td>@(rowNum++)</td>
                                <td>@(d.FscSerial?.SerialNo ?? "—")</td>
                                <td>@(lot?.PartiNo ?? "—")</td>
                                <td>@(lot?.Product?.ProductName ?? "—")</td>
                                <td>@(lot?.Supplier?.Name ?? "—")</td>
                                <td><span class="fsc-tag">@(lot?.FscType?.Code ?? "FSC'siz")</span></td>
                                <td style="text-align:right">@d.ConsumedWeight.ToString("N2")</td>
                                <td style="text-align:right">@d.WasteWeight.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="6" style="text-align:right">TOPLAM</td>
                            <td style="text-align:right">@tuketim.ToString("N2")</td>
                            <td style="text-align:right">@fire.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            }
        </div>

        <!-- İMZA ALANLARI -->
        <div class="signature-row">
            <div class="sig-box">Üretim Sorumlusu</div>
            <div class="sig-box">Depo Sorumlusu</div>
            <div class="sig-box">Kalite Kontrol</div>
        </div>

        <!-- ALT BİLGİ -->
        <div class="footer">
            <div>© @now.Year @companyName · FSC Takip ERP</div>
            <div>Bu belge elektronik ortamda üretilmiştir. @now.ToString("dd.MM.yyyy HH:mm")</div>
        </div>
    </div>
}

</body>
</html>
