@using FSCTakip.WebUI.Controllers
@{
    ViewData["Title"] = "Yarı Mamül Dönüşüm";
    var sources = ViewBag.SourceSerials as List<ConvSourceVM> ?? new List<ConvSourceVM>();
    var targets = ViewBag.TargetProducts as List<ConvTargetVM> ?? new List<ConvTargetVM>();
    var recent  = ViewBag.Recent as List<ConvRecentVM> ?? new List<ConvRecentVM>();
}

@section TopbarActions {
    <a href="/Purchase/Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-scroll me-1"></i> Hammadde Girişi
    </a>
    <a href="/Stock/RawMaterial" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-warehouse me-1"></i> Stok
    </a>
}

<div class="row g-3">
    <!-- Dönüşüm formu -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-semibold mb-0"><i class="fas fa-recycle text-success me-2"></i>Ham / YM → Yarı Mamül Dönüşümü</h6>
                <div class="text-muted" style="font-size:12px;">1xxxx ham kağıt veya 24xxx YM bobinini 23xxx baskılı yarı mamüle çevirir.</div>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Kaynak Bobin (Ham / YM) <span class="text-danger">*</span></label>
                    <select id="sourceSerialId" class="form-select" onchange="onSourceChange()">
                        <option value="">— Stoktaki bobin seçin —</option>
                        @foreach (var s in sources)
                        {
                            <option value="@s.Id" data-kalan="@s.CurrentWeight.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-fsc="@s.FscType">
                                @(s.UrunKod ?? "—") · @s.UrunAd · @s.SerialNo · kalan @s.CurrentWeight.ToString("N2") kg
                            </option>
                        }
                    </select>
                    <div id="srcInfo" class="form-text" style="display:none;font-size:11.5px;">
                        <i class="fas fa-shield-alt text-success me-1"></i>FSC tipi <strong id="srcFsc"></strong> hedefe devredilecek (CoC). Kalan: <strong id="srcKalan"></strong> kg
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Hedef Yarı Mamül (BB) <span class="text-danger">*</span></label>
                    <input type="text" id="targetSearch" class="form-control mb-2" placeholder="Kod / ad ile filtrele (örn: 23357)" oninput="filterTarget()">
                    <select id="targetProductId" class="form-select" size="6" style="height:auto;">
                        @foreach (var t in targets)
                        {
                            <option value="@t.Id" data-text="@((t.Kod + " " + t.Ad).ToLower())">@t.Kod — @t.Ad</option>
                        }
                    </select>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Tüketilen Ham (kg) <span class="text-danger">*</span></label>
                        <input type="number" id="consumedKg" class="form-control" step="0.01" min="0" placeholder="0,00" oninput="onConsumedChange()">
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Üretilen YM (kg) <span class="text-danger">*</span></label>
                        <input type="number" id="producedKg" class="form-control" step="0.01" min="0" placeholder="0,00" oninput="calcFire()">
                        <div class="form-text" style="font-size:11px;">Genelde tüketilen ile aynı (1:1). Fire varsa azaltın.</div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3 p-2 rounded" style="background:#f8fafc;border:1px solid #e5e7eb;">
                    <span class="text-muted" style="font-size:12.5px;"><i class="fas fa-burn text-warning me-1"></i>Fire (otomatik)</span>
                    <span class="fw-semibold" id="fireOut" style="color:#92400e;">0,00 kg · %0</span>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Dönüşüm Tarihi</label>
                        <input type="date" id="convDate" class="form-control">
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Not</label>
                        <input type="text" id="convNotes" class="form-control" placeholder="Opsiyonel...">
                    </div>
                </div>

                <button class="btn btn-success w-100 py-2 fw-semibold" onclick="convertNow()">
                    <i class="fas fa-recycle me-1"></i> DÖNÜŞTÜR
                </button>
            </div>
        </div>
    </div>

    <!-- Son dönüşümler -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-white border-0 pt-3 pb-2">
                <h6 class="fw-semibold mb-0"><i class="fas fa-history text-primary me-2"></i>Son Dönüşümler</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0" style="font-size:12.5px;">
                        <thead style="background:#f8fafc;">
                            <tr>
                                <th class="ps-3">Tarih</th><th>Parti</th><th>Hedef YM</th>
                                <th>FSC</th><th class="text-end">Üretilen</th><th class="text-end pe-3">Kalan</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!recent.Any())
                        {
                            <tr><td colspan="6" class="text-center text-muted py-4">Henüz dönüşüm kaydı yok.</td></tr>
                        }
                        @foreach (var r in recent)
                        {
                            <tr>
                                <td class="ps-3">@r.Tarih.ToString("dd.MM.yyyy")</td>
                                <td><span class="badge bg-light text-dark">@r.Parti</span></td>
                                <td>@r.Hedef</td>
                                <td><span class="badge" style="background:#dcfce7;color:#166534;">@r.FscType</span></td>
                                <td class="text-end">@r.Kg.ToString("N2") kg</td>
                                <td class="text-end pe-3 fw-semibold">@r.Kalan.ToString("N2") kg</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('convDate').value = new Date().toISOString().slice(0,10);

function onSourceChange() {
    const opt = document.getElementById('sourceSerialId').selectedOptions[0];
    const info = document.getElementById('srcInfo');
    if (!opt || !opt.value) { info.style.display = 'none'; return; }
    document.getElementById('srcFsc').textContent   = opt.dataset.fsc || '—';
    document.getElementById('srcKalan').textContent = parseFloat(opt.dataset.kalan || 0).toLocaleString('tr-TR', {minimumFractionDigits:2});
    info.style.display = '';
}

// Tüketilen girilince üretilen 1:1 öner (fire varsa kullanıcı düşürür)
function onConsumedChange() {
    const c = parseFloat(document.getElementById('consumedKg').value) || 0;
    const p = document.getElementById('producedKg');
    if (!p.value || parseFloat(p.value) === 0) p.value = c > 0 ? c.toFixed(2) : '';
    calcFire();
}

function filterTarget() {
    const term = (document.getElementById('targetSearch').value || '').toLowerCase().trim();
    document.querySelectorAll('#targetProductId option').forEach(o => {
        o.style.display = (!term || (o.dataset.text || '').includes(term)) ? '' : 'none';
    });
}

function calcFire() {
    const c = parseFloat(document.getElementById('consumedKg').value) || 0;
    const p = parseFloat(document.getElementById('producedKg').value) || 0;
    const fire = Math.max(0, c - p);
    const pct  = c > 0 ? (fire / c * 100) : 0;
    document.getElementById('fireOut').textContent =
        `${fire.toLocaleString('tr-TR',{minimumFractionDigits:2})} kg · %${pct.toFixed(1)}`;
}

async function convertNow() {
    const sourceSerialId  = document.getElementById('sourceSerialId').value;
    const targetProductId = document.getElementById('targetProductId').value;
    const consumedKg      = parseFloat(document.getElementById('consumedKg').value) || 0;
    const producedKg      = parseFloat(document.getElementById('producedKg').value) || 0;

    if (!sourceSerialId)  { showToast('Kaynak bobin seçin.', 'warning'); return; }
    if (!targetProductId) { showToast('Hedef yarı mamül seçin.', 'warning'); return; }
    if (consumedKg <= 0 || producedKg <= 0) { showToast('Tüketilen ve üretilen miktar girin.', 'warning'); return; }
    if (producedKg > consumedKg) { showToast('Üretilen, tüketileni aşamaz.', 'warning'); return; }

    const tgtText = document.getElementById('targetProductId').selectedOptions[0].textContent.trim();
    if (!await appConfirm(`${consumedKg.toLocaleString('tr-TR')} kg ham → ${producedKg.toLocaleString('tr-TR')} kg "${tgtText}" üretilsin mi?\nFSC tipi kaynaktan devralınacak.`,
                          { title: 'Dönüşümü Onayla', icon: 'recycle', confirmText: 'Dönüştür' })) return;

    const fd = new FormData();
    fd.append('sourceSerialId',  sourceSerialId);
    fd.append('targetProductId', targetProductId);
    fd.append('producedKg',      producedKg);
    fd.append('consumedKg',      consumedKg);
    fd.append('date',            document.getElementById('convDate').value);
    fd.append('notes',           document.getElementById('convNotes').value);

    const res = await fetch('/Conversion/Convert', { method: 'POST', body: fd })
                    .then(r => r.json()).catch(() => ({ success: false, message: 'Sunucu hatası.' }));
    if (res.success) {
        showToast(res.message, 'success');
        setTimeout(() => location.reload(), 1000);
    } else {
        showToast(res.message, 'error');
    }
}
</script>
}
