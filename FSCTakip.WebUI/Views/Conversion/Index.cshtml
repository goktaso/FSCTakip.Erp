@using FSCTakip.WebUI.Controllers
@{
    ViewData["Title"] = "Yarı Mamül Dönüşüm";
    var sources = ViewBag.SourceSerials as List<ConvSourceVM> ?? new List<ConvSourceVM>();
    var targets = ViewBag.TargetProducts as List<ConvTargetVM> ?? new List<ConvTargetVM>();
    var recent  = ViewBag.Recent as List<ConvRecentVM> ?? new List<ConvRecentVM>();
}

@section TopbarActions {
    <a href="/Purchase/Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-scroll me-1"></i> Hammadde Girişi
    </a>
    <a href="/Stock/RawMaterial" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-warehouse me-1"></i> Stok
    </a>
}

<div class="row g-3">
    <!-- Dönüşüm formu -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-semibold mb-0"><i class="fas fa-recycle text-success me-2"></i>Ham / YM → Yarı Mamül Dönüşümü</h6>
                <div class="text-muted" style="font-size:12px;">1xxxx ham kağıt veya 24xxx YM bobinini 23xxx baskılı yarı mamüle çevirir.</div>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Kaynak Bobin (Ham / YM) <span class="text-danger">*</span></label>
                    <!-- MCD panel -->
                    <div class="mcd" id="mcd-src-bobin" data-placeholder="— Stoktaki bobin seçin —" style="width:100%;">
                        <button type="button" class="mcd-btn" onclick="mcdOpen('mcd-src-bobin')">
                            <span class="mcd-lbl">— Stoktaki bobin seçin —</span>
                            <i class="fas fa-angle-down mcd-arrow"></i>
                        </button>
                        <div class="mcd-panel" id="mcd-src-bobin-panel" style="display:none;width:100%;">
                            <div class="mcd-search-row">
                                <input type="text" class="mcd-search" placeholder="Dış kod, stok adı veya seri no ile filtrele..." oninput="mcdSearch(this)">
                            </div>
                            <div class="mcd-items" style="max-height:200px;">
                                @foreach (var s in sources)
                                {
                                    <label class="mcd-row" onclick="srcBobinSelect(@s.Id); return false;">
                                        @if (!string.IsNullOrEmpty(s.UrunIcKod)) { <span class="mcd-sub">@s.UrunIcKod</span> }
                                        @if (!string.IsNullOrEmpty(s.UrunKod))   { <span class="mcd-ext">@s.UrunKod</span> }
                                        <span class="mcd-name">@s.UrunAd · @s.SerialNo · kalan @s.CurrentWeight.ToString("N2") kg</span>
                                    </label>
                                }
                            </div>
                            <div class="mcd-empty" style="display:none;">Sonuç yok</div>
                        </div>
                    </div>
                    <!-- Gizli select — onSourceChange() için -->
                    <select id="sourceSerialId" style="display:none;" onchange="onSourceChange()">
                        <option value="">— Stoktaki bobin seçin —</option>
                        @foreach (var s in sources)
                        {
                            <option value="@s.Id"
                                    data-kalan="@s.CurrentWeight.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                    data-fsc="@s.FscType">
                                @s.UrunAd · @s.SerialNo
                            </option>
                        }
                    </select>
                    <div id="srcInfo" class="form-text" style="display:none;font-size:11.5px;">
                        <i class="fas fa-shield-alt text-success me-1"></i>FSC tipi <strong id="srcFsc"></strong> hedefe devredilecek (CoC). Kalan: <strong id="srcKalan"></strong> kg
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Hedef Yarı Mamül (BB) <span class="text-danger">*</span></label>
                    <!-- MCD panel -->
                    <div class="mcd" id="mcd-tgt-prod" data-placeholder="— Hedef seçin —" style="width:100%;">
                        <button type="button" class="mcd-btn" onclick="mcdOpen('mcd-tgt-prod')">
                            <span class="mcd-lbl">— Hedef seçin —</span>
                            <i class="fas fa-angle-down mcd-arrow"></i>
                        </button>
                        <div class="mcd-panel" id="mcd-tgt-prod-panel" style="display:none;width:100%;">
                            <div class="mcd-search-row">
                                <input type="text" class="mcd-search" placeholder="Kod / ad ile ara (örn: 23357)..." oninput="mcdSearch(this)">
                            </div>
                            <div class="mcd-items" style="max-height:200px;">
                                @foreach (var t in targets)
                                {
                                    <label class="mcd-row" onclick="tgtProdSelect(@t.Id, '@t.Ad.Replace("'", "\\'")', '@t.Kod'); return false;">
                                        <span class="mcd-sub">@t.Kod</span>
                                        @if (!string.IsNullOrEmpty(t.ExtKod)) { <span class="mcd-ext">@t.ExtKod</span> }
                                        <span class="mcd-name">@t.Ad</span>
                                    </label>
                                }
                            </div>
                            <div class="mcd-empty" style="display:none;">Sonuç yok</div>
                        </div>
                    </div>
                    <!-- Gizli select — convertNow() için -->
                    <select id="targetProductId" style="display:none;">
                        @foreach (var t in targets)
                        {
                            <option value="@t.Id">@t.Kod — @t.Ad</option>
                        }
                    </select>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Tüketilen Ham (kg) <span class="text-danger">*</span></label>
                        <input type="number" id="consumedKg" class="form-control" step="0.01" min="0" placeholder="0,00" oninput="onConsumedChange()">
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Üretilen YM (kg) <span class="text-danger">*</span></label>
                        <input type="number" id="producedKg" class="form-control" step="0.01" min="0" placeholder="0,00" oninput="calcFire()">
                        <div class="form-text" style="font-size:11px;">Genelde tüketilen ile aynı (1:1). Fire varsa azaltın.</div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3 p-2 rounded" style="background:#f8fafc;border:1px solid #e5e7eb;">
                    <span class="text-muted" style="font-size:12.5px;"><i class="fas fa-burn text-warning me-1"></i>Fire (otomatik)</span>
                    <span class="fw-semibold" id="fireOut" style="color:#92400e;">0,00 kg · %0</span>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Dönüşüm Tarihi</label>
                        <input type="date" id="convDate" class="form-control">
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Not</label>
                        <input type="text" id="convNotes" class="form-control" placeholder="Opsiyonel...">
                    </div>
                </div>

                <button class="btn btn-success w-100 py-2 fw-semibold" onclick="convertNow()">
                    <i class="fas fa-recycle me-1"></i> DÖNÜŞTÜR
                </button>
            </div>
        </div>
    </div>

    <!-- Son dönüşümler -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-white border-0 pt-3 pb-2">
                <h6 class="fw-semibold mb-0"><i class="fas fa-history text-primary me-2"></i>Son Dönüşümler</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0" style="font-size:12.5px;">
                        <thead style="background:#f8fafc;">
                            <tr>
                                <th class="ps-3">Tarih</th><th>Parti</th><th>Kaynak (Ham/YM)</th><th>Hedef YM</th>
                                <th>FSC</th><th class="text-end">Üretilen</th><th class="text-end">Fire</th><th class="text-end pe-3">Kalan</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!recent.Any())
                        {
                            <tr><td colspan="8" class="text-center text-muted py-4">Henüz dönüşüm kaydı yok.</td></tr>
                        }
                        @foreach (var r in recent)
                        {
                            <tr>
                                <td class="ps-3">@r.Tarih.ToString("dd.MM.yyyy")</td>
                                <td><span class="badge bg-light text-dark">@r.Parti</span></td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(r.KaynakKod))
                                    {
                                        <span class="badge" style="background:#eef2ff;color:#3730a3;font-weight:500;">@r.KaynakKod</span>
                                    }
                                    <span>@r.KaynakAd</span>
                                    <div class="text-muted" style="font-size:10.5px;">@r.KaynakSerial</div>
                                </td>
                                <td>@r.Hedef</td>
                                <td><span class="badge" style="background:#dcfce7;color:#166534;">@r.FscType</span></td>
                                <td class="text-end">@r.Kg.ToString("N2") kg</td>
                                <td class="text-end @(r.Fire > 0 ? "text-warning fw-semibold" : "text-muted")">@r.Fire.ToString("N2") kg</td>
                                <td class="text-end pe-3 fw-semibold">@r.Kalan.ToString("N2") kg</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
if(!window._mcdReady){window._mcdReady=true;
window.mcdOpen=function(id){var p=document.getElementById(id+'-panel');var o=p&&p.style.display!=='none';document.querySelectorAll('.mcd-panel').forEach(function(x){x.style.display='none'});if(!o&&p){p.style.display='flex';mcdUpdate(id)}};
window.mcdSearch=function(el){var t=el.value.toLowerCase();el.closest('.mcd-panel').querySelectorAll('.mcd-row:not(.mcd-header)').forEach(function(r){r.style.display=r.textContent.toLowerCase().includes(t)?'':'none'});var panel=el.closest('.mcd-panel');var items=panel.querySelectorAll('.mcd-items .mcd-row');var visible=Array.from(items).some(function(r){return r.style.display!=='none'});var empty=panel.querySelector('.mcd-empty');if(empty)empty.style.display=visible?'none':'block'};
window.mcdToggleAll=function(cb,id){document.getElementById(id+'-panel').querySelectorAll('.mcd-row:not(.mcd-header)').forEach(function(r){if(r.style.display!=='none'){var c=r.querySelector('.mcd-cb');if(c)c.checked=cb.checked}});mcdUpdate(id)};
window.mcdUpdate=function(id){var p=document.getElementById(id+'-panel');var c=document.getElementById(id);if(!p||!c)return;var n=p.querySelectorAll('.mcd-cb:checked').length;var l=c.querySelector('.mcd-lbl');if(l)l.textContent=n===0?(c.dataset.placeholder||'— Seçiniz —'):n+' seçildi';var a=p.querySelector('.mcd-all-cb');var v=p.querySelectorAll('.mcd-row:not(.mcd-header):not([style*="none"]) .mcd-cb').length;if(a&&v>0)a.checked=(n>=v)};
document.addEventListener('mousedown',function(e){if(!e.target.closest('.mcd'))document.querySelectorAll('.mcd-panel').forEach(function(p){p.style.display='none'})});}
</script>
<style>
.mcd{position:relative}.mcd-btn{width:100%;text-align:left;display:flex;justify-content:space-between;align-items:center;cursor:pointer;background:#fff;border:1px solid #d1d5db;color:#111;padding:5px 10px;border-radius:6px;font-size:13px}.mcd-btn:hover{border-color:#1976d2}.mcd-panel{position:absolute;top:calc(100% + 4px);left:0;min-width:300px;width:100%;background:#fff;border:1px solid #d1d5db;border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:1050;display:flex;flex-direction:column;overflow:hidden}.mcd-search-row{padding:8px 10px;border-bottom:1px solid #f1f5f9}.mcd-search{width:100%;border:1px solid #e5e7eb;border-radius:6px;padding:5px 10px;font-size:12.5px;outline:none}.mcd-items{overflow-y:auto}.mcd-row{display:flex;align-items:center;gap:8px;padding:6px 12px;cursor:pointer;font-size:12.5px;user-select:none}.mcd-row:hover{background:#eff6ff}.mcd-name{flex:1;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.mcd-sub{font-size:10.5px;color:#374151;background:#f3f4f6;padding:1px 5px;border-radius:4px;white-space:nowrap}.mcd-ext{font-size:10.5px;color:#3730a3;background:#eef2ff;padding:1px 5px;border-radius:4px;white-space:nowrap}.mcd-arrow{color:#6b7280;font-size:11px}.mcd-empty{padding:8px 12px;font-size:12px;color:#9ca3af;text-align:center}
</style>
<script>
document.getElementById('convDate').value = new Date().toISOString().slice(0,10);

function srcBobinSelect(id) {
    var sel = document.getElementById('sourceSerialId');
    if (!sel) return;
    sel.value = id;
    var evt = new Event('change');
    sel.dispatchEvent(evt);
    var opt = sel.querySelector('option[value="'+id+'"]');
    var lbl = document.querySelector('#mcd-src-bobin .mcd-lbl');
    if (lbl && opt) {
        var txt = opt.textContent.trim();
        lbl.textContent = txt.length > 60 ? txt.substring(0, 60) + '…' : txt;
    }
    document.querySelectorAll('.mcd-panel').forEach(function(p){ p.style.display='none'; });
}

function tgtProdSelect(id, name, kod) {
    var sel = document.getElementById('targetProductId');
    if (sel) sel.value = id;
    var lbl = document.querySelector('#mcd-tgt-prod .mcd-lbl');
    if (lbl) lbl.textContent = kod + ' — ' + name;
    document.querySelectorAll('.mcd-panel').forEach(function(p){ p.style.display='none'; });
}

function filterSource() { /* MCD kendi aramasını yapıyor — eski fonksiyon korunuyor */ }
function filterTarget() { /* MCD kendi aramasını yapıyor — eski fonksiyon korunuyor */ }

function onSourceChange() {
    const opt = document.getElementById('sourceSerialId').selectedOptions[0];
    const info = document.getElementById('srcInfo');
    if (!opt || !opt.value) { info.style.display = 'none'; return; }
    document.getElementById('srcFsc').textContent   = opt.dataset.fsc || '—';
    document.getElementById('srcKalan').textContent = parseFloat(opt.dataset.kalan || 0).toLocaleString('tr-TR', {minimumFractionDigits:2});
    info.style.display = '';
}

// Tüketilen girilince üretilen 1:1 öner (fire varsa kullanıcı düşürür)
function onConsumedChange() {
    const c = parseFloat(document.getElementById('consumedKg').value) || 0;
    const p = document.getElementById('producedKg');
    if (!p.value || parseFloat(p.value) === 0) p.value = c > 0 ? c.toFixed(2) : '';
    calcFire();
}

function filterTarget() {
    const term = (document.getElementById('targetSearch').value || '').toLowerCase().trim();
    document.querySelectorAll('#targetProductId option').forEach(o => {
        o.style.display = (!term || (o.dataset.text || '').includes(term)) ? '' : 'none';
    });
}

function calcFire() {
    const c = parseFloat(document.getElementById('consumedKg').value) || 0;
    const p = parseFloat(document.getElementById('producedKg').value) || 0;
    const fire = Math.max(0, c - p);
    const pct  = c > 0 ? (fire / c * 100) : 0;
    document.getElementById('fireOut').textContent =
        `${fire.toLocaleString('tr-TR',{minimumFractionDigits:2})} kg · %${pct.toFixed(1)}`;
}

async function convertNow() {
    const sourceSerialId  = document.getElementById('sourceSerialId').value;
    const targetProductId = document.getElementById('targetProductId').value;
    const consumedKg      = parseFloat(document.getElementById('consumedKg').value) || 0;
    const producedKg      = parseFloat(document.getElementById('producedKg').value) || 0;

    if (!sourceSerialId)  { showToast('Kaynak bobin seçin.', 'warning'); return; }
    if (!targetProductId) { showToast('Hedef yarı mamül seçin.', 'warning'); return; }
    if (consumedKg <= 0 || producedKg <= 0) { showToast('Tüketilen ve üretilen miktar girin.', 'warning'); return; }
    if (producedKg > consumedKg) { showToast('Üretilen, tüketileni aşamaz.', 'warning'); return; }

    const tgtText = document.getElementById('targetProductId').selectedOptions[0].textContent.trim();
    if (!await appConfirm(`${consumedKg.toLocaleString('tr-TR')} kg ham → ${producedKg.toLocaleString('tr-TR')} kg "${tgtText}" üretilsin mi?\nFSC tipi kaynaktan devralınacak.`,
                          { title: 'Dönüşümü Onayla', icon: 'recycle', confirmText: 'Dönüştür' })) return;

    const fd = new FormData();
    fd.append('sourceSerialId',  sourceSerialId);
    fd.append('targetProductId', targetProductId);
    fd.append('producedKg',      producedKg);
    fd.append('consumedKg',      consumedKg);
    fd.append('date',            document.getElementById('convDate').value);
    fd.append('notes',           document.getElementById('convNotes').value);

    const res = await fetch('/Conversion/Convert', { method: 'POST', body: fd })
                    .then(r => r.json()).catch(() => ({ success: false, message: 'Sunucu hatası.' }));
    if (res.success) {
        showToast(res.message, 'success');
        setTimeout(() => location.reload(), 1000);
    } else {
        showToast(res.message, 'error');
    }
}
</script>
}
