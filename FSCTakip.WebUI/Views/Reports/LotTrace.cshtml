@model FSCTakip.WebUI.Controllers.LotTraceResult?
@using FSCTakip.Core.Entities
@{
    ViewData["Title"] = "Lot Kullanım Raporu";
    var lots      = ViewBag.Lots      as List<FscLot>                           ?? new();
    var suppliers = ViewBag.Suppliers as List<FSCTakip.Core.Entities.Supplier>  ?? new();
    var fscTypes  = ViewBag.FscTypes  as List<FSCTakip.Core.Entities.FscType>   ?? new();
    int? lotId          = ViewBag.LotId       as int?;
    int? filtSupp       = ViewBag.SupplierId  as int?;
    int? filtFsc        = ViewBag.FscTypeId   as int?;
    string? filtStart   = ViewBag.StartDate   as string;
    string? filtEnd     = ViewBag.EndDate     as string;
    string? filtPCode   = ViewBag.ProductCode as string;
    string? filtExtCode = ViewBag.ExternalCode as string;
    string? filtPName   = ViewBag.ProductName as string;
    var prodIds     = ViewBag.ProductIds  as int[] ?? Array.Empty<int>();
    var allProducts = ViewBag.AllProducts as List<FSCTakip.Core.Entities.Product> ?? new();
}

@section TopbarActions {
    @if (Model != null)
    {
        <a href="/Reports/ExportLotTrace?lotId=@Model.Lot.Id" class="btn btn-outline-success btn-sm">
            <i class="fas fa-file-excel me-1"></i> Excel
        </a>
    }
}

<!-- Arama / Seçim -->
<div class="filter-card mb-3">
    <form method="get" action="/Reports/LotTrace" class="d-flex align-items-center gap-2 flex-wrap">
        <!-- Ek filtreler: dropdown listesini daraltır -->
        <select name="supplierId" class="form-select form-select-sm" style="max-width:200px;" onchange="this.form.submit()">
            <option value="">— Tüm Tedarikçiler —</option>
            @foreach (var s in suppliers)
            {
                <option value="@s.Id" selected="@(filtSupp == s.Id ? "selected" : null)">@s.Name</option>
            }
        </select>
        <select name="fscTypeId" class="form-select form-select-sm" style="max-width:160px;" onchange="this.form.submit()">
            <option value="">— FSC Tipi —</option>
            @foreach (var f in fscTypes)
            {
                <option value="@f.Id" selected="@(filtFsc == f.Id ? "selected" : null)">@f.Name</option>
            }
        </select>
        <input type="date" name="startDate" class="form-control form-control-sm" style="max-width:140px;"
               value="@(filtStart ?? "")" title="Başlangıç tarihi" onchange="this.form.submit()">
        <input type="date" name="endDate" class="form-control form-control-sm" style="max-width:140px;"
               value="@(filtEnd ?? "")" title="Bitiş tarihi" onchange="this.form.submit()">
        <!-- Ürün MCD -->
        <div class="mcd" id="mcd-lot-prod" data-placeholder="— Ürün/Stok —" style="min-width:240px;">
            <button type="button" class="mcd-btn" onclick="mcdOpen('mcd-lot-prod')">
                <span class="mcd-lbl">@(prodIds.Length > 0 ? prodIds.Length + " ürün seçildi" : "— Ürün/Stok —")</span>
                <i class="fas fa-angle-down mcd-arrow"></i>
            </button>
            <div class="mcd-panel" id="mcd-lot-prod-panel" style="display:none;">
                <div class="mcd-search-row">
                    <input type="text" class="mcd-search" placeholder="Kod veya ad ara..." oninput="mcdSearch(this)">
                </div>
                <label class="mcd-row mcd-header">
                    <input type="checkbox" class="mcd-all-cb" onchange="mcdToggleAll(this,'mcd-lot-prod')">
                    <span>Tümünü Seç / Temizle</span>
                </label>
                <div class="mcd-items">
                    @foreach (var p in allProducts)
                    {
                        bool sel = prodIds.Contains(p.Id);
                        <label class="mcd-row">
                            <input type="checkbox" name="productIds" value="@p.Id" class="mcd-cb"
                                   onchange="mcdUpdate('mcd-lot-prod')"
                                   @(sel ? "checked" : "")>
                            <span class="mcd-name" title="@p.ProductName">@p.ProductName</span>
                            @if (!string.IsNullOrEmpty(p.ProductCode))
                            { <span class="mcd-sub">@p.ProductCode</span> }
                            @if (!string.IsNullOrEmpty(p.ExternalCode))
                            { <span class="mcd-ext">@p.ExternalCode</span> }
                        </label>
                    }
                </div>
            </div>
        </div>
        <input name="productCode" class="form-control form-control-sm" style="max-width:120px;"
               placeholder="Stok kodu" value="@(filtPCode ?? "")" title="Stok kodu filtrele">
        <input name="externalCode" class="form-control form-control-sm" style="max-width:120px;"
               placeholder="Dış stok kodu" value="@(filtExtCode ?? "")" title="Dış stok kodu filtrele">
        <input name="productName" class="form-control form-control-sm" style="max-width:160px;"
               placeholder="Stok adı ara" value="@(filtPName ?? "")" title="Stok adına göre filtrele">

        <input type="text" id="lotSearch" class="form-control form-control-sm" style="max-width:200px;"
               placeholder="Parti no ara..." oninput="filterLots()" title="Lot listesini anlık filtrele (form göndermez)">

        <select name="lotId" class="form-select form-select-sm" style="max-width:380px;" onchange="this.form.submit()">
            <option value="">— Parti seçiniz —</option>
            @foreach (var l in lots)
            {
                bool sel = lotId == l.Id;
                <option value="@l.Id" selected="@(sel ? "selected" : null)">
                    @l.PartiNo — @(l.Supplier?.Name ?? "") (@l.ArrivalDate.ToString("dd.MM.yyyy"))
                </option>
            }
        </select>
        <span class="text-muted small">veya</span>
        <input name="search" class="form-control form-control-sm" style="max-width:200px;"
               placeholder="Parti / fatura no ara" value="@(ViewBag.Search ?? "")">
        <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search me-1"></i>Ara</button>
        @if (Model != null || filtSupp.HasValue || filtFsc.HasValue || !string.IsNullOrEmpty(filtStart) || !string.IsNullOrEmpty(filtPCode) || !string.IsNullOrEmpty(filtExtCode) || !string.IsNullOrEmpty(filtPName) || prodIds.Length > 0)
        {
            <a href="/Reports/LotTrace" class="btn btn-outline-secondary btn-sm">Temizle</a>
        }
    </form>
</div>

@if (Model == null)
{
    <div class="table-card text-center py-5 text-muted">
        <i class="fas fa-boxes fa-3x mb-3 d-block" style="color:#d1d5db;"></i>
        <p class="mb-0">Yukarıdan bir parti seçin ya da parti/fatura numarasıyla arama yapın.</p>
        <p class="small mt-1">Seçilen partiye ait tüm seri (bobin) kullanımlarını, üretilen mamulleri ve tüketilen KG miktarlarını görüntüleyebilirsiniz.</p>
    </div>
}
else
{
    var lot = Model.Lot;
    var culture = new System.Globalization.CultureInfo("tr-TR");

    <!-- ── Özet Kartlar ──────────────────────────────────────────────── -->
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="table-card p-3 text-center">
                <div style="font-size:22px;font-weight:700;color:#1d4ed8;">@Model.Serials.Count</div>
                <div class="text-muted small">Seri / Bobin</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="table-card p-3 text-center">
                <div style="font-size:22px;font-weight:700;color:#d97706;">@Model.TotalWorkOrders</div>
                <div class="text-muted small">İş Emri</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="table-card p-3 text-center">
                <div style="font-size:22px;font-weight:700;color:#16a34a;">@Model.TotalConsumedKg.ToString("N1", culture)</div>
                <div class="text-muted small">Tüketilen (kg)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="table-card p-3 text-center">
                <div style="font-size:22px;font-weight:700;color:#dc2626;">@Model.TotalWasteKg.ToString("N1", culture)</div>
                <div class="text-muted small">Fire (kg)</div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <!-- Parti Bilgileri -->
        <div class="col-md-5">
            <div class="table-card h-100">
                <div class="p-3 border-bottom d-flex align-items-center gap-2">
                    <span style="width:28px;height:28px;border-radius:8px;background:#dbeafe;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="fas fa-layer-group" style="color:#1d4ed8;font-size:13px;"></i>
                    </span>
                    <strong style="font-size:14px;">Parti Bilgileri</strong>
                </div>
                <table class="table table-sm mb-0">
                    <tr><td class="text-muted small ps-3" style="width:45%">Parti No</td>
                        <td class="fw-bold">@lot.PartiNo</td></tr>
                    <tr><td class="text-muted small ps-3">Geliş Tarihi</td>
                        <td>@lot.ArrivalDate.ToString("dd.MM.yyyy")</td></tr>
                    <tr><td class="text-muted small ps-3">Tedarikçi</td>
                        <td>@(lot.Supplier?.Name ?? "—")</td></tr>
                    <tr><td class="text-muted small ps-3">Tedarikçi FSC</td>
                        <td>
                        @if (!string.IsNullOrEmpty(lot.Supplier?.FscCode))
                        { <span class="badge badge-success">@lot.Supplier.FscCode</span> }
                        else { <span class="text-muted">—</span> }
                        </td></tr>
                    <tr><td class="text-muted small ps-3">FSC Tipi</td>
                        <td>
                        @if (lot.FscType != null)
                        { <span class="badge badge-primary">@lot.FscType.Name</span> }
                        </td></tr>
                    <tr><td class="text-muted small ps-3">Hammadde</td>
                        <td class="small">@(lot.Product?.ProductName ?? "—")</td></tr>
                    <tr><td class="text-muted small ps-3">Fatura No</td>
                        <td class="small">
                        @if (!string.IsNullOrEmpty(lot.InvoiceNo) && !string.IsNullOrEmpty(lot.InvoicePdfPath))
                        {
                            <button class="doc-num-btn" onclick="showPdf('/@lot.InvoicePdfPath','Fatura — @lot.InvoiceNo')">
                                <i class="fas fa-file-pdf me-1" style="color:#dc2626;font-size:11px;"></i>@lot.InvoiceNo
                            </button>
                        }
                        else { <span>@(lot.InvoiceNo ?? "—")</span> }
                        </td></tr>
                    <tr><td class="text-muted small ps-3">İrsaliye No</td>
                        <td class="small">
                        @if (!string.IsNullOrEmpty(lot.DispatchNo) && !string.IsNullOrEmpty(lot.DispatchPdfPath))
                        {
                            <button class="doc-num-btn" onclick="showPdf('/@lot.DispatchPdfPath','İrsaliye — @lot.DispatchNo')">
                                <i class="fas fa-file-pdf me-1" style="color:#dc2626;font-size:11px;"></i>@lot.DispatchNo
                            </button>
                        }
                        else { <span>@(lot.DispatchNo ?? "—")</span> }
                        </td></tr>
                </table>
            </div>
        </div>

        <!-- FSC Zinciri Özeti -->
        <div class="col-md-7">
            <div class="table-card h-100">
                <div class="p-3 border-bottom d-flex align-items-center gap-2">
                    <span style="width:28px;height:28px;border-radius:8px;background:#dcfce7;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="fas fa-sitemap" style="color:#16a34a;font-size:13px;"></i>
                    </span>
                    <strong style="font-size:14px;">FSC İzlenebilirlik Zinciri</strong>
                </div>
                <div class="p-3">
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex align-items-center gap-2 p-2 rounded" style="background:#f0fdf4;border:1px solid #bbf7d0;">
                            <span class="badge badge-success">1</span>
                            <div class="small">
                                <strong>Tedarikçi:</strong> @(lot.Supplier?.Name ?? "—")
                                @if (!string.IsNullOrEmpty(lot.Supplier?.FscCode))
                                { <span class="badge badge-success ms-1" style="font-size:10px;">@lot.Supplier.FscCode</span> }
                            </div>
                        </div>
                        <div class="text-center text-muted" style="font-size:18px;">↓</div>
                        <div class="d-flex align-items-center gap-2 p-2 rounded" style="background:#eff6ff;border:1px solid #bfdbfe;">
                            <span class="badge badge-primary">2</span>
                            <span class="small"><strong>Parti:</strong> @lot.PartiNo &nbsp;·&nbsp; <strong>@Model.Serials.Count</strong> seri (bobin)
                                &nbsp;·&nbsp; <strong>@Model.Serials.Sum(s => s.InitialWeight).ToString("N1", culture) kg</strong> başlangıç</span>
                        </div>
                        <div class="text-center text-muted" style="font-size:18px;">↓</div>
                        <div class="d-flex align-items-center gap-2 p-2 rounded" style="background:#fefce8;border:1px solid #fde68a;">
                            <span class="badge badge-warning">3</span>
                            <span class="small"><strong>Üretim:</strong>
                                <strong>@Model.TotalWorkOrders</strong> iş emri &nbsp;·&nbsp;
                                <strong>@Model.TotalConsumedKg.ToString("N1", culture) kg</strong> tüketim &nbsp;·&nbsp;
                                <strong>@Model.TotalWasteKg.ToString("N1", culture) kg</strong> fire</span>
                        </div>
                        <div class="text-center text-muted" style="font-size:18px;">↓</div>
                        <div class="d-flex align-items-center gap-2 p-2 rounded" style="background:#fdf4ff;border:1px solid #e9d5ff;">
                            <span class="badge" style="background:#7c3aed;color:#fff;">4</span>
                            <span class="small"><strong>Satış:</strong>
                                @Model.SalesLines.Count kalem &nbsp;·&nbsp;
                                @Model.SalesLines.Select(l => l.SalesOrderId).Distinct().Count() sipariş</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Üretim Kullanım Detayı ──────────────────────────────────────── -->
    <div class="table-card mb-3">
        <div class="p-3 border-bottom d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <span style="width:28px;height:28px;border-radius:8px;background:#fef3c7;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="fas fa-industry" style="color:#d97706;font-size:13px;"></i>
                </span>
                <strong style="font-size:14px;">Üretim Kullanım Detayı</strong>
                <span class="badge badge-warning ms-1">@Model.ProductionRows.Count kayıt</span>
            </div>
            <span class="text-muted small">Bu partiden hangi mamul üretildi, ne kadar kağıt tüketildi</span>
        </div>
        @if (!Model.ProductionRows.Any())
        {
            <div class="text-center text-muted py-4 small">Bu parti henüz hiçbir üretimde kullanılmamış.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>TARİH</th>
                            <th>İŞ EMRİ</th>
                            <th>MAMUL</th>
                            <th>MAKİNE</th>
                            <th>KULLANILAN SERİ</th>
                            <th class="text-end">TÜKETİM (kg)</th>
                            <th class="text-end">FİRE (kg)</th>
                            <th class="text-end">FİRE %</th>
                            <th class="text-end">ÜRETİLEN (adet)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            decimal grandConsumed = 0;
                            decimal grandWaste    = 0;
                            decimal grandProduced = 0;
                        }
                        @foreach (var row in Model.ProductionRows)
                        {
                            grandConsumed += row.ConsumedKg;
                            grandWaste    += row.WasteKg;
                            grandProduced += row.ProducedQty;
                            <tr>
                                <td class="text-muted small">@row.ProductionDate.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <a href="/Production/Detail/@row.WorkOrderId" class="fw-semibold small text-primary">
                                        @row.WorkOrderNo
                                    </a>
                                </td>
                                <td class="small">
                                    <div class="fw-semibold">@row.ProductName</div>
                                    @if (!string.IsNullOrEmpty(row.ProductCode))
                                    { <div class="text-muted" style="font-size:11px;">@row.ProductCode</div> }
                                </td>
                                <td class="text-muted small">@row.MachineName</td>
                                <td class="small text-muted" style="font-size:11px;">@row.SerialNos</td>
                                <td class="text-end fw-semibold small">@row.ConsumedKg.ToString("N2", culture)</td>
                                <td class="text-end small text-danger">@row.WasteKg.ToString("N2", culture)</td>
                                <td class="text-end small">
                                    @{
                                        var fr = row.FireRate;
                                        var frColor = fr >= 5 ? "#dc2626" : fr >= 2 ? "#d97706" : "#16a34a";
                                    }
                                    <span style="color:@frColor;font-weight:600;">%@fr.ToString("N1", culture)</span>
                                </td>
                                <td class="text-end small">
                                    @if (row.ProducedQty > 0)
                                    { <span class="fw-semibold">@row.ProducedQty.ToString("N0", culture)</span> }
                                    else
                                    { <span class="text-muted">—</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr style="background:#f8fafc;font-weight:600;border-top:2px solid #e2e8f0;">
                            <td colspan="5" class="small ps-3 text-muted">TOPLAM</td>
                            <td class="text-end small">@grandConsumed.ToString("N2", culture)</td>
                            <td class="text-end small text-danger">@grandWaste.ToString("N2", culture)</td>
                            <td class="text-end small">
                                @{
                                    var totalFr = grandConsumed > 0 ? grandWaste / grandConsumed * 100 : 0;
                                    var totalFrColor = totalFr >= 5 ? "#dc2626" : totalFr >= 2 ? "#d97706" : "#16a34a";
                                }
                                <span style="color:@totalFrColor;">%@totalFr.ToString("N1", culture)</span>
                            </td>
                            <td class="text-end small">@grandProduced.ToString("N0", culture)</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>

    <!-- ── Seri (Bobin) Listesi ───────────────────────────────────────── -->
    <div class="table-card mb-3">
        <div class="p-3 border-bottom d-flex align-items-center gap-2">
            <span style="width:28px;height:28px;border-radius:8px;background:#eff6ff;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="fas fa-barcode" style="color:#1d4ed8;font-size:13px;"></i>
            </span>
            <strong style="font-size:14px;">Seri (Bobin) Listesi</strong>
            <span class="badge badge-blue ms-1">@Model.Serials.Count adet</span>
        </div>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>SERİ NO</th>
                        <th class="text-end">BAŞLANGIÇ (kg)</th>
                        <th class="text-end">KALAN (kg)</th>
                        <th class="text-end">TÜKETİLEN (kg)</th>
                        <th>KULLANILDIĞI İŞ EMİRLERİ</th>
                        <th class="text-center">DURUM</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Serials)
                    {
                        var consumed = s.InitialWeight - s.CurrentWeight;
                        var pct      = s.InitialWeight > 0 ? (int)(consumed * 100 / s.InitialWeight) : 0;
                        var wos      = s.ProductionDetails.Select(pd => pd.WorkOrder?.WorkOrderNo).Where(n => n != null).Distinct().ToList();
                        <tr>
                            <td class="fw-semibold small">@s.SerialNo</td>
                            <td class="text-end small">@s.InitialWeight.ToString("N1", culture)</td>
                            <td class="text-end small @(s.CurrentWeight <= 0 ? "text-muted" : "")">@s.CurrentWeight.ToString("N1", culture)</td>
                            <td class="text-end small text-danger">@consumed.ToString("N1", culture)</td>
                            <td class="small">
                                @foreach (var wo in wos)
                                { <span class="badge badge-primary me-1" style="font-size:10px;">@wo</span> }
                                @if (!wos.Any()) { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-center">
                                @if (s.CurrentWeight <= 0)
                                { <span class="badge badge-secondary">Tükendi</span> }
                                else if (pct >= 80)
                                { <span class="badge badge-warning">Azalıyor (%@pct)</span> }
                                else
                                { <span class="badge badge-success">Devam (%@pct)</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── İlgili Satışlar ───────────────────────────────────────────── -->
    @if (Model.SalesLines.Any())
    {
        <div class="table-card">
            <div class="p-3 border-bottom d-flex align-items-center gap-2">
                <span style="width:28px;height:28px;border-radius:8px;background:#dcfce7;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="fas fa-truck" style="color:#16a34a;font-size:13px;"></i>
                </span>
                <strong style="font-size:14px;">Bu Partiden Üretilip Satılan Ürünler</strong>
                <span class="badge badge-success ms-1">@Model.SalesLines.Count kalem</span>
            </div>
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>SİPARİŞ NO</th>
                            <th>MÜŞTERİ</th>
                            <th>ÜRÜN</th>
                            <th>İŞ EMRİ</th>
                            <th class="text-end">MİKTAR</th>
                            <th>SEVKİYAT</th>
                            <th class="text-center">DURUM</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sl in Model.SalesLines)
                        {
                            <tr>
                                <td class="fw-semibold small">
                                    <a href="/Sales/Detail/@sl.SalesOrderId" class="text-primary">@sl.SalesOrder.SalesOrderNo</a>
                                </td>
                                <td class="small">@(sl.SalesOrder.Customer?.Name ?? "—")</td>
                                <td class="small fw-semibold">@(sl.Product?.ProductName ?? "—")</td>
                                <td class="small">
                                    @if (sl.WorkOrderId.HasValue)
                                    { <a href="/Production/Detail/@sl.WorkOrderId" class="text-muted">@sl.WorkOrder?.WorkOrderNo</a> }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td class="text-end small">@sl.Quantity.ToString("N0", culture) @sl.Unit</td>
                                <td class="text-muted small">@(sl.SalesOrder.DispatchDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                                <td class="text-center">
                                    @if (sl.SalesOrder.Status == SalesOrderStatus.TeslimEdildi)
                                    { <span class="badge badge-success">Teslim Edildi</span> }
                                    else
                                    { <span class="badge badge-warning">Taslak</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="table-card text-center py-3 text-muted small">
            <i class="fas fa-info-circle me-1"></i>Bu partiden üretilen ürünler henüz satışa bağlanmamış.
        </div>
    }
}

<style>
.mcd { position: relative; }
.mcd-btn { width:100%; text-align:left; display:flex; justify-content:space-between; align-items:center; cursor:pointer; background:#fff; border:1px solid #d1d5db; color:#111; padding:5px 10px; border-radius:6px; font-size:13px; }
.mcd-btn:hover { border-color:#1976d2; }
.mcd-panel { position:absolute; top:calc(100% + 4px); left:0; min-width:280px; max-width:380px; background:#fff; border:1px solid #d1d5db; border-radius:8px; box-shadow:0 8px 24px rgba(0,0,0,.12); z-index:1050; display:flex; flex-direction:column; overflow:hidden; }
.mcd-search-row { padding:8px 10px; border-bottom:1px solid #f1f5f9; }
.mcd-search { width:100%; border:1px solid #e5e7eb; border-radius:6px; padding:5px 10px; font-size:12.5px; outline:none; }
.mcd-header { background:#f8fafc; border-bottom:1px solid #e5e7eb; font-weight:600; font-size:12.5px; color:#374151; }
.mcd-items { overflow-y:auto; max-height:260px; }
.mcd-row { display:flex; align-items:center; gap:8px; padding:6px 12px; cursor:pointer; font-size:12.5px; user-select:none; }
.mcd-row:hover { background:#eff6ff; }
.mcd-cb, .mcd-all-cb { cursor:pointer; accent-color:#1976d2; min-width:15px; height:15px; }
.mcd-name { flex:1; color:#111827; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:200px; }
.mcd-sub { font-size:10.5px; color:#374151; background:#f3f4f6; padding:1px 5px; border-radius:4px; }
.mcd-ext { font-size:10.5px; color:#3730a3; background:#eef2ff; padding:1px 5px; border-radius:4px; }
.mcd-arrow { color:#6b7280; font-size:11px; }
</style>

@section Scripts {
<script>
function filterLots() {
    var term = (document.getElementById('lotSearch')?.value || '').toLowerCase().trim();
    document.querySelectorAll('select[name="lotId"] option').forEach(function(o) {
        if (!o.value) return; // placeholder'ı her zaman göster
        o.style.display = (!term || o.textContent.toLowerCase().includes(term)) ? '' : 'none';
    });
}

(function(){
    window.mcdOpen = function(id) {
        var panel = document.getElementById(id+'-panel');
        var isOpen = panel && panel.style.display !== 'none';
        document.querySelectorAll('.mcd-panel').forEach(function(p){ p.style.display='none'; });
        if (!isOpen && panel) { panel.style.display='flex'; mcdUpdate(id); }
    };
    window.mcdSearch = function(input) {
        var term = input.value.toLowerCase();
        input.closest('.mcd-panel').querySelectorAll('.mcd-row:not(.mcd-header)').forEach(function(row){
            row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
        });
    };
    window.mcdToggleAll = function(cb, id) {
        document.getElementById(id+'-panel').querySelectorAll('.mcd-row:not(.mcd-header)').forEach(function(row){
            if (row.style.display !== 'none') { var c = row.querySelector('.mcd-cb'); if(c) c.checked = cb.checked; }
        });
        mcdUpdate(id);
    };
    window.mcdUpdate = function(id) {
        var panel = document.getElementById(id+'-panel');
        var container = document.getElementById(id);
        if (!panel || !container) return;
        var checked = panel.querySelectorAll('.mcd-cb:checked').length;
        var lbl = container.querySelector('.mcd-lbl');
        if (lbl) lbl.textContent = checked === 0 ? (container.dataset.placeholder||'— Seçiniz —') : checked + ' ürün seçildi';
        var allCb = panel.querySelector('.mcd-all-cb');
        var visible = panel.querySelectorAll('.mcd-row:not(.mcd-header):not([style*="none"]) .mcd-cb').length;
        if (allCb && visible > 0) allCb.checked = (checked >= visible);
    };
    if (!window._mcdClickBound) {
        document.addEventListener('mousedown', function(e){
            if (!e.target.closest('.mcd')) document.querySelectorAll('.mcd-panel').forEach(function(p){ p.style.display='none'; });
        });
        window._mcdClickBound = true;
    }
})();
</script>
}
