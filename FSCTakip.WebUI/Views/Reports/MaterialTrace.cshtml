@model FSCTakip.WebUI.Controllers.MaterialTraceModel
@using FSCTakip.Core.Entities
@{
    ViewData["Title"] = ViewData["Title"]?.ToString() ?? "Materyal İzleme";
    var culture     = new System.Globalization.CultureInfo("tr-TR");
    var hammaddeler = ViewBag.Hammaddeler as List<FSCTakip.Core.Entities.Product> ?? new();
    var mamuller    = ViewBag.Mamuller    as List<FSCTakip.Core.Entities.Product> ?? new();
    var suppliers   = ViewBag.Suppliers   as List<FSCTakip.Core.Entities.Supplier> ?? new();
    var fscTypes    = ViewBag.FscTypes    as List<FSCTakip.Core.Entities.FscType>  ?? new();
    string mode         = ViewBag.Mode         as string ?? "hammadde";
    var hammaddeIds     = ViewBag.HammaddeIds  as int[] ?? Array.Empty<int>();
    int? mamulId        = ViewBag.MamulId      as int?;
    string? partiNo = ViewBag.PartiNo     as string;
    string? seriNo  = ViewBag.SerialNo    as string;
    string startDate = ViewBag.StartDate  as string ?? DateTime.Today.ToString("yyyy-01-01");
    string endDate   = ViewBag.EndDate    as string ?? DateTime.Today.ToString("yyyy-MM-dd");
    string? stockSearch = ViewBag.StockSearch as string;
    var supplierIds = ViewBag.SupplierIds as int[] ?? Array.Empty<int>();
    var fscTypeIds  = ViewBag.FscTypeIds  as int[] ?? Array.Empty<int>();
    bool hasRows    = Model?.Rows.Count > 0;
    bool hasHammaddeFilter = hammaddeIds.Length > 0;
}

@section TopbarActions {
    @if (hasRows)
    {
        <a href="/Reports/ExportMaterialTrace?mode=@mode@(string.Join("", hammaddeIds.Select(id => "&hammaddeIds=" + id)))&mamulId=@mamulId&partiNo=@partiNo&serialNo=@seriNo&startDate=@startDate&endDate=@endDate"
           class="btn btn-outline-success btn-sm">
            <i class="fas fa-file-excel me-1"></i> Excel
        </a>
    }
}

<!-- ── Filtre Kartı ──────────────────────────────────────────────────────────── -->
<div class="filter-card mb-3">

    <!-- Mod Sekmeleri -->
    <div class="d-flex gap-1 mb-3 p-1 rounded" style="background:#f1f5f9;width:fit-content;">
        <a href="/Reports/MaterialTrace?mode=hammadde&startDate=@startDate&endDate=@endDate"
           class="btn btn-sm @(mode=="hammadde"?"btn-primary":"btn-outline-secondary")">
            <i class="fas fa-boxes me-1"></i> Hammadde Bazlı
        </a>
        <a href="/Reports/MaterialTrace?mode=mamul&startDate=@startDate&endDate=@endDate"
           class="btn btn-sm @(mode=="mamul"?"btn-primary":"btn-outline-secondary")">
            <i class="fas fa-box me-1"></i> Mamul Bazlı
        </a>
        <a href="/Reports/MaterialTrace?mode=parti&startDate=@startDate&endDate=@endDate"
           class="btn btn-sm @(mode=="parti"?"btn-primary":"btn-outline-secondary")">
            <i class="fas fa-layer-group me-1"></i> Parti / Lot Bazlı
        </a>
    </div>

    <!-- Filtre Formu -->
    <form method="get" action="/Reports/MaterialTrace" class="d-flex flex-wrap gap-2 align-items-end">
        <input type="hidden" name="mode" value="@mode">

        @if (mode == "hammadde")
        {
            <div style="display:flex;flex-direction:column;min-width:260px;">
                <label class="form-label small fw-semibold mb-1">Hammadde <span class="text-danger">*</span></label>
                <div class="mcd" id="mcd-mt-ham" data-placeholder="— Hammadde seçiniz —" style="min-width:260px;">
                    <button type="button" class="mcd-btn" onclick="mcdOpen('mcd-mt-ham')">
                        <span class="mcd-lbl">@(hammaddeIds.Length > 0 ? hammaddeIds.Length + " hammadde seçildi" : "— Hammadde seçiniz —")</span>
                        <i class="fas fa-angle-down mcd-arrow"></i>
                    </button>
                    <div class="mcd-panel" id="mcd-mt-ham-panel" style="display:none;">
                        <div class="mcd-search-row">
                            <input type="text" class="mcd-search" placeholder="Hammadde ara..." oninput="mcdSearch(this)">
                        </div>
                        <label class="mcd-row mcd-header">
                            <input type="checkbox" class="mcd-all-cb" onchange="mcdToggleAll(this,'mcd-mt-ham')">
                            <span>Tümünü Seç / Temizle</span>
                        </label>
                        <div class="mcd-items">
                            @foreach (var p in hammaddeler)
                            {
                                bool selH = hammaddeIds.Contains(p.Id);
                                <label class="mcd-row">
                                    <input type="checkbox" name="hammaddeIds" value="@p.Id" class="mcd-cb"
                                           onchange="mcdUpdate('mcd-mt-ham')"
                                           checked="@(selH ? "checked" : null)">
                                    <span class="mcd-name" title="@p.ProductName">@p.ProductName</span>
                                    @if (!string.IsNullOrEmpty(p.ExternalCode)) { <span class="mcd-ext">@p.ExternalCode</span> }
                                    @if (!string.IsNullOrEmpty(p.ProductCode))  { <span class="mcd-sub">@p.ProductCode</span> }
                                </label>
                            }
                        </div>
                        <div class="mcd-empty" style="display:none;">Sonuç yok</div>
                    </div>
                </div>
            </div>
            <div style="display:flex;flex-direction:column;min-width:160px;">
                <label class="form-label small fw-semibold mb-1">Parti No (opsiyonel)</label>
                <input name="partiNo" class="form-control form-control-sm" placeholder="örn: 24H0051" value="@partiNo">
            </div>
            <div style="display:flex;flex-direction:column;min-width:140px;">
                <label class="form-label small fw-semibold mb-1">Üretim Başlangıç</label>
                <input type="date" name="startDate" class="form-control form-control-sm" value="@startDate">
            </div>
            <div style="display:flex;flex-direction:column;min-width:140px;">
                <label class="form-label small fw-semibold mb-1">Üretim Bitiş</label>
                <input type="date" name="endDate" class="form-control form-control-sm" value="@endDate">
            </div>
        }
        else if (mode == "mamul")
        {
            <div style="display:flex;flex-direction:column;min-width:260px;">
                <label class="form-label small fw-semibold mb-1">Mamul <span class="text-danger">*</span></label>
                <div class="mcd" id="mcd-mat-mamul" data-placeholder="— Mamul seçiniz —">
                    <button type="button" class="mcd-btn" onclick="mcdOpen('mcd-mat-mamul')">
                        <span class="mcd-lbl">
                            @{
                                var selMamulText = mamuller.FirstOrDefault(p => p.Id == mamulId)?.ProductName;
                            }
                            @(selMamulText ?? "— Mamul seçiniz —")
                        </span>
                        <i class="fas fa-angle-down mcd-arrow"></i>
                    </button>
                    <div class="mcd-panel" id="mcd-mat-mamul-panel" style="display:none;">
                        <div class="mcd-search-row">
                            <input type="text" class="mcd-search" placeholder="Mamul ara..." oninput="mcdSearch(this)">
                        </div>
                        <div class="mcd-items">
                            @foreach (var p in mamuller)
                            {
                                bool isSel = mamulId == p.Id;
                                <label class="mcd-row" onclick="mcdSingleSelect('mcd-mat-mamul', @p.Id, '@Html.Raw(p.ProductName?.Replace("'", "\\'") ?? "")')">
                                    <input type="radio" name="mamulId" value="@p.Id"
                                           @(isSel ? "checked" : "")
                                           style="accent-color:#1976d2;min-width:15px;cursor:pointer;">
                                    <span class="mcd-name" title="@p.ProductName">@p.ProductName</span>
                                    @if (!string.IsNullOrEmpty(p.ProductCode))  { <span class="mcd-sub">@p.ProductCode</span> }
                                    @if (!string.IsNullOrEmpty(p.ExternalCode)) { <span class="mcd-ext">@p.ExternalCode</span> }
                                </label>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div style="display:flex;flex-direction:column;min-width:140px;">
                <label class="form-label small fw-semibold mb-1">Üretim Başlangıç</label>
                <input type="date" name="startDate" class="form-control form-control-sm" value="@startDate">
            </div>
            <div style="display:flex;flex-direction:column;min-width:140px;">
                <label class="form-label small fw-semibold mb-1">Üretim Bitiş</label>
                <input type="date" name="endDate" class="form-control form-control-sm" value="@endDate">
            </div>
        }
        else  @* parti *@
        {
            <div style="display:flex;flex-direction:column;min-width:160px;">
                <label class="form-label small fw-semibold mb-1">Parti No</label>
                <input name="partiNo" class="form-control form-control-sm" placeholder="örn: 24H0051" value="@partiNo">
            </div>
            <div style="display:flex;flex-direction:column;min-width:160px;">
                <label class="form-label small fw-semibold mb-1">Seri No</label>
                <input name="serialNo" class="form-control form-control-sm" placeholder="örn: 24H0051-01" value="@seriNo">
            </div>
            <div style="display:flex;flex-direction:column;min-width:140px;">
                <label class="form-label small fw-semibold mb-1">Üretim Başlangıç</label>
                <input type="date" name="startDate" class="form-control form-control-sm" value="@startDate">
            </div>
            <div style="display:flex;flex-direction:column;min-width:140px;">
                <label class="form-label small fw-semibold mb-1">Üretim Bitiş</label>
                <input type="date" name="endDate" class="form-control form-control-sm" value="@endDate">
            </div>
        }

        <!-- Ortak ek filtreler (tüm modlarda) -->
        <div style="display:flex;flex-direction:column;min-width:180px;">
            <label class="form-label small fw-semibold mb-1">Stok Adı / Kodu</label>
            <input name="stockSearch" class="form-control form-control-sm"
                   placeholder="Stok adı veya kodu ara..."
                   value="@(stockSearch ?? "")">
        </div>
        <div style="display:flex;flex-direction:column;min-width:160px;">
            <label class="form-label small fw-semibold mb-1">Tedarikçi</label>
            <div class="mcd" id="mcd-mt-sup" data-placeholder="— Tüm Tedarikçiler —">
                <button type="button" class="mcd-btn" onclick="mcdOpen('mcd-mt-sup')">
                    <span class="mcd-lbl">@(supplierIds.Length > 0 ? supplierIds.Length + " seçildi" : "— Tüm Tedarikçiler —")</span>
                    <i class="fas fa-angle-down mcd-arrow"></i>
                </button>
                <div class="mcd-panel" id="mcd-mt-sup-panel" style="display:none;">
                    <div class="mcd-search-row">
                        <input type="text" class="mcd-search" placeholder="Tedarikçi ara..." oninput="mcdSearch(this)">
                    </div>
                    <label class="mcd-row mcd-header">
                        <input type="checkbox" class="mcd-all-cb" onchange="mcdToggleAll(this,'mcd-mt-sup')">
                        <span>Tümünü Seç / Temizle</span>
                    </label>
                    <div class="mcd-items">
                        @foreach (var s in suppliers)
                        {
                            bool sel = supplierIds.Contains(s.Id);
                            <label class="mcd-row">
                                <input type="checkbox" name="supplierIds" value="@s.Id" class="mcd-cb"
                                       onchange="mcdUpdate('mcd-mt-sup')"
                                       @(sel ? "checked" : "")>
                                <span class="mcd-name">@s.Name</span>
                            </label>
                        }
                    </div>
                    <div class="mcd-empty" style="display:none;">Sonuç yok</div>
                </div>
            </div>
        </div>
        <div style="display:flex;flex-direction:column;min-width:140px;">
            <label class="form-label small fw-semibold mb-1">FSC Tipi</label>
            <div class="mcd" id="mcd-mt-fsc" data-placeholder="— Tüm FSC Tipleri —">
                <button type="button" class="mcd-btn" onclick="mcdOpen('mcd-mt-fsc')">
                    <span class="mcd-lbl">@(fscTypeIds.Length > 0 ? fscTypeIds.Length + " seçildi" : "— Tüm FSC Tipleri —")</span>
                    <i class="fas fa-angle-down mcd-arrow"></i>
                </button>
                <div class="mcd-panel" id="mcd-mt-fsc-panel" style="display:none;">
                    <div class="mcd-search-row">
                        <input type="text" class="mcd-search" placeholder="FSC tipi ara..." oninput="mcdSearch(this)">
                    </div>
                    <label class="mcd-row mcd-header">
                        <input type="checkbox" class="mcd-all-cb" onchange="mcdToggleAll(this,'mcd-mt-fsc')">
                        <span>Tümünü Seç / Temizle</span>
                    </label>
                    <div class="mcd-items">
                        @foreach (var f in fscTypes)
                        {
                            bool sel = fscTypeIds.Contains(f.Id);
                            <label class="mcd-row">
                                <input type="checkbox" name="fscTypeIds" value="@f.Id" class="mcd-cb"
                                       onchange="mcdUpdate('mcd-mt-fsc')"
                                       @(sel ? "checked" : "")>
                                <span class="mcd-name">@f.Name</span>
                            </label>
                        }
                    </div>
                    <div class="mcd-empty" style="display:none;">Sonuç yok</div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 align-items-end pb-1">
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="fas fa-search me-1"></i> Sorgula
            </button>
            @if (Model?.Rows.Count > 0 || hasHammaddeFilter || mamulId.HasValue || !string.IsNullOrEmpty(partiNo))
            {
                <a href="/Reports/MaterialTrace?mode=@mode" class="btn btn-outline-secondary btn-sm">Temizle</a>
            }
        </div>
    </form>
</div>

<!-- ── Boş Durum ─────────────────────────────────────────────────────────────── -->
@if (Model == null || (!hasRows && !hasHammaddeFilter && !mamulId.HasValue && string.IsNullOrEmpty(partiNo) && string.IsNullOrEmpty(seriNo)))
{
    <div class="table-card text-center py-5 text-muted">
        <i class="fas fa-search-location fa-3x mb-3 d-block" style="color:#d1d5db;"></i>
        @if (mode == "hammadde")
        {
            <p class="mb-1 fw-semibold">Hammadde Kullanım İzleme</p>
            <p class="small">Seçilen hammaddenin hangi parti ve lotuyla, hangi mamülün üretiminde, hangi gün ve makinede, ne kadar kullanıldığını gösterir.</p>
        }
        else if (mode == "mamul")
        {
            <p class="mb-1 fw-semibold">Mamul Hammadde Analizi</p>
            <p class="small">Seçilen mamülün üretimlerinde hangi hammaddenin hangi partisinden ne kadar tüketildiğini gösterir.</p>
        }
        else
        {
            <p class="mb-1 fw-semibold">Parti / Lot Kullanım İzleme</p>
            <p class="small">Girilen parti veya seri numarasının hangi tarihlerde, hangi iş emirlerinde, hangi mamüller için kullanıldığını gösterir.</p>
        }
    </div>
}
else if (hasRows)
{
    <!-- ── Özet Kartlar ──────────────────────────────────────────────────────── -->
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="table-card p-3 text-center">
                <div style="font-size:22px;font-weight:700;color:#1d4ed8;">@Model.TotalWorkOrders</div>
                <div class="text-muted small">İş Emri</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="table-card p-3 text-center">
                <div style="font-size:22px;font-weight:700;color:#d97706;">@Model.TotalLots</div>
                <div class="text-muted small">Parti (Lot)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="table-card p-3 text-center">
                <div style="font-size:22px;font-weight:700;color:#16a34a;">@Model.TotalConsumedKg.ToString("N1", culture)</div>
                <div class="text-muted small">Tüketilen (kg)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="table-card p-3 text-center">
                <div style="font-size:22px;font-weight:700;color:#dc2626;">@Model.TotalWasteKg.ToString("N1", culture)</div>
                <div class="text-muted small">Fire (kg)</div>
            </div>
        </div>
    </div>

    <!-- ── Gruplama Özeti ────────────────────────────────────────────────────── -->
    @if (mode == "hammadde")
    {
        <!-- Mamul bazında özet -->
        var mamulOzet = Model.Rows
            .GroupBy(r => new { r.MamulAdi, r.MamulKodu })
            .Select(g => new { g.Key.MamulAdi, g.Key.MamulKodu, Kg = g.Sum(r => r.TuketilenKg), Fire = g.Sum(r => r.FireKg), WoCount = g.Select(r => r.WorkOrderId).Distinct().Count() })
            .OrderByDescending(x => x.Kg).ToList();
        <div class="table-card mb-3">
            <div class="p-3 border-bottom d-flex align-items-center gap-2">
                <span style="width:28px;height:28px;border-radius:8px;background:#fef3c7;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="fas fa-chart-bar" style="color:#d97706;font-size:13px;"></i>
                </span>
                <strong style="font-size:14px;">Mamul Bazında Kullanım Özeti</strong>
            </div>
            <div class="table-responsive">
                <table class="data-table">
                    <thead><tr>
                        <th>MAMUL</th>
                        <th>KOD</th>
                        <th class="text-end">İŞ EMRİ</th>
                        <th class="text-end">TÜKETİLEN (kg)</th>
                        <th class="text-end">FİRE (kg)</th>
                        <th class="text-end">FİRE %</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var item in mamulOzet)
                        {
                            var fr = item.Kg > 0 ? item.Fire / item.Kg * 100 : 0;
                            <tr>
                                <td class="fw-semibold small">@item.MamulAdi</td>
                                <td class="text-muted small">@item.MamulKodu</td>
                                <td class="text-end small">@item.WoCount</td>
                                <td class="text-end small fw-semibold">@item.Kg.ToString("N2", culture)</td>
                                <td class="text-end small text-danger">@item.Fire.ToString("N2", culture)</td>
                                <td class="text-end small">
                                    <span style="color:@(fr >= 5 ? "#dc2626" : fr >= 2 ? "#d97706" : "#16a34a");font-weight:600;">%@fr.ToString("N1", culture)</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (mode == "mamul")
    {
        <!-- Hammadde/Parti bazında özet -->
        var hammaddeOzet = Model.Rows
            .GroupBy(r => new { r.HammaddeAdi, r.PartiNo, r.FscTipi, r.Tedarikci })
            .Select(g => new { g.Key.HammaddeAdi, g.Key.PartiNo, g.Key.FscTipi, g.Key.Tedarikci, Kg = g.Sum(r => r.TuketilenKg), Fire = g.Sum(r => r.FireKg) })
            .OrderByDescending(x => x.Kg).ToList();
        <div class="table-card mb-3">
            <div class="p-3 border-bottom d-flex align-items-center gap-2">
                <span style="width:28px;height:28px;border-radius:8px;background:#dbeafe;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="fas fa-chart-bar" style="color:#1d4ed8;font-size:13px;"></i>
                </span>
                <strong style="font-size:14px;">Hammadde / Parti Bazında Kullanım Özeti</strong>
            </div>
            <div class="table-responsive">
                <table class="data-table">
                    <thead><tr>
                        <th>HAMMADDE</th>
                        <th>PARTİ NO</th>
                        <th>FSC TİPİ</th>
                        <th>TEDARİKÇİ</th>
                        <th class="text-end">TÜKETİLEN (kg)</th>
                        <th class="text-end">FİRE (kg)</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var item in hammaddeOzet)
                        {
                            <tr>
                                <td class="fw-semibold small">@item.HammaddeAdi</td>
                                <td class="small"><span class="badge badge-warning">@item.PartiNo</span></td>
                                <td class="small">@if(!string.IsNullOrEmpty(item.FscTipi)){<span class="badge badge-primary" style="font-size:10px;">@item.FscTipi</span>}</td>
                                <td class="text-muted small">@item.Tedarikci</td>
                                <td class="text-end small fw-semibold">@item.Kg.ToString("N2", culture)</td>
                                <td class="text-end small text-danger">@item.Fire.ToString("N2", culture)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else  @* parti *@
    {
        <!-- Mamul bazında özet -->
        var partiMamulOzet = Model.Rows
            .GroupBy(r => new { r.MamulAdi, r.WorkOrderNo, r.WorkOrderId, r.MakineName })
            .Select(g => new { g.Key.MamulAdi, g.Key.WorkOrderNo, g.Key.WorkOrderId, g.Key.MakineName, Kg = g.Sum(r => r.TuketilenKg), Fire = g.Sum(r => r.FireKg), Tarih = g.Min(r => r.UretimTarihi) })
            .OrderBy(x => x.Tarih).ToList();
        <div class="table-card mb-3">
            <div class="p-3 border-bottom d-flex align-items-center gap-2">
                <span style="width:28px;height:28px;border-radius:8px;background:#dcfce7;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="fas fa-chart-bar" style="color:#16a34a;font-size:13px;"></i>
                </span>
                <strong style="font-size:14px;">İş Emri Bazında Kullanım Özeti</strong>
            </div>
            <div class="table-responsive">
                <table class="data-table">
                    <thead><tr>
                        <th>ÜRETİM TARİHİ</th>
                        <th>İŞ EMRİ</th>
                        <th>MAMUL</th>
                        <th>MAKİNE</th>
                        <th class="text-end">TÜKETİLEN (kg)</th>
                        <th class="text-end">FİRE (kg)</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var item in partiMamulOzet)
                        {
                            <tr>
                                <td class="text-muted small">@item.Tarih.ToString("dd.MM.yyyy")</td>
                                <td><a href="/Production/Detail/@item.WorkOrderId" class="fw-semibold small text-primary">@item.WorkOrderNo</a></td>
                                <td class="fw-semibold small">@item.MamulAdi</td>
                                <td class="text-muted small">@item.MakineName</td>
                                <td class="text-end small fw-semibold">@item.Kg.ToString("N2", culture)</td>
                                <td class="text-end small text-danger">@item.Fire.ToString("N2", culture)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- ── Detay Tablosu ─────────────────────────────────────────────────────── -->
    <div class="table-card">
        <div class="p-3 border-bottom d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <span style="width:28px;height:28px;border-radius:8px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="fas fa-table" style="color:#475569;font-size:13px;"></i>
                </span>
                <strong style="font-size:14px;">Satır Bazında Detay</strong>
                <span class="badge badge-secondary ms-1">@Model.Rows.Count kayıt</span>
            </div>
        </div>
        <div class="table-responsive">
            <table class="data-table" style="font-size:12px;">
                <thead>
                    <tr>
                        <th>ÜRETİM TARİHİ</th>
                        <th>İŞ EMRİ</th>
                        <th>MAMUL</th>
                        <th>MAKİNE</th>
                        <th>HAMMADDE</th>
                        <th>PARTİ NO</th>
                        <th>SERİ NO</th>
                        <th>FSC TİPİ</th>
                        <th>TEDARİKÇİ</th>
                        <th class="text-end">TÜKETİM (kg)</th>
                        <th class="text-end">FİRE (kg)</th>
                        <th class="text-end">FİRE %</th>
                        <th class="text-end">ÜRETİLEN (adet)</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        decimal gConsumed = 0; decimal gWaste = 0; decimal gProduced = 0;
                        string? lastWoNo = null;
                    }
                    @foreach (var row in Model.Rows)
                    {
                        gConsumed += row.TuketilenKg;
                        gWaste    += row.FireKg;
                        if (row.UretilenAdet > 0) gProduced += row.UretilenAdet;
                        bool newWo = row.WorkOrderNo != lastWoNo;
                        lastWoNo   = row.WorkOrderNo;
                        <tr class="@(newWo && row != Model.Rows.First() ? "border-top-2" : "")">
                            <td class="text-muted">@row.UretimTarihi.ToString("dd.MM.yyyy")</td>
                            <td>
                                <a href="/Production/Detail/@row.WorkOrderId" class="fw-semibold text-primary">@row.WorkOrderNo</a>
                            </td>
                            <td>
                                <div class="fw-semibold">@row.MamulAdi</div>
                                @if (!string.IsNullOrEmpty(row.MamulKodu)){<div class="text-muted" style="font-size:10px;">@row.MamulKodu</div>}
                            </td>
                            <td class="text-muted">@row.MakineName</td>
                            <td>
                                <div>@row.HammaddeAdi</div>
                                @if (!string.IsNullOrEmpty(row.HammaddeKodu)){<div class="text-muted" style="font-size:10px;">@row.HammaddeKodu</div>}
                            </td>
                            <td><span class="badge badge-warning" style="font-size:10px;">@row.PartiNo</span></td>
                            <td class="text-muted" style="font-size:11px;">@row.SerialNo</td>
                            <td>
                                @if (!string.IsNullOrEmpty(row.FscTipi) && row.FscTipi != "—")
                                { <span class="badge badge-primary" style="font-size:10px;">@row.FscTipi</span> }
                            </td>
                            <td class="text-muted" style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@row.Tedarikci">@row.Tedarikci</td>
                            <td class="text-end fw-semibold">@row.TuketilenKg.ToString("N2", culture)</td>
                            <td class="text-end text-danger">@row.FireKg.ToString("N2", culture)</td>
                            <td class="text-end">
                                @{ var fr = row.FireRate; }
                                <span style="color:@(fr >= 5 ? "#dc2626" : fr >= 2 ? "#d97706" : "#16a34a");font-weight:600;">%@fr.ToString("N1", culture)</span>
                            </td>
                            <td class="text-end">
                                @if (row.UretilenAdet > 0){<span class="fw-semibold">@row.UretilenAdet.ToString("N0", culture)</span>}
                                else{<span class="text-muted">—</span>}
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="background:#f8fafc;font-weight:700;border-top:2px solid #cbd5e1;">
                        <td colspan="9" class="ps-3 text-muted small">GENEL TOPLAM</td>
                        <td class="text-end">@gConsumed.ToString("N2", culture)</td>
                        <td class="text-end text-danger">@gWaste.ToString("N2", culture)</td>
                        <td class="text-end">
                            @{ var totalFr = gConsumed > 0 ? gWaste / gConsumed * 100 : 0; }
                            <span style="color:@(totalFr >= 5 ? "#dc2626" : totalFr >= 2 ? "#d97706" : "#16a34a");">%@totalFr.ToString("N1", culture)</span>
                        </td>
                        <td class="text-end">@gProduced.ToString("N0", culture)</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}
else if (hasHammaddeFilter || mamulId.HasValue || !string.IsNullOrEmpty(partiNo) || !string.IsNullOrEmpty(seriNo))
{
    <div class="table-card text-center py-4 text-muted">
        <i class="fas fa-inbox fa-2x mb-2 d-block" style="color:#d1d5db;"></i>
        <p class="mb-0">Seçilen kriterlere uygun üretim kaydı bulunamadı.</p>
    </div>
}

@section Scripts {
<style>
.mcd{position:relative}
.mcd-btn{width:100%;text-align:left;display:flex;justify-content:space-between;align-items:center;cursor:pointer;background:#fff;border:1px solid #d1d5db;color:#111;padding:5px 10px;border-radius:6px;font-size:13px}
.mcd-btn:hover{border-color:#1976d2}
.mcd-panel{position:absolute;top:calc(100% + 4px);left:0;min-width:300px;max-width:400px;background:#fff;border:1px solid #d1d5db;border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:1050;display:flex;flex-direction:column;overflow:hidden}
.mcd-search-row{padding:8px 10px;border-bottom:1px solid #f1f5f9}
.mcd-search{width:100%;border:1px solid #e5e7eb;border-radius:6px;padding:5px 10px;font-size:12.5px;outline:none}
.mcd-items{overflow-y:auto;max-height:260px}
.mcd-row{display:flex;align-items:center;gap:8px;padding:6px 12px;cursor:pointer;font-size:12.5px;user-select:none}
.mcd-row:hover{background:#eff6ff}
.mcd-name{flex:1;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px}
.mcd-sub{font-size:10.5px;color:#374151;background:#f3f4f6;padding:1px 5px;border-radius:4px;white-space:nowrap}
.mcd-ext{font-size:10.5px;color:#3730a3;background:#eef2ff;padding:1px 5px;border-radius:4px;white-space:nowrap}
.mcd-search:focus{border-color:#1976d2}
.mcd-header{background:#f8fafc;border-bottom:1px solid #e5e7eb;font-weight:600;font-size:12.5px;color:#374151}
.mcd-cb,.mcd-all-cb{cursor:pointer;accent-color:#1976d2;min-width:15px;height:15px}
.mcd-arrow{color:#6b7280;font-size:11px}
</style>
<script>
if(!window._mcdReady){window._mcdReady=true;
window.mcdOpen=function(id){var p=document.getElementById(id+'-panel');var o=p&&p.style.display!=='none';document.querySelectorAll('.mcd-panel').forEach(function(x){x.style.display='none'});if(!o&&p){p.style.display='flex';if(typeof mcdUpdate==='function')mcdUpdate(id)}};
window.mcdSearch=function(el){var t=el.value.toLowerCase();el.closest('.mcd-panel').querySelectorAll('.mcd-row:not(.mcd-header)').forEach(function(r){r.style.display=r.textContent.toLowerCase().includes(t)?'':'none'})};
window.mcdToggleAll=function(cb,id){document.getElementById(id+'-panel').querySelectorAll('.mcd-row:not(.mcd-header)').forEach(function(r){if(r.style.display!=='none'){var c=r.querySelector('.mcd-cb');if(c)c.checked=cb.checked}});mcdUpdate(id)};
window.mcdUpdate=function(id){var p=document.getElementById(id+'-panel');var c=document.getElementById(id);if(!p||!c)return;var n=p.querySelectorAll('.mcd-cb:checked').length;var l=c.querySelector('.mcd-lbl');if(l)l.textContent=n===0?(c.dataset.placeholder||'— Seçiniz —'):n+' seçildi';var a=p.querySelector('.mcd-all-cb');var v=p.querySelectorAll('.mcd-row:not(.mcd-header):not([style*="none"]) .mcd-cb').length;if(a&&v>0)a.checked=(n>=v)};
document.addEventListener('mousedown',function(e){if(!e.target.closest('.mcd'))document.querySelectorAll('.mcd-panel').forEach(function(p){p.style.display='none'})});}
window.mcdSingleSelect=function(id,val,label){var container=document.getElementById(id);var lbl=container&&container.querySelector('.mcd-lbl');if(lbl)lbl.textContent=label;setTimeout(function(){document.querySelectorAll('.mcd-panel').forEach(function(p){p.style.display='none'});},100);};
</script>
<script>
    $(document).on('init.dt', 'table.data-table', function() {
        var dt = $(this).DataTable();
        var si = document.getElementById('globalSearch');
        var sd = document.getElementById('searchDropdown');
        if (!si) return;
        if (sd) sd.classList.remove('show');
        si.addEventListener('input', function(e) {
            if (sd) sd.classList.remove('show');
            dt.search(this.value).draw();
            e.stopPropagation();
        }, true);
        si.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') { this.value = ''; dt.search('').draw(); e.preventDefault(); e.stopPropagation(); }
        }, true);
    });
</script>
}
