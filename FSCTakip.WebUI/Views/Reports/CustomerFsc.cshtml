@model List<FSCTakip.Core.Entities.Customer>
@{
    ViewData["Title"] = "Müşteri FSC Lisans Durumu";
    DateTime today = ViewBag.Today;
}

@section TopbarPrimary {
    <span class="topbar-title"><i class="fas fa-certificate me-2 text-warning"></i>Müşteri FSC Lisans Durumu</span>
}

<!-- Stat Cards -->
<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:16px;">
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-shield-alt"></i></div>
        <div class="stat-info"><div class="stat-value">@ViewBag.Valid</div><div class="stat-label">Geçerli Lisans</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fas fa-exclamation-triangle"></i></div>
        <div class="stat-info"><div class="stat-value">@ViewBag.Expiring</div><div class="stat-label">30 Gün İçinde Bitiyor</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red"><i class="fas fa-times-circle"></i></div>
        <div class="stat-info"><div class="stat-value">@ViewBag.Expired</div><div class="stat-label">Süresi Geçmiş / Pasif</div></div>
    </div>
</div>

<!-- Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>MÜŞTERİ KODU</th>
                    <th>MÜŞTERİ ADI</th>
                    <th>FSC LİSANS KODU</th>
                    <th>SON GEÇERLİLİK</th>
                    <th>KALAN GÜN</th>
                    <th>DURUM</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    int? daysLeft = c.FscExpiryDate.HasValue ? (int)(c.FscExpiryDate.Value - today).TotalDays : null;
                    string statusClass, statusText;

                    if (!c.IsFscActive || (daysLeft.HasValue && daysLeft <= 0))
                    {
                        statusClass = "badge-danger"; statusText = "Geçersiz";
                    }
                    else if (daysLeft.HasValue && daysLeft <= 30)
                    {
                        statusClass = "badge-warning"; statusText = "Yakında Bitiyor";
                    }
                    else
                    {
                        statusClass = "badge-success"; statusText = "Geçerli";
                    }

                    <tr class="@(statusText == "Yakında Bitiyor" ? "table-warning" : statusText == "Geçersiz" ? "table-danger" : "")">
                        <td class="text-muted small">@c.CustomerCode</td>
                        <td><strong>@c.Name</strong></td>
                        <td>
                            @if (!string.IsNullOrEmpty(c.FscLicenseCode))
                            {
                                <span class="badge badge-primary">@c.FscLicenseCode</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="small">
                            @if (c.FscExpiryDate.HasValue)
                            {
                                @c.FscExpiryDate.Value.ToString("dd.MM.yyyy")
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="small fw-semibold @(daysLeft.HasValue && daysLeft <= 30 ? "text-danger" : "text-muted")">
                            @if (daysLeft.HasValue)
                            {
                                if (daysLeft <= 0) { <span>Süresi Geçti</span> }
                                else { <span>@daysLeft gün</span> }
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td><span class="badge @statusClass">@statusText</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="alert alert-warning mt-3" style="font-size:13px;">
    <i class="fas fa-exclamation-triangle me-2"></i>
    <strong>Uyarı:</strong> FSC lisansı sona eren müşterilere FSC etiketli ürün satışı yapılması CoC zincirini tehlikeye atar. Denetimde bu tablonun tüm satırları <strong>Geçerli</strong> olmalıdır.
</div>
