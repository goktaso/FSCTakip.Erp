@model List<FSCTakip.WebUI.Controllers.CocRow>
@using FSCTakip.Core.Entities
@{
    ViewData["Title"] = "FSC Chain of Custody";
    var customers   = ViewBag.Customers  as List<Customer> ?? new();
    var products    = ViewBag.Products   as List<Product>  ?? new();
    string? start   = ViewBag.StartDate;
    string? end     = ViewBag.EndDate;
    int? filtCust   = ViewBag.CustomerId  as int?;
    var productIds  = ViewBag.ProductIds as int[] ?? Array.Empty<int>();
    int totalLines  = ViewBag.TotalLines  ?? 0;
    int fullChain   = ViewBag.FullChain   ?? 0;
    int missing     = ViewBag.MissingChain ?? 0;
    int pct         = totalLines > 0 ? (int)(fullChain * 100.0 / totalLines) : 0;
}

@section TopbarActions {
    <button class="topbar-btn btn-filter" onclick="toggleFilter()">
        <i class="fas fa-filter"></i> Filtrele
    </button>
    <a href="/Reports/ExportCoc?startDate=@start&endDate=@end&customerId=@filtCust@(string.Join("", productIds.Select(id => "&productIds=" + id)))"
       class="topbar-btn btn-excel">
        <i class="fas fa-file-excel"></i> Excel
    </a>
}

<!-- Özet Kartları -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-file-invoice"></i></div>
            <div>
                <div class="stat-value" id="cardTotal">@totalLines</div>
                <div class="stat-label">Toplam Kalem</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-link"></i></div>
            <div>
                <div class="stat-value" id="cardFull">@fullChain</div>
                <div class="stat-label">Zincir Tam</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon red"><i class="fas fa-unlink"></i></div>
            <div>
                <div class="stat-value" id="cardMissing">@missing</div>
                <div class="stat-label">Zincir Eksik</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon @(pct >= 90 ? "green" : pct >= 60 ? "amber" : "red")">
                <i class="fas fa-percent"></i>
            </div>
            <div>
                <div class="stat-value" id="cardPct">%@pct</div>
                <div class="stat-label">Tamamlanma Oranı</div>
            </div>
        </div>
    </div>
</div>

<!-- Filtre Paneli -->
<div id="filterPanel" class="filter-panel mb-3" style="@(start != null || end != null || filtCust != null || productIds.Length > 0 ? "" : "display:none;")">
    <form method="get" action="/Reports/ChainOfCustody">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label">Başlangıç</label>
                <input type="date" name="startDate" value="@start" class="form-control form-control-sm">
            </div>
            <div class="col-md-2">
                <label class="form-label">Bitiş</label>
                <input type="date" name="endDate" value="@end" class="form-control form-control-sm">
            </div>
            <div class="col-md-3">
                <label class="form-label">Müşteri</label>
                <select name="customerId" class="form-select form-select-sm">
                    <option value="">— Tümü —</option>
                    @foreach (var c in customers)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Ürün</label>
                <div class="mcd" id="mcd-coc-prod" data-placeholder="— Ürün —">
                    <button type="button" class="mcd-btn" onclick="mcdOpen('mcd-coc-prod')">
                        <span class="mcd-lbl">@(productIds.Length > 0 ? productIds.Length + " ürün seçildi" : "— Ürün —")</span>
                        <i class="fas fa-angle-down mcd-arrow"></i>
                    </button>
                    <div class="mcd-panel" id="mcd-coc-prod-panel" style="display:none;">
                        <div class="mcd-search-row">
                            <input type="text" class="mcd-search" placeholder="Ürün ara..." oninput="mcdSearch(this)">
                        </div>
                        <label class="mcd-row mcd-header">
                            <input type="checkbox" class="mcd-all-cb" onchange="mcdToggleAll(this,'mcd-coc-prod')">
                            <span>Tümünü Seç / Temizle</span>
                        </label>
                        <div class="mcd-items">
                            @foreach (var p in products)
                            {
                                bool sel = productIds.Contains(p.Id);
                                <label class="mcd-row">
                                    <input type="checkbox" name="productIds" value="@p.Id" class="mcd-cb"
                                           onchange="mcdUpdate('mcd-coc-prod')"
                                           checked="@(sel ? "checked" : null)">
                                    <span class="mcd-name" title="@p.ProductName">@p.ProductName</span>
                                    @if (!string.IsNullOrEmpty(p.ProductCode))
                                    { <span class="mcd-sub">@p.ProductCode</span> }
                                    @if (!string.IsNullOrEmpty(p.ExternalCode))
                                    { <span class="mcd-ext">@p.ExternalCode</span> }
                                </label>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 d-flex gap-2 align-items-end">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fas fa-search me-1"></i>Sorgula
                </button>
                <a href="/Reports/ChainOfCustody" class="btn btn-outline-secondary btn-sm">Temizle</a>
            </div>
        </div>
    </form>
</div>

<!-- CoC Tablosu -->
<div class="table-card">
    <table class="data-table">
        <thead>
            <tr>
                <th style="width:80px;">DURUM</th>
                <th>SEVKİYAT</th>
                <th>SİPARİŞ NO</th>
                <th>MÜŞTERİ</th>
                <th>ÜRÜN</th>
                <th class="text-end">MİKTAR</th>
                <th>İŞ EMRİ</th>
                <th>FSC LOT(LAR)</th>
                <th>TEDARİKÇİ / FSC</th>
                <th class="text-center" style="width:60px;">İZLE</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="10">
                        <div class="empty-state">
                            <i class="fas fa-link"></i>
                            <p>
                                Henüz teslim edilmiş sipariş kaydı yok.<br>
                                <span style="font-size:12px;">Filtre uygulandıysa tarih aralığını genişletmeyi deneyin.</span>
                            </p>
                        </div>
                    </td>
                </tr>
            }
            @foreach (var r in Model)
            {
                <tr class="data-row" data-chain="@(r.ChainComplete ? "full" : "missing")" style="@(!r.ChainComplete ? "background:#fffbeb;" : "")">
                    <td>
                        @if (r.ChainComplete)
                        {
                            <span class="badge badge-green" style="font-size:11px;">
                                <i class="fas fa-check-circle me-1"></i>Tam
                            </span>
                        }
                        else
                        {
                            <span class="badge badge-red" style="font-size:11px;"
                                  title="İş emri veya tedarikçi FSC bağlantısı eksik">
                                <i class="fas fa-exclamation-circle me-1"></i>Eksik
                            </span>
                        }
                    </td>
                    <td class="text-muted" style="font-size:12px;">
                        @(r.DispatchDate?.ToString("dd.MM.yyyy") ?? "—")
                    </td>
                    <td>
                        <a href="/Sales/Detail/@r.SalesOrderId" class="table-link fw-semibold" style="font-size:12px;">
                            @r.SalesOrderNo
                        </a>
                    </td>
                    <td>
                        <div style="font-size:13px;">@r.CustomerName</div>
                        @if (!string.IsNullOrEmpty(r.CustomerFscLicense))
                        {
                            <span class="badge badge-green" style="font-size:10px;margin-top:2px;">
                                <i class="fas fa-certificate me-1"></i>@r.CustomerFscLicense
                            </span>
                        }
                    </td>
                    <td class="fw-semibold" style="font-size:13px;">@r.ProductName</td>
                    <td class="text-end" style="font-size:13px;">
                        @r.Quantity.ToString("N0")
                        <span class="text-muted" style="font-size:11px;">@r.Unit</span>
                    </td>
                    <td>
                        @if (r.WorkOrderNo != null && r.WorkOrderId.HasValue)
                        {
                            <a href="/Production/Detail/@r.WorkOrderId" class="table-link" style="font-size:12px;">
                                @r.WorkOrderNo
                            </a>
                        }
                        else
                        {
                            <span class="badge badge-red" style="font-size:10px;">
                                <i class="fas fa-minus me-1"></i>Bağlı Değil
                            </span>
                        }
                    </td>
                    <td>
                        @if (r.LotNos.Any())
                        {
                            @foreach (var lot in r.LotNos)
                            {
                                <span class="badge badge-blue me-1" style="font-size:10px;">@lot</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        @if (r.SupplierNames.Any())
                        {
                            <div style="font-size:12px;font-weight:500;">@string.Join(", ", r.SupplierNames)</div>
                            @if (r.SupplierFscCodes.Any())
                            {
                                <div class="text-muted" style="font-size:10px;">@string.Join(", ", r.SupplierFscCodes)</div>
                            }
                            <div style="margin-top:2px;">
                                @foreach (var fsc in r.FscTypes)
                                {
                                    <span class="badge badge-green me-1" style="font-size:10px;">@fsc</span>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td class="text-center">
                        <a href="/Reports/Traceability/@r.SalesOrderId"
                           class="btn btn-sm"
                           style="padding:3px 8px;border-radius:5px;background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;"
                           title="Satış → Üretim → Lot tam izlenebilirlik zinciri">
                            <i class="fas fa-search"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.Any())
    {
        <div class="px-4 py-2 border-top d-flex align-items-center gap-3"
             style="font-size:12px;color:#6b7280;background:#fafafa;">
            <span>
                <strong id="footCount">@Model.Count</strong> kalem &nbsp;·&nbsp;
                FSC Zincir Tamamlanma:
                <strong id="footPct" class="@(pct >= 90 ? "text-success" : pct >= 60 ? "text-warning" : "text-danger")">
                    %@pct
                </strong>
            </span>
            <div class="progress" style="height:6px;width:160px;">
                <div id="footBar" class="progress-bar @(pct >= 90 ? "bg-success" : pct >= 60 ? "bg-warning" : "bg-danger")"
                     style="width:@pct%;"></div>
            </div>
            <span class="ms-auto" style="font-size:11px;">
                <i class="fas fa-info-circle me-1"></i>
                Yalnızca <strong>Teslim Edildi</strong> statüsündeki siparişler gösterilir.
                FSC denetiminde her satır için tedarikçi sertifika kopyası sunulabilir.
            </span>
        </div>
    }
</div>

@section Scripts {
<style>
.mcd { position: relative; }
.mcd-btn { width:100%; text-align:left; display:flex; justify-content:space-between; align-items:center; cursor:pointer; background:var(--surface,#fff); border:1px solid var(--border,#d1d5db); color:var(--text,#111); padding:5px 10px; border-radius:6px; font-size:13px; }
.mcd-btn:hover { border-color:#1976d2; }
.mcd-panel { position:absolute; top:calc(100% + 4px); left:0; min-width:280px; max-width:380px; background:#fff; border:1px solid #d1d5db; border-radius:8px; box-shadow:0 8px 24px rgba(0,0,0,.12); z-index:1050; display:flex; flex-direction:column; overflow:hidden; }
.mcd-search-row { padding:8px 10px; border-bottom:1px solid #f1f5f9; }
.mcd-search { width:100%; border:1px solid #e5e7eb; border-radius:6px; padding:5px 10px; font-size:12.5px; outline:none; }
.mcd-search:focus { border-color:#1976d2; box-shadow:0 0 0 2px rgba(25,118,210,.15); }
.mcd-header { background:#f8fafc; border-bottom:1px solid #e5e7eb; font-weight:600; font-size:12.5px; color:#374151; }
.mcd-items { overflow-y:auto; max-height:260px; }
.mcd-row { display:flex; align-items:center; gap:8px; padding:6px 12px; cursor:pointer; font-size:12.5px; user-select:none; }
.mcd-row:hover { background:#eff6ff; }
.mcd-cb, .mcd-all-cb { cursor:pointer; accent-color:#1976d2; min-width:15px; height:15px; }
.mcd-name { flex:1; color:#111827; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:200px; }
.mcd-sub { font-size:10.5px; color:#374151; background:#f3f4f6; padding:1px 5px; border-radius:4px; white-space:nowrap; }
.mcd-ext { font-size:10.5px; color:#3730a3; background:#eef2ff; padding:1px 5px; border-radius:4px; white-space:nowrap; }
.mcd-arrow { color:#6b7280; font-size:11px; }
</style>
<script>
(function(){
    window.mcdOpen = function(id) {
        var panel = document.getElementById(id+'-panel');
        var isOpen = panel && panel.style.display !== 'none';
        document.querySelectorAll('.mcd-panel').forEach(function(p){ p.style.display='none'; });
        if (!isOpen && panel) { panel.style.display='flex'; mcdUpdate(id); }
    };
    window.mcdSearch = function(input) {
        var term = input.value.toLowerCase();
        input.closest('.mcd-panel').querySelectorAll('.mcd-row:not(.mcd-header)').forEach(function(row){
            row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
        });
    };
    window.mcdToggleAll = function(cb, id) {
        document.getElementById(id+'-panel').querySelectorAll('.mcd-row:not(.mcd-header)').forEach(function(row){
            if (row.style.display !== 'none') { var c = row.querySelector('.mcd-cb'); if(c) c.checked = cb.checked; }
        });
        mcdUpdate(id);
    };
    window.mcdUpdate = function(id) {
        var panel = document.getElementById(id+'-panel');
        var container = document.getElementById(id);
        if (!panel || !container) return;
        var checked = panel.querySelectorAll('.mcd-cb:checked').length;
        var lbl = container.querySelector('.mcd-lbl');
        if (lbl) lbl.textContent = checked === 0 ? (container.dataset.placeholder||'— Seçiniz —') : checked + ' ürün seçildi';
        var allCb = panel.querySelector('.mcd-all-cb');
        var visible = panel.querySelectorAll('.mcd-row:not(.mcd-header):not([style*="none"]) .mcd-cb').length;
        if (allCb && visible > 0) allCb.checked = (checked >= visible);
    };
    document.addEventListener('mousedown', function(e){
        if (!e.target.closest('.mcd')) document.querySelectorAll('.mcd-panel').forEach(function(p){ p.style.display='none'; });
    });
})();
</script>
<script>
    function toggleFilter() {
        var p = document.getElementById('filterPanel');
        if (p) p.style.display = p.style.display === 'none' ? '' : 'none';
    }

    $(document).on('init.dt', 'table.data-table', function() {
        var dt = $(this).DataTable();
        var si = document.getElementById('globalSearch');
        var sd = document.getElementById('searchDropdown');
        if (!si) return;
        if (sd) sd.classList.remove('show');
        si.addEventListener('input', function(e) {
            if (sd) sd.classList.remove('show');
            dt.search(this.value).draw();
            e.stopPropagation();
        }, true);
        si.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') { this.value = ''; dt.search('').draw(); e.preventDefault(); e.stopPropagation(); }
        }, true);
    });

    $(document).on('draw.dt', 'table.data-table', function() {
        var dt = $(this).DataTable();
        var total = 0, full = 0, missing = 0;
        dt.rows({ search: 'applied' }).nodes().each(function(tr) {
            if (!tr.classList.contains('data-row')) return;
            total++;
            if (tr.dataset.chain === 'full') full++;
            else missing++;
        });
        var pct = total > 0 ? Math.round(full * 100 / total) : 0;
        var g = function(id) { return document.getElementById(id); };
        if (g('cardTotal'))   g('cardTotal').textContent   = total;
        if (g('cardFull'))    g('cardFull').textContent    = full;
        if (g('cardMissing')) g('cardMissing').textContent = missing;
        if (g('cardPct'))     g('cardPct').textContent     = '%' + pct;
        if (g('footCount'))   g('footCount').textContent   = total;
        if (g('footPct'))     g('footPct').textContent     = '%' + pct;
        if (g('footBar'))     g('footBar').style.width     = pct + '%';
    });
</script>
}
