@section Scripts {
<script>
    const TOTAL = 24;
    let done = new Set(JSON.parse(localStorage.getItem('ts_done') || '[]'));

    function toggle(id) {
        if (done.has(id)) done.delete(id);
        else done.add(id);
        localStorage.setItem('ts_done', JSON.stringify([...done]));
        render();
    }

    function render() {
        document.querySelectorAll('.step').forEach(el => {
            const check = el.querySelector('.step-check');
            if (done.has(el.id)) check.classList.add('done');
            else check.classList.remove('done');
        });
        const pct = Math.round(done.size * 100 / TOTAL);
        document.getElementById('progFill').style.width = pct + '%';
        document.getElementById('progLabel').textContent = done.size + ' / ' + TOTAL;
        document.getElementById('bigPct').textContent = pct + '%';
        document.getElementById('completionBanner').style.display = done.size >= TOTAL ? 'block' : 'none';

        // Nav active phase
        const phases = [1,2,3,4,5,6];
        const links  = document.querySelectorAll('.ts-phase-link');
        phases.forEach((p, i) => {
            const ids  = Array.from({length:4}, (_,j) => `s${p}_${j+1}`);
            const all  = ids.every(id => done.has(id));
            const some = ids.some(id => done.has(id));
            links[i].style.color = all ? '#16a34a' : some ? '#d97706' : '';
        });
    }

    function goPhase(n) {
        const el = document.getElementById('phase' + n);
        if (el) el.scrollIntoView({ behavior:'smooth', block:'start' });
        document.querySelectorAll('.ts-phase-link').forEach((l,i) => l.classList.toggle('active', i === n-1));
    }

    // Scroll spy
    const observer = new IntersectionObserver(entries => {
        entries.forEach(e => {
            if (e.isIntersecting) {
                const num = e.target.id.replace('phase','');
                document.querySelectorAll('.ts-phase-link').forEach((l,i) => l.classList.toggle('active', i === parseInt(num)-1));
            }
        });
    }, { rootMargin:'-20% 0% -70% 0%', threshold:0 });
    document.querySelectorAll('.phase-card').forEach(el => observer.observe(el));

    render();
</script>
}
