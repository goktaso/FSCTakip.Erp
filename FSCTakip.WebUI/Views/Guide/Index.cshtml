    <button class="gm-btn-secondary"><i class="fas fa-filter"></i> Filtrele</button>
    <button class="gm-btn-excel"><i class="fas fa-file-excel"></i> Excel</button>
    <span class="gm-user"><i class="fas fa-user-circle"></i> Özay Göktaş</span>
  </div>
  <div class="gm-body">
    <div class="gm-stats">
      <div class="gm-stat"><div class="gm-stat-icon green"><i class="fas fa-boxes"></i></div><div><div class="gm-stat-val">47</div><div class="gm-stat-lbl">Toplam Lot</div></div></div>
      <div class="gm-stat"><div class="gm-stat-icon blue"><i class="fas fa-weight-hanging"></i></div><div><div class="gm-stat-val">382.450</div><div class="gm-stat-lbl">Toplam Giriş (kg)</div></div></div>
      <div class="gm-stat"><div class="gm-stat-icon purple"><i class="fas fa-scroll"></i></div><div><div class="gm-stat-val">215</div><div class="gm-stat-lbl">Toplam Bobin</div></div></div>
      <div class="gm-stat"><div class="gm-stat-icon amber"><i class="fas fa-battery-half"></i></div><div><div class="gm-stat-val">128.900</div><div class="gm-stat-lbl">Kalan Hammadde (kg)</div></div></div>
    </div>
    <div class="gm-table-wrap">
      <table class="gm-table">
        <thead><tr><th>LOT NO</th><th>TEDARİKÇİ</th><th>FSC TİPİ</th><th>GELİŞ TARİHİ</th><th>BOBİN</th><th>GİRİŞ (kg)</th><th>KALAN (kg)</th><th>İŞLEM</th></tr></thead>
