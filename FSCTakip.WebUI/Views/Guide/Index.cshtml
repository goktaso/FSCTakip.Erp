    };

    // Her bölüm başlığından sonra mockup'ı enjekte et
    Object.entries(mockups).forEach(([id, html]) => {
        const heading = document.getElementById(id);
        if (!heading) return;
        // code bloklarını (ASCII art) mockup ile değiştir
        const wrapper = document.createElement('div');
        wrapper.innerHTML = html;
        // İlk <pre> bloğunu bul ve mockup ile değiştir — bulamazsa başlığın hemen altına ekle
        let inserted = false;
        let next = heading.nextElementSibling;
        while (next) {
            if (next.tagName === 'PRE' || (next.tagName === 'DIV' && next.querySelector('pre'))) {
                next.replaceWith(wrapper);
                inserted = true;
                break;
            }
            if (next.tagName === 'H2' || next.tagName === 'H3') break;
            next = next.nextElementSibling;
        }
        if (!inserted) heading.insertAdjacentElement('afterend', wrapper);
    });

    // TOC active state on scroll
    const tocLinks = document.querySelectorAll('.toc-item[href]');
    const observer = new IntersectionObserver(entries => {
        entries.forEach(e => {
            if (e.isIntersecting) {
                tocLinks.forEach(l => l.classList.remove('active'));
                const link = document.querySelector(`.toc-item[href="#${e.target.id}"]`);
                if (link) link.classList.add('active');
            }
        });
    }, { rootMargin: '-20% 0% -70% 0%', threshold: 0 });

    document.querySelectorAll('.md-body h2[id]').forEach(el => observer.observe(el));

    // Scroll to section
    function scrollTo(id) {
        const el = document.getElementById(id);
        if (el) {
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }

    // Hash navigation on load
    if (window.location.hash) {
        setTimeout(() => {
            const id = window.location.hash.substring(1);
            scrollTo(id);
        }, 300);
    }
</script>
