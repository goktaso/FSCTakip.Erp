@model IEnumerable<FSCTakip.Core.Entities.ProductGroup>
@{
    ViewData["Title"] = "Gruplar";
}

<div class="card shadow mb-4">
    <div id="filterPanel" class="card-body border-bottom bg-light" style="display:none;">
        <div class="row align-items-end">
            <div class="col-md-9">
                <label class="small font-weight-bold text-uppercase">Grup Ara</label>
                <input type="text" id="searchBox" class="form-control form-control-sm" placeholder="Grup adı veya kodu...">
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary btn-sm btn-block" onclick="filterTable()">
                    <i class="fas fa-search mr-1"></i> Sorgula
                </button>
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="dataTable">
                <thead class="bg-light text-dark text-uppercase small font-weight-bold">
                    <tr>
                        <th style="width:70px;">ID</th>
                        <th>Grup Kodu</th>
                        <th>Grup Adı</th>
                        <th>Aralık Başlangıç</th>
                        <th>Aralık Bitiş</th>
                        <th class="text-right" style="width:130px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        var safeName = item.GroupName?.Replace("'", "\\'") ?? "";
                        <tr>
                            <td>@item.Id</td>
                            <td><code>@item.GroupCode</code></td>
                            <td><strong>@item.GroupName</strong></td>
                            <td>@item.RangeStart</td>
                            <td>@item.RangeEnd</td>
                            <td class="text-right">
                                <button class="btn btn-sm btn-outline-primary mr-1"
                                        onclick="editItem(@item.Id, @item.GroupCode, '@safeName', @item.RangeStart, @item.RangeEnd)">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteItem(@item.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title font-weight-bold"><i class="fas fa-layer-group mr-2"></i>Grup Formu</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <form asp-action="Save" method="post">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="formId" value="0" />
                    <div class="form-group">
                        <label class="small font-weight-bold">Grup Kodu</label>
                        <input type="number" name="GroupCode" id="formGroupCode" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label class="small font-weight-bold">Grup Adı</label>
                        <input type="text" name="GroupName" id="formGroupName" class="form-control" required />
                    </div>
                    <div class="row">
                        <div class="col-6 form-group">
                            <label class="small font-weight-bold">Aralık Başlangıç</label>
                            <input type="number" name="RangeStart" id="formRangeStart" class="form-control" />
                        </div>
                        <div class="col-6 form-group">
                            <label class="small font-weight-bold">Aralık Bitiş</label>
                            <input type="number" name="RangeEnd" id="formRangeEnd" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary btn-sm px-4">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAddModal() {
            $('#formId').val(0);
            $('#formGroupCode').val('');
            $('#formGroupName').val('');
            $('#formRangeStart').val('');
            $('#formRangeEnd').val('');
            $('.modal-title').html('<i class="fas fa-plus mr-2"></i>Yeni Grup');
            $('#addModal').modal('show');
        }
        function editItem(id, code, name, start, end) {
            $('#formId').val(id);
            $('#formGroupCode').val(code);
            $('#formGroupName').val(name);
            $('#formRangeStart').val(start);
            $('#formRangeEnd').val(end);
            $('.modal-title').html('<i class="fas fa-edit mr-2"></i>Grup Düzenle');
            $('#addModal').modal('show');
        }
        function filterTable() {
            var v = $('#searchBox').val().toLowerCase();
            $('#dataTable tbody tr').filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(v) > -1);
            });
        }
        function exportToExcel() {
            window.location.href = '/Gruplar/Export';
        }
        function deleteItem(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: 'Bu kayıt silinecek.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Sil',
                cancelButtonText: 'Vazgeç'
            }).then(function (r) {
                if (r.isConfirmed) {
                    $.post('/Gruplar/Delete', { id: id }, function (res) {
                        if (res.success) {
                            Swal.fire('Silindi!', '', 'success').then(function () { location.reload(); });
                        } else {
                            Swal.fire('Hata', res.message || 'Silme işlemi başarısız.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}

