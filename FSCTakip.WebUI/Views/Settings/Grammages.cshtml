@{
    ViewData["Title"] = "Gramaj Tanımları";
}

<div id="filterPanel" class="card mb-3 shadow-sm" style="display:none; border-left: 5px solid #f39c12;">
    <div class="card-body">
        <div class="row">
            <div class="col-md-9 mb-2">
                <label class="small font-weight-bold">Gramaj Değeri (gr)</label>
                <input type="number" class="form-control form-control-sm" placeholder="Örn: 70">
            </div>
            <div class="col-md-3 mb-2 align-self-end">
                <button class="btn btn-primary btn-sm btn-block"><i class="fas fa-search"></i> Filtrele</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-dark">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Gramaj (g/m²)</th>
                        <th>Tolerans (+/-)</th>
                        <th>Durum</th>
                        <th class="text-right">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td><span class="fw-bold text-dark">70 gr</span></td>
                        <td>%3</td>
                        <td><span class="badge badge-success">Aktif</span></td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-light border text-primary" title="Düzenle"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-light border text-danger" title="Sil"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td><span class="fw-bold text-dark">80 gr</span></td>
                        <td>%3</td>
                        <td><span class="badge badge-success">Aktif</span></td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-light border text-primary" title="Düzenle"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-light border text-danger" title="Sil"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addGrammageModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title font-weight-bold"><i class="fas fa-weight-hanging mr-2"></i> Yeni Gramaj</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="grammageForm">
                    <div class="form-group text-center">
                        <label class="small font-weight-bold d-block text-left">Gramaj Değeri (g/m²)</label>
                        <div class="input-group">
                            <input type="number" class="form-control form-control-lg font-weight-bold" placeholder="00">
                            <div class="input-group-append">
                                <span class="input-group-text">gr</span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="small font-weight-bold">Tolerans Aralığı</label>
                        <input type="text" class="form-control" placeholder="Örn: %3">
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-success btn-block shadow-sm"><i class="fas fa-save"></i> Gramaj Tanımla</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // [2026-02-25] Layout'taki ana "Yeni Ekle" butonunu bu modal'a bağladık [cite: 2026-02-25]
            $(".btn-add").attr("onclick", "$('#addGrammageModal').modal('show')");
        });
    </script>
}