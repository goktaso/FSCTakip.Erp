@{
    ViewData["Title"] = "Torba Tip Tanımları";
}

<div id="filterPanel" class="card mb-3 shadow-sm" style="display:none; border-left: 5px solid #f39c12;">
    <div class="card-body">
        <div class="row">
            <div class="col-md-9 mb-2">
                <label class="small font-weight-bold">Torba Tipi veya Teknik Kod</label>
                <input type="text" class="form-control form-control-sm" placeholder="Torba yapısı ara...">
            </div>
            <div class="col-md-3 mb-2 align-self-end">
                <button class="btn btn-primary btn-sm btn-block"><i class="fas fa-search"></i> Filtrele</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-dark">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Torba Tipi</th>
                        <th>Teknik Kod</th>
                        <th>Körük Durumu</th>
                        <th>Pencere</th>
                        <th class="text-right">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td><span class="fw-bold">Dip Kese (V Kesim)</span></td>
                        <td>V-BAG-01</td>
                        <td><span class="badge badge-light border text-dark">Yan Körük</span></td>
                        <td><i class="fas fa-times text-danger"></i> Yok</td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-light border text-primary" title="Düzenle"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-light border text-danger" title="Sil"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td><span class="fw-bold">Blok Dip (Kare)</span></td>
                        <td>B-BAG-02</td>
                        <td><span class="badge badge-light border text-dark">Alt Körük</span></td>
                        <td><i class="fas fa-check text-success"></i> Var</td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-light border text-primary" title="Düzenle"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-light border text-danger" title="Sil"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addBagTypeModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title font-weight-bold"><i class="fas fa-shopping-bag mr-2"></i> Yeni Torba Tipi</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="bagTypeForm">
                    <div class="form-group">
                        <label class="small font-weight-bold">Torba Tanımı</label>
                        <input type="text" class="form-control" placeholder="Örn: Kulplu Blok Dip">
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="small font-weight-bold">Teknik Kod</label>
                                <input type="text" class="form-control" placeholder="BAG-X">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="small font-weight-bold">Körük Tipi</label>
                                <select class="form-control">
                                    <option>Yok</option>
                                    <option>Yan Körük</option>
                                    <option>Alt Körük</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="custom-control custom-switch mt-2">
                        <input type="checkbox" class="custom-control-input" id="windowSwitch">
                        <label class="custom-control-label small font-weight-bold" for="windowSwitch">Pencere Özelliği Var mı?</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary shadow-sm" data-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-success shadow-sm"><i class="fas fa-save"></i> Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // [2026-02-25] Layout'taki ana "Yeni Ekle" butonunu bu sayfadaki modal'a bağladık [cite: 2026-02-25]
            $(".btn-add").attr("onclick", "$('#addBagTypeModal').modal('show')");
        });
    </script>
}