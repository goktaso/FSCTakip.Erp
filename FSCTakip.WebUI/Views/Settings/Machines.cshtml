@{
    ViewData["Title"] = "Makine Tanımlamaları";
}

<div id="filterPanel" class="card mb-3 shadow-sm" style="display:none; border-left: 5px solid #f39c12;">
    <div class="card-body">
        <div class="row">
            <div class="col-md-4 mb-2">
                <label class="small font-weight-bold">Makine Adı</label>
                <input type="text" class="form-control form-control-sm" placeholder="Örn: T-1">
            </div>
            <div class="col-md-4 mb-2">
                <label class="small font-weight-bold">Marka</label>
                <input type="text" class="form-control form-control-sm" placeholder="Örn: Holweg">
            </div>
            <div class="col-md-4 mb-2 align-self-end">
                <button class="btn btn-primary btn-sm btn-block"><i class="fas fa-search"></i> Sorgula</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-dark">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Makine Adı</th>
                        <th>Marka</th>
                        <th>Kapasite (Adet/Dk)</th>
                        <th>Durum</th>
                        <th class="text-right">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td><span class="fw-bold">T-1 (Küçük Boy)</span></td>
                        <td>Garanti</td>
                        <td>120</td>
                        <td><span class="badge badge-success">Aktif</span></td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-light text-primary border"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-light text-danger border"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addMachineModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><i class="fas fa-plus-circle mr-2"></i> Yeni Makine Ekle</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="form-group">
                        <label class="small font-weight-bold">Makine Tanımı</label>
                        <input type="text" class="form-control" placeholder="Örn: NewLong-5">
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <div class="form-group">
                                <label class="small font-weight-bold">Marka</label>
                                <input type="text" class="form-control" placeholder="Marka">
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label class="small font-weight-bold">Kapasite</label>
                                <input type="number" class="form-control" placeholder="Hız">
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
