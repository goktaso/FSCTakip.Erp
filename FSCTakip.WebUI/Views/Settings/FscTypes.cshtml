@{
    ViewData["Title"] = "FSC Sertifika Tipleri";
}

<div id="filterPanel" class="card mb-3 shadow-sm" style="display:none; border-left: 5px solid #f39c12;">
    <div class="card-body">
        <div class="row">
            <div class="col-md-9 mb-2">
                <label class="small font-weight-bold">Sertifika Adı veya Açıklama</label>
                <input type="text" class="form-control form-control-sm" placeholder="FSC tipi ara...">
            </div>
            <div class="col-md-3 mb-2 align-self-end">
                <button class="btn btn-primary btn-sm btn-block"><i class="fas fa-search"></i> Filtrele</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-dark">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Sertifika Tipi</th>
                        <th>Kısa Kod</th>
                        <th>Açıklama</th>
                        <th>Etiket Rengi</th>
                        <th class="text-right">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td><span class="fw-bold text-success">FSC 100%</span></td>
                        <td>FSC-100</td>
                        <td>Tüm malzemeler FSC sertifikalı ormanlardan gelir.</td>
                        <td><span class="badge" style="background-color: #27ae60; color: white;">Yeşil</span></td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-light border text-primary" title="Düzenle"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-light border text-danger" title="Sil"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td><span class="fw-bold text-warning">FSC Mix</span></td>
                        <td>FSC-MIX</td>
                        <td>Sertifikalı ve kontrollü kaynakların karışımıdır.</td>
                        <td><span class="badge" style="background-color: #f39c12; color: white;">Turuncu</span></td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-light border text-primary" title="Düzenle"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-light border text-danger" title="Sil"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addFscTypeModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title font-weight-bold"><i class="fas fa-certificate mr-2"></i> Yeni FSC Tanımı</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="fscTypeForm">
                    <div class="form-group">
                        <label class="small font-weight-bold">Sertifika Tipi Adı</label>
                        <input type="text" class="form-control" placeholder="Örn: FSC Recycled">
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="small font-weight-bold">Kısa Kod</label>
                                <input type="text" class="form-control" placeholder="FSC-REC">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="small font-weight-bold">Renk Kodu (UI)</label>
                                <input type="color" class="form-control form-control-color w-100" value="#27ae60">
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="small font-weight-bold">Sertifika Kapsam Notu</label>
                        <textarea class="form-control" rows="3" placeholder="Bu sertifika hangi şartlarda kullanılır?"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary shadow-sm" data-dismiss="modal">Vazgeç</button>
                <button type="button" class="btn btn-success shadow-sm"><i class="fas fa-save"></i> Sertifikayı Tanımla</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // [2026-02-25] Layout'taki ana "Yeni Ekle" butonunu bu sayfadaki modal'a bağlar [cite: 2026-02-25]
            $(".btn-add").attr("onclick", "$('#addFscTypeModal').modal('show')");
        });
    </script>
}