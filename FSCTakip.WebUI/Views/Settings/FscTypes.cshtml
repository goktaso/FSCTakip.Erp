@{
    ViewData["Title"] = "FSC Sertifika Tipleri";
}

<div id="filterPanel" class="card mb-3 shadow-sm" style="display:none; border-left: 5px solid #f39c12;">
    <div class="card-body py-3">
        <input type="text" class="form-control" placeholder="Sertifika tipi ara (100%, Mix, Recycled)...">
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm border-top-info">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">FSC 100%</h5>
                    <i class="fas fa-check-double text-success"></i>
                </div>
                <p class="small text-muted mt-2">Tüm malzemeler FSC sertifikalı ormanlardan gelmektedir.</p>
                <button class="btn btn-sm btn-block btn-outline-primary">Detayları Düzenle</button>
            </div>
        </div>
    </div>
</div>