@{
    ViewData["Title"] = "Bobin En Tanımları";
}

<div id="filterPanel" class="card mb-3 shadow-sm" style="display:none; border-left: 5px solid #f39c12;">
    <div class="card-body">
        <div class="row">
            <div class="col-md-9 mb-2">
                <label class="small font-weight-bold">Bobin Eni (mm)</label>
                <input type="number" class="form-control form-control-sm" placeholder="Örn: 720">
            </div>
            <div class="col-md-3 mb-2 align-self-end">
                <button class="btn btn-primary btn-sm btn-block"><i class="fas fa-search"></i> Filtrele</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-dark">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Bobin Eni (mm)</th>
                        <th>Kullanım Alanı</th>
                        <th>Kayıt Tarihi</th>
                        <th>Durum</th>
                        <th class="text-right">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td><span class="fw-bold text-dark">720 mm</span></td>
                        <td>Büyük Boy Torba</td>
                        <td>01.03.2026</td>
                        <td><span class="badge badge-success">Aktif</span></td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-light border text-primary" title="Düzenle"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-light border text-danger" title="Sil"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td><span class="fw-bold text-dark">540 mm</span></td>
                        <td>Orta Boy Torba</td>
                        <td>01.03.2026</td>
                        <td><span class="badge badge-success">Aktif</span></td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-light border text-primary" title="Düzenle"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-light border text-danger" title="Sil"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addBobinEnModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title font-weight-bold"><i class="fas fa-ruler-horizontal mr-2"></i> Yeni En Tanımı</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="bobinEnForm">
                    <div class="form-group">
                        <label class="small font-weight-bold">Bobin Eni (mm)</label>
                        <input type="number" class="form-control form-control-lg text-center font-weight-bold" placeholder="000">
                    </div>
                    <div class="form-group">
                        <label class="small font-weight-bold">Açıklama / Not</label>
                        <input type="text" class="form-control" placeholder="Örn: T-1 Makinesi İçin">
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Vazgeç</button>
                <button type="button" class="btn btn-success btn-sm px-4"><i class="fas fa-save"></i> Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // [2026-02-25] Layout'taki ana "Yeni Ekle" butonunu bu sayfadaki modal'a bağlar [cite: 2026-02-25]
            $(".btn-add").attr("onclick", "$('#addBobinEnModal').modal('show')");
        });
    </script>
}