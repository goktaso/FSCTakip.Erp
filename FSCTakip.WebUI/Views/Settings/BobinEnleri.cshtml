@{
    ViewData["Title"] = "Bobin En Tanımları";
}

<div id="filterPanel" class="card mb-3 shadow-sm" style="display:none; border-left: 5px solid #f39c12;">
    <div class="card-body">
        <div class="row">
            <div class="col-md-9 mb-2">
                <input type="number" class="form-control form-control-sm" placeholder="En değeri ara (mm)...">
            </div>
            <div class="col-md-3 mb-2">
                <button class="btn btn-primary btn-sm btn-block">Sorgula</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th>Sıra</th>
                    <th>Bobin Eni (mm)</th>
                    <th>Oluşturma Tarihi</th>
                    <th class="text-right">İşlem</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td><strong>720 mm</strong></td>
                    <td>01.03.2026</td>
                    <td class="text-right">
                        <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>