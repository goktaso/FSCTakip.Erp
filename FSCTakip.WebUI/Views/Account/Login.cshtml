@inject FSCTakip.WebUI.Services.ICompanyBrandingService Branding
@{
    Layout = null;
    ViewData["Title"] = "Giriş Yap";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Giriş Yap — FSC Takip ERP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: #0f1621;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        /* Animated background dots */
        body::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 20% 20%, rgba(25,118,210,.12) 0%, transparent 50%),
                              radial-gradient(circle at 80% 80%, rgba(25,118,210,.08) 0%, transparent 50%);
            pointer-events: none;
        }

        .login-wrapper {
            width: 100%;
            max-width: 420px;
            padding: 20px;
            position: relative;
            z-index: 1;
        }

        /* Logo area */
        .login-logo {
            text-align: center;
            margin-bottom: 28px;
        }
        .login-logo .company-logo {
            width: 220px; max-width: 80%; height: auto;
            display: block; margin: 0 auto 16px;
            object-fit: contain;
            filter: drop-shadow(0 8px 24px rgba(0,0,0,.45));
        }
        .login-logo .company-name {
            font-size: 20px; font-weight: 700; color: #fff;
            letter-spacing: .02em;
        }
        .login-logo .company-sub {
            font-size: 12px; color: rgba(255,255,255,.45);
            text-transform: uppercase; letter-spacing: .1em; margin-top: 4px;
        }
        /* Firma logosu yokken ünvan metni ana marka olur */
        .login-logo .company-name.brand-primary {
            font-size: 26px; margin-top: 8px;
        }
        /* ARD ürün kredisi — küçük, müşteri markasının önüne geçmez */
        .login-logo .dev-credit {
            font-size: 10.5px; color: rgba(255,255,255,.35);
            margin-top: 14px; letter-spacing: .04em;
        }

        /* Card */
        .login-card {
            background: #1a2035;
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 16px;
            padding: 32px 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,.4);
        }

        .login-card h5 {
            font-size: 14px; font-weight: 500;
            color: rgba(255,255,255,.5);
            text-align: center; margin-bottom: 24px;
        }

        .form-label {
            font-size: 12.5px; font-weight: 600;
            color: rgba(255,255,255,.7);
            margin-bottom: 6px;
        }

        .input-group-text {
            background: #0f1621;
            border: 1px solid rgba(255,255,255,.12);
            border-right: none;
            color: rgba(255,255,255,.4);
            font-size: 14px;
        }

        .form-control, .form-select {
            background: #0f1621;
            border: 1px solid rgba(255,255,255,.12);
            border-left: none;
            color: #fff;
            font-size: 14px;
            padding: 10px 14px;
            border-radius: 0 8px 8px 0;
            transition: border-color .2s, box-shadow .2s;
        }
        .form-control:focus, .form-select:focus {
            background: #0f1621;
            color: #fff;
            border-color: #1976d2;
            box-shadow: 0 0 0 3px rgba(25,118,210,.2);
        }
        .form-control::placeholder { color: rgba(255,255,255,.25); }

        .input-group { border-radius: 8px; overflow: hidden; }
        .input-group .input-group-text { border-radius: 8px 0 0 8px; }

        /* Full-border variant for select */
        .form-select-full {
            background: #0f1621;
            border: 1px solid rgba(255,255,255,.12) !important;
            border-left: 1px solid rgba(255,255,255,.12) !important;
            border-radius: 8px !important;
            color: rgba(255,255,255,.7);
        }

        .input-group-icon {
            display: flex;
        }
        .input-group-icon .ig-icon {
            width: 44px; background: #0f1621;
            border: 1px solid rgba(255,255,255,.12);
            border-right: none; border-radius: 8px 0 0 8px;
            display: flex; align-items: center; justify-content: center;
            color: rgba(255,255,255,.4); font-size: 14px; flex-shrink: 0;
        }
        .input-group-icon .form-control,
        .input-group-icon .form-select {
            flex: 1; border-radius: 0 8px 8px 0;
        }

        .btn-login {
            width: 100%; height: 46px;
            background: linear-gradient(135deg, #1976d2, #1565c0);
            border: none; border-radius: 10px;
            color: #fff; font-size: 14px; font-weight: 600;
            letter-spacing: .04em; text-transform: uppercase;
            cursor: pointer; transition: all .2s;
            box-shadow: 0 4px 16px rgba(25,118,210,.35);
            display: flex; align-items: center; justify-content: center; gap: 8px;
            margin-top: 8px;
        }
        .btn-login:hover {
            background: linear-gradient(135deg, #1565c0, #0d47a1);
            box-shadow: 0 6px 24px rgba(25,118,210,.5);
            transform: translateY(-1px);
        }
        .btn-login:active { transform: translateY(0); }

        .alert-danger-custom {
            background: rgba(220,38,38,.12);
            border: 1px solid rgba(220,38,38,.3);
            color: #fca5a5;
            border-radius: 8px;
            font-size: 13px;
            padding: 10px 14px;
            margin-bottom: 18px;
        }

        .login-footer {
            text-align: center;
            margin-top: 20px;
            font-size: 12px;
            color: rgba(255,255,255,.2);
        }

        /* Divider */
        .form-divider { height: 1px; background: rgba(255,255,255,.06); margin: 20px 0; }

        /* Şifre göster/gizle butonu */
        .input-group-icon .pw-toggle {
            width: 44px; flex-shrink: 0;
            background: #0f1621;
            border: 1px solid rgba(255,255,255,.12);
            border-left: none;
            border-radius: 0 8px 8px 0;
            color: rgba(255,255,255,.4); font-size: 14px;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: color .2s;
        }
        .input-group-icon .pw-toggle:hover  { color: #1976d2; }
        .input-group-icon .pw-toggle:focus  { outline: none; color: #1976d2; }
        /* Toggle varken şifre input'unun sağ köşesi düz olsun */
        .input-group-icon .form-control.has-toggle { border-radius: 0; border-right: none; }
    </style>
</head>
<body>
<div class="login-wrapper">

    <div class="login-logo">
        @if (Branding.HasLogo)
        {
            <img src="/Company/Logo" alt="@Branding.CompanyName" class="company-logo" />
            <div class="company-name">@Branding.CompanyName</div>
        }
        else
        {
            @* Logo yoksa firma ünvanı ana marka olarak öne çıkar (ARD logosu basılmaz) *@
            <div class="company-name brand-primary">@Branding.CompanyName</div>
        }
        <div class="company-sub">FSC Takip ERP · Kraft Kağıt İzlenebilirlik Sistemi</div>
        <div class="dev-credit">ARD Sistem ve Danışmanlık tarafından geliştirilmiştir</div>
    </div>

    <div class="login-card">
        <h5>Sisteme Giriş Yapın</h5>

        @if (ViewBag.Error != null)
        {
            <div class="alert-danger-custom">
                <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.Error
            </div>
        }

        <form method="post" action="/Account/Login">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@Context.Request.Query["returnUrl"]" />

            <div class="mb-3">
                <label class="form-label">Kullanıcı Kodu</label>
                <div class="input-group-icon">
                    <div class="ig-icon"><i class="fas fa-user"></i></div>
                    <input type="text" class="form-control" name="username"
                           placeholder="Kullanıcı adınız" autocomplete="username" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Şifre</label>
                <div class="input-group-icon">
                    <div class="ig-icon"><i class="fas fa-lock"></i></div>
                    <input type="password" id="passwordInput" class="form-control has-toggle" name="password"
                           placeholder="••••••••" autocomplete="current-password" required />
                    <button type="button" class="pw-toggle" id="pwToggle"
                            aria-label="Şifreyi göster" title="Şifreyi göster" tabindex="-1">
                        <i class="fas fa-eye" id="pwToggleIcon"></i>
                    </button>
                </div>
            </div>

            <div class="form-divider"></div>

            <div class="mb-3">
                <label class="form-label">Şirket Veritabanı</label>
                <div class="input-group-icon">
                    <div class="ig-icon"><i class="fas fa-database"></i></div>
                    <select class="form-control" style="border-left:none;">
                        <option value="FscErpDb">FscErpDb (Varsayılan)</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn-login">
                <i class="fas fa-sign-in-alt"></i> GİRİŞ YAP
            </button>
        </form>
    </div>

    <div class="login-footer">
        &copy; @DateTime.Now.Year @Branding.CompanyName. Tüm hakları saklıdır.
    </div>

</div>

<script src="~/lib/jquery/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    (function () {
        var input  = document.getElementById('passwordInput');
        var btn    = document.getElementById('pwToggle');
        var icon   = document.getElementById('pwToggleIcon');
        if (!input || !btn) return;
        btn.addEventListener('click', function () {
            var show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            icon.className = show ? 'fas fa-eye-slash' : 'fas fa-eye';
            btn.setAttribute('aria-label', show ? 'Şifreyi gizle' : 'Şifreyi göster');
            btn.setAttribute('title',      show ? 'Şifreyi gizle' : 'Şifreyi göster');
            input.focus();
        });
    })();
</script>
</body>
</html>
