@{
    ViewData["Title"] = "Şifre Değiştir";
}

<div class="d-flex justify-content-center">
    <div class="card shadow-sm" style="max-width:480px;width:100%;border-radius:14px;overflow:hidden;">
        <div class="modal-header dark" style="padding:16px 20px;border-radius:0;">
            <div class="d-flex align-items-center gap-2">
                <div style="width:32px;height:32px;border-radius:8px;background:var(--accent);display:flex;align-items:center;justify-content:center;">
                    <i class="fas fa-key" style="font-size:13px;color:#fff;"></i>
                </div>
                <h5 class="modal-title fw-semibold mb-0 fs-6">Şifre Değiştir</h5>
            </div>
        </div>
        <div class="card-body p-4">
            @if (!string.IsNullOrEmpty(ViewBag.Error as string))
            {
                <div class="alert" style="background:rgba(220,38,38,.10);border:1px solid rgba(220,38,38,.3);color:#fca5a5;border-radius:8px;font-size:13px;padding:10px 14px;">
                    <i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error
                </div>
            }

            <form method="post" action="/Account/ChangePassword">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Mevcut Şifre</label>
                    <div class="input-group">
                        <input type="password" name="currentPassword" id="pwCurrent" class="form-control" required autocomplete="current-password" />
                        <button type="button" class="btn btn-outline-secondary" tabindex="-1"
                                onclick="togglePw('pwCurrent',this)" aria-label="Şifreyi göster/gizle">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Yeni Şifre</label>
                    <div class="input-group">
                        <input type="password" name="newPassword" id="pwNew" class="form-control"
                               placeholder="En az 6 karakter" required autocomplete="new-password" />
                        <button type="button" class="btn btn-outline-secondary" tabindex="-1"
                                onclick="togglePw('pwNew',this)" aria-label="Şifreyi göster/gizle">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold small">Yeni Şifre (Tekrar)</label>
                    <div class="input-group">
                        <input type="password" name="confirmPassword" id="pwConfirm" class="form-control" required autocomplete="new-password" />
                        <button type="button" class="btn btn-outline-secondary" tabindex="-1"
                                onclick="togglePw('pwConfirm',this)" aria-label="Şifreyi göster/gizle">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-save me-1"></i>Şifremi Değiştir
                    </button>
                    <a href="/" class="btn btn-outline-secondary">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePw(id, btn) {
    var inp = document.getElementById(id);
    var icon = btn.querySelector('i');
    if (inp.type === 'password') {
        inp.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
        btn.setAttribute('aria-label', 'Şifreyi gizle');
    } else {
        inp.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
        btn.setAttribute('aria-label', 'Şifreyi göster');
    }
}
</script>
}
