@model IEnumerable<FSCTakip.Core.Entities.PaperColor>
@{
    ViewData["Title"] = "Kağıt Rengi";
}

<div class="card shadow mb-4">
    <div id="filterPanel" class="card-body border-bottom bg-light" style="display:none;">
        <div class="row align-items-end">
            <div class="col-md-9">
                <label class="small font-weight-bold text-uppercase">Renk Ara</label>
                <input type="text" id="searchBox" class="form-control form-control-sm" placeholder="Örn: Beyaz, Kahverengi...">
            </div>
            <div class="col-md-3">
                <button class="btn btn-warning btn-sm btn-block text-white" onclick="filterTable()">
                    <i class="fas fa-search mr-1"></i> Sorgula
                </button>
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="dataTable">
                <thead class="bg-light text-dark text-uppercase small font-weight-bold">
                    <tr>
                        <th style="width:70px;">ID</th>
                        <th>Renk Adı</th>
                        <th>Durum</th>
                        <th class="text-right" style="width:130px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        var safeName = item.Name?.Replace("'", "\\'") ?? "";
                        <tr>
                            <td>@item.Id</td>
                            <td><strong>@item.Name</strong></td>
                            <td>
                                <span class="badge @(item.IsActive ? "badge-success" : "badge-secondary")">
                                    @(item.IsActive ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td class="text-right">
                                <button class="btn btn-sm btn-outline-primary mr-1"
                                        onclick="editItem(@item.Id, '@safeName')">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteItem(@item.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-warning text-white">
                <h5 class="modal-title font-weight-bold"><i class="fas fa-palette mr-2"></i>Kağıt Rengi Formu</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <form asp-action="Save" method="post">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="formId" value="0" />
                    <div class="form-group">
                        <label class="small font-weight-bold">Renk Adı</label>
                        <input type="text" name="Name" id="formName" class="form-control" placeholder="Örn: Beyaz" required />
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-warning btn-sm px-4 text-white">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAddModal() {
            $('#formId').val(0);
            $('#formName').val('');
            $('.modal-title').html('<i class="fas fa-plus mr-2"></i>Yeni Kağıt Rengi');
            $('#addModal').modal('show');
        }
        function editItem(id, name) {
            $('#formId').val(id);
            $('#formName').val(name);
            $('.modal-title').html('<i class="fas fa-edit mr-2"></i>Kağıt Rengi Düzenle');
            $('#addModal').modal('show');
        }
        function filterTable() {
            var v = $('#searchBox').val().toLowerCase();
            $('#dataTable tbody tr').filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(v) > -1);
            });
        }
        function exportToExcel() {
            window.location.href = '/KagitRenk/Export';
        }
        function deleteItem(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: 'Bu kayıt silinecek.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Evet, Sil',
                cancelButtonText: 'Vazgeç'
            }).then(function (r) {
                if (r.isConfirmed) {
                    $.post('/KagitRenk/Delete', { id: id }, function (res) {
                        if (res.success) {
                            Swal.fire('Silindi!', '', 'success').then(function () { location.reload(); });
                        } else {
                            Swal.fire('Hata', res.message || 'Silme işlemi başarısız.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}

