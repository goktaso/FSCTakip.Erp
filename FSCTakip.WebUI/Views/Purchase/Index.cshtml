@section Scripts {
<script>
function showPdfFromBtn(btn) {
    showPdf(btn.dataset.pdfPath, btn.dataset.pdfTitle);
}

/* ─── GLOBAL STATE ───────────────────────────────────────────── */
let _lotEditMode = false;
let _diffRowCount = 0;

/* ─── MODAL AÇMA ─────────────────────────────────────────────── */
function openNewEntryModal() {
    _lotEditMode = false;
    resetLotForm();
    document.getElementById('lotModalTitle').textContent    = 'Yeni Hammadde Girişi';
    document.getElementById('lotModalSubtitle').textContent = 'Parti numarasını tedarikçi belgesinden giriniz';
    document.getElementById('lotModalHint').innerHTML       = '<i class="fas fa-info-circle me-1"></i>Parti No: tedarikçi fatura/irsaliyesindeki parti/seri numarası.';
    document.getElementById('bobinSection').style.display  = '';
    document.getElementById('editModeBobinNote').style.display = 'none';
    document.getElementById('equalModePanel').style.display = '';
    document.getElementById('bobinModeGroup').style.display = '';
    document.getElementById('saveLotBtn').innerHTML = '<i class="fas fa-save me-1"></i> Kaydet';
    bootstrap.Modal.getOrCreateInstance(document.getElementById('lotModal')).show();
}

function resetLotForm() {
    ['lotId','partiNo','truckPlate','dispatchNo','invoiceNo','invoiceAmount','lotNotes'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = '';
    });
    document.getElementById('arrivalDate').value  = new Date().toISOString().split('T')[0];
    document.getElementById('supplierId').value   = '';
    document.getElementById('fscTypeId').value    = '';
    document.getElementById('productId').value    = '';
    document.getElementById('currency').value     = 'TRY';
    document.getElementById('supplierFscWarning').style.display = 'none';
    document.getElementById('eqCount').value  = '';
    document.getElementById('eqWeight').value = '';
    document.getElementById('eqTotal').textContent = '—';
    document.getElementById('modeEqual').checked = true;
    setProductUnit('KG', null);
    showEqualMode();
    _diffRowCount = 0;
    document.getElementById('diffRows').innerHTML = '';
    document.getElementById('diffTotal').textContent = '— kg';
    // Dosya inputlarını sıfırla
    ['dispatchFile','invoiceFile'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = '';
    });
    setPdfFileName('dispatchFile');
    setPdfFileName('invoiceFile');
}

/* ─── DÜZENLEME MODU ─────────────────────────────────────────── */
function editLot(id) {
    _lotEditMode = true;
    fetch(`/Purchase/GetLot/${id}`)
        .then(r => r.json()).then(res => {
            if (!res.success) { showToast(res.message || 'Kayıt yüklenemedi.', 'error'); return; }
            const d = res.data;
            resetLotForm();
            document.getElementById('lotId').value            = d.id;
            document.getElementById('partiNo').value          = d.partiNo || '';
            document.getElementById('arrivalDate').value      = d.arrivalDate;
            document.getElementById('supplierId').value       = d.supplierId;
            document.getElementById('fscTypeId').value        = d.fscTypeId;
            document.getElementById('productId').value        = d.productId || '';
            document.getElementById('truckPlate').value       = d.truckPlate || '';
            document.getElementById('dispatchNo').value       = d.dispatchNo || '';
            document.getElementById('invoiceNo').value        = d.invoiceNo || '';
            document.getElementById('invoiceAmount').value    = d.invoiceAmount || '';
            document.getElementById('currency').value         = d.currency || 'TRY';
            document.getElementById('lotNotes').value         = d.notes || '';
            document.getElementById('lotModalTitle').textContent    = 'Düzenle — Parti ' + d.partiNo;
            document.getElementById('lotModalSubtitle').textContent = d.partiNo;
            document.getElementById('lotModalHint').innerHTML       = '<i class="fas fa-pencil-alt me-1"></i>Belge bilgilerini ve lot detaylarını güncelleyebilirsiniz.';
            // Düzenleme modunda bobin alanını gizle
            document.getElementById('equalModePanel').style.display = 'none';
            document.getElementById('diffModePanel').style.display  = 'none';
            document.getElementById('bobinModeGroup').style.display = 'none';
            document.getElementById('editModeBobinNote').style.display = '';
            document.getElementById('goToDetailLink').href = '/Purchase/Detail/' + d.id;
            document.getElementById('saveLotBtn').innerHTML = '<i class="fas fa-save me-1"></i> Güncelle';
            bootstrap.Modal.getOrCreateInstance(document.getElementById('lotModal')).show();
        })
        .catch(() => showToast('Bağlantı hatası.', 'error'));
}

/* ─── EŞİT / FARKLI MOD DEĞİŞİMİ ───────────────────────────── */
document.querySelectorAll('input[name="bobinMode"]').forEach(r => {
    r.addEventListener('change', () => {
        if (r.value === 'equal') showEqualMode();
        else showDiffMode();
    });
});

function showEqualMode() {
    document.getElementById('equalModePanel').style.display = '';
    document.getElementById('diffModePanel').style.display  = 'none';
}

function showDiffMode() {
    document.getElementById('equalModePanel').style.display = 'none';
    document.getElementById('diffModePanel').style.display  = '';
    if (_diffRowCount === 0) addDiffRow();
}

/* ─── AĞIRLIK BİRİMİ YÖNETİMİ (ürün bazlı, dinamik) ────────── */
let _currentUnit   = 'KG';
let _currentFactor = null;   // null = bilinmiyor (dönüşüm yok)

function setProductUnit(unit, factor) {
    _currentUnit   = (unit || 'KG').toUpperCase();
    _currentFactor = factor > 0 ? factor : null;
    const label = _currentUnit;
    // Birim rozeti
    const badge = document.getElementById('weightUnitBadge');
    badge.textContent = _currentUnit;
    badge.style.display = '';
    // Eşit mod label
    document.getElementById('eqWeightLabel').innerHTML =
        `Birim Ağırlık (${label}) <span class="text-danger">*</span>`;
    document.getElementById('eqWeightUnit').textContent = label;
    // Farklı mod tablo başlığı
    document.getElementById('diffWeightColHeader').textContent = `Ağırlık (${label})`;
    // Mevcut diff satır etiketlerini güncelle
    document.querySelectorAll('.diff-unit-label').forEach(el => el.textContent = label);
    updateEqualTotal();
    updateDiffTotal();
}

/* ─── EŞİT MOD TOPLAM ────────────────────────────────────────── */
function updateEqualTotal() {
    const cnt        = parseFloat(document.getElementById('eqCount').value) || 0;
    const wgt        = parseFloat(document.getElementById('eqWeight').value) || 0;
    const totalInput = cnt * wgt;
    if (totalInput <= 0) {
        document.getElementById('eqTotal').textContent = '—';
        return;
    }
    let txt = totalInput.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 3 })
              + ' ' + _currentUnit;
    if (_currentFactor && _currentUnit !== 'KG') {
        const totalKg = totalInput * _currentFactor;
        txt += ` = ${totalKg.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 0 })} kg`;
    }
    document.getElementById('eqTotal').textContent = txt;
}

/* ─── FARKLI MOD SATIRLARI ───────────────────────────────────── */
function addDiffRow() {
    _diffRowCount++;
    const unit = _currentUnit;
    const tbody = document.getElementById('diffRows');
    const tr = document.createElement('tr');
    tr.id = 'diffRow_' + _diffRowCount;
    tr.innerHTML = `
        <td style="padding:6px 12px;color:#6b7280;font-size:13px;vertical-align:middle;">${_diffRowCount}</td>
        <td style="padding:4px 8px;">
            <div class="input-group input-group-sm">
                <input type="number" class="form-control diff-weight" min="0.001" step="0.001"
                       placeholder="0.000" oninput="updateDiffTotal()">
                <span class="input-group-text diff-unit-label">${unit}</span>
            </div>
        </td>
        <td style="padding:4px 8px;text-align:center;">
            <button type="button" onclick="removeDiffRow(${_diffRowCount})"
                    class="btn btn-sm" style="padding:2px 8px;background:#fef2f2;border:1px solid #fecaca;color:#991b1b;border-radius:6px;">
                <i class="fas fa-times"></i>
            </button>
        </td>`;
    tbody.appendChild(tr);
    tr.querySelector('input').focus();
}

function removeDiffRow(id) {
    const el = document.getElementById('diffRow_' + id);
    if (el) el.remove();
    updateDiffTotal();
}

function updateDiffTotal() {
    let sum = 0;
    document.querySelectorAll('.diff-weight').forEach(inp => {
        sum += parseFloat(inp.value) || 0;
    });
    if (sum <= 0) {
        document.getElementById('diffTotal').textContent = '— kg';
        return;
    }
    let txt = sum.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 3 })
              + ' ' + _currentUnit;
    if (_currentFactor && _currentUnit !== 'KG') {
        const sumKg = sum * _currentFactor;
        txt += ` = ${sumKg.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 0 })} kg`;
    }
    document.getElementById('diffTotal').textContent = txt;
}

/* ─── PDF DROPZONE YARDIMCILARI ─────────────────────────────── */
function setPdfFileName(inputId) {
    const input = document.getElementById(inputId);
    const nameEl = document.getElementById(inputId + 'Name');
    if (!input || !nameEl) return;
    const fileName = input.files && input.files.length ? input.files[0].name : 'Dosya seçilmedi';
    nameEl.textContent = fileName;
}

function initPdfDropzones() {
    const map = ['dispatchFile', 'invoiceFile'];

    map.forEach(inputId => {
        const input = document.getElementById(inputId);
        const zone = document.querySelector(`.pdf-dropzone[data-input-id="${inputId}"]`);
        if (!input || !zone) return;

        input.addEventListener('change', () => setPdfFileName(inputId));

        ['dragenter', 'dragover'].forEach(evt => {
            zone.addEventListener(evt, e => {
                e.preventDefault();
                e.stopPropagation();
                zone.classList.add('is-dragover');
            });
        });

        ['dragleave', 'dragend', 'drop'].forEach(evt => {
            zone.addEventListener(evt, e => {
                e.preventDefault();
                e.stopPropagation();
                zone.classList.remove('is-dragover');
            });
        });

        zone.addEventListener('drop', e => {
            const files = e.dataTransfer?.files;
            if (!files || !files.length) return;
            input.files = files;
            setPdfFileName(inputId);
        });

        setPdfFileName(inputId);
    });
}

initPdfDropzones();

/* ─── ÜRÜN ARAMA + LİSTE FİLTRELEME (TEK ALAN) ─────────────── */
function initProductSelectSearch() {
    const searchInput = document.getElementById('productSearch');
    const productSelect = document.getElementById('productId');
    if (!searchInput || !productSelect) return;

    const allOptions = Array.from(productSelect.options).map(o => ({
        value:  o.value,
        text:   o.textContent,
        search: (o.dataset.search || '').toLowerCase(),
        code:   o.dataset.code   || '',
        unit:   o.dataset.unit   || '',
        factor: o.dataset.factor || ''
    }));

    function renderOptions(term) {
        const q = (term || '').trim().toLowerCase();
        const current = productSelect.value;

        productSelect.innerHTML = '';
        const placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.textContent = '— Ürün seçiniz (stok hareketine işlenir) —';
        productSelect.appendChild(placeholder);

        allOptions.forEach(item => {
            if (!item.value) return;
            if (q && !item.search.includes(q)) return;

            const opt = document.createElement('option');
            opt.value = item.value;
            opt.textContent = item.text;
            opt.dataset.search = item.search;
            opt.dataset.code   = item.code;
            opt.dataset.unit   = item.unit;
            opt.dataset.factor = item.factor;
            productSelect.appendChild(opt);
        });

        if (current && Array.from(productSelect.options).some(o => o.value === current)) {
            productSelect.value = current;
        } else if (productSelect.options.length > 1) {
            productSelect.selectedIndex = 1;
        }
        // selectedIndex ile programatik seçim change event tetiklemez — manuel uygula
        applySelectedProductUnit();
    }

    function applySelectedProductUnit() {
        const sel = Array.from(productSelect.options).find(o => o.value === productSelect.value);
        if (!sel || !sel.value) return;
        const unit   = (sel.dataset.unit   || 'KG').trim().toUpperCase();
        const factor = parseFloat(sel.dataset.factor) || null;
        setProductUnit(unit, factor);
    }

    searchInput.addEventListener('input', function () {
        renderOptions(this.value);
    });

    productSelect.addEventListener('change', function () {
        if (!this.value) return;

        const selected = Array.from(this.options).find(o => o.value === this.value);
        if (!selected) return;

        // Ürün birimini UnitConversion tablosundan gelen data-unit/data-factor ile uygula
        const unit   = (selected.dataset.unit   || 'KG').trim().toUpperCase();
        const factor = parseFloat(selected.dataset.factor) || null;
        setProductUnit(unit, factor);

        // Seçim yapıldıktan sonra liste tek satıra düşsün ama arama kutusu aynen kalsın
        const selectedId     = selected.value;
        const selectedText   = selected.textContent || '';
        const selectedSearch = selected.dataset.search || '';
        const selectedCode   = selected.dataset.code   || '';
        const selectedUnit   = selected.dataset.unit   || '';
        const selectedFactor = selected.dataset.factor || '';

        productSelect.innerHTML = '';
        const opt = document.createElement('option');
        opt.value = selectedId;
        opt.textContent = selectedText;
        opt.dataset.search = selectedSearch;
        opt.dataset.code   = selectedCode;
        opt.dataset.unit   = selectedUnit;
        opt.dataset.factor = selectedFactor;
        productSelect.appendChild(opt);
        productSelect.value = selectedId;
    });

    renderOptions('');
}

initProductSelectSearch();

/* ─── FATURA TUTARI (TR/EN ONDALIK DÜZENLEME) ───────────────── */
function normalizeAmountInput(raw) {
    if (raw == null) return '';
    let v = String(raw).trim();
    if (!v) return '';

    // Sadece rakam, nokta ve virgül bırak
    v = v.replace(/[^\d.,]/g, '');
    if (!v) return '';

    const hasComma = v.includes(',');
    const hasDot = v.includes('.');

    if (hasComma && hasDot) {
        // Son görüleni ondalık kabul et
        const decIndex = Math.max(v.lastIndexOf(','), v.lastIndexOf('.'));
        let intPart = v.slice(0, decIndex).replace(/[.,]/g, '');
        let decPart = v.slice(decIndex + 1).replace(/[.,]/g, '');
        if (!intPart) intPart = '0';
        return decPart ? `${intPart}.${decPart}` : intPart;
    }

    if (hasComma) {
        const parts = v.split(',');
        const intPart = parts[0].replace(/\./g, '') || '0';
        const decPart = parts.slice(1).join('');
        return decPart ? `${intPart}.${decPart}` : intPart;
    }

    // Sadece nokta varsa: birden fazla ise sonuncuyu ondalık kabul et
    const dotParts = v.split('.');
    if (dotParts.length > 2) {
        const decPart = dotParts.pop();
        const intPart = dotParts.join('') || '0';
        return decPart ? `${intPart}.${decPart}` : intPart;
    }

    return v;
}

const invoiceAmountInput = document.getElementById('invoiceAmount');
if (invoiceAmountInput) {
    invoiceAmountInput.addEventListener('input', function () {
        // Yazarken sadece geçersiz karakterleri temizle
        this.value = this.value.replace(/[^\d.,]/g, '');
    });

    invoiceAmountInput.addEventListener('blur', function () {
        // Kayıt öncesi normalize et (3886,80 -> 3886.80)
        this.value = normalizeAmountInput(this.value);
    });
}

/* ─── PURCHASE SAYFASI: TÜM ARAMA → DataTables API ─────────────── */
// Tek gerçek kaynağı DataTables: hem "Ara:" kutusu hem topbar globalSearch
// DataTables.search().draw() üzerinden geçer → draw.dt → kartlar güncellenir.
$(document).on('init.dt', 'table.data-table', function () {
    var dt = $(this).DataTable();
    var searchInput  = document.getElementById('globalSearch');
    var searchDropdown = document.getElementById('searchDropdown');

    // Topbar globalSearch → DataTables arama API'sine yönlendir
    if (searchInput) {
        if (searchDropdown) searchDropdown.classList.remove('show');

        searchInput.addEventListener('input', function (e) {
            if (searchDropdown) searchDropdown.classList.remove('show');
            dt.search(this.value).draw();
            e.stopPropagation();
        }, true);

        searchInput.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                this.value = '';
                dt.search('').draw();
                if (searchDropdown) searchDropdown.classList.remove('show');
                e.preventDefault();
                e.stopPropagation();
            }
        }, true);

        // Sayfa ilk yüklendiğinde topbar'da değer varsa DataTables'a uygula
        if (searchInput.value) dt.search(searchInput.value).draw();
    }
});

/* ─── STAT KART: Her draw (filtre/sayfa/sıralama) sonrası güncelle ─ */
// rows({ search:'applied' }) → filtre uygulanmış TÜM satırlar (paginate'den bağımsız)
$(document).on('draw.dt', 'table.data-table', function () {
    var dt = $(this).DataTable();
    var lot = 0, giris = 0, bobin = 0, kalan = 0;
    dt.rows({ search: 'applied' }).nodes().each(function (tr) {
        lot++;
        giris += parseFloat(tr.dataset.giris) || 0;
        bobin += parseInt(tr.dataset.bobin)   || 0;
        kalan += parseFloat(tr.dataset.kalan) || 0;
    });
    function fmtN(n) { return Math.round(n).toLocaleString('tr-TR'); }
    var g = function (id) { return document.getElementById(id); };
    if (g('cardLot'))   g('cardLot').textContent   = lot;
    if (g('cardGiris')) g('cardGiris').textContent = fmtN(giris);
    if (g('cardBobin')) g('cardBobin').textContent = bobin;
    if (g('cardKalan')) g('cardKalan').textContent = fmtN(kalan);
});

/* ─── TEDARİKÇİ FSC UYARI ───────────────────────────────────── */
document.getElementById('supplierId').addEventListener('change', function () {
    const fscOk = this.options[this.selectedIndex]?.dataset.fsc === 'true';
    document.getElementById('supplierFscWarning').style.display = fscOk ? 'none' : 'block';
});

/* ─── KAYDET ─────────────────────────────────────────────────── */
async function saveLot() {
    const partiNo     = document.getElementById('partiNo').value.trim();
    const supplierId  = document.getElementById('supplierId').value;
    const fscTypeId   = document.getElementById('fscTypeId').value;
    const arrivalDate = document.getElementById('arrivalDate').value;

    if (!partiNo) {
        showToast('Parti No zorunludur.', 'warning');
        document.getElementById('partiNo').focus();
        return;
    }
    if (!supplierId) {
        showToast('Tedarikçi seçimi zorunludur. FSC hammadde girişinde sertifikalı tedarikçi belirtilmelidir.', 'warning');
        document.getElementById('supplierId').focus();
        return;
    }
    const fscWarning = document.getElementById('supplierFscWarning');
    if (fscWarning && fscWarning.style.display !== 'none') {
        const ok = await appConfirm(
            'Seçili tedarikçinin FSC sertifikası geçersiz veya süresi dolmuş. Yine de devam etmek istiyor musunuz?',
            { title: 'FSC Sertifikası Geçersiz', confirmText: 'Devam Et', danger: false }
        );
        if (!ok) return;
    }
    const productId = document.getElementById('productId').value;
    if (!productId) {
        showToast('Ürün seçimi zorunludur.', 'warning');
        document.getElementById('productId').focus();
        return;
    }
    if (!fscTypeId || !arrivalDate) {
        showToast('FSC Tipi ve Geliş Tarihi zorunludur.', 'warning');
        return;
    }

    // Bobin validasyonu (sadece yeni kayıt)
    let serialsJson = null;
    if (!_lotEditMode) {
        const mode = document.querySelector('input[name="bobinMode"]:checked').value;
        if (mode === 'equal') {
            const cnt = parseInt(document.getElementById('eqCount').value);
            const wgt = parseFloat(document.getElementById('eqWeight').value);
            if (!cnt || cnt < 1 || !wgt || wgt <= 0) {
                showToast('Bobin sayısı ve birim ağırlık giriniz.', 'warning');
                return;
            }
            serialsJson = `equal:${cnt}:${wgt}`;   // ham değer; server UnitConversion ile KG'ye çevirir
        } else {
            const weights = [];
            document.querySelectorAll('.diff-weight').forEach(inp => {
                const v = parseFloat(inp.value);
                if (v > 0) weights.push(v);         // ham değer; server dönüştürür
            });
            if (weights.length === 0) {
                showToast('En az 1 bobin ağırlığı giriniz.', 'warning');
                return;
            }
            serialsJson = JSON.stringify(weights);
        }
    }

    const btn = document.getElementById('saveLotBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Kaydediliyor...';

    const fd = new FormData();
    const id = document.getElementById('lotId').value;
    if (id) fd.append('Id', id);
    fd.append('PartiNo',     partiNo);
    fd.append('SupplierId',  supplierId);
    fd.append('FscTypeId',   fscTypeId);
    fd.append('ArrivalDate', arrivalDate);
    fd.append('ProductId', productId);
    fd.append('TruckPlate',  document.getElementById('truckPlate').value);
    fd.append('DispatchNo',  document.getElementById('dispatchNo').value);
    fd.append('InvoiceNo',   document.getElementById('invoiceNo').value);
    const amt = normalizeAmountInput(document.getElementById('invoiceAmount').value);
    if (amt) fd.append('InvoiceAmount', amt);
    fd.append('Currency', document.getElementById('currency').value);
    fd.append('Notes',    document.getElementById('lotNotes').value);
    const df  = document.getElementById('dispatchFile').files[0];
    const inf = document.getElementById('invoiceFile').files[0];
    if (df)  fd.append('dispatchFile', df);
    if (inf) fd.append('invoiceFile',  inf);
    if (serialsJson) fd.append('serialsJson', serialsJson);

    try {
        const res  = await fetch('/Purchase/SaveLot', { method: 'POST', body: fd });
        const json = await res.json();
        if (json.success) {
            bootstrap.Modal.getInstance(document.getElementById('lotModal'))?.hide();
            const cnt  = json.serialCount > 0 ? ` · ${json.serialCount} bobin eklendi` : '';
            showToast(`Parti ${json.partiNo} kaydedildi${cnt}.`, 'success');
            if (json.fscUyari) showToast(json.fscUyari, 'warning');
            setTimeout(() => location.reload(), 1200);
        } else {
            showToast(json.message, 'error');
        }
    } catch (e) {
        showToast('Bağlantı hatası.', 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = _lotEditMode
            ? '<i class="fas fa-save me-1"></i> Güncelle'
            : '<i class="fas fa-save me-1"></i> Kaydet';
    }
}

</script>
}
