@model IEnumerable<FSCTakip.Core.Entities.PaperWeight>
@{
    ViewData["Title"] = "Kağıt Gramaj Tanımları";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="m-0 font-weight-bold text-secondary"><i class="fas fa-weight-hanging mr-2"></i>Gramaj Listesi</h5>
    <div>
        <button class="btn btn-sm btn-outline-secondary" onclick="$('#filterPanel').slideToggle()">
            <i class="fas fa-filter"></i> Filtrele
        </button>
        <button class="btn btn-sm btn-outline-success" onclick="location.href='@Url.Action("ExportWeights", "Paper")'">
            <i class="fas fa-file-excel"></i> Excel
        </button>
        <button class="btn btn-sm btn-outline-dark" onclick="window.print()">
            <i class="fas fa-print"></i> Yazdır
        </button>
        <button class="btn btn-sm btn-secondary text-white" onclick="openAddModal()">
            <i class="fas fa-plus"></i> Yeni Gramaj Ekle
        </button>
    </div>
</div>

@* --- FİLTRELEME PANELİ --- *@
<div id="filterPanel" class="card mb-3 shadow-sm border-left-secondary" style="display:none;">
    <div class="card-body py-3">
        <div class="row align-items-end">
            <div class="col-md-9">
                <label class="small font-weight-bold text-uppercase">Gramaj Ara (Değer veya Birim)</label>
                <input type="text" id="searchTerm" class="form-control form-control-sm" placeholder="Örn: 80 veya gr/m2...">
            </div>
            <div class="col-md-3">
                <button class="btn btn-secondary btn-sm btn-block text-white" onclick="filterTable()">
                    <i class="fas fa-search mr-1"></i> Sorgula
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="weightsTable">
                <thead class="bg-light text-dark text-uppercase small font-weight-bold">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Gramaj (Değer)</th>
                        <th>Birim</th>
                        @* [YENİ]: Durum başlığı eklendi *@
                        <th class="text-center">Durum</th>
                        <th class="text-right" style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><code>#@item.Id</code></td>
                            <td><strong class="text-primary">@item.Value</strong></td>
                            <td><span class="badge badge-light border">@item.Unit</span></td>

                            @* --- [BAŞLANGIÇ: YENİ EKLENEN DURUM SWITCH ALANI] --- *@
                            <td class="text-center">
                                <div class="custom-control custom-switch">
                                    <input type="checkbox" class="custom-control-input" id="status_@item.Id"
                                           @(item.IsActive ? "checked" : "")
                                           onchange="toggleWeightStatus(@item.Id)">
                                    <label class="custom-control-label cursor-pointer" for="status_@item.Id">
                                        <span id="badge_@item.Id" class="badge @(item.IsActive ? "badge-success" : "badge-secondary")">
                                            @(item.IsActive ? "Aktif" : "Pasif")
                                        </span>
                                    </label>
                                </div>
                            </td>
                            @* --- [BİTİŞ: YENİ EKLENEN DURUM SWITCH ALANI] --- *@

                            <td class="text-right">
                                <button class="btn btn-sm btn-outline-primary mr-1"
                                        onclick="editWeight(@item.Id, '@item.Value', '@item.Unit', @item.IsActive.ToString().ToLower())">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteWeight(@item.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* --- MODAL --- *@
<div class="modal fade" id="weightModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-secondary text-white">
                <h6 class="modal-title font-weight-bold">Yeni Gramaj Tanımla</h6>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <form asp-controller="Paper" asp-action="SaveWeight" method="post">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="weightId" value="0" />
                    <div class="form-group">
                        <label class="small font-weight-bold">Gramaj Değeri</label>
                        <input type="number" step="0.01" class="form-control" name="Value" id="weightValue" required>
                    </div>
                    <div class="form-group">
                        <label class="small font-weight-bold">Birim</label>
                        <input type="text" class="form-control" name="Unit" id="weightUnit" value="gr/m2">
                    </div>
                    <div class="custom-control custom-switch mt-3">
                        <input type="checkbox" class="custom-control-input" id="isActiveSwitch" name="IsActive" checked>
                        <label class="custom-control-label small font-weight-bold" for="isActiveSwitch">Aktif</label>
                    </div>
                </div>
                <div class="modal-footer bg-light p-2">
                    <button type="button" class="btn btn-light btn-sm" data-dismiss="modal">Kapat</button>
                    <button type="submit" class="btn btn-secondary btn-sm text-white px-3">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterTable() {
            var value = $("#searchTerm").val().toLowerCase();
            $("#weightsTable tbody tr").filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
            });
        }

        // --- [YENİ EKLENEN: GRAMAJ DURUM GÜNCELLEME (AJAX)] ---
        function toggleWeightStatus(id) {
            $.post('/Paper/ToggleWeightStatus', { id: id }, function (res) {
                if (res.success) {
                    const badge = $(`#badge_${id}`);
                    if (res.isActive) {
                        badge.removeClass('badge-secondary').addClass('badge-success').text('Aktif');
                    } else {
                        badge.removeClass('badge-success').addClass('badge-secondary').text('Pasif');
                    }
                } else {
                    Swal.fire('Hata!', res.message, 'error');
                    $(`#status_${id}`).prop('checked', !$(`#status_${id}`).is(':checked'));
                }
            });
        }

        function openAddModal() {
            $('#weightId').val(0);
            $('#weightValue').val('');
            $('#isActiveSwitch').prop('checked', true);
            $('.modal-title').text('Yeni Gramaj Tanımla');
            $('#weightModal').modal('show');
        }

        function editWeight(id, value, unit, isActive) {
            $('#weightId').val(id);
            $('#weightValue').val(value.replace(',', '.'));
            $('#weightUnit').val(unit);
            $('#isActiveSwitch').prop('checked', isActive);
            $('.modal-title').text('Gramaj Düzenle');
            $('#weightModal').modal('show');
        }

        function deleteWeight(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu gramaj kaydını silmek istediğinize emin misiniz?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#5a5c69',
                cancelButtonColor: '#e74a3b',
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Paper/DeleteWeight', { id: id }, function(res) {
                        if (res.success) {
                            location.reload();
                        } else {
                            Swal.fire('Hata!', res.message, 'error');
                        }
                    });
                }
            })
        }
    </script>
}