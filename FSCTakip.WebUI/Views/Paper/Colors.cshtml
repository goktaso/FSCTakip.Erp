@{
    ViewData["Title"] = "Kağıt Renk Tanımları";
}

<div id="filterPanel" class="card mb-3 shadow-sm border-left-warning" style="display:none;">
    <div class="card-body py-3">
        <div class="row align-items-end">
            <div class="col-md-9">
                <label class="small font-weight-bold text-uppercase">Renk Adı Ara</label>
                <input type="text" id="colorSearch" class="form-control form-control-sm" placeholder="Örn: Beyaz, Kahverengi...">
            </div>
            <div class="col-md-3">
                <button class="btn btn-warning btn-sm btn-block text-white" onclick="filterColors()">
                    <i class="fas fa-search mr-1"></i> Sorgula
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="colorsTable">
                <thead class="bg-light text-dark">
                    <tr>
                        <th style="width: 80px;">Önizleme</th>
                        <th>Renk Adı</th>
                        <th>Renk Kodu (HEX)</th>
                        <th>Durum</th>
                        <th class="text-right" style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><div style="width:30px; height:30px; background:#FFFFFF; border:1px solid #ddd; border-radius:4px;"></div></td>
                        <td><strong>Beyaz (Standart)</strong></td>
                        <td><code>#FFFFFF</code></td>
                        <td><span class="badge badge-success">Aktif</span></td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-outline-primary mr-1"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td><div style="width:30px; height:30px; background:#D2B48C; border:1px solid #ddd; border-radius:4px;"></div></td>
                        <td><strong>Kahverengi / Kraft</strong></td>
                        <td><code>#D2B48C</code></td>
                        <td><span class="badge badge-success">Aktif</span></td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-outline-primary mr-1"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addColorModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-warning text-white p-2 pl-3">
                <h6 class="modal-title font-weight-bold"><i class="fas fa-palette mr-2"></i>Yeni Renk Ekle</h6>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="small font-weight-bold">Renk Tanımı</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Örn: Somon">
                </div>
                <div class="form-group">
                    <label class="small font-weight-bold">Renk Seçimi</label>
                    <input type="color" class="form-control form-control-sm" style="height:45px; cursor:pointer;">
                </div>
            </div>
            <div class="modal-footer bg-light p-2">
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Kapat</button>
                <button type="button" class="btn btn-warning btn-sm px-3 text-white">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Layout'taki global "Yeni Ekle" butonuyla tetiklenir
        function openAddModal() {
            $('#addColorModal').modal('show');
        }

        function filterColors() {
            var value = $("#colorSearch").val().toLowerCase();
            $("#colorsTable tbody tr").filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        }
    </script>
}