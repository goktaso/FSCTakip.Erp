@model IEnumerable<FSCTakip.Core.Entities.PaperType>
@{
    ViewData["Title"] = "Kağıt Tipi Tanımları";
}

@* --- ÜST PANEL: Standart Buton Grubu (Filtre, Excel, Yazdır, Ekle) --- *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="m-0 font-weight-bold text-secondary"><i class="fas fa-layer-group mr-2"></i>Kağıt Tipi Listesi</h5>
    <div>
        <button class="btn btn-sm btn-outline-secondary" onclick="$('#filterPanel').slideToggle()">
            <i class="fas fa-filter"></i> Filtrele
        </button>
        <button class="btn btn-sm btn-outline-success" onclick="exportToExcel()">
            <i class="fas fa-file-excel"></i> Excel
        </button>
        <button class="btn btn-sm btn-outline-dark" onclick="window.print()">
            <i class="fas fa-print"></i> Yazdır
        </button>
        <button class="btn btn-sm btn-secondary text-white" onclick="openAddModal()">
            <i class="fas fa-plus"></i> Yeni Tip Ekle
        </button>
    </div>
</div>

@* --- FİLTRELEME PANELİ --- *@
<div id="filterPanel" class="card mb-3 shadow-sm border-left-secondary" style="display:none;">
    <div class="card-body py-3">
        <div class="row align-items-end">
            <div class="col-md-9">
                <label class="small font-weight-bold text-uppercase">Kağıt Tipi Ara</label>
                <input type="text" id="searchTerm" class="form-control form-control-sm" placeholder="Örn: Kraft, Sülfit...">
            </div>
            <div class="col-md-3">
                <button class="btn btn-secondary btn-sm btn-block text-white" onclick="filterTable()">
                    <i class="fas fa-search mr-1"></i> Sorgula
                </button>
            </div>
        </div>
    </div>
</div>

@* --- TABLO ALANI --- *@
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="typesTable">
                <thead class="bg-light text-dark text-uppercase small font-weight-bold">
                    <tr>
                        <th style="width: 60px;">ID</th>
                        <th>Kağıt Tipi Adı</th>
                        <th>Kısa Kod</th>
                        @* [YENİ]: Durum Switch Sütunu *@
                        <th class="text-center">Durum</th>
                        <th class="text-right" style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><code>#@item.Id</code></td>
                                <td><strong class="text-primary">@item.Name</strong></td>
                                <td><span class="badge badge-light border">@item.ShortCode</span></td>

                                @* --- [BAŞLANGIÇ: YENİ DURUM SWITCH] --- *@
                                <td class="text-center">
                                    <div class="custom-control custom-switch">
                                        <input type="checkbox" class="custom-control-input" id="status_@item.Id"
                                               @(item.IsActive ? "checked" : "")
                                               onchange="toggleTypeStatus(@item.Id)">
                                        <label class="custom-control-label cursor-pointer" for="status_@item.Id">
                                            <span id="badge_@item.Id" class="badge @(item.IsActive ? "badge-success" : "badge-secondary")">
                                                @(item.IsActive ? "Aktif" : "Pasif")
                                            </span>
                                        </label>
                                    </div>
                                </td>
                                @* --- [BİTİŞ: YENİ DURUM SWITCH] --- *@

                                <td class="text-right">
                                    <button class="btn btn-sm btn-outline-primary mr-1"
                                            onclick="editType(@item.Id, '@(item.Name?.Replace("'", "\\'") ?? "")', '@(item.ShortCode?.Replace("'", "\\'") ?? "")', @item.IsActive.ToString().ToLower())">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteType(@item.Id)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* --- MODAL: EKLE/DÜZENLE --- *@
<div class="modal fade" id="addTypeModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-secondary text-white">
                <h6 class="modal-title font-weight-bold">Kağıt Tipi Formu</h6>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <form asp-controller="Paper" asp-action="SaveType" method="post">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="typeId" value="0" />
                    <div class="form-group">
                        <label class="small font-weight-bold">Kağıt Tipi Adı <span class="text-danger">*</span></label>
                        <input type="text" name="Name" id="typeName" class="form-control" required placeholder="Örn: Testliner">
                    </div>
                    <div class="form-group">
                        <label class="small font-weight-bold">Kısa Kod (ERP Kodu)</label>
                        <input type="text" name="ShortCode" id="typeShortCode" class="form-control" placeholder="Örn: TST">
                    </div>
                    <div class="custom-control custom-switch mt-3">
                        <input type="checkbox" class="custom-control-input" id="isActiveSwitch" name="IsActive" checked>
                        <label class="custom-control-label small font-weight-bold" for="isActiveSwitch">Aktif</label>
                    </div>
                </div>
                <div class="modal-footer bg-light p-2">
                    <button type="button" class="btn btn-light btn-sm" data-dismiss="modal">Kapat</button>
                    <button type="submit" class="btn btn-secondary btn-sm px-3 text-white">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tablo filtreleme
        function filterTable() {
            var value = $("#searchTerm").val().toLowerCase();
            $("#typesTable tbody tr").filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
            });
        }

        // --- [YENİ: DURUM GÜNCELLEME (AJAX)] ---
        function toggleTypeStatus(id) {
            $.post('/Paper/ToggleTypeStatus', { id: id }, function (res) {
                if (res.success) {
                    const badge = $(`#badge_${id}`);
                    if (res.isActive) {
                        badge.removeClass('badge-secondary').addClass('badge-success').text('Aktif');
                    } else {
                        badge.removeClass('badge-success').addClass('badge-secondary').text('Pasif');
                    }
                } else {
                    Swal.fire('Hata!', res.message, 'error');
                    $(`#status_${id}`).prop('checked', !$(`#status_${id}`).is(':checked'));
                }
            });
        }

        function openAddModal() {
            $('#typeId').val(0);
            $('#typeName').val('');
            $('#typeShortCode').val('');
            $('#isActiveSwitch').prop('checked', true);
            $('.modal-title').text('Yeni Kağıt Tipi');
            $('#addTypeModal').modal('show');
        }

        function editType(id, name, shortCode, isActive) {
            $('#typeId').val(id);
            $('#typeName').val(name);
            $('#typeShortCode').val(shortCode);
            $('#isActiveSwitch').prop('checked', isActive);
            $('.modal-title').text('Kağıt Tipi Düzenle');
            $('#addTypeModal').modal('show');
        }

        function deleteType(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: 'Bu kağıt tipi silinecektir!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#5a5c69',
                cancelButtonColor: '#e74a3b',
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Paper/DeleteType', { id: id }, function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            Swal.fire('Hata!', response.message, 'error');
                        }
                    });
                }
            });
        }

        function exportToExcel() {
            window.location.href = '/Paper/ExportTypes';
        }
    </script>
}