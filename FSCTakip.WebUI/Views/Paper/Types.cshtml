@{
    ViewData["Title"] = "Kağıt Tipi Tanımları";
}
@model IEnumerable<FSCTakip.Core.Entities.PaperType>

<div class="card shadow mb-4">
@* [2026-02-25] Kuralı: Ortak buton yapısı. Başlığı gönderiyoruz. *@
@await Html.PartialAsync("_TableActions", "Kağıt Tipleri")

<div id="filterPanel" class="card mb-3 shadow-sm border-left-primary" style="display:none;">
    <div class="card-body py-3">
        <div class="row align-items-end">
            <div class="col-md-9">
                <label class="small font-weight-bold text-uppercase">Kağıt Tipi Ara</label>
                <input type="text" id="searchTerm" class="form-control form-control-sm" placeholder="Örn: Kraft, Sülfit...">
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary btn-sm btn-block" onclick="filterTable()">
                    <i class="fas fa-search mr-1"></i> Sorgula
                </button>
            </div>
        </div>
    </div>
    </div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="typesTable">
                <thead class="bg-light text-dark">
                    <tr>
                        <th style="width: 60px;">ID</th>
                        <th>Kağıt Tipi Adı</th>
                        <th>Kısa Kod</th>
                        <th>Durum</th>
                        <th class="text-right" style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td><strong>Kraft Kağıt</strong></td>
                        <td><span class="badge badge-secondary">KRT</span></td>
                        <td><span class="badge badge-success">Aktif</span></td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-outline-primary mr-1" title="Düzenle"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger" title="Sil"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td><strong>Sülfit Kağıt</strong></td>
                        <td><span class="badge badge-secondary">SLF</span></td>
                        <td><span class="badge badge-success">Aktif</span></td>
                        <td class="text-right">
                            <button class="btn btn-sm btn-outline-primary mr-1"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addTypeModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-plus-circle mr-2"></i>Yeni Kağıt Tipi</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="small font-weight-bold">Kağıt Tipi Adı</label>
                    <input type="text" class="form-control" placeholder="Örn: Testliner">
                </div>
                <div class="form-group">
                    <label class="small font-weight-bold">Kısa Kod (ERP Kodu)</label>
                    <input type="text" class="form-control" placeholder="Örn: TST">
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Vazgeç</button>
                <button type="button" class="btn btn-primary btn-sm px-4">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Layout'taki global "Yeni Ekle" butonuyla tetiklenir
        function openAddModal() {
            $('#addTypeModal').modal('show');
        }

        function filterTable() {
            var value = $("#searchTerm").val().toLowerCase();
            $("#typesTable tbody tr").filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        }
    </script>
}