@model FSCTakip.WebUI.Services.LicenseInfo
@using FSCTakip.WebUI.Services
@{
    Layout = null;
    var isValid = Model.State == LicenseState.Valid;
    var isTrial = Model.State == LicenseState.Trial;
    var (stateText, stateColor, stateBg) = Model.State switch
    {
        LicenseState.Valid           => ("Lisans Geçerli", "#166534", "#dcfce7"),
        LicenseState.Trial           => ($"Deneme Sürümü — {Model.TrialDaysLeft} Gün Kaldı", "#92400e", "#fef3c7"),
        LicenseState.Missing         => ("Lisans Dosyası Bulunamadı", "#991b1b", "#fee2e2"),
        LicenseState.Expired         => ("Lisans Süresi Dolmuş", "#991b1b", "#fee2e2"),
        LicenseState.MachineMismatch => ("Lisans Bu Sunucuya Ait Değil", "#991b1b", "#fee2e2"),
        _                            => ("Lisans Geçersiz", "#991b1b", "#fee2e2")
    };
}
<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Lisans Durumu — FSC Takip ERP</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root { --brand:#1976d2; --brand-dark:#1565c0; --bg-dark:#0f1621; --surface:#1a2035;
        --border:rgba(255,255,255,.12); --text:#fff; --text-muted:rgba(255,255,255,.7); }
* { box-sizing:border-box; margin:0; padding:0; }
body { font-family:'Inter','Segoe UI',sans-serif; background:var(--bg-dark); color:var(--text);
       min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px; }
.card { background:var(--surface); border:1px solid var(--border); border-radius:16px;
        max-width:560px; width:100%; padding:36px; box-shadow:0 20px 60px rgba(0,0,0,.4); }
h1 { font-size:18px; font-weight:700; margin-bottom:4px; }
.sub { color:var(--text-muted); font-size:13px; margin-bottom:24px; }
.state { display:inline-block; padding:8px 16px; border-radius:8px; font-weight:700; font-size:14px; margin-bottom:20px; }
.row { display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid rgba(255,255,255,.08); font-size:13px; }
.row .k { color:var(--text-muted); }
.machine { font-family:Consolas,monospace; font-size:16px; letter-spacing:2px; background:var(--bg-dark);
           border:1px dashed var(--border); border-radius:8px; padding:12px; text-align:center; margin:16px 0; user-select:all; }
.note { font-size:12px; color:var(--text-muted); line-height:1.6; margin-top:8px; }
.up { margin-top:24px; padding-top:20px; border-top:1px solid var(--border); }
input[type=file] { width:100%; background:var(--bg-dark); border:1px solid var(--border); border-radius:8px;
                   padding:10px; color:var(--text); font-size:13px; margin-bottom:12px; }
button { width:100%; background:linear-gradient(135deg,var(--brand),var(--brand-dark)); color:#fff; border:none;
         border-radius:10px; padding:12px; font-weight:700; text-transform:uppercase; letter-spacing:.04em;
         cursor:pointer; font-size:13px; }
button:hover { transform:translateY(-1px); box-shadow:0 6px 24px rgba(25,118,210,.5); }
.msg { margin-top:12px; font-size:13px; padding:10px 12px; border-radius:8px; display:none; }
a.back { display:inline-block; margin-top:16px; color:var(--brand); font-size:13px; text-decoration:none; }
</style>
</head>
<body>
<div class="card">
    <h1>FSC Takip ERP — Lisans Durumu</h1>
    <div class="sub">ARD Sistem ve Danışmanlık</div>

    <span class="state" style="color:@stateColor;background:@stateBg;">@stateText</span>

    @if (isValid)
    {
        <div class="row"><span class="k">Lisans Sahibi</span><span>@Model.LicensedTo</span></div>
        <div class="row"><span class="k">Lisans No</span><span>@Model.LicenseId</span></div>
        <div class="row"><span class="k">Geçerlilik</span><span>@(Model.ValidUntil?.ToString("dd.MM.yyyy") ?? "Süresiz")</span></div>
        <a class="back" href="/">← Uygulamaya dön</a>
    }
    else
    {
        @if (isTrial)
        {
            <div class="row"><span class="k">Deneme Bitişi</span><span>@Model.ValidUntil?.ToString("dd.MM.yyyy")</span></div>
            <div class="note">
                Sistem deneme süresi boyunca tüm özellikleriyle kullanılabilir; süre dolduğunda
                erişim kapanır ve <strong>veriler korunur</strong>. Kalıcı lisans için aşağıdaki
                <strong>sunucu kimlik kodunu</strong> ARD Sistem ve Danışmanlık'a iletin;
                size bu sunucuya özel bir <code>license.lic</code> dosyası gönderilecektir.
            </div>
        }
        else
        {
            <div class="note">
                Uygulamayı kullanabilmek için geçerli bir lisans dosyası gereklidir.
                Aşağıdaki <strong>sunucu kimlik kodunu</strong> ARD Sistem ve Danışmanlık'a iletin;
                size bu sunucuya özel bir <code>license.lic</code> dosyası gönderilecektir.
            </div>
        }
        <div class="machine">@Model.MachineKey</div>
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="note">Ayrıntı: @Model.Error</div>
        }
        <div class="up">
            <input type="file" id="licFile" accept=".lic" />
            <button onclick="uploadLic()">Lisans Dosyasını Yükle</button>
            <div class="msg" id="licMsg"></div>
        </div>
        @if (isTrial)
        {
            <a class="back" href="/">← Uygulamaya dön</a>
        }
    }
</div>

<script>
async function uploadLic() {
    const f = document.getElementById('licFile').files[0];
    const msg = document.getElementById('licMsg');
    if (!f) { show('Önce dosya seçin.', false); return; }
    const fd = new FormData(); fd.append('file', f);
    try {
        const r = await fetch('/License/Upload', { method: 'POST', body: fd });
        const j = await r.json();
        show(j.message, j.success);
        if (j.success) setTimeout(() => location.href = '/', 1200);
    } catch { show('Bağlantı hatası.', false); }
    function show(t, ok) {
        msg.style.display = 'block';
        msg.textContent = t;
        msg.style.background = ok ? '#dcfce7' : '#fee2e2';
        msg.style.color = ok ? '#166534' : '#991b1b';
    }
}
</script>
</body>
</html>
