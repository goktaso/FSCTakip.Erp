@model IEnumerable<FSCTakip.Core.Entities.Unit>
@{
    ViewData["Title"] = "Birim Tanımları";
}

@* 1. Filtre Paneli (Turuncu Kenarlıklı Standart) *@
<div id="filterPanel" class="card mb-3 shadow-sm" style="display:none; border-left: 5px solid #f39c12;">
    <div class="card-body text-center py-4">
        <div class="d-flex justify-content-center gap-3">
            <input type="text" id="unitSearchInput" class="form-control w-50" placeholder="Birim adı veya kısa kod ara...">
            <button class="btn btn-warning text-white px-4" onclick="filterTable()">Listele</button>
        </div>
    </div>
</div>

@* 2. Liste Kartı *@
<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3">
        <h6 class="m-0 font-weight-bold text-secondary"><i class="fas fa-layer-group mr-2"></i> Birim Listesi</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="mainTable">
                <thead class="bg-light text-muted text-uppercase">
                    <tr>
                        <th style="width: 70px;">ID</th>
                        <th>BİRİM ADI</th>
                        <th>KISA KOD</th>
                        <th style="width: 160px;">DURUM</th>
                        <th style="width: 120px;" class="text-center">İŞLEMLER</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-danger small font-weight-bold">#@item.Id</td>
                            <td><span class="font-weight-bold text-primary">@item.Name</span></td>
                            <td><span class="badge badge-light border px-2 py-1">@item.ShortCode</span></td>
                            <td>
                                <div class="d-flex align-items-center">
                                    @* Kayan Çubuk (Toggle Switch) *@
                                    <div class="custom-control custom-switch mr-2">
                                        <input type="checkbox" class="custom-control-input" id="switch_@item.Id"
                                               @(item.IsActive ? "checked" : "")
                                               onchange="toggleStatus(@item.Id)">
                                        <label class="custom-control-label" for="switch_@item.Id"></label>
                                    </div>
                                    @* Rozet (Label) *@
                                    <span id="badge_@item.Id" class="badge @(item.IsActive ? "badge-success" : "badge-danger") px-2" style="min-width: 50px;">
                                        @(item.IsActive ? "Aktif" : "Pasif")
                                    </span>
                                </div>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary mr-1" onclick="editUnit(@item.Id)" title="Düzenle">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteUnit(@item.Id)" title="Sil">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* 3. Kayıt/Düzenleme Modalı *@
<div class="modal fade" id="unitModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title font-weight-bold">Birim Tanımı</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="Save" method="post">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="unitId" value="0" />
                    <div class="form-group">
                        <label class="small font-weight-bold text-uppercase">Birim Adı</label>
                        <input type="text" name="Name" id="unitName" class="form-control" required placeholder="Örn: ADET">
                    </div>
                    <div class="form-group">
                        <label class="small font-weight-bold text-uppercase">Kısa Kod</label>
                        <input type="text" name="ShortCode" id="unitShortCode" class="form-control" placeholder="Örn: PCS">
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary shadow-sm" data-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-success shadow-sm px-4"><i class="fas fa-save mr-1"></i> Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Layout'taki mor "Yeni Ekle" butonuna fonksiyonu bağla
            $(".btn-add").off("click").removeAttr("onclick").on("click", function(e) {
                e.preventDefault();
                openNewModal();
            });

            // Filtre paneli aç/kapat
            $(".btn-filter-toggle").on("click", function() {
                $('#filterPanel').slideToggle();
            });
        });

        // Yeni Kayıt Modalı
        function openNewModal() {
            $('#unitId').val(0);
            $('#unitName').val('');
            $('#unitShortCode').val('');
            $('#unitModal').modal('show');
        }

        // Düzenleme Verisini Getir
        function editUnit(id) {
            $.get("/Units/GetUnit/" + id, function(res) {
                if(res.success) {
                    $('#unitId').val(res.id);
                    $('#unitName').val(res.name);
                    $('#unitShortCode').val(res.shortCode);
                    $('#unitModal').modal('show');
                }
            });
        }

        // Aktif/Pasif Switch Değişimi
        function toggleStatus(id) {
            $.post("/Units/ToggleStatus/" + id, function(res) {
                if(res.success) {
                    var badge = $("#badge_" + id);
                    if(res.isActive) {
                        badge.text("Aktif").removeClass("badge-danger").addClass("badge-success");
                    } else {
                        badge.text("Pasif").removeClass("badge-success").addClass("badge-danger");
                    }
                }
            });
        }

        // Havalı Silme İşlemi (SweetAlert2)
        function deleteUnit(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu birim tanımı kalıcı olarak silinecektir!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post("/Units/Delete/" + id, function (res) {
                        if (res.success) {
                            Swal.fire({
                                title: 'Silindi!',
                                text: 'Birim başarıyla kaldırıldı.',
                                icon: 'success',
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire(
                                'Hata!',
                                res.message || 'Silme işlemi sırasında bir hata oluştu.',
                                'error'
                            );
                        }
                    });
                }
            });
        }

        // Tablo içi Arama (Hızlı Filtre)
        function filterTable() {
            var val = $("#unitSearchInput").val().toUpperCase();
            $("#mainTable tbody tr").each(function() {
                $(this).toggle($(this).text().toUpperCase().indexOf(val) > -1);
            });
        }
    </script>

    <style>
        /* Görüntüdeki Toggle Switch Tasarımı */
        .custom-switch .custom-control-label::before {
            height: 1.5rem;
            width: 2.5rem;
            border-radius: 1rem;
        }

        .custom-switch .custom-control-label::after {
            width: calc(1.5rem - 4px);
            height: calc(1.5rem - 4px);
            border-radius: 1rem;
            top: calc(0.25rem + 2px);
        }

        .custom-switch .custom-control-input:checked ~ .custom-control-label::after {
            transform: translateX(1rem);
        }

        /* Tablo ve Badge Detayları */
        .table thead th {
            font-size: 11px;
            letter-spacing: 0.5px;
            border-bottom: 2px solid #f0f0f0;
            vertical-align: middle;
        }

        .gap-3 {
            gap: 1rem;
        }

        .badge {
            font-weight: 500;
            font-size: 85%;
        }

        .text-primary {
            color: #007bff !important;
        }
    </style>
}