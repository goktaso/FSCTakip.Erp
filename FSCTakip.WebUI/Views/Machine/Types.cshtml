@model IEnumerable<FSCTakip.Core.Entities.MachineType>
@{
    ViewData["Title"] = "Makine Türü Tanımları";
}

<div class="topbar-area">
    <div class="d-flex align-items-center gap-2">
        <button class="btn-topbar-add" onclick="openAddModal()">
            <span class="btn-add-icon"><i class="fas fa-plus"></i></span>
            Yeni Tür Ekle
        </button>
    </div>
    <div class="d-flex gap-2 ms-auto align-items-center">
        <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Machines", "Machine")">
            <i class="fas fa-arrow-left"></i> Makinelere Dön
        </a>
        <button class="btn btn-sm btn-outline-secondary" onclick="$('#filterPanel').slideToggle()">
            <i class="fas fa-filter"></i> Filtrele
        </button>
        <button class="btn btn-sm btn-outline-success" onclick="exportToExcel()">
            <i class="fas fa-file-excel"></i> Excel
        </button>
        <span class="topbar-user">
            <i class="fas fa-user-circle"></i>
            @(User.Identity?.Name ?? "Kullanıcı")
        </span>
    </div>
</div>

@* --- FİLTRELEME PANELİ --- *@
<div id="filterPanel" class="card mb-3 shadow-sm border-left-secondary" style="display:none;">
    <div class="card-body py-3">
        <div class="row align-items-end">
            <div class="col-md-9">
                <label class="small font-weight-bold text-uppercase">Makine Türü Ara</label>
                <input type="text" id="searchTerm" class="form-control form-control-sm" placeholder="Örn: Baskı, Kesim...">
            </div>
            <div class="col-md-3">
                <button class="btn btn-secondary btn-sm btn-block text-white" onclick="filterTable()">
                    <i class="fas fa-search mr-1"></i> Sorgula
                </button>
            </div>
        </div>
    </div>
</div>

@* --- TABLO ALANI --- *@
<div class="card shadow-sm border-0 table-card">
    <div class="table-header">
        <div class="d-flex align-items-center gap-2">
            <i class="fas fa-tags text-primary"></i>
            <span>Makine Türü Listesi</span>
            <span class="badge badge-blue">@Model.Count() kayıt</span>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 data-table" id="typesTable">
                <thead class="bg-light text-dark text-uppercase small font-weight-bold">
                    <tr>
                        <th style="width: 60px;">ID</th>
                        <th>Makine Türü Adı</th>
                        <th class="text-center">Durum</th>
                        <th class="text-right" style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><code>#@item.Id</code></td>
                                <td><strong class="text-primary">@item.Name</strong></td>

                                <td class="text-center">
                                    <div class="custom-control custom-switch">
                                        <input type="checkbox" class="custom-control-input" id="status_@item.Id"
                                               @(item.IsActive ? "checked" : "")
                                               onchange="toggleTypeStatus(@item.Id)">
                                        <label class="custom-control-label cursor-pointer" for="status_@item.Id">
                                            <span id="badge_@item.Id" class="badge @(item.IsActive ? "badge-success" : "badge-secondary")">
                                                @(item.IsActive ? "Aktif" : "Pasif")
                                            </span>
                                        </label>
                                    </div>
                                </td>

                                <td class="text-right">
                                    <button class="btn btn-sm btn-outline-primary mr-1"
                                            onclick="editType(@item.Id, '@(item.Name?.Replace("'", "\\'") ?? "")', @item.IsActive.ToString().ToLower())">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteType(@item.Id)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="fas fa-tags"></i></div>
                                <h6>Henüz makine türü kaydı yok</h6>
                                <p>+ Yeni Tür Ekle butonunu kullanın.</p>
                            </div>
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* --- MODAL: EKLE/DÜZENLE --- *@
<div class="modal fade" id="addTypeModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header dark">
                <h6 class="modal-title font-weight-bold"><i class="fas fa-tags mr-2"></i>Makine Türü Formu</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Machine" asp-action="SaveType" method="post">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="typeId" value="0" />
                    <div class="form-group">
                        <label class="small font-weight-bold">Makine Türü Adı <span class="text-danger">*</span></label>
                        <input type="text" name="Name" id="typeName" class="form-control" required placeholder="Örn: Baskı">
                    </div>
                    <div class="custom-control custom-switch mt-3">
                        <input type="checkbox" class="custom-control-input" id="isActiveSwitch" name="IsActive" checked>
                        <label class="custom-control-label small font-weight-bold" for="isActiveSwitch">Aktif</label>
                    </div>
                </div>
                <div class="modal-footer bg-light p-2">
                    <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Kapat</button>
                    <button type="submit" class="btn btn-secondary btn-sm px-3 text-white">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterTable() {
            var value = $("#searchTerm").val().toLowerCase();
            $("#typesTable tbody tr").filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
            });
        }

        function toggleTypeStatus(id) {
            $.post('/Machine/ToggleTypeStatus', { id: id }, function (res) {
                if (res.success) {
                    const badge = $(`#badge_${id}`);
                    if (res.isActive) {
                        badge.removeClass('badge-secondary').addClass('badge-success').text('Aktif');
                    } else {
                        badge.removeClass('badge-success').addClass('badge-secondary').text('Pasif');
                    }
                } else {
                    Swal.fire('Hata!', res.message, 'error');
                    $(`#status_${id}`).prop('checked', !$(`#status_${id}`).is(':checked'));
                }
            });
        }

        function openAddModal() {
            $('#typeId').val(0);
            $('#typeName').val('');
            $('#isActiveSwitch').prop('checked', true);
            $('.modal-title').html('<i class="fas fa-plus mr-2"></i>Yeni Makine Türü');
            bootstrap.Modal.getOrCreateInstance(document.getElementById('addTypeModal')).show();
        }

        function editType(id, name, isActive) {
            $('#typeId').val(id);
            $('#typeName').val(name);
            $('#isActiveSwitch').prop('checked', isActive);
            $('.modal-title').html('<i class="fas fa-edit mr-2"></i>Makine Türü Düzenle');
            bootstrap.Modal.getOrCreateInstance(document.getElementById('addTypeModal')).show();
        }

        function deleteType(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: 'Bu makine türü silinecektir!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#5a5c69',
                cancelButtonColor: '#e74a3b',
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Machine/DeleteType', { id: id }, function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            Swal.fire('Hata!', response.message, 'error');
                        }
                    });
                }
            });
        }

        function exportToExcel() {
            window.location.href = '/Machine/ExportTypes';
        }
    </script>
}
