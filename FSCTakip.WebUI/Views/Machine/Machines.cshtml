@model IEnumerable<FSCTakip.Core.Entities.Machine>
@{
    ViewData["Title"] = "Makine Tanımlamaları";
    var machineTypes = ViewBag.MachineTypes as List<FSCTakip.Core.Entities.MachineType> ?? new();
}

<div class="topbar-area">
    <div class="d-flex align-items-center gap-2">
        <button class="btn-topbar-add" onclick="openAddModal()">
            <span class="btn-add-icon"><i class="fas fa-plus"></i></span>
            Yeni Makine Ekle
        </button>
    </div>
    <div class="d-flex gap-2 ms-auto align-items-center">
        <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Types", "Machine")">
            <i class="fas fa-tags"></i> Makine Türleri
        </a>
        <button class="btn btn-sm btn-outline-secondary" onclick="$('#filterPanel').slideToggle()">
            <i class="fas fa-filter"></i> Filtrele
        </button>
        <button class="btn btn-sm btn-outline-success" onclick="location.href='@Url.Action("ExportMachines", "Machine")'">
            <i class="fas fa-file-excel"></i> Excel
        </button>
        <span class="topbar-user">
            <i class="fas fa-user-circle"></i>
            @(User.Identity?.Name ?? "Kullanıcı")
        </span>
    </div>
</div>

@* --- FİLTRELEME PANELİ --- *@
<div id="filterPanel" class="card mb-3 shadow-sm border-left-secondary" style="display:none;">
    <div class="card-body py-3">
        <div class="row align-items-end">
            <div class="col-md-5">
                <label class="small font-weight-bold text-uppercase">Makine Adı / Kod</label>
                <input type="text" id="machineSearch" class="form-control form-control-sm" placeholder="Ara...">
            </div>
            <div class="col-md-4">
                <label class="small font-weight-bold text-uppercase">Makine Türü</label>
                <select class="form-control form-control-sm" id="machineTypeFilter">
                    <option value="">Tümü</option>
                    @foreach (var t in machineTypes)
                    {
                        <option value="@t.Name">@t.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-secondary btn-sm btn-block text-white" onclick="filterTable()">
                    <i class="fas fa-search mr-1"></i> Sorgula
                </button>
            </div>
        </div>
    </div>
</div>

@* --- TABLO ALANI --- *@
<div class="card shadow-sm border-0 table-card">
    <div class="table-header">
        <div class="d-flex align-items-center gap-2">
            <i class="fas fa-industry text-primary"></i>
            <span>Makine Listesi</span>
            <span class="badge badge-blue">@Model.Count() kayıt</span>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 data-table" id="machineTable">
                <thead class="bg-light text-dark text-uppercase small font-weight-bold">
                    <tr>
                        <th style="width: 100px;">Kod</th>
                        <th>Makine Adı</th>
                        <th>Tür</th>
                        <th class="text-center">Durum</th>
                        <th class="text-right" style="width: 130px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><code>@item.Code</code></td>
                                <td><strong class="text-primary">@item.Name</strong></td>
                                <td><span class="badge badge-light border text-dark">@(item.MachineType?.Name ?? "-")</span></td>

                                <td class="text-center">
                                    <div class="custom-control custom-switch">
                                        <input type="checkbox" class="custom-control-input" id="status_@item.Id"
                                               @(item.IsActive ? "checked" : "")
                                               onchange="toggleMachineStatus(@item.Id)">
                                        <label class="custom-control-label cursor-pointer" for="status_@item.Id">
                                            <span id="badge_@item.Id" class="badge @(item.IsActive ? "badge-success" : "badge-secondary")">
                                                @(item.IsActive ? "Aktif" : "Pasif")
                                            </span>
                                        </label>
                                    </div>
                                </td>

                                <td class="text-right">
                                    <button class="btn btn-sm btn-outline-primary mr-1"
                                            onclick="editMachine(@item.Id, '@item.Name', '@item.Code', @item.MachineTypeId, @item.IsActive.ToString().ToLower())">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteMachine(@item.Id)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="fas fa-industry"></i></div>
                                <h6>Henüz makine kaydı yok</h6>
                                <p>+ Yeni Makine Ekle butonunu kullanın.</p>
                            </div>
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* --- MODAL: EKLE/DÜZENLE --- *@
<div class="modal fade" id="machineModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header dark">
                <h6 class="modal-title font-weight-bold"><i class="fas fa-industry mr-2"></i>Makine Formu</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Machine" asp-action="SaveMachine" method="post">
                <div class="modal-body">
                    <input type="hidden" name="Id" id="machineId" value="0" />
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label class="small font-weight-bold">Makine Adı <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="Name" id="machineName" required>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="small font-weight-bold">Makine Kodu <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="Code" id="machineCode" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="small font-weight-bold">Makine Türü</label>
                        <select class="form-control" name="MachineTypeId" id="machineType">
                            @foreach (var t in machineTypes)
                            {
                                <option value="@t.Id">@t.Name</option>
                            }
                        </select>
                        <small class="text-muted">Listede yoksa <a href="@Url.Action("Types", "Machine")">Makine Türleri</a>'nden ekleyin.</small>
                    </div>
                    <div class="custom-control custom-switch mt-2">
                        <input type="checkbox" class="custom-control-input" id="isActiveSwitch" name="IsActive" checked>
                        <label class="custom-control-label small font-weight-bold" for="isActiveSwitch">Aktif</label>
                    </div>
                </div>
                <div class="modal-footer bg-light p-2">
                    <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Kapat</button>
                    <button type="submit" class="btn btn-secondary btn-sm px-4 text-white">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterTable() {
            var searchTerm = $("#machineSearch").val().toLowerCase();
            var typeFilter = $("#machineTypeFilter").val().toLowerCase();

            $("#machineTable tbody tr").filter(function() {
                var textMatch = $(this).find('td:nth-child(1)').text().toLowerCase().indexOf(searchTerm) > -1 ||
                                $(this).find('td:nth-child(2)').text().toLowerCase().indexOf(searchTerm) > -1;

                var typeMatch = typeFilter === "" || $(this).find('td:nth-child(3)').text().toLowerCase().indexOf(typeFilter) > -1;

                $(this).toggle(textMatch && typeMatch);
            });
        }

        function toggleMachineStatus(id) {
            $.post('/Machine/ToggleMachineStatus', { id: id }, function (res) {
                if (res.success) {
                    const badge = $(`#badge_${id}`);
                    if (res.isActive) {
                        badge.removeClass('badge-secondary').addClass('badge-success').text('Aktif');
                    } else {
                        badge.removeClass('badge-success').addClass('badge-secondary').text('Pasif');
                    }
                } else {
                    Swal.fire('Hata!', res.message, 'error');
                    $(`#status_${id}`).prop('checked', !$(`#status_${id}`).is(':checked'));
                }
            });
        }

        function openAddModal() {
            $('#machineId').val(0);
            $('#machineName').val('');
            $('#machineCode').val('');
            $('#machineType').prop('selectedIndex', 0);
            $('#isActiveSwitch').prop('checked', true);
            $('.modal-title').html('<i class="fas fa-plus mr-2"></i>Yeni Makine Ekle');
            bootstrap.Modal.getOrCreateInstance(document.getElementById('machineModal')).show();
        }

        function editMachine(id, name, code, machineTypeId, isActive) {
            $('#machineId').val(id);
            $('#machineName').val(name);
            $('#machineCode').val(code);
            $('#machineType').val(machineTypeId);
            $('#isActiveSwitch').prop('checked', isActive);
            $('.modal-title').html('<i class="fas fa-edit mr-2"></i>Makine Düzenle');
            bootstrap.Modal.getOrCreateInstance(document.getElementById('machineModal')).show();
        }

        function deleteMachine(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: 'Bu makine silinecektir!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#5a5c69',
                cancelButtonColor: '#e74a3b',
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Machine/DeleteMachine', { id: id }, function(res) {
                        if (res.success) {
                            location.reload();
                        } else {
                            Swal.fire('Hata!', res.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
