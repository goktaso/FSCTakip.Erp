@model IEnumerable<FSCTakip.Core.Entities.Machine>
@{
    ViewData["Title"] = "Makine Tanımlamaları";
}

<div class="card shadow mb-4">
    @* [2026-02-25] Kuralı: Ortak buton yapısını çağırıyoruz *@
    @await Html.PartialAsync("_TableActions", "Makine Tanımlamaları")

    <div id="filterPanel" class="card-body border-bottom bg-light" style="display:none;">
        <div class="row align-items-end">
            <div class="col-md-5">
                <label class="small font-weight-bold text-uppercase text-danger">Makine Adı / Kod</label>
                <input type="text" id="machineSearch" class="form-control form-control-sm border-danger" placeholder="Örn: Matbaa-01...">
            </div>
            <div class="col-md-4">
                <label class="small font-weight-bold text-uppercase text-danger">Makine Türü</label>
                <select class="form-control form-control-sm border-danger" id="machineTypeFilter">
                    <option value="">Tümü</option>
                    <option value="Printing">Matbaa</option>
                    <option value="Cutting">Kesim</option>
                    <option value="Slitting">Dilimleme</option>
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-danger btn-sm btn-block" onclick="filterMachines()">
                    <i class="fas fa-search mr-1"></i> Sorgula
                </button>
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="machineTable">
                <thead class="bg-light text-dark text-uppercase small font-weight-bold">
                    <tr>
                        <th style="width: 70px;">Kod</th>
                        <th>Makine Adı</th>
                        <th>Tür</th>
                        <th>Maks. Hız</th>
                        <th>Kapasite</th>
                        <th>Durum</th>
                        <th class="text-right" style="width: 120px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><code>@item.Code</code></td>
                                <td><strong>@item.Name</strong></td>
                                <td><span class="badge badge-info">@item.Type</span></td>
                                <td><small>---</small></td> @* Veritabanı şemana göre güncellenebilir *@
                                <td><small>---</small></td>
                                <td>
                                    <span class="badge @(item.IsActive ? "badge-success" : "badge-secondary")">
                                        @(item.IsActive ? "Aktif" : "Pasif")
                                    </span>
                                </td>
                                <td class="text-right">
                                    <button class="btn btn-sm btn-outline-primary mr-1" title="Düzenle"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-outline-danger" title="Sil"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        @* Test verisi (Veritabanı boşsa görünür) *@
                        <tr>
                            <td><code>M-01</code></td>
                            <td><strong>8 Renk Flexo Matbaa</strong></td>
                            <td><span class="badge badge-info">Matbaa</span></td>
                            <td><small>250 m/dk</small></td>
                            <td><small>45.000 m</small></td>
                            <td><span class="badge badge-success">Aktif</span></td>
                            <td class="text-right">
                                <button class="btn btn-sm btn-outline-primary mr-1"><i class="fas fa-edit"></i></button>
                                <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addMachineModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title font-weight-bold"><i class="fas fa-industry mr-2"></i>Yeni Makine Tanımla</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="addMachineForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="small font-weight-bold">Makine Adı</label>
                            <input type="text" class="form-control" name="Name" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small font-weight-bold">Makine Kodu</label>
                            <input type="text" class="form-control" name="Code" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small font-weight-bold">Makine Türü</label>
                            <select class="form-control" name="Type">
                                <option value="Printing">Matbaa</option>
                                <option value="Cutting">Kesim</option>
                                <option value="Slitting">Dilimleme</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small font-weight-bold">Durum</label>
                            <div class="custom-control custom-switch mt-2">
                                <input type="checkbox" class="custom-control-input" id="isActiveSwitch" name="IsActive" checked>
                                <label class="custom-control-label" for="isActiveSwitch">Aktif</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Vazgeç</button>
                <button type="button" class="btn btn-danger" onclick="saveMachine()">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterMachines() {
            // Filtreleme mantığı buraya gelecek
            toastr.info("Filtreleme uygulandı.");
        }

        function saveMachine() {
            // Kaydetme Ajax işlemleri buraya gelecek
            $('#addMachineModal').modal('hide');
            toastr.success("Makine başarıyla kaydedildi.");
        }

        // Excel aktarımı site.js üzerinden merkezi yönetilecek
    </script>
}