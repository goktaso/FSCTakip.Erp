@model IEnumerable<FSCTakip.Core.Entities.SalesOrder>
@using FSCTakip.Core.Entities
@{
    ViewData["Title"] = "Satış / Sevkiyat";
    var customers = ViewBag.Customers as List<Customer> ?? new();

    var total        = Model.Count();
    var taslak       = Model.Count(s => s.Status == SalesOrderStatus.Taslak);
    var teslim       = Model.Count(s => s.Status == SalesOrderStatus.TeslimEdildi);
    var toplamAdet   = Model.Sum(s => s.Lines.Sum(l => l.Quantity));
    var toplamTutar  = Model.Sum(s => s.InvoiceAmount ?? 0);
}

@section TopbarPrimary {
    <button class="btn-topbar-add" data-bs-toggle="modal" data-bs-target="#salesModal">
        <span class="btn-add-icon"><i class="fas fa-plus"></i></span>
        Yeni Sipariş
    </button>
}

@section TopbarActions {
    <button class="topbar-btn btn-filter" onclick="toggleFilter()">
        <i class="fas fa-filter"></i> Filtrele
    </button>
    <a href="/Sales/ExportIndex" class="topbar-btn btn-excel">
        <i class="fas fa-file-excel"></i> Excel
    </a>
}

<!-- Stat Kartları -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-file-invoice"></i></div>
            <div>
                <div class="stat-value">@total</div>
                <div class="stat-label">Toplam Sipariş</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon amber"><i class="fas fa-clock"></i></div>
            <div>
                <div class="stat-value">@taslak</div>
                <div class="stat-label">Bekleyen (Taslak)</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-truck"></i></div>
            <div>
                <div class="stat-value">@teslim</div>
                <div class="stat-label">Teslim Edildi</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon purple"><i class="fas fa-lira-sign"></i></div>
            <div>
                <div class="stat-value">@toplamTutar.ToString("N0")</div>
                <div class="stat-label">Toplam Tutar (TRY)</div>
            </div>
        </div>
    </div>
</div>

<!-- Filtre Paneli -->
<div id="filterPanel" class="filter-panel mb-3" style="display:none;">
    <form method="get" action="/Sales/Index">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label">Başlangıç</label>
                <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control form-control-sm">
            </div>
            <div class="col-md-2">
                <label class="form-label">Bitiş</label>
                <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control form-control-sm">
            </div>
            <div class="col-md-3">
                <label class="form-label">Müşteri</label>
                <select name="customerId" class="form-select form-select-sm">
                    <option value="">— Tümü —</option>
                    @foreach (var c in customers)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Durum</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">— Tümü —</option>
                    <option value="1">Taslak</option>
                    <option value="2">Teslim Edildi</option>
                    <option value="3">İptal</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2 align-items-end">
                <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search me-1"></i>Sorgula</button>
                <a href="/Sales/Index" class="btn btn-outline-secondary btn-sm">Temizle</a>
            </div>
        </div>
    </form>
</div>

<!-- Tablo -->
<div class="table-card">
    <table class="data-table">
        <thead>
            <tr>
                <th>SİPARİŞ NO</th>
                <th>MÜŞTERİ</th>
                <th>SİPARİŞ TARİHİ</th>
                <th>İRSALİYE NO</th>
                <th>FATURA NO</th>
                <th class="text-end">TUTAR</th>
                <th class="text-center">KALEM</th>
                <th class="text-end">TOPLAM ADET</th>
                <th>DURUM</th>
                <th>İŞLEM</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="10">
                    <div class="empty-state">
                        <div class="empty-icon"><i class="fas fa-file-invoice"></i></div>
                        <h6>Henüz satış kaydı yok</h6>
                        <p><strong>+ Yeni Sipariş</strong> butonu ile ilk siparişi oluşturun.</p>
                    </div>
                </td></tr>
            }
            @foreach (var s in Model)
            {
                var statusBadge = s.Status switch {
                    SalesOrderStatus.Taslak       => "badge-amber",
                    SalesOrderStatus.TeslimEdildi => "badge-green",
                    SalesOrderStatus.Iptal        => "badge-red",
                    _ => "badge-gray"
                };
                var statusText = s.Status switch {
                    SalesOrderStatus.Taslak       => "Taslak",
                    SalesOrderStatus.TeslimEdildi => "Teslim Edildi",
                    SalesOrderStatus.Iptal        => "İptal",
                    _ => ""
                };
                <tr>
                    <td>
                        <a href="/Sales/Detail/@s.Id" class="table-link fw-semibold">@s.SalesOrderNo</a>
                    </td>
                    <td>
                        <div class="fw-semibold" style="font-size:13px;">@s.Customer?.Name</div>
                        @if (!string.IsNullOrEmpty(s.DeliveryAddress))
                        {
                            <div class="text-muted" style="font-size:11px;">@s.DeliveryAddress</div>
                        }
                    </td>
                    <td class="text-muted">@s.OrderDate.ToString("dd.MM.yyyy")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(s.DispatchNo) && !string.IsNullOrEmpty(s.DispatchPdfPath))
                        {
                            <button class="doc-num-btn"
                                    onclick="showPdf('/@s.DispatchPdfPath','İrsaliye — @s.DispatchNo')"
                                    title="İrsaliyeyi görüntüle">
                                <i class="fas fa-file-pdf me-1" style="color:#dc2626;font-size:11px;"></i>@s.DispatchNo
                            </button>
                        }
                        else { <span class="text-muted">@(s.DispatchNo ?? "—")</span> }
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(s.InvoiceNo) && !string.IsNullOrEmpty(s.InvoicePdfPath))
                        {
                            <button class="doc-num-btn"
                                    onclick="showPdf('/@s.InvoicePdfPath','Fatura — @s.InvoiceNo')"
                                    title="Faturayı görüntüle">
                                <i class="fas fa-file-pdf me-1" style="color:#dc2626;font-size:11px;"></i>@s.InvoiceNo
                            </button>
                        }
                        else { <span class="text-muted">@(s.InvoiceNo ?? "—")</span> }
                    </td>
                    <td class="text-end fw-semibold">
                        @if (s.InvoiceAmount.HasValue)
                        {
                            @s.InvoiceAmount.Value.ToString("N2") <span class="text-muted" style="font-size:11px;">@s.Currency</span>
                        }
                        else { <span class="text-muted">—</span> }
                    </td>
                    <td class="text-center"><span class="badge badge-blue">@s.Lines.Count</span></td>
                    <td class="text-end fw-semibold">@s.Lines.Sum(l => l.Quantity).ToString("N0")</td>
                    <td><span class="badge @statusBadge">@statusText</span></td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="/Sales/Detail/@s.Id" class="btn btn-sm btn-outline-secondary" title="Detay">
                                <i class="fas fa-eye"></i>
                            </a>
                            @if (s.Status == SalesOrderStatus.Taslak)
                            {
                                <button class="btn btn-sm btn-outline-secondary" onclick="editOrder(@s.Id)" title="Düzenle">
                                    <i class="fas fa-pen"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteOrder(@s.Id,'@s.SalesOrderNo')" title="Sil">
                                    <i class="fas fa-trash"></i>
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Sipariş Modal -->
<div class="modal fade" id="salesModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header card-header-accent">
                <span id="salesModalTitle"><i class="fas fa-file-invoice me-2"></i>Yeni Sipariş</span>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3">
                <input type="hidden" id="salesOrderId">
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label">Sipariş No</label>
                        <input type="text" id="salesOrderNo" class="form-control form-control-sm" placeholder="Otomatik">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Sipariş Tarihi *</label>
                        <input type="date" id="salesOrderDate" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Durum</label>
                        <select id="salesStatus" class="form-select form-select-sm">
                            <option value="1">Taslak</option>
                            <option value="2">Teslim Edildi</option>
                            <option value="3">İptal</option>
                        </select>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Müşteri *</label>
                        <select id="salesCustomerId" class="form-select form-select-sm">
                            <option value="">— Seçiniz —</option>
                            @foreach (var c in customers)
                            {
                                <option value="@c.Id" data-fsc="@c.IsFscActive">@c.CustomerCode — @c.Name</option>
                            }
                        </select>
                        <div id="customerFscInfo" style="display:none;margin-top:4px;"></div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">İrsaliye No</label>
                        <input type="text" id="salesDispatchNo" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Fatura No</label>
                        <input type="text" id="salesInvoiceNo" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Tutar</label>
                        <input type="number" id="salesInvoiceAmount" class="form-control form-control-sm" step="0.01" min="0">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Para Birimi</label>
                        <select id="salesCurrency" class="form-select form-select-sm">
                            <option value="TRY">TRY — Türk Lirası</option>
                            <option value="USD">USD — Dolar</option>
                            <option value="EUR">EUR — Euro</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Araç Plakası</label>
                        <input type="text" id="salesPlate" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Teslimat Adresi</label>
                        <input type="text" id="salesAddress" class="form-control form-control-sm">
                    </div>
                    <div class="col-12">
                        <label class="form-label">Notlar</label>
                        <textarea id="salesNotes" class="form-control form-control-sm" rows="2"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Vazgeç</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="saveOrder()">
                    <i class="fas fa-save me-1"></i> Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let _salesEditMode = false;

document.getElementById('salesModal').addEventListener('show.bs.modal', function () {
    if (!_salesEditMode) {
        ['salesOrderId','salesOrderNo','salesDispatchNo','salesInvoiceNo',
         'salesInvoiceAmount','salesPlate','salesAddress','salesNotes'].forEach(id => {
            const el = document.getElementById(id); if (el) el.value = '';
        });
        document.getElementById('salesOrderDate').value = new Date().toISOString().split('T')[0];
        document.getElementById('salesCustomerId').value = '';
        document.getElementById('salesCurrency').value = 'TRY';
        document.getElementById('salesStatus').value = '1';
        document.getElementById('customerFscInfo').style.display = 'none';
        document.getElementById('salesModalTitle').innerHTML = '<i class="fas fa-file-invoice me-2"></i>Yeni Sipariş';
    }
    _salesEditMode = false;
});

document.getElementById('salesCustomerId').addEventListener('change', function () {
    const opt = this.options[this.selectedIndex];
    const info = document.getElementById('customerFscInfo');
    if (opt && opt.dataset.fsc === 'True') {
        info.style.display = 'block';
        info.innerHTML = '<span class="badge badge-green"><i class="fas fa-certificate me-1"></i>FSC Sertifikalı Müşteri — CoC kaydı otomatik oluşturulur</span>';
    } else {
        info.style.display = 'none';
    }
});

function editOrder(id) {
    _salesEditMode = true;
    fetch(`/Sales/GetOrder/${id}`)
        .then(r => r.json()).then(res => {
            if (!res.success) { _salesEditMode = false; return; }
            const d = res.data;
            document.getElementById('salesOrderId').value       = d.id;
            document.getElementById('salesOrderNo').value       = d.salesOrderNo;
            document.getElementById('salesOrderDate').value     = d.orderDate;
            document.getElementById('salesCustomerId').value    = d.customerId;
            document.getElementById('salesDispatchNo').value    = d.dispatchNo || '';
            document.getElementById('salesInvoiceNo').value     = d.invoiceNo || '';
            document.getElementById('salesInvoiceAmount').value = d.invoiceAmount || '';
            document.getElementById('salesCurrency').value      = d.currency || 'TRY';
            document.getElementById('salesPlate').value         = d.plateNumber || '';
            document.getElementById('salesAddress').value       = d.deliveryAddress || '';
            document.getElementById('salesStatus').value        = d.status;
            document.getElementById('salesNotes').value         = d.notes || '';
            document.getElementById('salesModalTitle').innerHTML = `<i class="fas fa-pen me-2"></i>Sipariş Düzenle — ${d.salesOrderNo}`;
            bootstrap.Modal.getOrCreateInstance(document.getElementById('salesModal')).show();
        });
}

function saveOrder() {
    const customerId = document.getElementById('salesCustomerId').value;
    if (!customerId) { showToast('Müşteri seçiniz', 'warning'); return; }

    const fd = new FormData();
    fd.append('salesOrderId',    document.getElementById('salesOrderId').value || '0');
    fd.append('customerId',      customerId);
    fd.append('orderDate',       document.getElementById('salesOrderDate').value);
    fd.append('dispatchNo',      document.getElementById('salesDispatchNo').value);
    fd.append('invoiceNo',       document.getElementById('salesInvoiceNo').value);
    fd.append('invoiceAmount',   document.getElementById('salesInvoiceAmount').value);
    fd.append('currency',        document.getElementById('salesCurrency').value);
    fd.append('plateNumber',     document.getElementById('salesPlate').value);
    fd.append('deliveryAddress', document.getElementById('salesAddress').value);
    fd.append('status',          document.getElementById('salesStatus').value);
    fd.append('notes',           document.getElementById('salesNotes').value);

    fetch('/Sales/SaveOrder', { method: 'POST', body: fd })
        .then(r => r.json()).then(res => {
            if (res.success) {
                bootstrap.Modal.getInstance(document.getElementById('salesModal'))?.hide();
                showToast(res.message + ' (' + res.salesOrderNo + ')', 'success');
                setTimeout(() => location.reload(), 1200);
            } else {
                showToast(res.message, 'error');
            }
        });
}

function deleteOrder(id, no) {
    if (!confirm(`"${no}" siparişini silmek istiyor musunuz?`)) return;
    fetch(`/Sales/DeleteOrder/${id}`, { method: 'POST' })
        .then(r => r.json()).then(res => {
            showToast(res.message, res.success ? 'success' : 'error');
            if (res.success) setTimeout(() => location.reload(), 1000);
        });
}
</script>
}
